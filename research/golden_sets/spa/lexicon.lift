<entry id="desobediencia" guid="bc4bedfd-62d3-5e20-b86d-58a70dfcf825"><lexical-unit><form lang="es"><text>desobediencia</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desobediencia_0" guid="2e1c94fc-9ace-55e6-aa8c-0832dad9d421"><grammatical-info value="Noun"/><gloss lang="en"><text>disobedience</text></gloss></sense></entry>
