<entry id="abrir" guid="b5de70e2-a254-52a7-a9a1-33eaedf8c7e7"><lexical-unit><form lang="es"><text>abrir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abrir_0" guid="ae555f16-cc6a-5398-bd0e-fef5b64167a6"><grammatical-info value="Verb"/><gloss lang="en"><text>to open, open up</text></gloss></sense><sense id="abrir_1" guid="78ea501b-ec3b-5d89-b75d-a9f92234cf5c"><grammatical-info value="Verb"/><gloss lang="en"><text>to unlock</text></gloss></sense><sense id="abrir_2" guid="27436c43-60ed-5d7f-814e-cf54dd42c209"><grammatical-info value="Verb"/><gloss lang="en"><text>to turn on</text></gloss></sense><sense id="abrir_3" guid="efe90963-a446-5c65-b11f-6841f2e799bb"><grammatical-info value="Verb"/><gloss lang="en"><text>to start, open, open up, set up (a business, restaurant, etc.)</text></gloss></sense><sense id="abrir_4" guid="ca866fea-59ca-5500-82bf-f6bcbcb92c25"><grammatical-info value="Verb"/><gloss lang="en"><text>to crack, crack open, to pop (e.g., a safe, a bottle, a coconut)</text></gloss></sense><sense id="abrir_5" guid="6fb4e71b-85b3-5967-9d54-c65ee51a7be4"><grammatical-info value="Verb"/><gloss lang="en"><text>to break, break open, (new ground, a game, etc.); to break out (e.g., champagne); to breach</text></gloss></sense><sense id="abrir_6" guid="355798b0-aa5e-5036-8e06-efb046a384c6"><grammatical-info value="Verb"/><gloss lang="en"><text>to spread (one's legs, arms, fingers)</text></gloss></sense><sense id="abrir_7" guid="cf2cf651-5020-5a76-946c-c3692ea1f232"><grammatical-info value="Verb"/><gloss lang="en"><text>to answer (the door)</text></gloss></sense></entry>
