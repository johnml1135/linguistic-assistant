<entry id="retornar" guid="f78f2ff7-320c-5ab8-b74f-287a4427d0e0"><lexical-unit><form lang="es"><text>retornar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="retornar_0" guid="4ca15943-a513-56e1-b652-5452775e78a2"><grammatical-info value="Verb"/><gloss lang="en"><text>to return, give back</text></gloss></sense><sense id="retornar_1" guid="225fb6c5-9e1f-5533-9888-4cb6f0a9e24c"><grammatical-info value="Verb"/><gloss lang="en"><text>to return, come back</text></gloss></sense></entry>
<entry id="retraer" guid="012af789-0d16-5dbb-85e9-f1d2a0b39cd4"><lexical-unit><form lang="es"><text>retraer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="retraer_0" guid="edb7d811-e42e-5254-b0b1-b08fb407fdcf"><grammatical-info value="Verb"/><gloss lang="en"><text>to withdraw, to retract (something)</text></gloss></sense><sense id="retraer_1" guid="32639e98-baff-56f7-867f-6213fef357db"><grammatical-info value="Verb"/><gloss lang="en"><text>to bring back (to cause one to remember)</text></gloss></sense><sense id="retraer_2" guid="1bcd1596-6a61-50a3-ba1a-ba142f0294f4"><grammatical-info value="Verb"/><gloss lang="en"><text>to withdraw (oneself), to shrink back</text></gloss></sense></entry>
<entry id="retribución" guid="323c8173-0466-518b-987a-3698416da487"><lexical-unit><form lang="es"><text>retribución</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="retribución_0" guid="233baa82-0144-5862-8183-014f256be367"><grammatical-info value="Noun"/><gloss lang="en"><text>retribution</text></gloss></sense><sense id="retribución_1" guid="e4bf1330-0f96-550d-ba4b-aa1254b92d94"><grammatical-info value="Noun"/><gloss lang="en"><text>payment</text></gloss></sense></entry>
