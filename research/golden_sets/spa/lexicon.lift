<entry id="haber" guid="5d33b127-6df8-5ec7-9cbc-f44e57401270"><lexical-unit><form lang="es"><text>haber</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="haber_0" guid="637cf6ad-5489-536f-8b41-c2932a5f3bdd"><grammatical-info value="Verb"/><gloss lang="en"><text>have; forms the perfect aspect</text></gloss></sense><sense id="haber_1" guid="ca0a4e3c-7e33-5fe7-b3a5-acda7e6911fe"><grammatical-info value="Verb"/><gloss lang="en"><text>to hold, to possess</text></gloss></sense><sense id="haber_2" guid="6f1d6f24-235f-5179-a978-56d78ff4eb3f"><grammatical-info value="Verb"/><gloss lang="en"><text>to exist; there be; “there is”, “there are” (hay); “there was”, “there were” (había)</text></gloss></sense><sense id="haber_3" guid="ecb7e3ee-0dc4-5464-aeaa-833516cd00a0"><grammatical-info value="Verb"/><gloss lang="en"><text>to have to</text></gloss></sense><sense id="haber_4" guid="fab494ad-4c9e-5c04-b1a9-5345fa2009b2"><grammatical-info value="Verb"/><gloss lang="en"><text>to be necessary</text></gloss></sense><sense id="haber_5" guid="bd321e77-8ac7-5844-9fe4-e74caf58b4b1"><grammatical-info value="Verb"/><gloss lang="en"><text>used to denote a past obligation</text></gloss></sense><sense id="haber_6" guid="12fce534-7053-5b99-8d4d-a69ea467af3a"><grammatical-info value="Verb"/><gloss lang="en"><text>asset</text></gloss></sense><sense id="haber_7" guid="9ad6dc7a-a009-5043-95e3-a53582f52c4c"><grammatical-info value="Verb"/><gloss lang="en"><text>history</text></gloss></sense></entry>
