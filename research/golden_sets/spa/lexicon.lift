<entry id="ador" guid="bc1cd0a6-9a12-5784-9919-da205bc9b624"><lexical-unit><form lang="es"><text>ador</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ador_0" guid="271a06ba-40e6-53fb-a37d-218b29c94fb7"><grammatical-info value="Noun"/><gloss lang="en"><text>a time period allotted for watering crops</text></gloss></sense></entry>
<entry id="adorador" guid="4cd99d12-9546-52ed-b372-22d62f36574a"><lexical-unit><form lang="es"><text>adorador</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="adorador_0" guid="8cd436da-7dd1-512b-9380-fc6e7e97935c"><grammatical-info value="Noun"/><gloss lang="en"><text>admirer, adorer, worshiper</text></gloss></sense></entry>
