<entry id="resplandecer" guid="883045e5-bb98-5cb1-b8e7-7d4548a67c5b"><lexical-unit><form lang="es"><text>resplandecer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="resplandecer_0" guid="8d9d8024-3a77-5c07-9969-66520f700f87"><grammatical-info value="Verb"/><gloss lang="en"><text>to shine brightly, glitter, glow, be resplendent</text></gloss></sense></entry>
<entry id="resplandeciente" guid="4a8b733f-6d2e-50c0-98c4-477a8d1e35b0"><lexical-unit><form lang="es"><text>resplandeciente</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="resplandeciente_0" guid="70d07723-c354-55ac-9730-538d2820fc9c"><grammatical-info value="Adjective"/><gloss lang="en"><text>resplendent</text></gloss></sense><sense id="resplandeciente_1" guid="ec18d045-e97f-5719-be51-f50623445547"><grammatical-info value="Adjective"/><gloss lang="en"><text>bright, shining</text></gloss></sense><sense id="resplandeciente_2" guid="5fbbd20c-6ecd-5c72-972a-2e6b81ca64f3"><grammatical-info value="Adjective"/><gloss lang="en"><text>radiant</text></gloss></sense><sense id="resplandeciente_3" guid="f2a89dba-c0f9-5d52-83f1-d5f737bb4319"><grammatical-info value="Adjective"/><gloss lang="en"><text>dazzling</text></gloss></sense></entry>
<entry id="resplandor" guid="244e2ea3-97a4-5534-a370-8f942d850773"><lexical-unit><form lang="es"><text>resplandor</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="resplandor_0" guid="02a8a19d-95d7-5b57-8aec-6c7a2f8f0a7a"><grammatical-info value="Noun"/><gloss lang="en"><text>radiance, glare, sheen, splendor, glow</text></gloss></sense></entry>
<entry id="responde" guid="9d8b23c0-43f2-5f6a-9d8c-5a54fd959798"><lexical-unit><form lang="es"><text>responde</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="responde_0" guid="d0e08850-51ba-5d34-8f1a-772f1b15f9a3"><grammatical-info value="Verb"/></sense></entry>
<entry id="responder" guid="58dc1900-28dc-5464-bcc6-01d069f80235"><lexical-unit><form lang="es"><text>responder</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="responder_0" guid="0be5986b-03e5-5f65-bd08-6e0ae6b35bcc"><grammatical-info value="Verb"/><gloss lang="en"><text>to answer, to reply</text></gloss></sense><sense id="responder_1" guid="269026f3-4dc9-5fc9-90b0-dd73e3987961"><grammatical-info value="Verb"/><gloss lang="en"><text>to talk back, to answer back (to respond defiantly and inappropriately)</text></gloss></sense><sense id="responder_2" guid="6ec1bd7c-f986-522b-afe3-5fcdd4f73e6c"><grammatical-info value="Verb"/><gloss lang="en"><text>to respond, to react (to someone else's actions)</text></gloss></sense><sense id="responder_3" guid="52da15a6-7b9f-5298-b770-5808b8a1314a"><grammatical-info value="Verb"/><gloss lang="en"><text>to answer for, to be responsible for, vouch for (with por)</text></gloss></sense><sense id="responder_4" guid="fefe5cd4-2dfa-545b-9460-ee8b66994073"><grammatical-info value="Verb"/><gloss lang="en"><text>to react, to respond (to a treatment, with a)</text></gloss></sense></entry>
