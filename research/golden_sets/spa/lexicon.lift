<entry id="entender" guid="283f525c-1e95-5235-9a38-893171b93f8a"><lexical-unit><form lang="es"><text>entender</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="entender_0" guid="51dd91b2-53c9-5d3a-81bb-9cc8d4eecea8"><grammatical-info value="Verb"/><gloss lang="en"><text>to understand, to fathom</text></gloss></sense><sense id="entender_1" guid="5c64ab95-8d5d-5f8d-b1f8-eab33b398a2a"><grammatical-info value="Verb"/><gloss lang="en"><text>to hear</text></gloss></sense><sense id="entender_2" guid="09aabd27-08a4-50fb-999a-3ee9a5dd51c2"><grammatical-info value="Verb"/><gloss lang="en"><text>to be queer; to bat for the other team</text></gloss></sense><sense id="entender_3" guid="7c3d3516-3403-5e07-b5d8-4975def6949d"><grammatical-info value="Verb"/><gloss lang="en"><text>to get on; get along</text></gloss></sense><sense id="entender_4" guid="014f2faf-1e91-5bb3-856d-d4425133f49f"><grammatical-info value="Verb"/><gloss lang="en"><text>to get it on; do it (have an amorous relationship)</text></gloss></sense><sense id="entender_5" guid="5e1e0939-c85d-5e96-b594-ce77e13a5951"><grammatical-info value="Verb"/><gloss lang="en"><text>understanding; opinion</text></gloss></sense></entry>
