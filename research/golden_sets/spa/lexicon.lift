<entry id="cono" guid="91805259-689d-51b2-a7a2-9b82cd9bb51d"><lexical-unit><form lang="es"><text>cono</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cono_0" guid="bb716b17-9c1a-58fd-9fbe-ec77652a1b1c"><grammatical-info value="Noun"/><gloss lang="en"><text>cone</text></gloss></sense><sense id="cono_1" guid="4decb141-e9f4-5828-a63f-515b27561039"><grammatical-info value="Noun"/><gloss lang="en"><text>cone (fruit of a conifer tree)</text></gloss></sense><sense id="cono_2" guid="4f42234c-0a79-52cb-9b99-bbc9f66debe6"><grammatical-info value="Noun"/><gloss lang="en"><text>cone cell</text></gloss></sense><sense id="cono_3" guid="5388c1cc-d882-522d-8bcc-f31c7263287d"><grammatical-info value="Noun"/><gloss lang="en"><text>ice cream cone</text></gloss></sense><sense id="cono_4" guid="3a699c12-5941-5ac2-8e8d-42662dc826a7"><grammatical-info value="Noun"/><gloss lang="en"><text>cone snail, Conus.</text></gloss></sense><sense id="cono_5" guid="b0783a0d-614b-54eb-b59e-713ae1d38d2a"><grammatical-info value="Noun"/><gloss lang="en"><text>someone who doesn't move whilst playing a sport</text></gloss></sense></entry>
<entry id="conocer" guid="d1e2c82e-94d9-54b7-b1cf-2faabd6b6e69"><lexical-unit><form lang="es"><text>conocer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="conocer_0" guid="6b0fee1f-db0b-5e20-9fe3-66a87f169e65"><grammatical-info value="Verb"/><gloss lang="en"><text>to meet</text></gloss></sense><sense id="conocer_1" guid="fd706ba2-7345-5267-96bd-bc86ab01931d"><grammatical-info value="Verb"/><gloss lang="en"><text>to get to know, become acquainted (with)</text></gloss></sense><sense id="conocer_2" guid="bc5b895b-3d75-5fae-9ef9-904cbbf8ed78"><grammatical-info value="Verb"/><gloss lang="en"><text>to see, to visit, to explore (i.e., to get to know a place for the first time)</text></gloss></sense><sense id="conocer_3" guid="17c875ce-9c0c-517f-87a3-17f79da6a7be"><grammatical-info value="Verb"/><gloss lang="en"><text>to hear, to know (implies hearing for the first time)</text></gloss></sense><sense id="conocer_4" guid="4772703c-5e11-5780-9766-e612ffdca929"><grammatical-info value="Verb"/><gloss lang="en"><text>to discover, to get to or come to know, to learn about, to find out</text></gloss></sense><sense id="conocer_5" guid="703055f1-eaaf-5a3e-a254-40926e8ae0a0"><grammatical-info value="Verb"/><gloss lang="en"><text>to know, to have known</text></gloss></sense><sense id="conocer_6" guid="8a16b2b9-4bce-5e25-839a-1e1440087bf5"><grammatical-info value="Verb"/><gloss lang="en"><text>to know oneself</text></gloss></sense></entry>
