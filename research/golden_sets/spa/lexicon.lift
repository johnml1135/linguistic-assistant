<entry id="trabar" guid="3d12140f-cdaa-5f6c-b520-e07ab3c9e7e0"><lexical-unit><form lang="es"><text>trabar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="trabar_0" guid="e8b0f656-580b-58b0-909e-475657405021"><grammatical-info value="Verb"/><gloss lang="en"><text>to connect, to join (pieces of wood)</text></gloss></sense><sense id="trabar_1" guid="4e391763-7d50-572c-b986-5259d1555450"><grammatical-info value="Verb"/><gloss lang="en"><text>to obstruct</text></gloss></sense><sense id="trabar_2" guid="2348e08f-1e87-5892-ba81-5d3f7c4f768a"><grammatical-info value="Verb"/><gloss lang="en"><text>to hold back</text></gloss></sense><sense id="trabar_3" guid="33d62ed0-d36f-5785-b02c-c01c3b9c7a56"><grammatical-info value="Verb"/><gloss lang="en"><text>to fasten</text></gloss></sense><sense id="trabar_4" guid="aa04612e-b45f-5b56-a339-c0dfe88ec8f2"><grammatical-info value="Verb"/><gloss lang="en"><text>to thicken (sauce, pudding etc.)</text></gloss></sense><sense id="trabar_5" guid="69092d09-a66c-55ae-b594-d4be3c348042"><grammatical-info value="Verb"/><gloss lang="en"><text>to get caught up, to become entangled</text></gloss></sense><sense id="trabar_6" guid="367d1a9c-fa93-5a87-880b-f53212d20cfb"><grammatical-info value="Verb"/><gloss lang="en"><text>to jam, to get jammed, to get stuck, to seize up</text></gloss></sense><sense id="trabar_7" guid="2c147c2d-ff8f-58db-9ec8-e2841b89f3ba"><grammatical-info value="Verb"/><gloss lang="en"><text>to trick, to deceive, to hoodwink, to cheat</text></gloss></sense></entry>
<entry id="tradición" guid="84ca4e57-148f-5a92-bf97-dd09f5023239"><lexical-unit><form lang="es"><text>tradición</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tradición_0" guid="b017ace8-d46f-559c-ae58-b83e3d60be39"><grammatical-info value="Noun"/><gloss lang="en"><text>tradition</text></gloss></sense><sense id="tradición_1" guid="00bd5fc1-ea47-5728-8477-d3dc958d1455"><grammatical-info value="Noun"/><gloss lang="en"><text>lore</text></gloss></sense></entry>
<entry id="traer" guid="dfb81a0a-a439-5254-91c3-178a45d671c1"><lexical-unit><form lang="es"><text>traer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="traer_0" guid="3a5c7f0d-8c9b-52b8-aa40-09a0410baff3"><grammatical-info value="Verb"/><gloss lang="en"><text>to bring, to fetch</text></gloss></sense><sense id="traer_1" guid="57e53ad5-95ad-568d-b3dc-546704d6d642"><grammatical-info value="Verb"/><gloss lang="en"><text>to attract, draw, pull</text></gloss></sense><sense id="traer_2" guid="e788f469-5dee-5aae-83e2-311bc9e2d66f"><grammatical-info value="Verb"/><gloss lang="en"><text>to bring about, cause, occasion</text></gloss></sense><sense id="traer_3" guid="96eab47a-fa3a-59d8-9d12-49843048c826"><grammatical-info value="Verb"/><gloss lang="en"><text>to make (cause to be in or have a certain condition or state)</text></gloss></sense><sense id="traer_4" guid="6ac2a844-440a-501c-9f5f-fe2febe384b8"><grammatical-info value="Verb"/><gloss lang="en"><text>to wear (ellipsis of traer puesto)</text></gloss></sense><sense id="traer_5" guid="7da9f451-c8e5-5742-8bde-9c912fe63bc5"><grammatical-info value="Verb"/><gloss lang="en"><text>to bring forward, advance, adduce</text></gloss></sense><sense id="traer_6" guid="1eb27df8-1819-56b5-acd0-bf3fb3198e7d"><grammatical-info value="Verb"/><gloss lang="en"><text>to make, compel, oblige</text></gloss></sense><sense id="traer_7" guid="fc7f4478-7c37-5f2c-9bce-a55a1a154dcf"><grammatical-info value="Verb"/><gloss lang="en"><text>to persuade</text></gloss></sense></entry>
<entry id="tragar" guid="dc9d89f5-3039-5887-9efb-0f5878f11be7"><lexical-unit><form lang="es"><text>tragar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tragar_0" guid="065fbb9c-000b-5d4a-a527-35934b622bcd"><grammatical-info value="Verb"/><gloss lang="en"><text>to swallow (to cause to pass from the mouth into the stomach)</text></gloss></sense><sense id="tragar_1" guid="351fc661-3c9e-553e-a0dc-73c07a5d33ab"><grammatical-info value="Verb"/><gloss lang="en"><text>to swallow, consume, absorb (take (something) in so that it disappears)</text></gloss></sense><sense id="tragar_2" guid="a928c9d1-fbfa-568f-ae5b-536d1fc51042"><grammatical-info value="Verb"/><gloss lang="en"><text>to gulp, swallow, devour (eat quickly and eagerly)</text></gloss></sense><sense id="tragar_3" guid="910bbb53-e430-54f7-92ad-9e718639c27e"><grammatical-info value="Verb"/><gloss lang="en"><text>to buy into, fall for (easily believe something without questioning)</text></gloss></sense><sense id="tragar_4" guid="9758aa6f-5459-5c19-b06e-ce5ae32d392b"><grammatical-info value="Verb"/><gloss lang="en"><text>to stand, tolerate</text></gloss></sense><sense id="tragar_5" guid="ab590a9e-710a-5b0a-b429-c9d5592590b3"><grammatical-info value="Verb"/><gloss lang="en"><text>to eat</text></gloss></sense></entry>
<entry id="traidor" guid="e60e3073-22a9-597d-9120-34623d511995"><lexical-unit><form lang="es"><text>traidor</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="traidor_0" guid="d1b6c6cc-11a7-5d1c-a71d-8f05caedf7d9"><grammatical-info value="Adjective"/><gloss lang="en"><text>traitorous (characteristic of a traitor)</text></gloss></sense><sense id="traidor_1" guid="ef5cc28a-458d-5d34-b601-1d3f1d3a61d8"><grammatical-info value="Adjective"/><gloss lang="en"><text>unpredictable</text></gloss></sense><sense id="traidor_2" guid="1eba9fce-3fdd-5e60-b56a-ea8cfc1a5a35"><grammatical-info value="Adjective"/><gloss lang="en"><text>traitor, betrayer, backstabber</text></gloss></sense><sense id="traidor_3" guid="c06fba11-50b3-573a-a5b4-17ea8cb9c825"><grammatical-info value="Adjective"/><gloss lang="en"><text>snake</text></gloss></sense></entry>
<entry id="traje" guid="a7df7ace-1cee-5d1c-a39a-4df32a6b9ff7"><lexical-unit><form lang="es"><text>traje</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="traje_0" guid="5d04c958-7e8c-5eb7-9f4b-da22679f5cc0"><grammatical-info value="Noun"/><gloss lang="en"><text>suit</text></gloss></sense><sense id="traje_1" guid="ce99a06a-1cdc-522a-bbf6-34f8b1741cb3"><grammatical-info value="Noun"/><gloss lang="en"><text>dress (distinctive style for particular occasion)</text></gloss></sense><sense id="traje_2" guid="441f6332-fad5-5391-826b-a2e820f37288"><grammatical-info value="Noun"/><gloss lang="en"><text>gown, dress (e.g. bridal gown, evening gown)</text></gloss></sense><sense id="traje_3" guid="ed00bb1c-3eaa-5493-9ea8-69e014572fde"><grammatical-info value="Noun"/><gloss lang="en"><text>costume, outfit, getup (e.g. superhero costume; a regional, national, folk costume)</text></gloss></sense></entry>
