<entry id="tierra" guid="ea4533ef-8663-55af-835a-cb053e4ab9bb"><lexical-unit><form lang="es"><text>tierra</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tierra_0" guid="bfc164bc-b165-59e0-a4c0-3e0ccdb85304"><grammatical-info value="Noun"/><gloss lang="en"><text>Earth (planet of the Solar System in which all of humanity resides)</text></gloss></sense><sense id="tierra_1" guid="6e8aaffb-4540-57ec-aa3e-cb45d9237639"><grammatical-info value="Noun"/><gloss lang="en"><text>land, ground (Earth surface not covered by oceans or other bodies of water)</text></gloss></sense><sense id="tierra_2" guid="f98ce17e-1201-51fd-86cb-a91ba9d69320"><grammatical-info value="Noun"/><gloss lang="en"><text>earth, soil (the unconsolidated mineral or organic material on the immediate surface of the earth)</text></gloss></sense><sense id="tierra_3" guid="b60ec7cf-82bb-5c0e-ac1c-a06d8e23215f"><grammatical-info value="Noun"/><gloss lang="en"><text>land, terrain (an area of land or the particular features of it)</text></gloss></sense><sense id="tierra_4" guid="aff5c32a-913c-54e3-bd06-cbb00b8d252b"><grammatical-info value="Noun"/><gloss lang="en"><text>land, terrain (reserved for growing crops)</text></gloss></sense><sense id="tierra_5" guid="18821b39-1429-5485-9697-f67d9aca1b29"><grammatical-info value="Noun"/><gloss lang="en"><text>homeland (one's country of birth)</text></gloss></sense><sense id="tierra_6" guid="3e6267c8-b4d2-5f41-8731-fbbfdb22ab89"><grammatical-info value="Noun"/><gloss lang="en"><text>land, country, nation, territory (country or region)</text></gloss></sense><sense id="tierra_7" guid="62c558d7-93ff-5930-9425-cb74d35ab3f2"><grammatical-info value="Noun"/><gloss lang="en"><text>ground, earth (connection electrically to the earth on equipment)</text></gloss></sense></entry>
<entry id="tildar" guid="e1796949-b637-5f21-982c-23cc17da2aa6"><lexical-unit><form lang="es"><text>tildar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tildar_0" guid="05fcfc91-5fb1-562b-9432-d2609fb1d5f0"><grammatical-info value="Verb"/><gloss lang="en"><text>to declare or brand as; to stigmatize</text></gloss></sense><sense id="tildar_1" guid="36ad71d1-e358-54ba-8f75-ead9b2f11bd6"><grammatical-info value="Verb"/><gloss lang="en"><text>to put a tilde or other accent mark over</text></gloss></sense><sense id="tildar_2" guid="f9017f42-20ab-581a-af21-57c710afca45"><grammatical-info value="Verb"/><gloss lang="en"><text>(informal) hang (of a computer, to stop working)</text></gloss></sense><sense id="tildar_3" guid="5fea31a1-b571-5592-88c7-f5e0f04a139b"><grammatical-info value="Verb"/><gloss lang="en"><text>(informal) to go into a trance, a stupor</text></gloss></sense></entry>
