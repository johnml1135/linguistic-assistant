<entry id="adelantar" guid="53f515ae-0fca-5730-b4e8-ce56e161a35e"><lexical-unit><form lang="es"><text>adelantar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="adelantar_0" guid="e97b9dd0-e682-5582-a082-4d9d69fc2268"><grammatical-info value="Verb"/><gloss lang="en"><text>to bring forward, advance, to move forward (in space or time)</text></gloss></sense><sense id="adelantar_1" guid="e30a2aee-d7cf-59e3-9093-e9b8f5866ae2"><grammatical-info value="Verb"/><gloss lang="en"><text>to pay in advance</text></gloss></sense><sense id="adelantar_2" guid="bc13bac9-61ed-55dc-95dd-95c7950020ee"><grammatical-info value="Verb"/><gloss lang="en"><text>to outstrip, to outrun</text></gloss></sense><sense id="adelantar_3" guid="53b1bbb8-9cd5-5321-80a5-294d5bc73a7d"><grammatical-info value="Verb"/><gloss lang="en"><text>to make progress</text></gloss></sense><sense id="adelantar_4" guid="60c7b874-4df0-5ce9-bfb3-00e9f5360480"><grammatical-info value="Verb"/><gloss lang="en"><text>to overtake, to pass (to pass a more slowly moving object)</text></gloss></sense><sense id="adelantar_5" guid="5f463db7-5827-5a3b-8c4f-9cac5852ddb2"><grammatical-info value="Verb"/><gloss lang="en"><text>to move up, speed up (to make something happen faster or come sooner)</text></gloss></sense><sense id="adelantar_6" guid="23d5945e-10a0-5b6c-98fc-0f09c2f3d00e"><grammatical-info value="Verb"/><gloss lang="en"><text>to fast forward (e.g. a film or recording)</text></gloss></sense><sense id="adelantar_7" guid="35637b4e-a8e6-586b-84bb-a9793f636e9e"><grammatical-info value="Verb"/><gloss lang="en"><text>to preempt</text></gloss></sense></entry>
<entry id="ademar" guid="72bdde4b-3aac-52b2-b3a0-ef2b8e702f52"><lexical-unit><form lang="es"><text>ademar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ademar_0" guid="e5eaa883-fb3e-57a5-99f6-f737196b0d9a"><grammatical-info value="Verb"/><gloss lang="en"><text>to encase</text></gloss></sense><sense id="ademar_1" guid="d5555d18-99d8-5bc2-b573-0ae89c7e930b"><grammatical-info value="Verb"/><gloss lang="en"><text>to shore up</text></gloss></sense></entry>
