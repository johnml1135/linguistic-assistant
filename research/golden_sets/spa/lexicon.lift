<entry id="defender" guid="4487a504-3dae-532b-94d9-9e4d07f4d235"><lexical-unit><form lang="es"><text>defender</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="defender_0" guid="11514a3a-c418-595c-815c-dc062c4806d3"><grammatical-info value="Verb"/><gloss lang="en"><text>to defend, to protect, to hold down</text></gloss></sense><sense id="defender_1" guid="4596fda8-bd2b-5fe7-baac-322d962dbdba"><grammatical-info value="Verb"/><gloss lang="en"><text>to stand up for, to stick up for</text></gloss></sense><sense id="defender_2" guid="3992bb3a-cee0-5998-9f4b-4636980564e7"><grammatical-info value="Verb"/><gloss lang="en"><text>to uphold</text></gloss></sense><sense id="defender_3" guid="9f225166-27de-5ed8-94ca-0cf5ece22a52"><grammatical-info value="Verb"/><gloss lang="en"><text>to prohibit</text></gloss></sense><sense id="defender_4" guid="7b37821d-7132-527e-aac5-3446cdcf4105"><grammatical-info value="Verb"/><gloss lang="en"><text>to claim</text></gloss></sense><sense id="defender_5" guid="ceac89e1-dc80-52bf-9f39-e5018afb58ef"><grammatical-info value="Verb"/><gloss lang="en"><text>to fight back</text></gloss></sense><sense id="defender_6" guid="0deee173-0d69-517c-a5b4-76cc2f8b3d46"><grammatical-info value="Verb"/><gloss lang="en"><text>to defend oneself, to protect oneself</text></gloss></sense><sense id="defender_7" guid="6255bb1c-dbb2-5570-bc05-964d50ae72b2"><grammatical-info value="Verb"/><gloss lang="en"><text>to stand up for oneself, to stick up for oneself</text></gloss></sense></entry>
