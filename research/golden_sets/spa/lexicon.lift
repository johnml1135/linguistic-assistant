<entry id="josé" guid="72c869e1-1adc-59f4-bb9b-e3f32a5379bc"><lexical-unit><form lang="es"><text>josé</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="josé_0" guid="a3569a81-c63d-5778-9a58-82ae519419db"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a male given name from Latin [in turn from Ancient Greek, in turn from Hebrew], feminine equivalent Josefa, equivalent to English Joseph; diminutive forms Che, Coché, Josecito, Joselito, Pepe, Pepito</text></gloss></sense><sense id="josé_1" guid="ce972bdd-b3ac-5f89-95b5-8a15bdcfe07a"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Joseph (eleventh and favorite son of Jacob, by his wife Rachel)</text></gloss></sense><sense id="josé_2" guid="d5aa545a-9593-5759-951a-f53f9e24645a"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Joseph (the husband of Mary, mother of Jesus)</text></gloss></sense><sense id="josé_3" guid="d1d971fe-a537-522b-84d8-14d110d3db63"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the letter J in the Spanish spelling alphabet</text></gloss></sense></entry>
<entry id="jota" guid="16818c33-4971-5d9b-a04e-cf23feeb0599"><lexical-unit><form lang="es"><text>jota</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="jota_0" guid="db9d8d2b-cf8b-567a-bd00-73b7133fe40c"><grammatical-info value="Noun"/><gloss lang="en"><text>jot; iota</text></gloss></sense><sense id="jota_1" guid="3f5dce7c-6eb6-5dcb-8bf5-5dffa8d807e3"><grammatical-info value="Noun"/><gloss lang="en"><text>The name of the Latin script letter J/j.</text></gloss></sense><sense id="jota_2" guid="94b0cc2b-793b-5f63-aff9-7f7620ee17bd"><grammatical-info value="Noun"/><gloss lang="en"><text>a jack in a deck of cards</text></gloss></sense><sense id="jota_3" guid="9a818e77-2f4a-50fc-8f0a-d9a85b034a06"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative form of joto (“faggot”)</text></gloss></sense><sense id="jota_4" guid="dec614f4-0d08-5849-a8e7-4ffe0daa0fbf"><grammatical-info value="Noun"/><gloss lang="en"><text>jota (Iberian folk dance)</text></gloss></sense><sense id="jota_5" guid="9ca07968-41bb-55a1-864c-c820fc8463b0"><grammatical-info value="Noun"/><gloss lang="en"><text>jota (music to which a jota is danced)</text></gloss></sense></entry>
