<entry id="respuesta" guid="8e2e287a-8a43-5ccf-b0dd-71f746344a6d"><lexical-unit><form lang="es"><text>respuesta</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="respuesta_0" guid="9e5aa995-5c26-55e2-ba7e-7315a9ee4a65"><grammatical-info value="Noun"/><gloss lang="en"><text>reply, response, answer</text></gloss></sense></entry>
<entry id="restablecer" guid="1167bfaf-5d52-59e0-b6b1-651d086a5de4"><lexical-unit><form lang="es"><text>restablecer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="restablecer_0" guid="84a9e2a3-d72a-5494-b05e-097f61c9fe5d"><grammatical-info value="Verb"/><gloss lang="en"><text>to restore</text></gloss></sense><sense id="restablecer_1" guid="9ca63999-8889-5d50-aad8-337981e64a27"><grammatical-info value="Verb"/><gloss lang="en"><text>to reset</text></gloss></sense><sense id="restablecer_2" guid="f0458ffb-3132-5925-ad31-ba8d3600cd88"><grammatical-info value="Verb"/><gloss lang="en"><text>to recover, recuperate</text></gloss></sense></entry>
<entry id="restar" guid="2ae8e5b7-712c-57a2-8440-729f9840d8c4"><lexical-unit><form lang="es"><text>restar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="restar_0" guid="564ce813-d7b1-5028-9f54-995d2cebfb82"><grammatical-info value="Verb"/><gloss lang="en"><text>to subtract, to reduce, to deduct</text></gloss></sense><sense id="restar_1" guid="7c931b52-ed20-575d-a961-520603527c6c"><grammatical-info value="Verb"/><gloss lang="en"><text>to remain</text></gloss></sense><sense id="restar_2" guid="47c08fde-e06c-5a26-b1e0-c3af15849449"><grammatical-info value="Verb"/><gloss lang="en"><text>to return (hit the ball back after a serve)</text></gloss></sense></entry>
<entry id="restauración" guid="116a624f-d80e-5933-8584-91ba28876f97"><lexical-unit><form lang="es"><text>restauración</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="restauración_0" guid="054b0d1c-d871-5c17-ae39-c8abbb7c630d"><grammatical-info value="Noun"/><gloss lang="en"><text>restoration, reconstruction</text></gloss></sense><sense id="restauración_1" guid="67a9f18d-3405-553c-9b85-880b981f19a1"><grammatical-info value="Noun"/><gloss lang="en"><text>restoration (political)</text></gloss></sense><sense id="restauración_2" guid="dd4f85ce-0299-56be-88f6-61c79c2e4bec"><grammatical-info value="Noun"/><gloss lang="en"><text>restaurateurship, restaurant-management</text></gloss></sense></entry>
