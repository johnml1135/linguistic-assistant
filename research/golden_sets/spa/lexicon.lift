<entry id="designar" guid="26191905-afa8-583e-849d-4e4f17e81b7a"><lexical-unit><form lang="es"><text>designar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="designar_0" guid="dd0f378c-c21c-5205-850a-da4efecec378"><grammatical-info value="Verb"/><gloss lang="en"><text>to designate</text></gloss></sense></entry>
<entry id="desistir" guid="6205bd18-f82b-57cf-a716-d779ae6818ab"><lexical-unit><form lang="es"><text>desistir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desistir_0" guid="d6e1d610-df25-5f2f-b82e-05e4496fa0ac"><grammatical-info value="Verb"/><gloss lang="en"><text>to desist, to give up</text></gloss></sense><sense id="desistir_1" guid="085a3799-25d3-53ba-86cf-4f9c6dee15e6"><grammatical-info value="Verb"/><gloss lang="en"><text>to waive a right</text></gloss></sense></entry>
<entry id="desleal" guid="9fa6864e-9a62-5914-a169-710c1a26a200"><lexical-unit><form lang="es"><text>desleal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desleal_0" guid="675762c4-27f4-5af3-b997-e7346593807e"><grammatical-info value="Adjective"/><gloss lang="en"><text>not adhering to the rules of propriety, dishonest, unfair, disloyal, not true</text></gloss></sense></entry>
<entry id="desmayar" guid="f52a4179-2a54-5e75-848b-183c51cdaad3"><lexical-unit><form lang="es"><text>desmayar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desmayar_0" guid="e7999c36-03e2-571a-85d8-561c4c8a53c4"><grammatical-info value="Verb"/><gloss lang="en"><text>to dishearten</text></gloss></sense><sense id="desmayar_1" guid="29e94304-edaa-5eab-9480-22c224e6075b"><grammatical-info value="Verb"/><gloss lang="en"><text>to faint (lose consciousness)</text></gloss></sense></entry>
<entry id="desmenuzado" guid="e9bd1b84-3a3f-5120-845e-2a0df63a65f4"><lexical-unit><form lang="es"><text>desmenuzado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desmenuzado_0" guid="fffc90ec-1793-5e0d-a483-56f9818d3fe4"><grammatical-info value="Verb"/></sense></entry>
<entry id="desmenuzar" guid="e6fa8aa6-dc21-569b-be17-a32c9c7367ae"><lexical-unit><form lang="es"><text>desmenuzar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desmenuzar_0" guid="342939dd-b688-5eb1-8d6b-20330fab5a60"><grammatical-info value="Verb"/><gloss lang="en"><text>to crumble</text></gloss></sense><sense id="desmenuzar_1" guid="17158b61-d0f2-5681-905d-37fcdb0fecbe"><grammatical-info value="Verb"/><gloss lang="en"><text>to fine-tooth comb</text></gloss></sense></entry>
