<entry id="cuanto" guid="a38d73be-c08e-5f06-a879-8bb37325ea65"><lexical-unit><form lang="es"><text>cuanto</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cuanto_0" guid="c444e4b1-1368-57d3-a677-9329f942501d"><grammatical-info value="Pronoun"/><gloss lang="en"><text>whatever quantity, as much, however much</text></gloss></sense><sense id="cuanto_1" guid="86cb0dff-a7de-546a-af5f-6c9bea2e86e8"><grammatical-info value="Pronoun"/><gloss lang="en"><text>as much [of]; as many; however much; however many</text></gloss></sense><sense id="cuanto_2" guid="d695ea18-f969-5517-b665-9f11ca8d48c7"><grammatical-info value="Pronoun"/><gloss lang="en"><text>few; quite a few; a handful</text></gloss></sense><sense id="cuanto_3" guid="c0a2b06b-b25a-546a-83fa-c58f00ff2715"><grammatical-info value="Pronoun"/><gloss lang="en"><text>however much; however many; (constructing parallel comparatives) “the..., the...”</text></gloss></sense><sense id="cuanto_4" guid="0e5965d9-c42b-55e3-b517-f38f691302ae"><grammatical-info value="Pronoun"/><gloss lang="en"><text>as much; however much; in whatever quantity</text></gloss></sense><sense id="cuanto_5" guid="5c168096-9b58-5c50-959c-698b0c736151"><grammatical-info value="Pronoun"/><gloss lang="en"><text>quantum</text></gloss></sense></entry>
<entry id="cuarenta" guid="6358c588-587d-5abd-b991-455cd8ce5425"><lexical-unit><form lang="es"><text>cuarenta</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cuarenta_0" guid="1d3e297a-cd9a-5276-994a-2cc703b664df"><grammatical-info value="Numeral"/><gloss lang="en"><text>forty</text></gloss></sense></entry>
<entry id="cuarta" guid="7e99361e-ea33-5143-88a7-4d8c2376e75d"><lexical-unit><form lang="es"><text>cuarta</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cuarta_0" guid="67e2fbfb-baef-5364-ba2b-53105aae631a"><grammatical-info value="Noun"/><gloss lang="en"><text>synonym of disciplina (a hemp whip resembling a cat-o'-nine-tails)</text></gloss></sense><sense id="cuarta_1" guid="ce18f072-dc7f-5259-8bbb-3868f35e0927"><grammatical-info value="Noun"/><gloss lang="en"><text>synonym of látigo (a short horse whip)</text></gloss></sense><sense id="cuarta_2" guid="90ca497c-e37b-5eec-b9e6-fdaa149c50c6"><grammatical-info value="Noun"/><gloss lang="en"><text>fourth, quarter (one of four equal divisions of some whole)</text></gloss></sense><sense id="cuarta_3" guid="980d4c8e-3fa2-5138-9312-b1f24b625b20"><grammatical-info value="Noun"/><gloss lang="en"><text>quatorze (set of four similar cards in piquet)</text></gloss></sense><sense id="cuarta_4" guid="074fe44c-54ae-5c08-a486-1c2537d793b7"><grammatical-info value="Noun"/><gloss lang="en"><text>synonym of cuarta funeral (the right of a church to part of the payment for its parishioners' funeral and mass services when held elsewhere)</text></gloss></sense><sense id="cuarta_5" guid="d7e6a6b1-5ad9-58e5-a090-7881e8641a2b"><grammatical-info value="Noun"/><gloss lang="en"><text>battalion (particularly a battalion forming exactly one-fourth of a company)</text></gloss></sense><sense id="cuarta_6" guid="e56b41b2-b1a9-5e8a-9161-cd5e4053f5a4"><grammatical-info value="Noun"/><gloss lang="en"><text>quadrant (an astronomical tool)</text></gloss></sense><sense id="cuarta_7" guid="d996b9e6-b281-5b1c-8be9-af71ac14719f"><grammatical-info value="Noun"/><gloss lang="en"><text>cuarta, quarter-ferrado (a Galician unit of dry measure equivalent to about 3–4.5 L depending on the substance measured)</text></gloss></sense></entry>
<entry id="cuarto" guid="71571fd6-c70f-5c18-baa0-e91ea5074627"><lexical-unit><form lang="es"><text>cuarto</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cuarto_0" guid="596d44bf-b90c-559f-9a89-324a1b5a4250"><grammatical-info value="Adjective"/><gloss lang="en"><text>fourth</text></gloss></sense><sense id="cuarto_1" guid="b72fbc48-282f-5624-80ff-dc2987b13f8b"><grammatical-info value="Adjective"/><gloss lang="en"><text>fourth (in a series)</text></gloss></sense><sense id="cuarto_2" guid="32ed74cb-4e79-5a3e-a20d-75845e5892b9"><grammatical-info value="Adjective"/><gloss lang="en"><text>fourth, quarter (one of four equal divisions of a whole)</text></gloss></sense><sense id="cuarto_3" guid="ad08cb68-eee1-559d-85ce-43d35bf08c27"><grammatical-info value="Adjective"/><gloss lang="en"><text>quarter-hour (one of four equal divisions of an hour)</text></gloss></sense><sense id="cuarto_4" guid="20ced44b-bf16-5216-9d26-e7deaa6bdad3"><grammatical-info value="Adjective"/><gloss lang="en"><text>watch (one of the four approximately equal divisions of the night, especially for shifts of watchmen)</text></gloss></sense><sense id="cuarto_5" guid="cce65fc6-b7cc-5fe3-8dd8-971a9f02fd10"><grammatical-info value="Adjective"/><gloss lang="en"><text>watch (one of the four equal divisions of soldiers, guards, police, &amp;c. for routine patrols)</text></gloss></sense><sense id="cuarto_6" guid="d57f44c7-ea40-5712-b694-c39911b1dd1f"><grammatical-info value="Adjective"/><gloss lang="en"><text>English or American quart (a unit of liquid measure equal to ¹⁄₄ galón, equivalent to about 0.95 L)</text></gloss></sense><sense id="cuarto_7" guid="2b729b59-a610-560f-97a7-b2b4c329bbde"><grammatical-info value="Adjective"/><gloss lang="en"><text>cuarto, quarter-sack (a traditional unit of dry measure equal to ¹⁄₄ saco, equivalent to about 27.8 L)</text></gloss></sense></entry>
<entry id="cuaternión" guid="b4b84d04-d787-5357-b21b-0fff3051b868"><lexical-unit><form lang="es"><text>cuaternión</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cuaternión_0" guid="0c2f118b-edc1-51f1-853d-b0c616f7d3d0"><grammatical-info value="Noun"/><gloss lang="en"><text>quaternion</text></gloss></sense></entry>
