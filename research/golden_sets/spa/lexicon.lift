<entry id="polvo" guid="20d6a203-600b-52d9-83a6-6b562267db13"><lexical-unit><form lang="es"><text>polvo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="polvo_0" guid="c75b5948-f53e-52e4-89bb-58b5bd173b86"><grammatical-info value="Noun"/><gloss lang="en"><text>dust (fine, dry particles of matter found in the air and covering the surface of objects)</text></gloss></sense><sense id="polvo_1" guid="a4cce25b-a788-5b5b-a658-557ba906aca0"><grammatical-info value="Noun"/><gloss lang="en"><text>powder, dust (fine particles of a dry substance)</text></gloss></sense><sense id="polvo_2" guid="b9e719c3-936e-504a-adcc-9309d0f3c7bf"><grammatical-info value="Noun"/><gloss lang="en"><text>fuck, screw (sexual intercourse)</text></gloss></sense><sense id="polvo_3" guid="e7940b4d-2f0c-5abf-b99b-7baa6846364c"><grammatical-info value="Noun"/><gloss lang="en"><text>see polvos</text></gloss></sense></entry>
