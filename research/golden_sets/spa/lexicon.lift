<entry id="ajeno" guid="29d4ad21-e807-5343-824c-f31c46f5847d"><lexical-unit><form lang="es"><text>ajeno</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ajeno_0" guid="5ba4ca4f-2a1e-582b-9e56-fc4b35a04486"><grammatical-info value="Adjective"/><gloss lang="en"><text>of others, belonging to someone else</text></gloss></sense><sense id="ajeno_1" guid="58e09e35-aebc-5f3d-a147-b66cf46f2390"><grammatical-info value="Adjective"/><gloss lang="en"><text>distant, alien, foreign</text></gloss></sense><sense id="ajeno_2" guid="07139f95-862b-5abf-af12-7f9ef97a6beb"><grammatical-info value="Adjective"/><gloss lang="en"><text>extraneous, external</text></gloss></sense></entry>
<entry id="ajustar" guid="a1341988-edc0-53d0-92ee-09b5bfe2f16e"><lexical-unit><form lang="es"><text>ajustar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ajustar_0" guid="41dbcbb6-abf7-524a-a679-f4d043f10730"><grammatical-info value="Verb"/><gloss lang="en"><text>to adjust, to set</text></gloss></sense><sense id="ajustar_1" guid="1c92c98f-a12e-5338-9ad2-891ab3ff69f0"><grammatical-info value="Verb"/><gloss lang="en"><text>to fine-tune</text></gloss></sense><sense id="ajustar_2" guid="a6002ee5-cd56-55fe-9e19-7dfe6d2154c4"><grammatical-info value="Verb"/><gloss lang="en"><text>to fit</text></gloss></sense><sense id="ajustar_3" guid="f0c809c7-cdf5-56ae-83a6-adbc407ea1d7"><grammatical-info value="Verb"/><gloss lang="en"><text>to conform to, abide by, act in accordance with</text></gloss></sense><sense id="ajustar_4" guid="47a5b6f8-fe94-5039-bb8a-1afef914a822"><grammatical-info value="Verb"/><gloss lang="en"><text>to adjust (oneself/itself)</text></gloss></sense></entry>
<entry id="al" guid="37b0b61b-ac3e-5ff2-9d62-b7fe86fe5f41"><lexical-unit><form lang="es"><text>al</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="al_0" guid="26753b30-4019-5c8d-997e-b4ea110ad049"><grammatical-info value="Adposition"/><gloss lang="en"><text>initialism of América Latina</text></gloss></sense><sense id="al_1" guid="37391793-5324-5d22-b950-433c31ed3f6a"><grammatical-info value="Adposition"/><gloss lang="en"><text>contraction of a + el, literally “at the, to the”</text></gloss></sense><sense id="al_2" guid="693326a7-fffc-5982-9364-12e4a0da785a"><grammatical-info value="Adposition"/><gloss lang="en"><text>upon</text></gloss></sense></entry>
