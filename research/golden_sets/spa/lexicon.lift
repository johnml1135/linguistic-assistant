<entry id="cum" guid="192c5806-99b7-5d58-b03b-a478a8247fd7"><lexical-unit><form lang="es"><text>cum</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cum_0" guid="8affadbe-e17a-5dea-aaa1-e9fa449078e1"><grammatical-info value="Proper noun"/><gloss lang="en"><text>cum, semen</text></gloss></sense></entry>
<entry id="cumbre" guid="434ff939-08a6-5f64-b845-a13edf3f680c"><lexical-unit><form lang="es"><text>cumbre</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cumbre_0" guid="9e9b4c5b-52e7-5dbb-8b11-afa1a8bfbbe2"><grammatical-info value="Noun"/><gloss lang="en"><text>summit, peak, top, hilltop (topmost point or surface, especially of a mountain)</text></gloss></sense><sense id="cumbre_1" guid="eed209e3-0273-5b59-a884-5ddc2c3ce934"><grammatical-info value="Noun"/><gloss lang="en"><text>summit (gathering or assembly of leaders)</text></gloss></sense><sense id="cumbre_2" guid="fa1452ca-6980-5429-b9d5-dfa0a00aead8"><grammatical-info value="Noun"/><gloss lang="en"><text>apex, acme</text></gloss></sense><sense id="cumbre_3" guid="46f16db0-2282-51ea-a6a4-eaa76be2f33e"><grammatical-info value="Noun"/><gloss lang="en"><text>main; primary; culminating; peak</text></gloss></sense></entry>
<entry id="cumplido" guid="813436a5-90de-5c3a-a624-472f4e0ac7a5"><lexical-unit><form lang="es"><text>cumplido</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cumplido_0" guid="0771773f-45f0-5614-bdc9-55af3cdbee14"><grammatical-info value="Verb"/><gloss lang="en"><text>polite</text></gloss></sense><sense id="cumplido_1" guid="96fd61a2-0657-5194-baf7-09d2d684cac4"><grammatical-info value="Verb"/><gloss lang="en"><text>thoughtful</text></gloss></sense><sense id="cumplido_2" guid="e262d894-94f8-5c90-8f2c-46301e31ffa9"><grammatical-info value="Verb"/><gloss lang="en"><text>compliment</text></gloss></sense></entry>
<entry id="cumplimentar" guid="ca915048-f5cd-5b8c-be76-e539f04da63f"><lexical-unit><form lang="es"><text>cumplimentar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cumplimentar_0" guid="de7bae7c-08e0-570d-89f6-5ed9d5e7b651"><grammatical-info value="Verb"/><gloss lang="en"><text>to congratulate</text></gloss></sense><sense id="cumplimentar_1" guid="026a5bf9-3cd5-5b91-9d5d-eea03447ee16"><grammatical-info value="Verb"/><gloss lang="en"><text>to fill out/fill in (as a form)</text></gloss></sense></entry>
<entry id="cumplimiento" guid="039bc9e1-6034-5f44-803a-3761f7b505fe"><lexical-unit><form lang="es"><text>cumplimiento</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cumplimiento_0" guid="10347ca3-3ee7-598f-9ba2-656bc5200f52"><grammatical-info value="Noun"/><gloss lang="en"><text>compliance</text></gloss></sense><sense id="cumplimiento_1" guid="f11b7fc6-74db-5aef-8957-8627c9b80290"><grammatical-info value="Noun"/><gloss lang="en"><text>fulfillment, completion</text></gloss></sense><sense id="cumplimiento_2" guid="193497e3-fcaf-5405-b6f9-75557ac1d749"><grammatical-info value="Noun"/><gloss lang="en"><text>formality</text></gloss></sense></entry>
<entry id="cumplir" guid="9d04afa8-bb36-5d8a-887b-168332ed712b"><lexical-unit><form lang="es"><text>cumplir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cumplir_0" guid="ad27a3d9-a5c4-572c-8f7d-2e545348bc0a"><grammatical-info value="Verb"/><gloss lang="en"><text>to fulfil, to fulfill, to meet, to deliver (e.g., requirements, prerequisites, promise, vow)</text></gloss></sense><sense id="cumplir_1" guid="d556b2cc-0058-5fa5-94c9-eae2ec8523ec"><grammatical-info value="Verb"/><gloss lang="en"><text>to achieve, to accomplish, to carry out, to perform, to complete, to discharge, to fulfil (e.g., one's duties, responsibilities)</text></gloss></sense><sense id="cumplir_2" guid="f1ce46fb-4894-57aa-ae11-9d7db39fef9e"><grammatical-info value="Verb"/><gloss lang="en"><text>to turn a certain age (may be succeeded by los)</text></gloss></sense><sense id="cumplir_3" guid="25a824ff-40b3-5121-9446-a537ea246ad4"><grammatical-info value="Verb"/><gloss lang="en"><text>to serve (e.g., a prison sentence, an allotted time of punishment)</text></gloss></sense><sense id="cumplir_4" guid="a3da24b9-067e-5475-89b6-2e7bfa189b7f"><grammatical-info value="Verb"/><gloss lang="en"><text>to comply</text></gloss></sense><sense id="cumplir_5" guid="ccb3f4c4-3de0-5494-bc8e-ffd74199e38b"><grammatical-info value="Verb"/><gloss lang="en"><text>to comply with; to be fulfilled, met, honored, implemented, satisfied, performed, observed, respected, followed</text></gloss></sense><sense id="cumplir_6" guid="3464ea69-ba67-50ef-b969-fdc8cad76584"><grammatical-info value="Verb"/><gloss lang="en"><text>to be served (e.g. a prison sentence or punishment)</text></gloss></sense><sense id="cumplir_7" guid="6a0b3885-be64-5117-9b71-4f70d91763cb"><grammatical-info value="Verb"/><gloss lang="en"><text>to come true, to be fulfilled</text></gloss></sense></entry>
<entry id="cura" guid="99a9d21d-7f1c-56aa-a619-310bcdc9d6ff"><lexical-unit><form lang="es"><text>cura</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cura_0" guid="e9c1821c-8519-5f30-b8ae-b3a114a498af"><grammatical-info value="Noun"/><gloss lang="en"><text>cure (something that restores good health)</text></gloss></sense><sense id="cura_1" guid="47b13012-58ae-578b-b6c6-9f39b3ba86db"><grammatical-info value="Noun"/><gloss lang="en"><text>drunkenness</text></gloss></sense><sense id="cura_2" guid="e60aa525-7aac-5b74-a757-bdf22553952f"><grammatical-info value="Noun"/><gloss lang="en"><text>priest; curate</text></gloss></sense><sense id="cura_3" guid="62279ea6-7b5f-5cbc-b5f5-185079018367"><grammatical-info value="Noun"/><gloss lang="en"><text>avocado</text></gloss></sense><sense id="cura_4" guid="7c5c61d7-0c88-5b38-8a45-75b85314e223"><grammatical-info value="Noun"/><gloss lang="en"><text>female equivalent of curo (“someone from Courland”)</text></gloss></sense></entry>
<entry id="curado" guid="e5422e9e-1a69-56ea-b064-30c1bc1980b6"><lexical-unit><form lang="es"><text>curado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="curado_0" guid="6ef9874a-f810-5f95-8170-5de7bc0c4154"><grammatical-info value="Adjective"/><gloss lang="en"><text>cured, healed</text></gloss></sense><sense id="curado_1" guid="b4b2150b-97be-5a12-bc4e-9243c2a530bc"><grammatical-info value="Adjective"/><gloss lang="en"><text>cured, mature (of cheese, bacon, etc.)</text></gloss></sense><sense id="curado_2" guid="13dac07e-f08e-5709-80f9-b1043827aec1"><grammatical-info value="Adjective"/><gloss lang="en"><text>drunk, intoxicated</text></gloss></sense><sense id="curado_3" guid="525ce9c5-e460-5325-a234-6877a3ad0cfc"><grammatical-info value="Adjective"/><gloss lang="en"><text>funny, goofy, ridiculous, silly</text></gloss></sense><sense id="curado_4" guid="ecc198f9-7fef-5333-b833-0e93df5bd1db"><grammatical-info value="Adjective"/><gloss lang="en"><text>seasoning, layer of fat added to cookware</text></gloss></sense></entry>
<entry id="curador" guid="2bcdd97b-c8fb-5065-acce-51fb4cb6980b"><lexical-unit><form lang="es"><text>curador</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="curador_0" guid="fdadea1c-ac74-5518-ac55-bb2b54a24631"><grammatical-info value="Noun"/><gloss lang="en"><text>curator</text></gloss></sense><sense id="curador_1" guid="75e512f5-833d-5afc-af9e-6c06e020e7ea"><grammatical-info value="Noun"/><gloss lang="en"><text>executor</text></gloss></sense><sense id="curador_2" guid="491089ce-2cd9-59ab-80f8-b18454f6d83a"><grammatical-info value="Noun"/><gloss lang="en"><text>trustee</text></gloss></sense></entry>
