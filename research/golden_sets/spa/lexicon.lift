<entry id="acusar" guid="07f74fe7-fb86-5f37-b27b-05bd1f1f1333"><lexical-unit><form lang="es"><text>acusar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="acusar_0" guid="a9745a7e-da84-5956-bca6-a384391ed0db"><grammatical-info value="Verb"/><gloss lang="en"><text>to accuse, charge, indict</text></gloss></sense><sense id="acusar_1" guid="a165d8f1-35ee-5466-8b13-615c8ba7689c"><grammatical-info value="Verb"/><gloss lang="en"><text>to criminate</text></gloss></sense><sense id="acusar_2" guid="8e1fefba-9c12-526c-ba8f-9c0cd53524d1"><grammatical-info value="Verb"/><gloss lang="en"><text>to arraign</text></gloss></sense><sense id="acusar_3" guid="eeef670a-8416-56fb-942b-789a702f5942"><grammatical-info value="Verb"/><gloss lang="en"><text>to prosecute</text></gloss></sense><sense id="acusar_4" guid="83bf7f83-6609-5bac-a53c-e4e02e19af2b"><grammatical-info value="Verb"/><gloss lang="en"><text>to acknowledge (to notify sender of having received)</text></gloss></sense><sense id="acusar_5" guid="a2fd821f-6cc3-59f2-87cf-ae69a96d8f1a"><grammatical-info value="Verb"/><gloss lang="en"><text>to confess</text></gloss></sense><sense id="acusar_6" guid="4d6d81cc-68c7-5b48-b6da-934ac0bd1b27"><grammatical-info value="Verb"/><gloss lang="en"><text>to show; to show signs of</text></gloss></sense><sense id="acusar_7" guid="e51be67a-aabb-50b4-a184-9f9bae37d595"><grammatical-info value="Verb"/><gloss lang="en"><text>to snitch, tattle, rat, egg, squeal</text></gloss></sense></entry>
<entry id="acá" guid="68c92344-e1c8-5268-bdcc-dc323cda5319"><lexical-unit><form lang="es"><text>acá</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="acá_0" guid="cbda8aa7-77cd-5026-86b0-677c76c947f7"><grammatical-info value="Adverb"/><gloss lang="en"><text>here</text></gloss></sense><sense id="acá_1" guid="6181723c-5b92-54c9-9e8c-4fdbf0223666"><grammatical-info value="Adverb"/><gloss lang="en"><text>as of, up to (used with a time phrase to represent continuity up to the present)</text></gloss></sense><sense id="acá_2" guid="e6fde0b8-909a-5ae4-aacf-88da7e0d1c3c"><grammatical-info value="Adverb"/><gloss lang="en"><text>high quality</text></gloss></sense></entry>
