<entry id="a" guid="b1d95008-6dcf-5242-aeb4-b5a2f6f06bbf"><lexical-unit><form lang="es"><text>a</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="a_0" guid="3d86f534-7b18-5da8-bb93-1e8562f49c2e"><grammatical-info value="Adposition"/><gloss lang="en"><text>The first letter of the Spanish alphabet, written in the Latin script.</text></gloss></sense><sense id="a_1" guid="7274b29d-20f1-501d-ad40-5ded89fc6814"><grammatical-info value="Adposition"/><gloss lang="en"><text>bishop</text></gloss></sense><sense id="a_2" guid="f189e34e-bd18-5787-8ce7-55feedd3e95b"><grammatical-info value="Adposition"/><gloss lang="en"><text>Name of the letter A.</text></gloss></sense><sense id="a_3" guid="ecde8f1e-80e7-5a64-aec3-ecabc1bb3ee1"><grammatical-info value="Adposition"/><gloss lang="en"><text>to</text></gloss></sense><sense id="a_4" guid="8eee7cb5-fbf4-5bc4-9173-2f6b0469136c"><grammatical-info value="Adposition"/><gloss lang="en"><text>by</text></gloss></sense><sense id="a_5" guid="aea54584-53c7-53d5-9289-096228cbe346"><grammatical-info value="Adposition"/><gloss lang="en"><text>at</text></gloss></sense><sense id="a_6" guid="dff83781-c039-585e-9794-72bf8056c5ff"><grammatical-info value="Adposition"/><gloss lang="en"><text>misspelling of ha</text></gloss></sense></entry>
<entry id="aar" guid="33c3cfc3-7050-5ba9-9cf9-0b86e8d14b65"><lexical-unit><form lang="es"><text>aar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aar_0" guid="2ec0f835-db6d-5b43-be6b-f107837160fc"></sense></entry>
<entry id="aarón" guid="fa31cc0c-2e1f-55c6-b37e-c3b07d071708"><lexical-unit><form lang="es"><text>aarón</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aarón_0" guid="54209329-3e3b-5740-bdaa-016b5b5d45da"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a male given name from Latin [in turn from Ancient Greek, in turn from Hebrew], equivalent to English Aaron</text></gloss></sense></entry>
