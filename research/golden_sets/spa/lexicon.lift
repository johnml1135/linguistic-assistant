<entry id="administración" guid="c22cd54f-36bc-5055-9522-c63b97473a70"><lexical-unit><form lang="es"><text>administración</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="administración_0" guid="95548ea0-0c6c-52f8-9407-791e3429f2ce"><grammatical-info value="Noun"/><gloss lang="en"><text>administration (act of administering government or public affairs)</text></gloss></sense><sense id="administración_1" guid="6dfdf186-fec1-5e66-9d66-326458068856"><grammatical-info value="Noun"/><gloss lang="en"><text>administration (a body that administers)</text></gloss></sense><sense id="administración_2" guid="ac9e930e-1f87-5edb-bb7d-ea1d10744763"><grammatical-info value="Noun"/><gloss lang="en"><text>administration, administering (act of administering something to another)</text></gloss></sense></entry>
