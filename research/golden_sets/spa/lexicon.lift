<entry id="alargar" guid="e6faf23f-0dfb-5296-a1ff-bdd4d39d7d0e"><lexical-unit><form lang="es"><text>alargar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alargar_0" guid="cec1203d-c232-5f5b-b064-cc6c0e12a72b"><grammatical-info value="Verb"/><gloss lang="en"><text>to lengthen</text></gloss></sense><sense id="alargar_1" guid="1ac01cb1-46c7-5de6-bead-f4812a0d84c6"><grammatical-info value="Verb"/><gloss lang="en"><text>to stretch, to extend</text></gloss></sense></entry>
