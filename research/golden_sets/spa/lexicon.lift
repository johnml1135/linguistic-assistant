<entry id="sam" guid="4df851ac-965c-5706-9262-4eeba340d0d1"><lexical-unit><form lang="es"><text>sam</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sam_0" guid="d4e2f017-3e53-531b-a173-ee77f86fc8b1"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="samaria" guid="2e067b54-3338-59c6-96b2-b558adf5cd96"><lexical-unit><form lang="es"><text>samaria</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="samaria_0" guid="ca197861-7d01-5d40-aede-c7a75d23652f"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Samaria (the ancient capital of the northern Kingdom of Israel, in the modern West Bank)</text></gloss></sense><sense id="samaria_1" guid="b23da387-73e3-5f96-9b8f-f4d14d270b50"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Samaria (an ancient region of the region of Palestine, mostly in the northern part of the modern West Bank)</text></gloss></sense><sense id="samaria_2" guid="baedce59-b415-5ddd-b844-0e99e4ed4766"><grammatical-info value="Proper noun"/><gloss lang="en"><text>female equivalent of samario</text></gloss></sense></entry>
