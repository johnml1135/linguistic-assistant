<entry id="carga" guid="124c49bc-f99c-50b9-aca4-eeebe008ee8d"><lexical-unit><form lang="es"><text>carga</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="carga_0" guid="4b51a225-985b-512c-9fce-ed153487d5c2"><grammatical-info value="Noun"/><gloss lang="en"><text>load</text></gloss></sense><sense id="carga_1" guid="c0c361d3-53b8-5c16-b34d-defb2fc66606"><grammatical-info value="Noun"/><gloss lang="en"><text>burden</text></gloss></sense><sense id="carga_2" guid="d1750b49-44ba-5ace-9c4c-7076770805cc"><grammatical-info value="Noun"/><gloss lang="en"><text>cargo</text></gloss></sense><sense id="carga_3" guid="ac0cc2c5-94d8-5657-944c-0f0cae6b848f"><grammatical-info value="Noun"/><gloss lang="en"><text>charge</text></gloss></sense><sense id="carga_4" guid="e3feb02b-645c-5bdf-9289-e17deddbb940"><grammatical-info value="Noun"/><gloss lang="en"><text>carga (a traditional unit of dry measure equivalent to about 222 L)</text></gloss></sense><sense id="carga_5" guid="e2e26ee6-f7d1-5325-a90e-a0deaf3718f5"><grammatical-info value="Noun"/><gloss lang="en"><text>blitz</text></gloss></sense><sense id="carga_6" guid="f7e6592e-fb36-52a8-a873-937c10d673f5"><grammatical-info value="Noun"/><gloss lang="en"><text>female equivalent of cargo</text></gloss></sense></entry>
