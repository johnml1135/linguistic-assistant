<entry id="reunido" guid="f83b06b0-9125-57c0-a6ab-71d18a8f1a16"><lexical-unit><form lang="es"><text>reunido</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="reunido_0" guid="7a721835-5db9-5b8e-b268-4002ed150083"><grammatical-info value="Verb"/><gloss lang="en"><text>gathered</text></gloss></sense></entry>
<entry id="reunir" guid="b730dc5e-296a-57f8-9f9d-283ef4e37372"><lexical-unit><form lang="es"><text>reunir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="reunir_0" guid="3cf98a14-2284-5e0a-85d8-4d6544ecb186"><grammatical-info value="Verb"/><gloss lang="en"><text>to gather, to collect, to bring together, to assemble, to get together, to round up, to marshal, to compile, to put together, to pull together, to draw together, to pool</text></gloss></sense><sense id="reunir_1" guid="c0426b6b-be36-5373-847f-95f15f73e4c0"><grammatical-info value="Verb"/><gloss lang="en"><text>to satisfy, to meet, to possess (e.g. conditions, requirements, criteria, qualifications, characteristics)</text></gloss></sense><sense id="reunir_2" guid="509de55c-0a9d-54c3-8d8c-c310568c6832"><grammatical-info value="Verb"/><gloss lang="en"><text>to join, unite</text></gloss></sense><sense id="reunir_3" guid="2a334f3a-64c1-5f86-a768-519f7f760063"><grammatical-info value="Verb"/><gloss lang="en"><text>to reunite, reconvene</text></gloss></sense><sense id="reunir_4" guid="c8a1044e-ddf4-545a-8750-11d109c1eb46"><grammatical-info value="Verb"/><gloss lang="en"><text>to muster, to summon (e.g. the courage, determination, will, strength, energy)</text></gloss></sense><sense id="reunir_5" guid="60e105da-7446-5d4b-be5a-0914257b59fc"><grammatical-info value="Verb"/><gloss lang="en"><text>to raise, to muster (e.g. money, an army)</text></gloss></sense><sense id="reunir_6" guid="f5d01272-d722-588f-b0b6-1af47facf1b6"><grammatical-info value="Verb"/><gloss lang="en"><text>to huddle</text></gloss></sense><sense id="reunir_7" guid="1b90d796-3549-55b8-928a-03c50f625b9a"><grammatical-info value="Verb"/><gloss lang="en"><text>to meet, to meet up, to get together, to assemble, to convene, to rendezvous</text></gloss></sense></entry>
<entry id="revel" guid="ec35d629-5bab-5009-b753-195c6752b9ce"><lexical-unit><form lang="es"><text>revel</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="revel_0" guid="b3eb43ee-eaff-55cc-8936-07978c314bb6"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="revelación" guid="ef63a508-893b-55f3-9528-1bef5e6c066e"><lexical-unit><form lang="es"><text>revelación</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="revelación_0" guid="dad06951-80d0-5d6c-ba1b-17c035542851"><grammatical-info value="Noun"/><gloss lang="en"><text>revelation</text></gloss></sense><sense id="revelación_1" guid="7a8da2a4-7772-5d3b-bc99-310820c4db5a"><grammatical-info value="Noun"/><gloss lang="en"><text>insight</text></gloss></sense><sense id="revelación_2" guid="8b68ebc5-62ad-54c8-ab78-30ca909300be"><grammatical-info value="Noun"/><gloss lang="en"><text>unveiling</text></gloss></sense></entry>
<entry id="revelar" guid="4ac2fa60-8254-5af0-8b0f-a8679eea0604"><lexical-unit><form lang="es"><text>revelar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="revelar_0" guid="e6fcbed3-2d11-59ce-8d0e-55107993cc2b"><grammatical-info value="Verb"/><gloss lang="en"><text>to reveal</text></gloss></sense><sense id="revelar_1" guid="9365ce2c-8c87-5598-9af0-c31b3ef7a520"><grammatical-info value="Verb"/><gloss lang="en"><text>to develop (to bring out images latent in photographic film)</text></gloss></sense></entry>
<entry id="reventar" guid="c33c2b4e-e678-5571-b0d8-ca4e415779d2"><lexical-unit><form lang="es"><text>reventar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="reventar_0" guid="b79eaad2-ffd0-50ed-9e52-32d13f3eed56"><grammatical-info value="Verb"/><gloss lang="en"><text>to burst, explode, blow up, break</text></gloss></sense><sense id="reventar_1" guid="61f3e888-d8ce-51a4-bd52-4c2c86b8daa1"><grammatical-info value="Verb"/><gloss lang="en"><text>to annoy; hack off</text></gloss></sense><sense id="reventar_2" guid="fa891a9a-6301-57ac-83f4-7701ed752a5c"><grammatical-info value="Verb"/><gloss lang="en"><text>to die (to do something)</text></gloss></sense><sense id="reventar_3" guid="f523a783-975d-5489-a5c6-689b928001fd"><grammatical-info value="Verb"/><gloss lang="en"><text>to burst (into)</text></gloss></sense><sense id="reventar_4" guid="28553940-fe3a-5bcb-89f1-9c55f7b8cf80"><grammatical-info value="Verb"/><gloss lang="en"><text>to wear out; knacker</text></gloss></sense><sense id="reventar_5" guid="c3f821a6-9f9a-5842-8b2e-36b232830d67"><grammatical-info value="Verb"/><gloss lang="en"><text>to have anal sex</text></gloss></sense><sense id="reventar_6" guid="e3bc9860-acae-5c05-b309-a0804a5918a2"><grammatical-info value="Verb"/><gloss lang="en"><text>to diss, to mock, to roast (to subject someone to excessive banter and criticism, either amicably or ill-intentionedly)</text></gloss></sense></entry>
<entry id="reverdecer" guid="d1aac157-0a04-5a60-a855-8753f8c41572"><lexical-unit><form lang="es"><text>reverdecer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="reverdecer_0" guid="db684d3e-bed2-50ef-b5c1-c72adf3ae3f1"><grammatical-info value="Verb"/><gloss lang="en"><text>to become green again, go green again</text></gloss></sense><sense id="reverdecer_1" guid="8eecc934-89dd-58bf-8d39-e9a6ea155fda"><grammatical-info value="Verb"/><gloss lang="en"><text>to revive, reanimate</text></gloss></sense></entry>
