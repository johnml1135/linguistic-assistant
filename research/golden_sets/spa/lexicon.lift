<entry id="cargar" guid="d579a6ca-c8d9-583f-af14-bf6ae25cea02"><lexical-unit><form lang="es"><text>cargar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cargar_0" guid="32c1ec6c-0c48-515d-9742-c122e842e661"><grammatical-info value="Verb"/><gloss lang="en"><text>to load (to put a load on or in (a means of conveyance or a place of storage))</text></gloss></sense><sense id="cargar_1" guid="28141d81-6f5c-5e69-8da3-47313312a225"><grammatical-info value="Verb"/><gloss lang="en"><text>to load (to fill (a firearm or artillery) with munition)</text></gloss></sense><sense id="cargar_2" guid="5a73bbac-9287-5f33-bd41-fe3f1cc8b898"><grammatical-info value="Verb"/><gloss lang="en"><text>to load (to insert (an item or items) into an apparatus so as to ready it for operation, such as a reel of film into a camera, sheets of paper into a printer etc)</text></gloss></sense><sense id="cargar_3" guid="2619c9cd-59f6-5bfe-bf8c-741c3451bf76"><grammatical-info value="Verb"/><gloss lang="en"><text>to load (to load a software into the primary memory)</text></gloss></sense><sense id="cargar_4" guid="89bafab5-07bc-5ae8-b919-259ed0812a9d"><grammatical-info value="Verb"/><gloss lang="en"><text>to carry (to lift (something) and take it to another place; to transport (something) by lifting)</text></gloss></sense><sense id="cargar_5" guid="66d7fa49-5ee0-5ae5-a1f2-cc24acb71bb0"><grammatical-info value="Verb"/><gloss lang="en"><text>to charge (to replenish energy to (a battery, or a device containing a battery) by use of an electrical device plugged into a power outlet)</text></gloss></sense><sense id="cargar_6" guid="30e248c2-a7af-5ee9-9877-83b30e79e90b"><grammatical-info value="Verb"/><gloss lang="en"><text>to annoy, pester</text></gloss></sense><sense id="cargar_7" guid="93a3db77-d5b3-5553-9939-7ad6d184332f"><grammatical-info value="Verb"/><gloss lang="en"><text>to blitz</text></gloss></sense></entry>
<entry id="cargazón" guid="a50d47d9-512f-5a13-bfc8-ff65818b368d"><lexical-unit><form lang="es"><text>cargazón</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cargazón_0" guid="1d73b289-713c-55eb-97a1-2312bfd4e6ed"><grammatical-info value="Noun"/><gloss lang="en"><text>heavy load</text></gloss></sense><sense id="cargazón_1" guid="d50df96f-47ba-50ec-8c6a-0e43e33b24e1"><grammatical-info value="Noun"/><gloss lang="en"><text>heaviness</text></gloss></sense><sense id="cargazón_2" guid="417a62f1-c966-5a3f-9ce5-d15f485c9cb2"><grammatical-info value="Noun"/><gloss lang="en"><text>heavy cloud cover</text></gloss></sense></entry>
<entry id="caridad" guid="84e217df-de94-51dd-87df-39b5d8e64447"><lexical-unit><form lang="es"><text>caridad</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="caridad_0" guid="a64c1c36-7cbd-598f-a4fb-195af9792ff8"><grammatical-info value="Noun"/><gloss lang="en"><text>charity</text></gloss></sense><sense id="caridad_1" guid="191dba23-20e0-5dff-8613-8ba3876721af"><grammatical-info value="Noun"/><gloss lang="en"><text>a female given name, equivalent to English Charity</text></gloss></sense></entry>
<entry id="carnal" guid="17a559e8-08c3-5cdf-99b2-855fb36275b8"><lexical-unit><form lang="es"><text>carnal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="carnal_0" guid="5b7985df-c435-5089-9be9-ed87d47503fb"><grammatical-info value="Adjective"/><gloss lang="en"><text>carnal (relating to the physical, especially sexual, appetites)</text></gloss></sense><sense id="carnal_1" guid="9c8e3cca-3ec0-51e7-8a0e-8bac798eec49"><grammatical-info value="Adjective"/><gloss lang="en"><text>consanguineous, by blood (related through birth)</text></gloss></sense><sense id="carnal_2" guid="38dfc21b-0c55-5373-933c-894fd249ab93"><grammatical-info value="Adjective"/><gloss lang="en"><text>ellipsis of hermano carnal (“brother by blood”); brother (in opposition to adopted or in-law)</text></gloss></sense></entry>
<entry id="carne" guid="3379284e-3a1a-5ea4-afbd-65b2c05fd435"><lexical-unit><form lang="es"><text>carne</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="carne_0" guid="650ba9b8-f4c4-5478-8bec-33b1c3a3a40c"><grammatical-info value="Noun"/><gloss lang="en"><text>flesh, the soft part of a body which covers the bones</text></gloss></sense><sense id="carne_1" guid="8f49da9e-2e8c-53b6-8f93-a68f28e5fc0a"><grammatical-info value="Noun"/><gloss lang="en"><text>an animal’s meat, or by extension the edible “fleshy” or soft part of a fruit or vegetable</text></gloss></sense></entry>
<entry id="carnicería" guid="3df3facf-fbaa-59c7-a1c3-3f31b3fce589"><lexical-unit><form lang="es"><text>carnicería</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="carnicería_0" guid="00c9ebaa-ea65-540c-8489-1de7058c6b44"><grammatical-info value="Noun"/><gloss lang="en"><text>butchershop</text></gloss></sense><sense id="carnicería_1" guid="26ff0754-af66-56a8-985f-b04da24d1609"><grammatical-info value="Noun"/><gloss lang="en"><text>carnage</text></gloss></sense></entry>
<entry id="caro" guid="9fb9f08c-de6b-5333-b89f-12e3be7c6a95"><lexical-unit><form lang="es"><text>caro</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="caro_0" guid="fae67300-73bd-5a2d-b7e5-b408e0450507"><grammatical-info value="Adjective"/><gloss lang="en"><text>dear (loved)</text></gloss></sense><sense id="caro_1" guid="c9f1a0f6-7aeb-5757-8bb8-1f8df2a88268"><grammatical-info value="Adjective"/><gloss lang="en"><text>expensive</text></gloss></sense><sense id="caro_2" guid="bb81a56c-6912-5a51-9c9c-f23454d91cba"><grammatical-info value="Adjective"/><gloss lang="en"><text>costly</text></gloss></sense><sense id="caro_3" guid="4d129e0a-c8fa-545c-bf18-1031a88f7a8f"><grammatical-info value="Adjective"/><gloss lang="en"><text>a diminutive of the female given name Carolina</text></gloss></sense><sense id="caro_4" guid="8294c82f-c76b-531f-83bd-0e700df7067f"><grammatical-info value="Adjective"/><gloss lang="en"><text>Carus</text></gloss></sense></entry>
<entry id="carpintero" guid="edf8b8fe-1dfe-5777-8b65-fe706357c869"><lexical-unit><form lang="es"><text>carpintero</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="carpintero_0" guid="80ab22c3-4f61-5064-bb70-f956b6be603d"><grammatical-info value="Noun"/><gloss lang="en"><text>carpenter</text></gloss></sense><sense id="carpintero_1" guid="a4724808-dfe7-547c-9b40-0b7a58e502ab"><grammatical-info value="Noun"/><gloss lang="en"><text>woodpecker</text></gloss></sense><sense id="carpintero_2" guid="c9d9372b-3057-554c-adec-75e956b51052"><grammatical-info value="Noun"/><gloss lang="en"><text>a surname originating as an occupation</text></gloss></sense></entry>
<entry id="carpir" guid="084121e2-07b6-599f-8e62-92e9a0e9407c"><lexical-unit><form lang="es"><text>carpir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="carpir_0" guid="d2881b7d-a900-5c72-8663-20914d39d0c8"><grammatical-info value="Verb"/><gloss lang="en"><text>to weed; to hoe</text></gloss></sense></entry>
<entry id="carrera" guid="58318baa-6c69-5b4f-a086-f04bd33080c3"><lexical-unit><form lang="es"><text>carrera</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="carrera_0" guid="458bb1e4-048d-535a-b3a1-21e13308c11a"><grammatical-info value="Noun"/><gloss lang="en"><text>race</text></gloss></sense><sense id="carrera_1" guid="7f7400bf-e541-5c57-9b56-5a8949c71951"><grammatical-info value="Noun"/><gloss lang="en"><text>run (act of running)</text></gloss></sense><sense id="carrera_2" guid="fbed4bef-b5db-5470-800a-8085172ceee2"><grammatical-info value="Noun"/><gloss lang="en"><text>run</text></gloss></sense><sense id="carrera_3" guid="94bc644d-891a-586b-a249-817579363bae"><grammatical-info value="Noun"/><gloss lang="en"><text>college degree, major, main course of study</text></gloss></sense><sense id="carrera_4" guid="cbad2094-9e43-5b8d-bc05-578d2b06f04a"><grammatical-info value="Noun"/><gloss lang="en"><text>career</text></gloss></sense><sense id="carrera_5" guid="912e66e3-1a3d-5045-82c7-ac4f5f049dc1"><grammatical-info value="Noun"/><gloss lang="en"><text>run (line of knit stitches which have unravelled)</text></gloss></sense><sense id="carrera_6" guid="35e95466-c4e8-5f80-8134-43bbb2d80939"><grammatical-info value="Noun"/><gloss lang="en"><text>journey, fare (of a taxi)</text></gloss></sense><sense id="carrera_7" guid="f0fed529-e18a-55c9-ab74-d32c6ea84c05"><grammatical-info value="Noun"/><gloss lang="en"><text>path (of a moving object), trajectory</text></gloss></sense></entry>
<entry id="carro" guid="9ea3d31b-aa36-55cd-bf57-ecad1ff3f265"><lexical-unit><form lang="es"><text>carro</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="carro_0" guid="e98a0bc3-9d48-5e2b-a24a-20005b418b63"><grammatical-info value="Noun"/><gloss lang="en"><text>cart</text></gloss></sense><sense id="carro_1" guid="f030f664-40cd-533b-a9ca-c575b6e4a338"><grammatical-info value="Noun"/><gloss lang="en"><text>car, automobile (used especially in Central America, the Caribbean, Colombia, Peru, Ecuador, Venezuela and Mexico)</text></gloss></sense><sense id="carro_2" guid="7c9fd521-8826-58ef-837f-1a71481f7074"><grammatical-info value="Noun"/><gloss lang="en"><text>a bus or minivan used on public transportation to carry passengers from one part of a city to another (while it has the same meaning as 'auto', 'carro' is preferred when referring to public transportation automobiles)</text></gloss></sense><sense id="carro_3" guid="6da4509b-2e6d-5c61-b704-04ea84f2d770"><grammatical-info value="Noun"/><gloss lang="en"><text>train car</text></gloss></sense><sense id="carro_4" guid="dc125d74-419f-5257-8392-acfd82d2d3a9"><grammatical-info value="Noun"/><gloss lang="en"><text>cocaine paste</text></gloss></sense><sense id="carro_5" guid="1a05692b-dd1a-53e7-b858-6f367168a7d1"><grammatical-info value="Noun"/><gloss lang="en"><text>the Big Dipper (constellation)</text></gloss></sense></entry>
<entry id="carta" guid="a480cf26-039e-5e0f-ac34-c2f2b25b81f9"><lexical-unit><form lang="es"><text>carta</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="carta_0" guid="f9e6a9e0-700a-5bbf-9268-e8705d61eb93"><grammatical-info value="Noun"/><gloss lang="en"><text>letter (document)</text></gloss></sense><sense id="carta_1" guid="12b3caab-1896-58f2-9c0f-8d1baf5b64e1"><grammatical-info value="Noun"/><gloss lang="en"><text>map</text></gloss></sense><sense id="carta_2" guid="6c33670c-03a9-5866-a871-0ee01cf248fc"><grammatical-info value="Noun"/><gloss lang="en"><text>menu (list of dishes in a restaurant)</text></gloss></sense><sense id="carta_3" guid="3e606100-327d-5562-ab24-fc50820b93ab"><grammatical-info value="Noun"/><gloss lang="en"><text>playing card</text></gloss></sense></entry>
<entry id="carísimo" guid="f1d2daf4-dd68-5bca-916d-9426b4d6ebc1"><lexical-unit><form lang="es"><text>carísimo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="carísimo_0" guid="51624929-7de5-5813-bfa6-0acd6bb7ea52"><grammatical-info value="Adjective"/><gloss lang="en"><text>superlative degree of caro: very expensive</text></gloss></sense></entry>
<entry id="cas" guid="8818ac4d-980b-5ba6-9220-e1fd7147d9ac"><lexical-unit><form lang="es"><text>cas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cas_0" guid="68e9922b-40c4-507f-94dd-8436d4d18bfa"><grammatical-info value="Noun"/><gloss lang="en"><text>the fruit of a very tart species of guava</text></gloss></sense><sense id="cas_1" guid="6debaa74-f118-5f52-95d7-b0d507a63660"><grammatical-info value="Noun"/><gloss lang="en"><text>the tree that bears those fruits, Psidium friedrichsthalianum</text></gloss></sense></entry>
<entry id="casa" guid="e0c788d7-4061-540a-bd9c-138f903c71be"><lexical-unit><form lang="es"><text>casa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="casa_0" guid="f1d24d4c-ab0e-52f2-bf43-289576fa552c"><grammatical-info value="Noun"/><gloss lang="en"><text>house</text></gloss></sense></entry>
<entry id="casada" guid="79611afa-5814-56a9-aab9-afb2706be013"><lexical-unit><form lang="es"><text>casada</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="casada_0" guid="86104b70-cddc-59c1-8d61-9364883ad0fd"><grammatical-info value="Adjective"/><gloss lang="en"><text>female equivalent of casado: married woman</text></gloss></sense></entry>
<entry id="casamiento" guid="51f55991-fae1-5d2b-9cbd-0109db5c12cf"><lexical-unit><form lang="es"><text>casamiento</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="casamiento_0" guid="b09bdadb-4c4d-556d-9253-7cf6de11d623"><grammatical-info value="Noun"/><gloss lang="en"><text>marriage (event)</text></gloss></sense><sense id="casamiento_1" guid="757a75f2-b964-58fd-9a45-ef16307a882e"><grammatical-info value="Noun"/><gloss lang="en"><text>wedding</text></gloss></sense><sense id="casamiento_2" guid="c9bcfc94-d37d-596a-87c3-8960f108404a"><grammatical-info value="Noun"/><gloss lang="en"><text>dowry</text></gloss></sense><sense id="casamiento_3" guid="7cbb49b5-808d-5ba3-936a-99237914ef29"><grammatical-info value="Noun"/><gloss lang="en"><text>A dish made by mixing fried rice and beans together.</text></gloss></sense></entry>
<entry id="casar" guid="4ed91532-8027-58c7-822b-67943ba183f1"><lexical-unit><form lang="es"><text>casar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="casar_0" guid="19808ec1-4d09-5e5c-846b-276a11c8a721"><grammatical-info value="Verb"/><gloss lang="en"><text>to marry, wed someone to (unite two others in wedlock)</text></gloss></sense><sense id="casar_1" guid="25150bb4-0cca-5f87-9e5a-5e1c97316685"><grammatical-info value="Verb"/><gloss lang="en"><text>to marry off</text></gloss></sense><sense id="casar_2" guid="a8b55679-5b06-571f-9a12-f27bb827062c"><grammatical-info value="Verb"/><gloss lang="en"><text>to match (up), fit (together)</text></gloss></sense><sense id="casar_3" guid="865751bb-48b0-52a7-abfc-e4c6aa064867"><grammatical-info value="Verb"/><gloss lang="en"><text>to get married, marry (each other, one another)</text></gloss></sense><sense id="casar_4" guid="7b9a45ea-9b65-5acf-9c52-52b0bef5dbd2"><grammatical-info value="Verb"/><gloss lang="en"><text>to wed, marry, get married</text></gloss></sense></entry>
<entry id="cascar" guid="9e08fee8-a62f-5b33-87a4-0cf118532846"><lexical-unit><form lang="es"><text>cascar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cascar_0" guid="cd6cf2aa-da72-5989-8d95-b7a4d329e4dc"><grammatical-info value="Verb"/><gloss lang="en"><text>to crack, to split</text></gloss></sense><sense id="cascar_1" guid="bb1f99a0-8a99-55b9-bc94-b5bad9342f74"><grammatical-info value="Verb"/><gloss lang="en"><text>to hit</text></gloss></sense><sense id="cascar_2" guid="dc16ed27-f42a-528a-8643-a0085f5d0235"><grammatical-info value="Verb"/><gloss lang="en"><text>to wank</text></gloss></sense><sense id="cascar_3" guid="85ca2122-e96f-5732-a852-3e2b736e6d67"><grammatical-info value="Verb"/><gloss lang="en"><text>(informal) to chatter</text></gloss></sense><sense id="cascar_4" guid="74e6a0e3-7fc8-5317-846a-173ee22404ba"><grammatical-info value="Verb"/><gloss lang="en"><text>(reflexive) (dysphemistic) to snuff it (die)</text></gloss></sense><sense id="cascar_5" guid="09f53b52-7a15-55ed-aca4-75b2fa277a75"><grammatical-info value="Verb"/><gloss lang="en"><text>to slap (a fine on someone)</text></gloss></sense></entry>
