<entry id="saltar" guid="c385768a-ee49-55f4-8fd6-4d72d0d728bd"><lexical-unit><form lang="es"><text>saltar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="saltar_0" guid="fc9cf578-c469-5d44-ab84-47eebb24c93f"><grammatical-info value="Verb"/><gloss lang="en"><text>to jump</text></gloss></sense><sense id="saltar_1" guid="4c653630-e48a-56fa-995c-957db2d63025"><grammatical-info value="Verb"/><gloss lang="en"><text>to skip; miss (a meal etc.)</text></gloss></sense><sense id="saltar_2" guid="73ad2b0c-2c49-5a6f-9ab9-3d61ebfb6894"><grammatical-info value="Verb"/><gloss lang="en"><text>to sauté</text></gloss></sense><sense id="saltar_3" guid="55a5b34f-6ade-54b7-8d25-288d31e66d97"><grammatical-info value="Verb"/><gloss lang="en"><text>to miss (accidentally)</text></gloss></sense><sense id="saltar_4" guid="a17f7b70-dff8-5cbf-97f9-32cd41b53795"><grammatical-info value="Verb"/><gloss lang="en"><text>to break, breach (rules etc.)</text></gloss></sense></entry>
