<entry id="enfermo" guid="fdd8672c-cee9-5a90-aae5-8cf283ae4de9"><lexical-unit><form lang="es"><text>enfermo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="enfermo_0" guid="2ce914ec-3401-5cfb-baf2-e4042b79a317"><grammatical-info value="Noun"/><gloss lang="en"><text>sick, ill</text></gloss></sense></entry>
<entry id="enflaquecer" guid="d7d9cce2-013a-52e9-bbcf-97a974a25a15"><lexical-unit><form lang="es"><text>enflaquecer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="enflaquecer_0" guid="8a4b3db1-3c9d-564b-ae7e-0fc95418c51b"><grammatical-info value="Verb"/><gloss lang="en"><text>to make thin, weaken, emaciate (to cause to become extremely thin or wasted)</text></gloss></sense><sense id="enflaquecer_1" guid="4b8b3472-e061-58a4-b1c1-4d3ea66b113b"><grammatical-info value="Verb"/><gloss lang="en"><text>to thin out, lose weight (to become less heavy or obese)</text></gloss></sense><sense id="enflaquecer_2" guid="89df8ce9-500b-57f6-b38d-442b499e4802"><grammatical-info value="Verb"/><gloss lang="en"><text>to grow weak (to lose one's physical strength)</text></gloss></sense></entry>
<entry id="enfrentar" guid="585ea5cd-54c5-5453-a259-25074caa904b"><lexical-unit><form lang="es"><text>enfrentar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="enfrentar_0" guid="efe22835-addf-5f13-848d-562519de013e"><grammatical-info value="Verb"/><gloss lang="en"><text>to face, to confront, to address, to deal with, to meet, to tackle, to cope with, to handle, to contend, to contend with (e.g. reality, an issue, a problem)</text></gloss></sense><sense id="enfrentar_1" guid="d85d3b94-b2e7-5c3d-8fce-e4d851449aae"><grammatical-info value="Verb"/><gloss lang="en"><text>to counter, to combat (e.g. a threat, terrorism, criminal activity)</text></gloss></sense><sense id="enfrentar_2" guid="b39bcdb2-fbfb-5494-8a5a-a7b20c59e516"><grammatical-info value="Verb"/><gloss lang="en"><text>to pit (two sides against each other)</text></gloss></sense><sense id="enfrentar_3" guid="d4e68216-802d-54f0-9de3-2d075a72ae5e"><grammatical-info value="Verb"/><gloss lang="en"><text>to take on, to face off, to face off against, to fight, to engage, to clash (e.g. take on somebody in a challenge) (+ a)</text></gloss></sense><sense id="enfrentar_4" guid="15abf58d-f50f-52b2-b958-a7ce10a913b8"><grammatical-info value="Verb"/><gloss lang="en"><text>to face, to be facing, to be dealing with, to be up against (+ a)</text></gloss></sense></entry>
<entry id="enfurecer" guid="993ba01a-ff40-5252-aaa0-2b6b827874cf"><lexical-unit><form lang="es"><text>enfurecer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="enfurecer_0" guid="885fdec4-56e7-5460-ae7e-d7c7f7d7d594"><grammatical-info value="Verb"/><gloss lang="en"><text>to infuriate (to make furious)</text></gloss></sense><sense id="enfurecer_1" guid="2512a9c6-eec5-5cdd-806a-9d4c065e1127"><grammatical-info value="Verb"/><gloss lang="en"><text>to become furious</text></gloss></sense></entry>
<entry id="engañador" guid="17428396-9d42-5784-a7f2-3d59b93aae35"><lexical-unit><form lang="es"><text>engañador</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="engañador_0" guid="5ed95f31-04d4-577d-bd9a-78e758b18fa5"><grammatical-info value="Adjective"/><gloss lang="en"><text>deceptive</text></gloss></sense></entry>
<entry id="engañar" guid="bda41a09-39fa-59f7-a6ff-817bf8f176f1"><lexical-unit><form lang="es"><text>engañar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="engañar_0" guid="88713380-15e8-5438-9f2a-f020b14c7cf1"><grammatical-info value="Verb"/><gloss lang="en"><text>to trick, to deceive, to hoodwink, to cheat</text></gloss></sense><sense id="engañar_1" guid="8dd742a0-041a-5f8f-954a-9896bf260e8d"><grammatical-info value="Verb"/><gloss lang="en"><text>to cheat on, to be unfaithful to one's spouse</text></gloss></sense><sense id="engañar_2" guid="a3d1c72f-d1cb-58cf-8006-2768e9e0611b"><grammatical-info value="Verb"/><gloss lang="en"><text>to blindside</text></gloss></sense><sense id="engañar_3" guid="bc2993c5-6252-5578-b975-5a13a30231a9"><grammatical-info value="Verb"/><gloss lang="en"><text>to fool oneself, to kid oneself</text></gloss></sense></entry>
<entry id="engaño" guid="4c4e0c18-854f-5865-8aa8-8e841cc61f86"><lexical-unit><form lang="es"><text>engaño</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="engaño_0" guid="be55ea83-9b89-5c8e-89f0-af5248b957c5"><grammatical-info value="Noun"/><gloss lang="en"><text>deceit; fraud</text></gloss></sense></entry>
<entry id="engañosamente" guid="9647ae5b-9be3-516f-90b5-b917e1ae947d"><lexical-unit><form lang="es"><text>engañosamente</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="engañosamente_0" guid="e0c0385e-0053-58d7-9d1b-c3c20c5f79db"><grammatical-info value="Adverb"/><gloss lang="en"><text>deceitfully, misleadingly</text></gloss></sense></entry>
<entry id="engendrar" guid="3c61c552-5ad9-59ae-b195-852cbc668b26"><lexical-unit><form lang="es"><text>engendrar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="engendrar_0" guid="d3875a3e-c121-5818-b0db-1f668499cacb"><grammatical-info value="Verb"/><gloss lang="en"><text>to engender, spawn, beget</text></gloss></sense></entry>
<entry id="engordar" guid="60e69b61-e9f4-5403-9866-071f6b228d17"><lexical-unit><form lang="es"><text>engordar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="engordar_0" guid="4a3b109b-29dd-5d3d-93b3-0bdf3144e9a1"><grammatical-info value="Verb"/><gloss lang="en"><text>to get fat, grow fat, fatten</text></gloss></sense><sense id="engordar_1" guid="e23b0276-4dee-50b4-86b9-328d3b1af271"><grammatical-info value="Verb"/><gloss lang="en"><text>to cause to be fatter, fatten</text></gloss></sense></entry>
<entry id="engrandecer" guid="dd54ed3b-ab2a-5348-91dc-d3e44a8ebf4b"><lexical-unit><form lang="es"><text>engrandecer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="engrandecer_0" guid="800f454b-5abf-5631-ab5d-92c7d527e4fa"><grammatical-info value="Verb"/><gloss lang="en"><text>to enlarge, magnify</text></gloss></sense><sense id="engrandecer_1" guid="907d8242-a189-527b-a0a5-dbba73e2f322"><grammatical-info value="Verb"/><gloss lang="en"><text>to exalt, speak highly of</text></gloss></sense><sense id="engrandecer_2" guid="7a176560-6415-5409-a763-6f4da0c6498a"><grammatical-info value="Verb"/><gloss lang="en"><text>to exaggerate</text></gloss></sense></entry>
<entry id="engrandecido" guid="7996e27f-47d5-50c3-b0aa-6c716b3a0afe"><lexical-unit><form lang="es"><text>engrandecido</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="engrandecido_0" guid="0c418d04-795a-599a-8824-f06550aecf4b"><grammatical-info value="Verb"/></sense></entry>
<entry id="engrosar" guid="7abe1968-b6b2-5eb7-8201-49e28b81b0db"><lexical-unit><form lang="es"><text>engrosar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="engrosar_0" guid="5d27a5af-fd71-500e-b54b-c4306af140e2"><grammatical-info value="Verb"/><gloss lang="en"><text>to swell up, thicken</text></gloss></sense><sense id="engrosar_1" guid="407de822-83c5-5478-a60c-7f41a9326cbd"><grammatical-info value="Verb"/><gloss lang="en"><text>to increase</text></gloss></sense></entry>
<entry id="enloquecer" guid="b74585ec-d35c-5c8d-a49e-817f75417a0c"><lexical-unit><form lang="es"><text>enloquecer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="enloquecer_0" guid="9b2d0ca8-2e26-5a0d-be66-bc645dd12acb"><grammatical-info value="Verb"/><gloss lang="en"><text>to drive crazy, madden, drive insane, distract</text></gloss></sense><sense id="enloquecer_1" guid="39c9f4da-6d45-587f-aff0-a99252682d41"><grammatical-info value="Verb"/><gloss lang="en"><text>to go crazy, to go nuts, to go insane, to go wild</text></gloss></sense><sense id="enloquecer_2" guid="73c40814-2d78-517b-b758-16ab11c54a8e"><grammatical-info value="Verb"/><gloss lang="en"><text>to go crazy</text></gloss></sense><sense id="enloquecer_3" guid="2d49dcb2-e2b4-5b3e-9a7a-d4ac018f81ce"><grammatical-info value="Verb"/><gloss lang="en"><text>to run amok</text></gloss></sense></entry>
<entry id="enmudecer" guid="1fcf4d31-21fd-54b9-98cb-253901bc80ee"><lexical-unit><form lang="es"><text>enmudecer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="enmudecer_0" guid="3fc0e0c4-eea1-5c8d-a9d9-ff9098e5b7ab"><grammatical-info value="Verb"/><gloss lang="en"><text>to silence, to shut up</text></gloss></sense><sense id="enmudecer_1" guid="a8f322ab-b017-54b0-8af2-c0dbbc58b926"><grammatical-info value="Verb"/><gloss lang="en"><text>to go silent, become mute</text></gloss></sense></entry>
<entry id="enoc" guid="0842aafc-af74-5554-8b84-4345ce46383f"><lexical-unit><form lang="es"><text>enoc</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="enoc_0" guid="1ccf45e1-544e-54ed-8be0-fb141be750ac"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Enoch</text></gloss></sense><sense id="enoc_1" guid="a6569f7c-38fb-5ad3-a8c5-d150ebccd436"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a male given name, equivalent to English Enoch</text></gloss></sense></entry>
