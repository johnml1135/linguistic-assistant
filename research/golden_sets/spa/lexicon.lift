<entry id="administrar" guid="8f4fc272-4156-5d0c-b9be-3aac53630d36"><lexical-unit><form lang="es"><text>administrar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="administrar_0" guid="d85afa5d-8577-5d2a-879f-35da23049397"><grammatical-info value="Verb"/><gloss lang="en"><text>to administer (cause to take)</text></gloss></sense><sense id="administrar_1" guid="fb213261-ab8a-5752-b5c6-25d88c80a60d"><grammatical-info value="Verb"/><gloss lang="en"><text>to administer, to manage (manage or supervise the conduct of)</text></gloss></sense></entry>
