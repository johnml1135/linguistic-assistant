<entry id="curar" guid="3d173774-3c3b-5d71-888a-4f35f1492127"><lexical-unit><form lang="es"><text>curar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="curar_0" guid="4660af37-125b-55ff-b6ce-f08c48859cb1"><grammatical-info value="Verb"/><gloss lang="en"><text>to care, heed, study, strive, seek, work</text></gloss></sense><sense id="curar_1" guid="2f7afd78-2668-55cf-af1f-e747d743526d"><grammatical-info value="Verb"/><gloss lang="en"><text>to cure, heal (body, soul, mind, heart); nurse, treat, dress (a wound)</text></gloss></sense><sense id="curar_2" guid="7b13628d-2bc0-5ea1-a51a-70653f0b56b6"><grammatical-info value="Verb"/><gloss lang="en"><text>to remedy (an evil)</text></gloss></sense><sense id="curar_3" guid="370282c0-5d8e-5743-9e0a-0c3fe931e8a3"><grammatical-info value="Verb"/><gloss lang="en"><text>to clean, cleanse</text></gloss></sense><sense id="curar_4" guid="7100ba95-b9b9-5b39-b8c4-2fece214fcba"><grammatical-info value="Verb"/><gloss lang="en"><text>to prepare</text></gloss></sense><sense id="curar_5" guid="295d3c37-25a4-55cd-8d5e-6405edfae53c"><grammatical-info value="Verb"/><gloss lang="en"><text>to cure, salt, smoke</text></gloss></sense><sense id="curar_6" guid="f15c986c-8d79-5684-8d4f-46218694e737"><grammatical-info value="Verb"/><gloss lang="en"><text>to ripen</text></gloss></sense><sense id="curar_7" guid="013a8996-d3d6-56d9-8930-b61e8c618057"><grammatical-info value="Verb"/><gloss lang="en"><text>to dress, tan (animal hides)</text></gloss></sense></entry>
