<entry id="albo" guid="677914fd-dd2b-5779-ac1d-57ba06bf4ad7"><lexical-unit><form lang="es"><text>albo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="albo_0" guid="e3af8fa2-de1a-5c3e-b2ee-42fec96460bd"><grammatical-info value="Adjective"/><gloss lang="en"><text>white</text></gloss></sense></entry>
<entry id="alborotar" guid="c8bb08e5-5cbf-55e9-b017-cd3927fefdc3"><lexical-unit><form lang="es"><text>alborotar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alborotar_0" guid="6517cc80-69a1-567b-b360-49296fa0c4d6"><grammatical-info value="Verb"/><gloss lang="en"><text>to stir up, agitate</text></gloss></sense><sense id="alborotar_1" guid="7fbe4d51-1cce-54ef-ae34-2635601faaf8"><grammatical-info value="Verb"/><gloss lang="en"><text>to disturb, tease (provoke or disturb)</text></gloss></sense><sense id="alborotar_2" guid="cd6ad83d-f862-54af-a53d-4371bc015d29"><grammatical-info value="Verb"/><gloss lang="en"><text>to excite</text></gloss></sense><sense id="alborotar_3" guid="e61b8584-576a-597a-90b0-f835dacfc791"><grammatical-info value="Verb"/><gloss lang="en"><text>to infect, ballyhoo (make somebody enthusiastic about one's own passion)</text></gloss></sense><sense id="alborotar_4" guid="5b83980c-8c7b-5b04-9be6-3c6654e2ec01"><grammatical-info value="Verb"/><gloss lang="en"><text>to bother</text></gloss></sense></entry>
<entry id="alboroto" guid="e2b791ad-6836-5de1-a752-6c646bcd8a36"><lexical-unit><form lang="es"><text>alboroto</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alboroto_0" guid="c7afae2f-30c6-559b-bb83-f24eead921e8"><grammatical-info value="Verb"/><gloss lang="en"><text>fuss, commotion, ruckus, hubbub, brouhaha, ado, uproar, tumult, riot, bustle, din, rumpus, fracas, rowdiness</text></gloss></sense><sense id="alboroto_1" guid="4e5a35a9-f845-5cf9-814b-c9d1544fae8d"><grammatical-info value="Verb"/><gloss lang="en"><text>disturbance, racket, mayhem</text></gloss></sense><sense id="alboroto_2" guid="2615c06d-dec2-5d76-b0d9-5a451018143b"><grammatical-info value="Verb"/><gloss lang="en"><text>rampage</text></gloss></sense><sense id="alboroto_3" guid="34e4ab29-fcec-5f1b-bd8c-f2d54d677c5c"><grammatical-info value="Verb"/><gloss lang="en"><text>hoopla, ballyhoo</text></gloss></sense><sense id="alboroto_4" guid="a09b8d8f-5366-5d5f-9825-f56951a964c9"><grammatical-info value="Verb"/><gloss lang="en"><text>bedlam</text></gloss></sense><sense id="alboroto_5" guid="85aebd93-9926-5756-84e7-33f9bc5c12b5"><grammatical-info value="Verb"/><gloss lang="en"><text>A snack food which consistis of a ball of popcorn or sorghum, coated in sugar, honey or caramel</text></gloss></sense></entry>
<entry id="alcan" guid="e45923f0-6d7a-554d-9863-d119c9ced7c7"><lexical-unit><form lang="es"><text>alcan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alcan_0" guid="ac1379c3-68c3-5c78-bf54-34d8526a543d"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="alcance" guid="6a1f9cd5-bad2-54a4-b94c-65eac7422732"><lexical-unit><form lang="es"><text>alcance</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alcance_0" guid="3986d301-5f1b-56e9-80b9-83ec5b70a585"><grammatical-info value="Noun"/><gloss lang="en"><text>reach, range, scope (maximum distance something can reach)</text></gloss></sense></entry>
<entry id="alcanzar" guid="7de57418-f74c-545e-bfe3-b9240b7c5b08"><lexical-unit><form lang="es"><text>alcanzar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alcanzar_0" guid="dc9087b5-6edd-5f7c-8d63-649120493e3a"><grammatical-info value="Verb"/><gloss lang="en"><text>to reach; to get to to catch up</text></gloss></sense><sense id="alcanzar_1" guid="98e44c20-58fd-5e38-a9ec-43a6776dff9f"><grammatical-info value="Verb"/><gloss lang="en"><text>to accomplish; to achieve</text></gloss></sense><sense id="alcanzar_2" guid="aa39dda5-b8f2-583c-b1f8-7e2c33fc4bd8"><grammatical-info value="Verb"/><gloss lang="en"><text>to be enough; to suffice</text></gloss></sense><sense id="alcanzar_3" guid="d9ecc737-6b60-58bf-863e-60c2e40a6a81"><grammatical-info value="Verb"/><gloss lang="en"><text>to pass</text></gloss></sense><sense id="alcanzar_4" guid="8ee03240-3148-5315-bc28-57c81c92e735"><grammatical-info value="Verb"/><gloss lang="en"><text>to peak, to peak at</text></gloss></sense><sense id="alcanzar_5" guid="89453f69-f15b-5866-a15a-3e6b79a85b36"><grammatical-info value="Verb"/><gloss lang="en"><text>to get it (to receive punishment; to receive a beating)</text></gloss></sense></entry>
