<entry id="sagaz" guid="39cfa55e-372b-551e-94e8-abddf103ff28"><lexical-unit><form lang="es"><text>sagaz</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sagaz_0" guid="fce4b97c-3f34-57fb-b1a6-9fc263bbba4c"><grammatical-info value="Adjective"/><gloss lang="en"><text>sagacious, prudent, visionary</text></gloss></sense><sense id="sagaz_1" guid="ecf3dc98-39b7-5ef5-9778-e8d824340bf1"><grammatical-info value="Adjective"/><gloss lang="en"><text>acute; astute</text></gloss></sense><sense id="sagaz_2" guid="e060d202-2f6d-5158-9613-f1adcd55f7df"><grammatical-info value="Adjective"/><gloss lang="en"><text>proficient at dragging prey</text></gloss></sense><sense id="sagaz_3" guid="09cb7e6d-08f0-5acb-9cba-9bac00e3c421"><grammatical-info value="Adjective"/><gloss lang="en"><text>markedly clairvoyant</text></gloss></sense></entry>
