<entry id="encontrar" guid="d1ea3437-1edf-5da5-bdbe-4408f6029b27"><lexical-unit><form lang="es"><text>encontrar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="encontrar_0" guid="c6a6b36e-a8c9-5914-90c8-c2a3b559e360"><grammatical-info value="Verb"/><gloss lang="en"><text>to meet</text></gloss></sense><sense id="encontrar_1" guid="5a13c888-af96-52bb-830b-212fa20df0c8"><grammatical-info value="Verb"/><gloss lang="en"><text>to find, encounter, come across</text></gloss></sense><sense id="encontrar_2" guid="713c826a-da26-50fb-afac-ea6f24a43687"><grammatical-info value="Verb"/><gloss lang="en"><text>to meet, bump into</text></gloss></sense><sense id="encontrar_3" guid="e013b279-e14b-5f47-8bb8-7b001031f7a1"><grammatical-info value="Verb"/><gloss lang="en"><text>to think, consider, find</text></gloss></sense><sense id="encontrar_4" guid="6cd7f6fe-ea43-5771-b036-9954bd2221cd"><grammatical-info value="Verb"/><gloss lang="en"><text>to manage (to do something)</text></gloss></sense><sense id="encontrar_5" guid="6301bcb3-4111-5752-a2cd-1a29603d56d6"><grammatical-info value="Verb"/><gloss lang="en"><text>to be located</text></gloss></sense><sense id="encontrar_6" guid="696816d0-0c64-5693-9c71-cae4663ec0cf"><grammatical-info value="Verb"/><gloss lang="en"><text>to feel, be</text></gloss></sense></entry>
