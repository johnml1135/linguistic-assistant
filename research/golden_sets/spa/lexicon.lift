<entry id="ensoberbecer" guid="d061a81e-f798-5ba9-b77c-f1b6d8a9f182"><lexical-unit><form lang="es"><text>ensoberbecer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ensoberbecer_0" guid="6a27ee29-598e-52cc-8789-702615175bdb"><grammatical-info value="Verb"/><gloss lang="en"><text>to cause to be haughty</text></gloss></sense></entry>
