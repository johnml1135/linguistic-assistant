<entry id="abortivo" guid="4fb70e81-534f-5339-b0d9-93d3940c8dd2"><lexical-unit><form lang="es"><text>abortivo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abortivo_0" guid="43e4f95d-ff67-541f-bf36-024acd3df880"><grammatical-info value="Adjective"/><gloss lang="en"><text>abortive</text></gloss></sense></entry>
<entry id="abr" guid="a15ee696-a878-5987-880f-fd9d4682f163"><lexical-unit><form lang="es"><text>abr</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abr_0" guid="f1137b93-c6cd-56ba-aa85-07af14e28d34"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative form of abr.: abbreviation of abril (“April”)</text></gloss></sense></entry>
<entry id="abra" guid="e840604f-daf9-522a-8f71-6db8669ce954"><lexical-unit><form lang="es"><text>abra</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abra_0" guid="7f36ddb6-1fb2-569a-bc35-89ade11f6a92"><grammatical-info value="Verb"/><gloss lang="en"><text>small bay, inlet</text></gloss></sense><sense id="abra_1" guid="5945a0f1-03ea-52f0-8ae0-b4432da6890b"><grammatical-info value="Verb"/><gloss lang="en"><text>glade, clearing</text></gloss></sense></entry>
<entry id="abraham" guid="764ef2df-cc4a-5727-a67b-982abb2dc634"><lexical-unit><form lang="es"><text>abraham</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abraham_0" guid="3c66059c-88af-5c2b-9c89-0b6148fa70dc"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Abraham</text></gloss></sense><sense id="abraham_1" guid="2baa0534-07b2-5af7-ab50-e87ceca38314"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a male given name from Hebrew, of rare usage, equivalent to English Abraham</text></gloss></sense></entry>
<entry id="abrasado" guid="3908e73a-e0af-5bd8-8615-5dee3b1c692b"><lexical-unit><form lang="es"><text>abrasado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abrasado_0" guid="01bd5b86-0a81-5eac-9bf0-8af61e4d50ab"><grammatical-info value="Adjective"/><gloss lang="en"><text>melt</text></gloss></sense></entry>
<entry id="abrazar" guid="5216477c-2530-56c5-bade-6c8dfe390437"><lexical-unit><form lang="es"><text>abrazar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abrazar_0" guid="ac1fb00c-8bbf-5c9c-8c0c-290fb26a7219"><grammatical-info value="Verb"/><gloss lang="en"><text>to embrace; to adopt (a religion or way of life)</text></gloss></sense><sense id="abrazar_1" guid="fd51f08d-39cd-5453-931e-41faa9fb9ce9"><grammatical-info value="Verb"/><gloss lang="en"><text>to hug, to embrace, to cuddle, to hold (each other, one another)</text></gloss></sense></entry>
<entry id="abreviado" guid="68fca617-f286-5f53-b104-6a63fe3d798d"><lexical-unit><form lang="es"><text>abreviado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abreviado_0" guid="693d73f9-cde5-50e7-a782-8d6e661e83c9"><grammatical-info value="Adjective"/><gloss lang="en"><text>abridged</text></gloss></sense></entry>
<entry id="abreviador" guid="47ea0e34-3be7-58ec-bb6f-e07c1c32b60e"><lexical-unit><form lang="es"><text>abreviador</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abreviador_0" guid="d003278f-515b-5e7c-a89d-9c9f22306186"><grammatical-info value="Adjective"/><gloss lang="en"><text>that abbreviates</text></gloss></sense><sense id="abreviador_1" guid="a323aa97-5db1-53b4-82cd-20d158416924"><grammatical-info value="Adjective"/><gloss lang="en"><text>abbreviator</text></gloss></sense></entry>
