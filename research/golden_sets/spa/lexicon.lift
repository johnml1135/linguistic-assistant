<entry id="cast" guid="d16b8bc1-45ea-5ef5-a1ae-94e28b122a10"><lexical-unit><form lang="es"><text>cast</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cast_0" guid="262e1e85-d828-5785-969e-9cf3f3c60d7e"><grammatical-info value="Noun"/><gloss lang="en"><text>cast (group of actors)</text></gloss></sense></entry>
<entry id="casta" guid="ba9e3616-2957-5649-b54a-d9f299b8a3c7"><lexical-unit><form lang="es"><text>casta</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="casta_0" guid="3722bcd8-2c6d-5db8-bc4c-8a2240c64602"><grammatical-info value="Noun"/><gloss lang="en"><text>caste</text></gloss></sense><sense id="casta_1" guid="6b3e3aa9-adf7-5307-ae22-34032d78fd46"><grammatical-info value="Noun"/><gloss lang="en"><text>breed (of an animal)</text></gloss></sense><sense id="casta_2" guid="20064292-522c-5e3a-a13f-5abda130912d"><grammatical-info value="Noun"/><gloss lang="en"><text>establishment (the exclusive class of powerful people thought to really rule the country)</text></gloss></sense></entry>
