<entry id="lograr" guid="41adaed0-db84-5896-bafb-b061dadfc6cc"><lexical-unit><form lang="es"><text>lograr</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lograr_0" guid="a4890f47-696d-57a1-aee9-64c4526d4952"><grammatical-info value="Verb"/><gloss lang="en"><text>to get, to obtain</text></gloss></sense><sense id="lograr_1" guid="58bb6413-e6c8-5557-80e0-8b9959119a0b"><grammatical-info value="Verb"/><gloss lang="en"><text>to achieve, to manage to, to pull off</text></gloss></sense><sense id="lograr_2" guid="52bee95c-41db-5b5c-aaf1-7e0c10e9cc93"><grammatical-info value="Verb"/><gloss lang="en"><text>to be successful</text></gloss></sense></entry>
