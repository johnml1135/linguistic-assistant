<entry id="recoger" guid="0351d7ba-e465-536c-b0e9-a7cc5baa315c"><lexical-unit><form lang="es"><text>recoger</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="recoger_0" guid="ef4c17d5-a78f-5094-ba11-068c3a967754"><grammatical-info value="Verb"/><gloss lang="en"><text>to collect, to gather, to pick up, to fetch, to retrieve (something previously left behind)</text></gloss></sense><sense id="recoger_1" guid="5c4d9c7a-5099-573c-a79e-1e603f515263"><grammatical-info value="Verb"/><gloss lang="en"><text>to clean up (e.g., a room)</text></gloss></sense><sense id="recoger_2" guid="1ec51c47-6c41-5d35-a1a9-7f51e699918e"><grammatical-info value="Verb"/><gloss lang="en"><text>to pack up</text></gloss></sense><sense id="recoger_3" guid="d516e6e1-001d-5f8e-975f-a71e89c401a0"><grammatical-info value="Verb"/><gloss lang="en"><text>to harvest, reap (fruit)</text></gloss></sense><sense id="recoger_4" guid="30a69282-ae9d-53b4-aec0-489e29955414"><grammatical-info value="Verb"/><gloss lang="en"><text>to pick up on, glean, capture (e.g., a point, a link, distinction, subtlety, ambiguity, etc.)</text></gloss></sense><sense id="recoger_5" guid="fd8c4363-9220-50e3-9d0f-cb8c930d2054"><grammatical-info value="Verb"/><gloss lang="en"><text>to reflect</text></gloss></sense><sense id="recoger_6" guid="ecac9a2b-da83-509e-8e54-6774e794dc96"><grammatical-info value="Verb"/><gloss lang="en"><text>to go to bed</text></gloss></sense></entry>
