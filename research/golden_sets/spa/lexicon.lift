<entry id="sal" guid="0f1d8b6f-f6b5-5dab-81fa-35700a498f48"><lexical-unit><form lang="es"><text>sal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sal_0" guid="7e1976ee-8edc-57c2-af59-ad236c7530dd"><grammatical-info value="Noun"/><gloss lang="en"><text>salt; table salt</text></gloss></sense><sense id="sal_1" guid="14cc516d-4500-560a-b6cc-9bbe2c516cc8"><grammatical-info value="Noun"/><gloss lang="en"><text>salt</text></gloss></sense><sense id="sal_2" guid="adbc2ac6-832f-5cd2-987e-43a38aa91029"><grammatical-info value="Noun"/><gloss lang="en"><text>bad luck, misfortune</text></gloss></sense></entry>
<entry id="sala" guid="4d7fac99-36dc-5575-bda2-6d0ad962216e"><lexical-unit><form lang="es"><text>sala</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sala_0" guid="4b996559-13a5-5b34-b1fd-2057ab356cc0"><grammatical-info value="Noun"/><gloss lang="en"><text>room (a separate part of a building)</text></gloss></sense><sense id="sala_1" guid="e649e675-24de-5097-b563-1b788f22479b"><grammatical-info value="Noun"/><gloss lang="en"><text>large hall</text></gloss></sense><sense id="sala_2" guid="34f46e18-1d5a-5ac2-b1c8-766fe495637d"><grammatical-info value="Noun"/><gloss lang="en"><text>ward (section of a hospital)</text></gloss></sense><sense id="sala_3" guid="c9aa8023-3d46-5fc9-8093-cae890e257a4"><grammatical-info value="Noun"/><gloss lang="en"><text>courtroom</text></gloss></sense><sense id="sala_4" guid="3e2a459e-b30c-5d21-b685-69b5195bc3b5"><grammatical-info value="Noun"/><gloss lang="en"><text>a surname</text></gloss></sense></entry>
<entry id="salado" guid="b40387bf-ab4d-5138-a85c-d6cf91be6184"><lexical-unit><form lang="es"><text>salado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="salado_0" guid="50159c16-72da-5204-a697-93b1b5cc6597"><grammatical-info value="Adjective"/><gloss lang="en"><text>salty</text></gloss></sense><sense id="salado_1" guid="7241e0ac-e74d-5d1a-9631-37bfb194040b"><grammatical-info value="Adjective"/><gloss lang="en"><text>salted</text></gloss></sense><sense id="salado_2" guid="d8705cc8-5e4a-5391-b2c9-2b8230a75535"><grammatical-info value="Adjective"/><gloss lang="en"><text>brackish</text></gloss></sense><sense id="salado_3" guid="69bde354-afd5-5de4-81c3-2e6986b33827"><grammatical-info value="Adjective"/><gloss lang="en"><text>expensive</text></gloss></sense><sense id="salado_4" guid="9fbbb0cb-4885-5c71-8402-cad02accb9a2"><grammatical-info value="Adjective"/><gloss lang="en"><text>awesome</text></gloss></sense><sense id="salado_5" guid="92be325e-624d-5be2-aa70-a952a07bbd0e"><grammatical-info value="Adjective"/><gloss lang="en"><text>difficult, hard</text></gloss></sense></entry>
