<entry id="revivir" guid="f60188b5-6bba-5be8-ae34-aad98c7ecf37"><lexical-unit><form lang="es"><text>revivir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="revivir_0" guid="08efbcd8-868d-5814-b289-116ed8622b3f"><grammatical-info value="Verb"/><gloss lang="en"><text>to revive</text></gloss></sense><sense id="revivir_1" guid="7ba01127-7749-584d-9abc-3b29ab979ac3"><grammatical-info value="Verb"/><gloss lang="en"><text>to relive</text></gloss></sense></entry>
<entry id="revolcar" guid="fea0e71e-ea44-54d5-a67b-c073f72bb438"><lexical-unit><form lang="es"><text>revolcar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="revolcar_0" guid="82d31c3d-81a4-530c-867e-56ecf4dc3589"><grammatical-info value="Verb"/><gloss lang="en"><text>to revolt</text></gloss></sense><sense id="revolcar_1" guid="7e2aecc7-c3c0-5e8e-b0df-0cd9b0f8aca9"><grammatical-info value="Verb"/><gloss lang="en"><text>to knock down, floor</text></gloss></sense><sense id="revolcar_2" guid="08d417eb-c32e-528a-bc57-9eb264f4a3ec"><grammatical-info value="Verb"/><gloss lang="en"><text>to wallow; to roll around, roll over</text></gloss></sense></entry>
<entry id="revolver" guid="c31f3650-bbc3-589e-a85a-f549e9984b00"><lexical-unit><form lang="es"><text>revolver</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="revolver_0" guid="283245b2-a046-5237-b728-7186ec52c665"><grammatical-info value="Verb"/><gloss lang="en"><text>to stir, to mix</text></gloss></sense><sense id="revolver_1" guid="1d5555ee-beed-513b-86a8-c179f7ade443"><grammatical-info value="Verb"/><gloss lang="en"><text>to jumble up, to disarrange</text></gloss></sense><sense id="revolver_2" guid="0d04128b-95a4-5fcf-9ea7-995621e5e2d0"><grammatical-info value="Verb"/><gloss lang="en"><text>to turn over, to poke about, to rummage around in</text></gloss></sense><sense id="revolver_3" guid="cfd266d7-b2b8-5d53-ba36-e9df69b67473"><grammatical-info value="Verb"/><gloss lang="en"><text>to consider, to turn over, to ponder</text></gloss></sense><sense id="revolver_4" guid="12c9e605-0b6c-5091-9de8-478b6b1138d3"><grammatical-info value="Verb"/><gloss lang="en"><text>to disturb, to stir up, to upset</text></gloss></sense><sense id="revolver_5" guid="d529511a-eef0-53e3-a9f5-a0fdfcaa02bc"><grammatical-info value="Verb"/><gloss lang="en"><text>to swing around</text></gloss></sense><sense id="revolver_6" guid="a22cb649-abe2-5833-9765-332d7bdd5457"><grammatical-info value="Verb"/><gloss lang="en"><text>to wrap, to wrap up</text></gloss></sense><sense id="revolver_7" guid="2d18d786-2209-5fbd-82ef-ad297f74f44c"><grammatical-info value="Verb"/><gloss lang="en"><text>to turn 360 degrees, to revolve</text></gloss></sense></entry>
