<entry id="salar" guid="9e441e4b-cd3e-59a0-9964-5ce21d33ca2c"><lexical-unit><form lang="es"><text>salar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="salar_0" guid="8b6867ff-a51d-54b7-a523-117f6b803fd0"><grammatical-info value="Verb"/><gloss lang="en"><text>salt pan, salt flat</text></gloss></sense><sense id="salar_1" guid="d8bf9290-7384-554f-8724-4e1cfaa61756"><grammatical-info value="Verb"/><gloss lang="en"><text>to salt</text></gloss></sense></entry>
<entry id="salariar" guid="94d19304-cc35-5856-bac1-ecc79a83b9bc"><lexical-unit><form lang="es"><text>salariar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="salariar_0" guid="d875c5e3-c502-5cb6-b048-798b22b59b29"><grammatical-info value="Verb"/><gloss lang="en"><text>to salary; to put on the payroll</text></gloss></sense></entry>
<entry id="sale" guid="5c38469c-ba7f-5ef1-9239-83a85750fdda"><lexical-unit><form lang="es"><text>sale</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sale_0" guid="b6ffa148-0f8c-5cb2-8214-5e26b135f16e"><grammatical-info value="Verb"/><gloss lang="en"><text>ok</text></gloss></sense></entry>
<entry id="salem" guid="3ef7eb13-59fb-5cce-8f67-856511e8a795"><lexical-unit><form lang="es"><text>salem</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="salem_0" guid="c0811b9a-925d-5bdc-8a4e-f58469dc0ce7"><grammatical-info value="Proper noun"/><gloss lang="en"><text>salem</text></gloss></sense></entry>
<entry id="salga" guid="7c4012fe-9d7d-5a35-8b69-c60a8fd38689"><lexical-unit><form lang="es"><text>salga</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="salga_0" guid="d62ca043-d533-5578-b6f1-92d546335048"><grammatical-info value="Verb"/><gloss lang="en"><text>a kind of levy on salt in the Kingdom of Aragon</text></gloss></sense></entry>
<entry id="salida" guid="1b91145f-f515-5aa9-b5e5-f6ed69ceacc2"><lexical-unit><form lang="es"><text>salida</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="salida_0" guid="2d565ce9-4a11-5470-aafc-056620cdb6de"><grammatical-info value="Noun"/><gloss lang="en"><text>exit, way out</text></gloss></sense><sense id="salida_1" guid="3da61391-376e-5b6a-8349-df91f8016061"><grammatical-info value="Noun"/><gloss lang="en"><text>departure</text></gloss></sense><sense id="salida_2" guid="e63a9058-a2a0-5e45-9007-8ccda043bc35"><grammatical-info value="Noun"/><gloss lang="en"><text>future, future opportunity</text></gloss></sense><sense id="salida_3" guid="285a6737-39ee-5edf-9527-e602a0e8e068"><grammatical-info value="Noun"/><gloss lang="en"><text>output</text></gloss></sense></entry>
<entry id="salido" guid="9dce44e0-c7db-57fb-9d2b-51c63d08dcf0"><lexical-unit><form lang="es"><text>salido</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="salido_0" guid="30a21d83-179d-5529-b2eb-f37620103d6e"><grammatical-info value="Verb"/><gloss lang="en"><text>sticking out</text></gloss></sense><sense id="salido_1" guid="be1a2a5a-5aa6-5910-9f9e-472811fbbd4d"><grammatical-info value="Verb"/><gloss lang="en"><text>on heat</text></gloss></sense><sense id="salido_2" guid="61a573bd-5170-5db6-a13a-a9ed87d74993"><grammatical-info value="Verb"/><gloss lang="en"><text>horny</text></gloss></sense><sense id="salido_3" guid="8b8cf016-85d6-5b97-921a-f163e8f52f01"><grammatical-info value="Verb"/><gloss lang="en"><text>indiscreet; insolent; impertinent</text></gloss></sense></entry>
<entry id="salir" guid="66074f67-efc3-5293-80a0-d838e9130439"><lexical-unit><form lang="es"><text>salir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="salir_0" guid="9441478c-116c-5d51-a809-2fa6f1969a25"><grammatical-info value="Verb"/><gloss lang="en"><text>to go out, to leave, to depart, to head out</text></gloss></sense><sense id="salir_1" guid="5cd8825b-27da-5a20-ad84-bc06251934d3"><grammatical-info value="Verb"/><gloss lang="en"><text>to go out, to come out (to leave one's abode to go to public places)</text></gloss></sense><sense id="salir_2" guid="f4b10adf-074c-533f-bb40-1bf3b3ce34e7"><grammatical-info value="Verb"/><gloss lang="en"><text>to come out (e.g. from hiding), to come off (e.g. off the bench in a sport; off of a high place like a roof or ladder)</text></gloss></sense><sense id="salir_3" guid="27bc0ba2-7447-53aa-96cb-516c63978cfc"><grammatical-info value="Verb"/><gloss lang="en"><text>to exit, to leave, to walk out, to slip out</text></gloss></sense><sense id="salir_4" guid="91aa0d36-1c0a-5dab-b878-91b4a643c555"><grammatical-info value="Verb"/><gloss lang="en"><text>to step out (e.g. of a room, house or building)</text></gloss></sense><sense id="salir_5" guid="e4fdf608-3474-5bbf-ad85-03f90d8c4c25"><grammatical-info value="Verb"/><gloss lang="en"><text>to get off, to leave (e.g., get off work)</text></gloss></sense><sense id="salir_6" guid="64f7bb8e-270e-51da-ac25-14ba1143917a"><grammatical-info value="Verb"/><gloss lang="en"><text>to get off (e.g. get off the plane, an island, someone's property, the street) (+ de)</text></gloss></sense><sense id="salir_7" guid="8e87daf5-9724-586e-abcb-f8f44de478c2"><grammatical-info value="Verb"/><gloss lang="en"><text>to get out (e.g. out of the way, out of the sun) (+ de)</text></gloss></sense></entry>
<entry id="salivar" guid="1e4db72a-2b7d-5fb4-95a3-a91bbae58c0a"><lexical-unit><form lang="es"><text>salivar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="salivar_0" guid="5afa846b-0463-594d-97ea-3ad6b12eebbe"><grammatical-info value="Verb"/><gloss lang="en"><text>to salivate (to secrete saliva)</text></gloss></sense></entry>
