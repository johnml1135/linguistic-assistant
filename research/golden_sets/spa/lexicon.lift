<entry id="saciar" guid="5fdf1f9e-af87-50a6-9379-b7c87b8c645a"><lexical-unit><form lang="es"><text>saciar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="saciar_0" guid="a7648cc6-91c2-5274-9203-db436ce9c7cd"><grammatical-info value="Verb"/><gloss lang="en"><text>to satiate, sate, satisfy, quench, appease</text></gloss></sense></entry>
<entry id="saco" guid="b5f2bc29-5a6b-5d04-9d01-41e01fcf57b5"><lexical-unit><form lang="es"><text>saco</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="saco_0" guid="976a40b5-61e6-5022-8bc2-730afd22896c"><grammatical-info value="Noun"/><gloss lang="en"><text>bag, sack (a loose container)</text></gloss></sense><sense id="saco_1" guid="ff1eaef8-ffd3-5517-ba9f-cc2f7631bce3"><grammatical-info value="Noun"/><gloss lang="en"><text>gunny sack</text></gloss></sense><sense id="saco_2" guid="82f7444d-cf06-50c2-95ec-335d0b00d4ba"><grammatical-info value="Noun"/><gloss lang="en"><text>suit jacket (jacket portion of a formal suit)</text></gloss></sense><sense id="saco_3" guid="cb665045-06f9-5566-925d-c9b38e1478a5"><grammatical-info value="Noun"/><gloss lang="en"><text>English or American sack (a traditional unit of dry measure)</text></gloss></sense><sense id="saco_4" guid="658b79b0-3ef5-5e95-82b5-0e3b9a93e174"><grammatical-info value="Noun"/><gloss lang="en"><text>saco, Spanish sack (a traditional unit of dry measure equivalent to about 111 L)</text></gloss></sense></entry>
<entry id="sacrificar" guid="cdf2aef4-96e5-5ce5-bb36-149961c18591"><lexical-unit><form lang="es"><text>sacrificar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sacrificar_0" guid="0d70e427-72b7-59d1-9228-5c25f7a2393d"><grammatical-info value="Verb"/><gloss lang="en"><text>to sacrifice</text></gloss></sense><sense id="sacrificar_1" guid="5489ad8f-f935-5eef-869c-7e4873766e73"><grammatical-info value="Verb"/><gloss lang="en"><text>to put down, euthanize (an animal)</text></gloss></sense></entry>
