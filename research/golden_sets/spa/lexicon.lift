<entry id="der" guid="8cc87f1c-a920-502b-b22a-8e39eae5a46c"><lexical-unit><form lang="es"><text>der</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="der_0" guid="ad12bf18-dd07-5172-b3a5-c8655ce1c9d0"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="derecha" guid="8373aca6-bed0-5b30-8536-f56f0928d2ed"><lexical-unit><form lang="es"><text>derecha</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="derecha_0" guid="e36cbc16-acac-5f1d-ad81-31c3c59655e3"><grammatical-info value="Noun"/><gloss lang="en"><text>right (direction)</text></gloss></sense><sense id="derecha_1" guid="1b9a0381-58f1-57f7-adc3-f4f7f0f83378"><grammatical-info value="Noun"/><gloss lang="en"><text>right (ensemble of right-wing political parties; political conservatives as a group)</text></gloss></sense></entry>
<entry id="derechamente" guid="0634670d-19e7-5ccd-8689-4f76c148a998"><lexical-unit><form lang="es"><text>derechamente</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="derechamente_0" guid="93998fd5-d97c-517c-867c-cafe6c005942"><grammatical-info value="Adverb"/><gloss lang="en"><text>straight</text></gloss></sense><sense id="derechamente_1" guid="0d96b20f-73e6-5ba1-ba83-aa6a4b36cfde"><grammatical-info value="Adverb"/><gloss lang="en"><text>properly; correctly</text></gloss></sense></entry>
<entry id="derecho" guid="e5805148-0b78-55f5-9b07-9b2cab49eb19"><lexical-unit><form lang="es"><text>derecho</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="derecho_0" guid="bf40d31b-aeb3-5a61-8ba7-6cd1fba775e6"><grammatical-info value="Adjective"/><gloss lang="en"><text>straight (not crooked or bent; having a constant direction throughout its length)</text></gloss></sense><sense id="derecho_1" guid="428d6e7c-91ff-5655-8f7b-c1ff162e98ca"><grammatical-info value="Adjective"/><gloss lang="en"><text>straight; upright (perfectly horizontal or vertical; not diagonal or oblique)</text></gloss></sense><sense id="derecho_2" guid="2f5192cb-6ddf-5901-bd08-fd2401025990"><grammatical-info value="Adjective"/><gloss lang="en"><text>right, right-hand (designating the side of the body which is positioned to the east if one is facing north)</text></gloss></sense><sense id="derecho_3" guid="88d6c1d9-ec61-5a58-b37a-7bd41abb1fb6"><grammatical-info value="Adjective"/><gloss lang="en"><text>correct, appropriate, right</text></gloss></sense><sense id="derecho_4" guid="8561ba3f-c553-5ee1-b876-5fefa344ad91"><grammatical-info value="Adjective"/><gloss lang="en"><text>right (a legal, just or moral entitlement)</text></gloss></sense><sense id="derecho_5" guid="a06464b1-2e54-5514-8edf-80f7069ef7e2"><grammatical-info value="Adjective"/><gloss lang="en"><text>law, jurisprudence (the study of laws)</text></gloss></sense><sense id="derecho_6" guid="52c8784c-d2e7-50df-9c03-2c019ad5f811"><grammatical-info value="Adjective"/><gloss lang="en"><text>law (the profession of dealing with laws (as lawyers, judges, etc.))</text></gloss></sense><sense id="derecho_7" guid="9c206c29-784f-51f9-bcb7-fa0941e5748e"><grammatical-info value="Adjective"/><gloss lang="en"><text>right (the outward or most finished surface, as of a coin, piece of cloth, a carpet, etc.)</text></gloss></sense></entry>
<entry id="derrama" guid="df19a64a-801a-5a6e-82e6-dc7fdae538a5"><lexical-unit><form lang="es"><text>derrama</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="derrama_0" guid="849855d8-e5b7-5462-870d-83b26c170e0e"><grammatical-info value="Verb"/><gloss lang="en"><text>allotment (of money to be paid by a group of people)</text></gloss></sense><sense id="derrama_1" guid="bcc00673-83ce-53fe-abf1-f2c6f82aa491"><grammatical-info value="Verb"/><gloss lang="en"><text>washout</text></gloss></sense></entry>
<entry id="derramado" guid="b8a276e5-a190-5e66-8ef5-39916fa690d3"><lexical-unit><form lang="es"><text>derramado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="derramado_0" guid="3b402ed0-688b-5d66-a25a-7d5fdcc61cc4"><grammatical-info value="Verb"/><gloss lang="en"><text>spilt, spilled</text></gloss></sense></entry>
<entry id="derramamiento" guid="0953a78d-d114-5257-866e-f586f758de4e"><lexical-unit><form lang="es"><text>derramamiento</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="derramamiento_0" guid="798c0758-87db-5de3-b43c-370040829a28"><grammatical-info value="Noun"/><gloss lang="en"><text>spillage</text></gloss></sense><sense id="derramamiento_1" guid="2260417c-0932-5ae2-bc1c-d2c154ca05e3"><grammatical-info value="Noun"/><gloss lang="en"><text>shedding</text></gloss></sense><sense id="derramamiento_2" guid="ab543ef4-0782-544a-a319-74f55f0cc6d2"><grammatical-info value="Noun"/><gloss lang="en"><text>outpouring</text></gloss></sense></entry>
<entry id="derramar" guid="e3d67c9b-90d1-5ac1-91c8-8d5fe0986891"><lexical-unit><form lang="es"><text>derramar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="derramar_0" guid="057538a4-98cf-58aa-9635-c5b0b6b13a2f"><grammatical-info value="Verb"/><gloss lang="en"><text>to spill, to leak</text></gloss></sense><sense id="derramar_1" guid="a16281b9-c232-5d29-98ef-68fb40d33847"><grammatical-info value="Verb"/><gloss lang="en"><text>to shed (blood, sweat, tears, etc.)</text></gloss></sense><sense id="derramar_2" guid="3005b159-7d50-56a4-a2d0-6dfdd410fe9f"><grammatical-info value="Verb"/><gloss lang="en"><text>to pour out (e.g., love, wrath, blessings, one's heart)</text></gloss></sense></entry>
<entry id="derredor" guid="9ab8556c-a8cd-5e63-8af7-2691e2727527"><lexical-unit><form lang="es"><text>derredor</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="derredor_0" guid="fd16d8a8-b888-5f11-95ae-637e022aec70"><grammatical-info value="Noun"/><gloss lang="en"><text>surroundings</text></gloss></sense></entry>
<entry id="derribar" guid="7e51f9a2-1950-51e5-bff0-5dc404e351f8"><lexical-unit><form lang="es"><text>derribar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="derribar_0" guid="812067f6-dd30-5274-af82-57b901b5f050"><grammatical-info value="Verb"/><gloss lang="en"><text>to bring down, to shoot down</text></gloss></sense><sense id="derribar_1" guid="8ab5dbbf-788c-56d0-9913-dc634fd240bf"><grammatical-info value="Verb"/><gloss lang="en"><text>to knock down, to demolish, to break down, to tear down, to topple, to pull down, to kick down, to batter down</text></gloss></sense><sense id="derribar_2" guid="f0188d87-3a80-5f90-bad5-89284951ebe4"><grammatical-info value="Verb"/><gloss lang="en"><text>to overthrow</text></gloss></sense><sense id="derribar_3" guid="4d3a5e14-859c-56d0-90c2-9c55a77bc112"><grammatical-info value="Verb"/><gloss lang="en"><text>to take down, to tackle, to knock over</text></gloss></sense></entry>
<entry id="derrotar" guid="1c677ed9-1669-5e15-97f1-f958ff15883e"><lexical-unit><form lang="es"><text>derrotar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="derrotar_0" guid="a14355e6-5798-5a9e-a22b-48ae7f5446a6"><grammatical-info value="Verb"/><gloss lang="en"><text>to defeat</text></gloss></sense></entry>
<entry id="des" guid="a5348d20-7b9d-584a-a21c-04cfaea4c98b"><lexical-unit><form lang="es"><text>des</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="des_0" guid="2c4861dc-596c-5b38-bc89-0921e4a2ebb2"><grammatical-info value="Determiner"/><gloss lang="en"><text>since</text></gloss></sense></entry>
<entry id="desabrir" guid="94f87062-bd06-5b91-a2a9-1bfe7a544e57"><lexical-unit><form lang="es"><text>desabrir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desabrir_0" guid="a37ed8ab-5d2d-50db-917a-870926bfe5fe"><grammatical-info value="Verb"/><gloss lang="en"><text>to give a bad taste to</text></gloss></sense><sense id="desabrir_1" guid="89abd601-52b1-571e-80f5-c297744b4e3b"><grammatical-info value="Verb"/><gloss lang="en"><text>to embitter</text></gloss></sense></entry>
<entry id="desagradar" guid="078ebbf3-5a10-59e1-8d81-be5ddf5792ca"><lexical-unit><form lang="es"><text>desagradar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desagradar_0" guid="01ee1ac1-3f21-5f44-804f-1a65e62fff07"><grammatical-info value="Verb"/><gloss lang="en"><text>to displease, be disagreeable</text></gloss></sense></entry>
<entry id="desahogar" guid="91c19a28-d7e8-5eff-b6cd-8cd43c25c224"><lexical-unit><form lang="es"><text>desahogar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desahogar_0" guid="6fc2b7e0-08ca-57b7-9e3f-0acbe6e116fb"><grammatical-info value="Verb"/><gloss lang="en"><text>to unburden, to relieve</text></gloss></sense><sense id="desahogar_1" guid="e8eab195-1a42-5bdd-a813-9bfbbd449608"><grammatical-info value="Verb"/><gloss lang="en"><text>to vent, to rant, to violently express one's feelings</text></gloss></sense><sense id="desahogar_2" guid="f14be99b-cda8-5d52-8a37-17dede03baa9"><grammatical-info value="Verb"/><gloss lang="en"><text>to blow off steam, to let off steam, to pour one's heart out, to get off one's chest</text></gloss></sense></entry>
<entry id="desamparado" guid="9baa133c-f38b-534b-a032-2f439adff80f"><lexical-unit><form lang="es"><text>desamparado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desamparado_0" guid="dd078acd-5afa-5c2f-bd2d-becb7036621f"><grammatical-info value="Verb"/></sense></entry>
<entry id="desamparar" guid="705aa37b-e0cf-5304-8067-f1f58e499770"><lexical-unit><form lang="es"><text>desamparar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desamparar_0" guid="8c84ccfb-32d1-562f-ae9e-e67d3ae5f8c9"><grammatical-info value="Verb"/><gloss lang="en"><text>to forsake</text></gloss></sense></entry>
<entry id="desapacible" guid="623fddf9-bcab-5ad2-b522-2580eb577d35"><lexical-unit><form lang="es"><text>desapacible</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desapacible_0" guid="37566aaa-2e70-5b44-8a7d-8748881cb1cd"><grammatical-info value="Adjective"/><gloss lang="en"><text>unpleasant</text></gloss></sense><sense id="desapacible_1" guid="812f6653-b5fd-5afa-9ea3-2b9e4ed2c6ec"><grammatical-info value="Adjective"/><gloss lang="en"><text>horrible</text></gloss></sense></entry>
<entry id="desaparecer" guid="eb57eed2-680d-5623-b439-dc7f41034b47"><lexical-unit><form lang="es"><text>desaparecer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desaparecer_0" guid="3e2699a6-01f7-5c43-a5f7-8c1c3377c6c6"><grammatical-info value="Verb"/><gloss lang="en"><text>to disappear, to go missing, to vanish, to be gone</text></gloss></sense><sense id="desaparecer_1" guid="27bac84f-ec16-544f-a3da-c79281fa2606"><grammatical-info value="Verb"/><gloss lang="en"><text>to drop off (e.g. the map, the face of the earth)</text></gloss></sense><sense id="desaparecer_2" guid="ae5eff0d-8c05-5130-9a0b-d076c09f9140"><grammatical-info value="Verb"/><gloss lang="en"><text>to go away, to fade, to wear off, to subside</text></gloss></sense><sense id="desaparecer_3" guid="42050ee3-9621-5f36-9130-c2e9fc8d75c7"><grammatical-info value="Verb"/><gloss lang="en"><text>to make disappear</text></gloss></sense></entry>
<entry id="desapercibido" guid="ef30b6f6-6adb-5ffc-ac90-01cb81663270"><lexical-unit><form lang="es"><text>desapercibido</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desapercibido_0" guid="2fdea0ea-6221-5ed1-82b5-ee5ceb32c91a"><grammatical-info value="Adjective"/><gloss lang="en"><text>unnoticed, inconspicuous, discreet (without attracting attention)</text></gloss></sense></entry>
<entry id="desarraigar" guid="439e90a9-8e7f-5609-acca-e0431e9177b6"><lexical-unit><form lang="es"><text>desarraigar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desarraigar_0" guid="32c4036d-98a6-5ab5-87b0-d3058d8c3697"><grammatical-info value="Verb"/><gloss lang="en"><text>to uproot, root out, eradicate</text></gloss></sense></entry>
<entry id="desatado" guid="6f7fe054-db6b-52ce-8108-44c4a53fabd2"><lexical-unit><form lang="es"><text>desatado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desatado_0" guid="22f3d6bb-b59a-58d6-b7e1-4ebbb1b0fe47"><grammatical-info value="Verb"/><gloss lang="en"><text>undone; out of hand</text></gloss></sense><sense id="desatado_1" guid="fa9a5b31-235c-588d-873a-a24a1946c7d0"><grammatical-info value="Verb"/><gloss lang="en"><text>untied</text></gloss></sense></entry>
<entry id="desatar" guid="c6bad9da-4af2-5146-b807-6f75643fbada"><lexical-unit><form lang="es"><text>desatar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desatar_0" guid="626821f5-1dca-5a8f-9e49-786c89adff33"><grammatical-info value="Verb"/><gloss lang="en"><text>to untie, undo, unfasten, unleash</text></gloss></sense><sense id="desatar_1" guid="81570d91-3135-5843-90a4-8b0cd3d6584e"><grammatical-info value="Verb"/><gloss lang="en"><text>to provoke, set off, trigger (especially suddenly)</text></gloss></sense></entry>
<entry id="desavenencia" guid="745f7ffb-eeab-5a88-a745-12ce94860f89"><lexical-unit><form lang="es"><text>desavenencia</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desavenencia_0" guid="d48c23cf-73e2-5295-aceb-9aa60066c319"><grammatical-info value="Noun"/><gloss lang="en"><text>disagreement, quibble</text></gloss></sense></entry>
<entry id="descaminado" guid="07359ce9-cf7c-5eb9-982d-f4b61e19ef67"><lexical-unit><form lang="es"><text>descaminado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="descaminado_0" guid="1d23f322-68cd-5e6d-aaa4-8988a4069270"><grammatical-info value="Verb"/><gloss lang="en"><text>out of touch</text></gloss></sense></entry>
<entry id="descaminar" guid="5a0f3e21-630a-5e94-9937-761c24101b18"><lexical-unit><form lang="es"><text>descaminar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="descaminar_0" guid="7d7374be-2c07-5ac6-ad16-c7a3008911fd"><grammatical-info value="Verb"/><gloss lang="en"><text>to lead off the right track; to lead astray</text></gloss></sense><sense id="descaminar_1" guid="6b4bd63b-536c-5768-bfa0-e8fb0cec85f5"><grammatical-info value="Verb"/><gloss lang="en"><text>to lead (someone) off the straight and narrow</text></gloss></sense></entry>
<entry id="descansar" guid="d7464cdd-76d9-5a6d-b94f-bbab2a9cf330"><lexical-unit><form lang="es"><text>descansar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="descansar_0" guid="c0df527b-74fa-5c67-b19e-97438b7b2ce7"><grammatical-info value="Verb"/><gloss lang="en"><text>to rest, relax (be in a state of rest or inactivity)</text></gloss></sense><sense id="descansar_1" guid="5ce8d6ef-7596-5b7f-a699-145449627185"><grammatical-info value="Verb"/><gloss lang="en"><text>to sit, to rest</text></gloss></sense><sense id="descansar_2" guid="6fc36a72-d4de-5b61-bb87-7eccdcbde5fa"><grammatical-info value="Verb"/><gloss lang="en"><text>to rest (put into a state of rest)</text></gloss></sense></entry>
<entry id="descargar" guid="c636d702-2f8c-5f37-9ce9-68ee17832f7d"><lexical-unit><form lang="es"><text>descargar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="descargar_0" guid="b7c76ba9-c601-5c6c-9301-0ffd381c6f2e"><grammatical-info value="Verb"/><gloss lang="en"><text>to unload</text></gloss></sense><sense id="descargar_1" guid="267f2e1d-c841-5fbd-98c0-53b283b7a61a"><grammatical-info value="Verb"/><gloss lang="en"><text>to discharge</text></gloss></sense><sense id="descargar_2" guid="c8fbce75-f17f-5f95-8255-5bd9b46ef9b3"><grammatical-info value="Verb"/><gloss lang="en"><text>to fire, discharge (a weapon)</text></gloss></sense><sense id="descargar_3" guid="90c656b8-d592-5e29-9889-d4081324a79d"><grammatical-info value="Verb"/><gloss lang="en"><text>to download</text></gloss></sense></entry>
<entry id="descarriar" guid="44e14414-7420-5af6-b433-3cd7c5b8b38d"><lexical-unit><form lang="es"><text>descarriar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="descarriar_0" guid="a198a4fe-45a3-5bdb-9508-31a50a156375"><grammatical-info value="Verb"/><gloss lang="en"><text>to mislead, lead astray; to go wrong</text></gloss></sense></entry>
<entry id="descender" guid="f93267ce-6c24-5b71-8806-f20e9e94e053"><lexical-unit><form lang="es"><text>descender</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="descender_0" guid="204664e2-f023-54d5-bd59-209c66601b28"><grammatical-info value="Verb"/><gloss lang="en"><text>to descend</text></gloss></sense></entry>
<entry id="descolgar" guid="dc3d6e94-4e16-556a-bff1-cc53fcbf3ed2"><lexical-unit><form lang="es"><text>descolgar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="descolgar_0" guid="e6303711-6e95-50be-b9a6-26ab09d43a41"><grammatical-info value="Verb"/><gloss lang="en"><text>to unhang, let down, lower, take down</text></gloss></sense><sense id="descolgar_1" guid="a8698e6d-99a5-5893-9de6-0bc81291c6ae"><grammatical-info value="Verb"/><gloss lang="en"><text>to pick up (a telephone receiver)</text></gloss></sense><sense id="descolgar_2" guid="71eabcd5-845e-557e-9d11-c3b2e35ba9c0"><grammatical-info value="Verb"/><gloss lang="en"><text>to fall behind (in a race)</text></gloss></sense><sense id="descolgar_3" guid="5359b194-810e-528c-a0a3-becf2facd919"><grammatical-info value="Verb"/><gloss lang="en"><text>to show up, do or say something out of the blue</text></gloss></sense></entry>
<entry id="desconfianza" guid="df984a35-7c48-51a7-a31c-d00c1a7d15e3"><lexical-unit><form lang="es"><text>desconfianza</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desconfianza_0" guid="e7fa705b-60c0-58e8-a442-b741ef114364"><grammatical-info value="Noun"/><gloss lang="en"><text>mistrust, distrust</text></gloss></sense></entry>
<entry id="desconocer" guid="7e8ba6b0-7288-5304-b5f2-961c1400b59d"><lexical-unit><form lang="es"><text>desconocer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desconocer_0" guid="41769e4c-caf5-596a-85f0-20ec5a189b65"><grammatical-info value="Verb"/><gloss lang="en"><text>to not be familiar with, to not know, to not recognize</text></gloss></sense><sense id="desconocer_1" guid="2ccc7a6a-7bcb-5f46-87be-f7d3f42ea5cd"><grammatical-info value="Verb"/><gloss lang="en"><text>to ignore, to disregard</text></gloss></sense></entry>
<entry id="describir" guid="1191908b-e1f4-53f0-9335-a6c86cd3e293"><lexical-unit><form lang="es"><text>describir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="describir_0" guid="28711660-2422-5b78-832e-fe8298014ff4"><grammatical-info value="Verb"/><gloss lang="en"><text>to describe, represent in words</text></gloss></sense><sense id="describir_1" guid="a303ed7f-09be-53a9-ab4e-6749d0a0279d"><grammatical-info value="Verb"/><gloss lang="en"><text>to trace, describe</text></gloss></sense></entry>
<entry id="descubrir" guid="2796e421-a6d3-57be-bbfe-8a25074b70fb"><lexical-unit><form lang="es"><text>descubrir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="descubrir_0" guid="6ae478b9-1ee6-5ba7-8191-8c5e24e4ad09"><grammatical-info value="Verb"/><gloss lang="en"><text>to discover</text></gloss></sense><sense id="descubrir_1" guid="52029e4a-af84-5708-9682-e94da5a27d7b"><grammatical-info value="Verb"/><gloss lang="en"><text>to reveal</text></gloss></sense><sense id="descubrir_2" guid="f7924424-563f-5865-a555-46a66b97fc74"><grammatical-info value="Verb"/><gloss lang="en"><text>to invent</text></gloss></sense></entry>
<entry id="descuidar" guid="0d55101e-65f9-50d9-848c-75bd14459610"><lexical-unit><form lang="es"><text>descuidar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="descuidar_0" guid="352e2309-7978-527f-885f-9ee797b32679"><grammatical-info value="Verb"/><gloss lang="en"><text>to relieve from care</text></gloss></sense><sense id="descuidar_1" guid="e12d8049-055e-56ad-8d92-4ef0d0db6c89"><grammatical-info value="Verb"/><gloss lang="en"><text>to neglect</text></gloss></sense><sense id="descuidar_2" guid="32025bc5-0c3e-59a4-9bd7-936b9da5d7be"><grammatical-info value="Verb"/><gloss lang="en"><text>to not think</text></gloss></sense><sense id="descuidar_3" guid="6025bc63-b0ef-5c00-bc9f-6f61348bd4f8"><grammatical-info value="Verb"/><gloss lang="en"><text>to get sloppy, to get or grow careless</text></gloss></sense></entry>
<entry id="desde" guid="0489f76b-bc6e-5f47-b3a6-1f084e0fd5be"><lexical-unit><form lang="es"><text>desde</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desde_0" guid="15c4b8a7-bfeb-5106-94e0-a8d10cd46a93"><grammatical-info value="Adposition"/><gloss lang="en"><text>since (from a specified time in the past)</text></gloss></sense><sense id="desde_1" guid="87b3cae1-54f7-55bb-953e-9e7c6cc521d3"><grammatical-info value="Adposition"/><gloss lang="en"><text>from (a location)</text></gloss></sense><sense id="desde_2" guid="d77f610c-5391-5da6-8f8c-be389e59ffe8"><grammatical-info value="Adposition"/><gloss lang="en"><text>starting at (a quantity, such as a price)</text></gloss></sense></entry>
<entry id="dese" guid="c32e1fd5-d1d0-5a48-90c0-1d3ff9cb71b1"><lexical-unit><form lang="es"><text>dese</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="dese_0" guid="20ab5adc-f45e-5072-b87a-a29f427295a2"><grammatical-info value="Verb"/><gloss lang="en"><text>whatchamacallit, thingamabob</text></gloss></sense></entry>
<entry id="deseado" guid="d8365c86-c971-5f03-aece-1189008df0f2"><lexical-unit><form lang="es"><text>deseado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="deseado_0" guid="863abb1b-ff9f-5f2c-82b5-47abaf7e5bbb"><grammatical-info value="Adjective"/><gloss lang="en"><text>wanted, wished, desired</text></gloss></sense></entry>
<entry id="desear" guid="bcafb18c-56bf-5e44-8e9d-0fd48ed09f4f"><lexical-unit><form lang="es"><text>desear</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desear_0" guid="ffbf1262-5d7b-538b-8b1e-cc2a51d60f8c"><grammatical-info value="Verb"/><gloss lang="en"><text>to wish</text></gloss></sense><sense id="desear_1" guid="53bf5fc4-f130-5c86-9336-38c569767da1"><grammatical-info value="Verb"/><gloss lang="en"><text>to desire, to want, to hope for, to long for</text></gloss></sense><sense id="desear_2" guid="4aa29e7a-caa2-5fbb-b435-7c798813f27d"><grammatical-info value="Verb"/><gloss lang="en"><text>to look forward to</text></gloss></sense></entry>
<entry id="desechar" guid="3265b4f8-eff3-5caf-951c-4c97a588f2db"><lexical-unit><form lang="es"><text>desechar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desechar_0" guid="27d98f94-f86b-5f93-bbfc-b318ef519c74"><grammatical-info value="Verb"/><gloss lang="en"><text>to cast off, cast away, cast aside</text></gloss></sense><sense id="desechar_1" guid="fcc1ad05-912e-5420-a034-994a21891cc2"><grammatical-info value="Verb"/><gloss lang="en"><text>to dispose, scrap, discard, throw away, throw out</text></gloss></sense><sense id="desechar_2" guid="099ad601-c8b2-5dd3-b8c3-c0cfb5217c74"><grammatical-info value="Verb"/><gloss lang="en"><text>to dismiss, to reject, to drop</text></gloss></sense></entry>
<entry id="deseo" guid="c2ce0010-ad54-5063-a888-ea7f9f3e9612"><lexical-unit><form lang="es"><text>deseo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="deseo_0" guid="2dd87882-d34c-50c1-9f1f-c884ccd08a8e"><grammatical-info value="Noun"/><gloss lang="en"><text>desire, wish</text></gloss></sense></entry>
<entry id="desesperar" guid="ff327460-a44d-56e1-b35c-cd7cdf62b8d8"><lexical-unit><form lang="es"><text>desesperar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desesperar_0" guid="d4aa2dbe-581b-5fc0-aa98-67239376b143"><grammatical-info value="Verb"/><gloss lang="en"><text>to despair, exasperate</text></gloss></sense><sense id="desesperar_1" guid="870f290b-d82f-5c35-8ff5-b443bc520960"><grammatical-info value="Verb"/><gloss lang="en"><text>to despair (be driven to despair)</text></gloss></sense></entry>
<entry id="desfallecer" guid="cf6d005d-60fc-5ac9-ad96-1ccd26b5bbe5"><lexical-unit><form lang="es"><text>desfallecer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desfallecer_0" guid="72faab47-2873-58a5-843b-964d1a00f052"><grammatical-info value="Verb"/><gloss lang="en"><text>to become weak, wear out</text></gloss></sense></entry>
<entry id="desgarrar" guid="a6036a83-a98a-52d8-ab00-d1aed6119066"><lexical-unit><form lang="es"><text>desgarrar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desgarrar_0" guid="227161b5-f8ec-5dc8-9dc3-e58f326b23be"><grammatical-info value="Verb"/><gloss lang="en"><text>to tear, to rip, to rend (to hold or restrain in two places while pulling apart)</text></gloss></sense><sense id="desgarrar_1" guid="9629b364-a4e6-5551-b77e-2e9bfb1b68ae"><grammatical-info value="Verb"/><gloss lang="en"><text>to break (someone's heart)</text></gloss></sense></entry>
<entry id="desgastar" guid="3ffdf3a4-3aa5-5da6-8315-126af7890839"><lexical-unit><form lang="es"><text>desgastar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="desgastar_0" guid="e3532c90-623c-5a24-ae22-73109467f1f7"><grammatical-info value="Verb"/><gloss lang="en"><text>to use up or wear out</text></gloss></sense><sense id="desgastar_1" guid="8ebcb257-10be-54e0-bccd-45824f2f0f81"><grammatical-info value="Verb"/><gloss lang="en"><text>to wear down, to erode, to wear away</text></gloss></sense><sense id="desgastar_2" guid="1da1c711-2faa-5486-9b6f-517c8d107fca"><grammatical-info value="Verb"/><gloss lang="en"><text>to wear out, to get worn out</text></gloss></sense></entry>
<entry id="deshacer" guid="e65b22c8-e874-5568-b037-620443a30a46"><lexical-unit><form lang="es"><text>deshacer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="deshacer_0" guid="c525afff-fb5f-5768-99fb-30d4b0f0b3a6"><grammatical-info value="Verb"/><gloss lang="en"><text>to undo, to unmake</text></gloss></sense><sense id="deshacer_1" guid="11fdf4e5-4387-575a-974b-d4d35862aa07"><grammatical-info value="Verb"/><gloss lang="en"><text>to unpack</text></gloss></sense><sense id="deshacer_2" guid="76c8f517-ab33-591a-88d0-4484f06c19aa"><grammatical-info value="Verb"/><gloss lang="en"><text>to break, to break up (e.g. a treaty, a business, a band, a united effort)</text></gloss></sense><sense id="deshacer_3" guid="4db3ff50-fb71-501c-8dae-af3176a65271"><grammatical-info value="Verb"/><gloss lang="en"><text>to take back (something done or said)</text></gloss></sense><sense id="deshacer_4" guid="5ca080fd-3cdc-5299-a93b-ec24f86ff812"><grammatical-info value="Verb"/><gloss lang="en"><text>to reverse (a spell or curse)</text></gloss></sense><sense id="deshacer_5" guid="3e615986-df51-54ef-9183-30cc8399976d"><grammatical-info value="Verb"/><gloss lang="en"><text>to come undone, to unravel</text></gloss></sense><sense id="deshacer_6" guid="175ea55f-69a4-57e3-b361-e00287482654"><grammatical-info value="Verb"/><gloss lang="en"><text>to get rid of, to ditch, to dispose of, to dump (deshacerse de alguien o algo)</text></gloss></sense><sense id="deshacer_7" guid="f4e4cb59-502e-58da-a7b1-7e1bbc1ae205"><grammatical-info value="Verb"/><gloss lang="en"><text>to melt (deshacerse el hielo)</text></gloss></sense></entry>
<entry id="deshacimiento" guid="5f090075-8955-5334-8933-9a784671d0df"><lexical-unit><form lang="es"><text>deshacimiento</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="deshacimiento_0" guid="a52717f9-95c8-5c75-94b1-642d8663b92a"><grammatical-info value="Noun"/><gloss lang="en"><text>undoing</text></gloss></sense><sense id="deshacimiento_1" guid="36edf7f3-1f47-5a79-8a91-ae8708925dfd"><grammatical-info value="Noun"/><gloss lang="en"><text>riddance</text></gloss></sense></entry>
<entry id="deshecho" guid="f41e64bd-e444-526b-8150-38ae2843f569"><lexical-unit><form lang="es"><text>deshecho</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="deshecho_0" guid="29f6c427-4f74-5985-a299-b2bf85a76d50"><grammatical-info value="Verb"/><gloss lang="en"><text>undone</text></gloss></sense><sense id="deshecho_1" guid="f46b042c-f73f-5ff0-ad4a-9977a5531dcf"><grammatical-info value="Verb"/><gloss lang="en"><text>destroyed, broken (into pieces, not out of order)</text></gloss></sense><sense id="deshecho_2" guid="8ac9f97e-cae8-522f-841b-f91be9216d01"><grammatical-info value="Verb"/><gloss lang="en"><text>reverted (a command, magic, witchcraft, effect, etc.)</text></gloss></sense><sense id="deshecho_3" guid="00e8f284-c560-5a23-9357-48c034c77c39"><grammatical-info value="Verb"/><gloss lang="en"><text>melted (ice, gelatine, wax, etc.)</text></gloss></sense><sense id="deshecho_4" guid="d28b9c09-de4c-5ff1-9eac-145a0a2df411"><grammatical-info value="Verb"/><gloss lang="en"><text>very tired or exhausted, strengthless</text></gloss></sense><sense id="deshecho_5" guid="ba5114d4-9ba0-54c3-9a47-252be8a33b0d"><grammatical-info value="Verb"/><gloss lang="en"><text>demoralized, disheartened</text></gloss></sense></entry>
<entry id="deshonestidad" guid="c4b8f239-52a8-5d7e-a98d-840701630cbb"><lexical-unit><form lang="es"><text>deshonestidad</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="deshonestidad_0" guid="946872e7-7ac5-5ff6-9a27-b5b7962d7886"><grammatical-info value="Noun"/><gloss lang="en"><text>dishonesty</text></gloss></sense></entry>
<entry id="deshonesto" guid="7bd19d0b-af8c-5557-8215-84a34c18a991"><lexical-unit><form lang="es"><text>deshonesto</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="deshonesto_0" guid="375a2fca-8993-576c-bc22-85d1532e3ba4"><grammatical-info value="Adjective"/><gloss lang="en"><text>dishonest</text></gloss></sense></entry>
<entry id="deshonra" guid="f6e346dc-4e79-525e-9105-afaefead452b"><lexical-unit><form lang="es"><text>deshonra</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="deshonra_0" guid="ffd9498f-390e-55fb-8eca-ceb6d1d35cd2"><grammatical-info value="Verb"/><gloss lang="en"><text>dishonor</text></gloss></sense><sense id="deshonra_1" guid="3a0afa8e-9a21-5105-b6f7-fad28ff079b7"><grammatical-info value="Verb"/><gloss lang="en"><text>attainder</text></gloss></sense></entry>
