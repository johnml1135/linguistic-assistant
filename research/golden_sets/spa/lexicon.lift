<entry id="rescatar" guid="bcdd2f21-1828-5487-98c1-d7f2e38e749b"><lexical-unit><form lang="es"><text>rescatar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="rescatar_0" guid="26b89a2b-7b6a-5258-a9d3-69a002a38e2e"><grammatical-info value="Verb"/><gloss lang="en"><text>to rescue</text></gloss></sense></entry>
<entry id="resentido" guid="0571a837-2bd0-5d7a-851a-15f5e77ff470"><lexical-unit><form lang="es"><text>resentido</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="resentido_0" guid="da97e63c-900a-5556-8484-6524279896d3"><grammatical-info value="Adjective"/></sense></entry>
<entry id="resentirse" guid="5829cd0d-10bc-5ccc-acdd-7d63d6f522b9"><lexical-unit><form lang="es"><text>resentirse</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="resentirse_0" guid="3a78b284-4e21-5c77-a802-3dcf7d047b51"><grammatical-info value="Verb"/><gloss lang="en"><text>to fall apart; to feel the effects</text></gloss></sense><sense id="resentirse_1" guid="d4e0cc01-12e7-52da-b60b-85abe8f74e22"><grammatical-info value="Verb"/><gloss lang="en"><text>to regret, bemoan</text></gloss></sense><sense id="resentirse_2" guid="443024df-db81-5a15-b4fb-e6d832121569"><grammatical-info value="Verb"/><gloss lang="en"><text>to resent</text></gloss></sense></entry>
<entry id="reserva" guid="ed1f82ee-13ff-5196-aaaa-9f38ad1195b5"><lexical-unit><form lang="es"><text>reserva</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="reserva_0" guid="d51e3afe-1f6b-5324-b77b-7648477f1ced"><grammatical-info value="Noun"/><gloss lang="en"><text>reservation, booking (arrangement by which accommodation or transport arrangements are secured in advance)</text></gloss></sense><sense id="reserva_1" guid="89ce0377-62f1-5b1f-aa93-0c40dec14d0f"><grammatical-info value="Noun"/><gloss lang="en"><text>a reserve, reservation, preserve, sanctuary (area protected for a specific reason)</text></gloss></sense><sense id="reserva_2" guid="81273b03-ecad-5cd8-843d-b2821a3cb7ff"><grammatical-info value="Noun"/><gloss lang="en"><text>reserve (for game or hunting)</text></gloss></sense><sense id="reserva_3" guid="d813a773-fba5-52e9-9199-ef9bc949c6b9"><grammatical-info value="Noun"/><gloss lang="en"><text>reserve (armed forces in non-active duty)</text></gloss></sense><sense id="reserva_4" guid="cb2ab7e3-b2f4-59be-a938-2ebf1b3a3457"><grammatical-info value="Noun"/><gloss lang="en"><text>reserve (part of the team that doesn't start)</text></gloss></sense><sense id="reserva_5" guid="3a93e74e-a1b8-547f-8be7-5c2c3d72fbf1"><grammatical-info value="Noun"/><gloss lang="en"><text>reserve, supply, stock, stockpile, store, standby (something saved for future use)</text></gloss></sense><sense id="reserva_6" guid="07425927-f7e8-567f-a883-e9de57a75426"><grammatical-info value="Noun"/><gloss lang="en"><text>pool (e.g. talent pool, gene pool, pool of experts, pool of available workers)</text></gloss></sense><sense id="reserva_7" guid="0229daab-bba7-5bd3-a10a-a873e5e3483e"><grammatical-info value="Noun"/><gloss lang="en"><text>secrecy (i.e. discretion, confidence)</text></gloss></sense></entry>
<entry id="reservado" guid="20086aab-d320-57d1-81ea-c66f3c6b531b"><lexical-unit><form lang="es"><text>reservado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="reservado_0" guid="7424b9a3-5cd4-5716-bf4d-bc0df22524f6"><grammatical-info value="Adjective"/><gloss lang="en"><text>reserved</text></gloss></sense><sense id="reservado_1" guid="86c38990-ec2d-55bd-a772-9265cec28e36"><grammatical-info value="Adjective"/><gloss lang="en"><text>private, secretive</text></gloss></sense><sense id="reservado_2" guid="3a53ecff-6ba7-5b79-9c19-72e7b8c19785"><grammatical-info value="Adjective"/><gloss lang="en"><text>discrete</text></gloss></sense></entry>
<entry id="reservar" guid="bc8501fe-8103-5cb4-b72b-ffc62ffaea5f"><lexical-unit><form lang="es"><text>reservar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="reservar_0" guid="f47ddfa4-5643-597a-80d9-4e825ca61360"><grammatical-info value="Verb"/><gloss lang="en"><text>to reserve, keep, save</text></gloss></sense><sense id="reservar_1" guid="1808338e-f03a-5b8f-aa86-297dc3de854c"><grammatical-info value="Verb"/><gloss lang="en"><text>to put aside, set aside</text></gloss></sense><sense id="reservar_2" guid="8e708271-97cb-56f7-abfa-9a09f6763fb1"><grammatical-info value="Verb"/><gloss lang="en"><text>to put off, postpone</text></gloss></sense><sense id="reservar_3" guid="69a29e60-9e2e-59fb-b09e-4d94cd4b22dc"><grammatical-info value="Verb"/><gloss lang="en"><text>to exempt, exonerate</text></gloss></sense><sense id="reservar_4" guid="cc105eda-b8d6-50cc-80f0-d3d46e2a70e6"><grammatical-info value="Verb"/><gloss lang="en"><text>to conceal, keep secret</text></gloss></sense><sense id="reservar_5" guid="b6647603-8e8e-5e01-bb16-240544e64116"><grammatical-info value="Verb"/><gloss lang="en"><text>to book</text></gloss></sense><sense id="reservar_6" guid="e39df85e-092a-5fb8-847b-0a2bef4ce233"><grammatical-info value="Verb"/><gloss lang="en"><text>to reserve, to retain (one's right to something or one's judgment/opinion)</text></gloss></sense><sense id="reservar_7" guid="60f84276-8c6b-5681-8f0b-eca1402c2640"><grammatical-info value="Verb"/><gloss lang="en"><text>to be reserved, to be set aside</text></gloss></sense></entry>
<entry id="resfriar" guid="1ab80a36-a9b6-5057-9a38-646b3b4f9338"><lexical-unit><form lang="es"><text>resfriar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="resfriar_0" guid="b6522792-6bdd-53b1-8914-ac5a98b3055d"><grammatical-info value="Verb"/><gloss lang="en"><text>to cool, chill, grow cold</text></gloss></sense><sense id="resfriar_1" guid="adbbc80a-6d93-533f-9ca0-24e504158ec5"><grammatical-info value="Verb"/><gloss lang="en"><text>to catch a cold</text></gloss></sense></entry>
<entry id="residir" guid="b10a4f82-4568-5916-b5fe-d8343ef4bf17"><lexical-unit><form lang="es"><text>residir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="residir_0" guid="06e5ce82-ed3c-5393-9734-2dcb6ab10c2f"><grammatical-info value="Verb"/><gloss lang="en"><text>to reside; to live in</text></gloss></sense><sense id="residir_1" guid="cc4b691b-5a77-536f-a75f-3e46924ac080"><grammatical-info value="Verb"/><gloss lang="en"><text>to reside, lie, inhere</text></gloss></sense></entry>
<entry id="resistir" guid="ae622939-f8c0-595f-aa8c-10b08de495a1"><lexical-unit><form lang="es"><text>resistir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="resistir_0" guid="88342f9d-0915-58f1-bc2c-38a7eb4f2141"><grammatical-info value="Verb"/><gloss lang="en"><text>to tolerate, to put up with, to bear, to handle, to stand</text></gloss></sense><sense id="resistir_1" guid="fb022c7e-b7fe-5ca1-9df0-10cdf51501b4"><grammatical-info value="Verb"/><gloss lang="en"><text>to fight off, to survive, to defend oneself (from)</text></gloss></sense><sense id="resistir_2" guid="e0fac3e5-ef7e-5c5e-8ef2-40722299b985"><grammatical-info value="Verb"/><gloss lang="en"><text>to resist</text></gloss></sense></entry>
<entry id="resolución" guid="4ff165d0-4bc9-53cf-bd97-445f0491477d"><lexical-unit><form lang="es"><text>resolución</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="resolución_0" guid="0d27c2ac-c880-5837-9cf4-163df6ef7c44"><grammatical-info value="Noun"/><gloss lang="en"><text>resolution</text></gloss></sense></entry>
<entry id="resolver" guid="5fb0bb47-ccda-509d-a588-ce505bff1ed7"><lexical-unit><form lang="es"><text>resolver</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="resolver_0" guid="f2afca13-bfa8-5f5b-87ee-c77b8b8a4a56"><grammatical-info value="Verb"/><gloss lang="en"><text>to resolve, to sort out, to settle, to address, to tackle, to overcome, to iron out</text></gloss></sense><sense id="resolver_1" guid="11ee1b80-6eb9-53aa-ba40-4135cfa50764"><grammatical-info value="Verb"/><gloss lang="en"><text>to solve, to figure out, to work out, to crack</text></gloss></sense><sense id="resolver_2" guid="5c48fa9d-df3c-529b-aa55-a955dee1aa2a"><grammatical-info value="Verb"/><gloss lang="en"><text>to decide</text></gloss></sense><sense id="resolver_3" guid="d343ffed-afe6-536b-b531-4fc06f18ac57"><grammatical-info value="Verb"/><gloss lang="en"><text>to meet (e.g. demands, needs, requirements)</text></gloss></sense></entry>
<entry id="resonar" guid="f0ca1939-b4ca-5fb1-b5dc-bc795adf88b0"><lexical-unit><form lang="es"><text>resonar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="resonar_0" guid="5f177ee3-32af-58a6-bdda-7022dcd99970"><grammatical-info value="Verb"/><gloss lang="en"><text>to resonate</text></gloss></sense><sense id="resonar_1" guid="f0c3dcdd-3bba-569f-be2d-c57e2d402cde"><grammatical-info value="Verb"/><gloss lang="en"><text>to echo</text></gloss></sense><sense id="resonar_2" guid="8cbc4153-cbd7-52a2-93b6-ef4e7d66d3be"><grammatical-info value="Verb"/><gloss lang="en"><text>to ring (usually one's ears)</text></gloss></sense><sense id="resonar_3" guid="8a5db1a4-44ba-56e5-9374-b9fc5d74b6c5"><grammatical-info value="Verb"/><gloss lang="en"><text>to resound, ring</text></gloss></sense></entry>
<entry id="respectar" guid="6f0e9bba-fcef-5edc-92a4-0fe5992b3903"><lexical-unit><form lang="es"><text>respectar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="respectar_0" guid="f5774001-f010-58b3-85ad-f3950712bd25"><grammatical-info value="Verb"/><gloss lang="en"><text>to relate to; to be concerned or involved with</text></gloss></sense><sense id="respectar_1" guid="81958c6a-16a2-5171-8653-74c0b0ea2105"><grammatical-info value="Verb"/><gloss lang="en"><text>to respect (to have respect or consideration toward)</text></gloss></sense></entry>
