<entry id="llamar" guid="6f807f93-82ea-5f48-94de-53f27f40ea4e"><lexical-unit><form lang="es"><text>llamar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="llamar_0" guid="8e5f2a87-1159-56f6-9141-af43d51b33a6"><grammatical-info value="Verb"/><gloss lang="en"><text>to summon, to call</text></gloss></sense><sense id="llamar_1" guid="da5ec34d-a7a7-5de7-8052-bde81d67bb59"><grammatical-info value="Verb"/><gloss lang="en"><text>to call (on the telephone)</text></gloss></sense><sense id="llamar_2" guid="499aa064-1a25-5b78-bb35-583cb5920f49"><grammatical-info value="Verb"/><gloss lang="en"><text>to knock (on a door)</text></gloss></sense><sense id="llamar_3" guid="3d18e3c6-e1cc-5a4e-aedd-db80e8c4462a"><grammatical-info value="Verb"/><gloss lang="en"><text>to ring (a doorbell)</text></gloss></sense><sense id="llamar_4" guid="91b99dbc-fbc9-5aed-be58-cd34d53d3729"><grammatical-info value="Verb"/><gloss lang="en"><text>to refer to, to call</text></gloss></sense><sense id="llamar_5" guid="f9ccf21f-cab3-5c65-8eb7-370b15112103"><grammatical-info value="Verb"/><gloss lang="en"><text>to appeal; to attract</text></gloss></sense><sense id="llamar_6" guid="5899bd57-4c67-5fdb-9def-f6f89b9fb9b9"><grammatical-info value="Verb"/><gloss lang="en"><text>to be called</text></gloss></sense></entry>
<entry id="llamas" guid="1448581b-9e09-57cf-97d8-2cf560a27463"><lexical-unit><form lang="es"><text>llamas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="llamas_0" guid="010e6a9b-7bdb-54c7-a097-b946d11d11df"><grammatical-info value="Noun"/><gloss lang="en"><text>a name of several localities in Asturias, Spain</text></gloss></sense><sense id="llamas_1" guid="ab9a4e40-f321-51c4-a357-f0ad3bff6b18"><grammatical-info value="Noun"/><gloss lang="en"><text>a toponymic surname, the 544th most common in Mexico and 428th most common in Spain</text></gloss></sense></entry>
<entry id="llano" guid="406ab0d4-1ecb-5748-96c8-5b073f8e6934"><lexical-unit><form lang="es"><text>llano</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="llano_0" guid="83908178-7a2b-5cff-a0ac-396fee60762d"><grammatical-info value="Adjective"/><gloss lang="en"><text>even, flat, level</text></gloss></sense><sense id="llano_1" guid="918a101a-c225-5647-b86d-f0dd44fe71c8"><grammatical-info value="Adjective"/><gloss lang="en"><text>plain</text></gloss></sense><sense id="llano_2" guid="ec365cfd-84c8-59d4-b841-38fb34dd9c8f"><grammatical-info value="Adjective"/><gloss lang="en"><text>straightforward</text></gloss></sense><sense id="llano_3" guid="d55af5da-c42b-5810-aa8f-f8a33f0a5b6c"><grammatical-info value="Adjective"/><gloss lang="en"><text>paroxytone (penultimate accented)</text></gloss></sense><sense id="llano_4" guid="6f6e1060-c234-5f37-be61-310aba2e5e15"><grammatical-info value="Adjective"/><gloss lang="en"><text>plain (an open, grassy, mostly treeless land)</text></gloss></sense></entry>
<entry id="llanto" guid="27d276f3-6c96-51db-92cb-768691fba53d"><lexical-unit><form lang="es"><text>llanto</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="llanto_0" guid="9c5ce8bd-d5d3-5816-ab9a-6a0ba68765ea"><grammatical-info value="Noun"/><gloss lang="en"><text>crying</text></gloss></sense></entry>
<entry id="llave" guid="0248f5c9-bd83-56e8-ac1f-92ca45d2ad0a"><lexical-unit><form lang="es"><text>llave</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="llave_0" guid="59d7ae39-0626-598f-b7a1-b1cb92f89995"><grammatical-info value="Noun"/><gloss lang="en"><text>key (to open doors)</text></gloss></sense><sense id="llave_1" guid="002967a6-a425-5fda-abe2-6ad291007290"><grammatical-info value="Noun"/><gloss lang="en"><text>key (of musical instrument)</text></gloss></sense><sense id="llave_2" guid="66d4a937-2c68-5c0e-9e37-f778eb7cd9d5"><grammatical-info value="Noun"/><gloss lang="en"><text>key (in heraldry)</text></gloss></sense><sense id="llave_3" guid="2a9dc426-de4a-5b48-8855-a5be48e049bd"><grammatical-info value="Noun"/><gloss lang="en"><text>spanner, wrench</text></gloss></sense><sense id="llave_4" guid="f8c59cfd-4784-5039-92c2-f714f191edf2"><grammatical-info value="Noun"/><gloss lang="en"><text>faucet, tap, water tap, spigot</text></gloss></sense><sense id="llave_5" guid="e4840189-aa88-52cf-a8a4-340604c51395"><grammatical-info value="Noun"/><gloss lang="en"><text>curly bracket ({ and })</text></gloss></sense><sense id="llave_6" guid="041bc0dd-7cb7-5909-9a0f-6f67a755de4f"><grammatical-info value="Noun"/><gloss lang="en"><text>switch (a device to turn electric current on and off or direct its flow)</text></gloss></sense><sense id="llave_7" guid="25ee001d-b78e-5134-9f73-cdde860246ba"><grammatical-info value="Noun"/><gloss lang="en"><text>hold (position or grip used to control the opponent)</text></gloss></sense></entry>
<entry id="llegado" guid="5ecf61e8-51d1-51a6-8bfa-33da89b9e375"><lexical-unit><form lang="es"><text>llegado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="llegado_0" guid="c51abc12-4afb-5585-8393-cb153694bdd0"><grammatical-info value="Verb"/><gloss lang="en"><text>arrived, received, delivered</text></gloss></sense></entry>
<entry id="llegar" guid="aa60162b-7ac5-56ce-93d0-2697b5698285"><lexical-unit><form lang="es"><text>llegar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="llegar_0" guid="12cdd5a3-b866-5d6d-975b-72ce2a84b91c"><grammatical-info value="Verb"/><gloss lang="en"><text>to arrive, get (to)</text></gloss></sense><sense id="llegar_1" guid="03f804ca-e8c1-5a90-b361-4761895999aa"><grammatical-info value="Verb"/><gloss lang="en"><text>to get up to, to go up to, to reach (+ a or + hasta)</text></gloss></sense><sense id="llegar_2" guid="76cd52ab-9ef9-541b-bbf7-4ef9fe61c2fc"><grammatical-info value="Verb"/><gloss lang="en"><text>to be sufficient; to be enough</text></gloss></sense><sense id="llegar_3" guid="7ee4171c-bb62-5d2a-ac63-f0c3e6322feb"><grammatical-info value="Verb"/><gloss lang="en"><text>to manage (be successful)</text></gloss></sense></entry>
<entry id="llegue" guid="47d2c816-00a7-5c58-86f4-428b4892c4ac"><lexical-unit><form lang="es"><text>llegue</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="llegue_0" guid="6c434cc7-c8e8-5a5a-b797-f71fd9317d07"><grammatical-info value="Verb"/><gloss lang="en"><text>stab; stabbing</text></gloss></sense></entry>
<entry id="llenar" guid="b58fc4e2-d64d-5a83-987e-1e226ae5a913"><lexical-unit><form lang="es"><text>llenar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="llenar_0" guid="591fe22e-cbb8-57da-b472-191210195643"><grammatical-info value="Verb"/><gloss lang="en"><text>to fill something up</text></gloss></sense><sense id="llenar_1" guid="0d7dfc93-602c-5773-9a47-70f71d8c2ea9"><grammatical-info value="Verb"/><gloss lang="en"><text>to fill out or complete a form</text></gloss></sense><sense id="llenar_2" guid="3f7255eb-b990-5bc1-b413-dd01396a72d6"><grammatical-info value="Verb"/><gloss lang="en"><text>to complete a group</text></gloss></sense><sense id="llenar_3" guid="2b77f521-151e-5360-966e-ea9cd3274e03"><grammatical-info value="Verb"/><gloss lang="en"><text>to become full</text></gloss></sense><sense id="llenar_4" guid="c6835270-6e2c-5d69-b16f-d967ecefe3b9"><grammatical-info value="Verb"/><gloss lang="en"><text>to gorge, to chow down</text></gloss></sense><sense id="llenar_5" guid="4a25b3c9-a5dd-57b5-9a5d-24ca21914d44"><grammatical-info value="Verb"/><gloss lang="en"><text>to smear, soil, stain (something or someone); to become smeared, dirty, stained.</text></gloss></sense><sense id="llenar_6" guid="d26be124-d421-5aec-adab-97cfb75f35b1"><grammatical-info value="Verb"/><gloss lang="en"><text>to bother, to tire</text></gloss></sense></entry>
<entry id="lleno" guid="bfc20ec8-b4f3-5d83-b983-caf0a39f7aec"><lexical-unit><form lang="es"><text>lleno</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lleno_0" guid="6e717635-8e29-5189-b33a-877ff936e292"><grammatical-info value="Adjective"/><gloss lang="en"><text>full</text></gloss></sense></entry>
<entry id="llevado" guid="bc380a84-95e0-5e63-aa3b-332de01611c1"><lexical-unit><form lang="es"><text>llevado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="llevado_0" guid="784fddae-44cc-575d-a53e-fb01cb500504"><grammatical-info value="Verb"/></sense></entry>
<entry id="llevar" guid="77849f79-999a-53c3-9fa5-e5765bfb8787"><lexical-unit><form lang="es"><text>llevar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="llevar_0" guid="3c109e40-acca-5ca7-ae16-9a835ed2ec19"><grammatical-info value="Verb"/><gloss lang="en"><text>to take, to carry, to take away, to carry away, to carry around, to bring, to bear, to lug (implies to move something further from who speaks)</text></gloss></sense><sense id="llevar_1" guid="f3059960-9dfa-5d27-b102-3d103d372035"><grammatical-info value="Verb"/><gloss lang="en"><text>to take, to take out (implies moving someone further from the speaker)</text></gloss></sense><sense id="llevar_2" guid="19546139-0503-579f-98c4-fdd93bdcb533"><grammatical-info value="Verb"/><gloss lang="en"><text>to lead, to drive</text></gloss></sense><sense id="llevar_3" guid="b094590b-2e70-5588-a932-455dc22873c1"><grammatical-info value="Verb"/><gloss lang="en"><text>to have spent time, to have been</text></gloss></sense><sense id="llevar_4" guid="491765b7-d4f8-5cba-92f8-7a7f5ee64112"><grammatical-info value="Verb"/><gloss lang="en"><text>to wear (ellipsis of the more formal llevar puesto)</text></gloss></sense><sense id="llevar_5" guid="6719562d-3fa3-5801-8598-1576842dc8e3"><grammatical-info value="Verb"/><gloss lang="en"><text>to have, include (have as a component, part, accessory or ingredient)</text></gloss></sense><sense id="llevar_6" guid="67150b0b-1a06-55db-a553-49ad49b11e25"><grammatical-info value="Verb"/><gloss lang="en"><text>to give a lift, to give a ride</text></gloss></sense></entry>
<entry id="llorar" guid="d8b57689-f96c-5a89-8826-3324bd41efd5"><lexical-unit><form lang="es"><text>llorar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="llorar_0" guid="3725e0ab-6bf6-5fe5-a4d7-abf9b27bdf7b"><grammatical-info value="Verb"/><gloss lang="en"><text>to cry, to weep</text></gloss></sense><sense id="llorar_1" guid="bfef0d9b-e031-5312-9457-806b39e4dab9"><grammatical-info value="Verb"/><gloss lang="en"><text>to mourn</text></gloss></sense></entry>
<entry id="llover" guid="7bcb77ed-3293-514b-ad59-39ec2b1061d9"><lexical-unit><form lang="es"><text>llover</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="llover_0" guid="f1b7cc35-9f25-5aef-980f-f71bc85caeb1"><grammatical-info value="Verb"/><gloss lang="en"><text>to rain</text></gloss></sense></entry>
<entry id="lluvia" guid="ca960cf5-61c0-524d-abe1-a9783fed89f7"><lexical-unit><form lang="es"><text>lluvia</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lluvia_0" guid="a88eaeaf-b3bd-5968-bc9c-3a3e1bfc1405"><grammatical-info value="Noun"/><gloss lang="en"><text>rain</text></gloss></sense><sense id="lluvia_1" guid="79a7f1f5-10ca-585d-8ff0-82a121d0933a"><grammatical-info value="Noun"/><gloss lang="en"><text>shower (precipitation)</text></gloss></sense></entry>
<entry id="lo" guid="8815ed98-85ae-51c7-85ba-b97672772371"><lexical-unit><form lang="es"><text>lo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lo_0" guid="b37e451c-0eb6-539d-af54-53efda73b881"><grammatical-info value="Pronoun"/><gloss lang="en"><text>accusative of él and usted (when referring to a man), and a variant of ello in many constructions; him, you (formal), it, that</text></gloss></sense><sense id="lo_1" guid="38fa29e7-9c97-5b0f-811c-7430dd6c511a"><grammatical-info value="Pronoun"/><gloss lang="en"><text>neuter definite article used only before nominalized adjectives: the, that which is</text></gloss></sense></entry>
<entry id="loa" guid="080e90e6-6493-5888-9394-68ef81d2910f"><lexical-unit><form lang="es"><text>loa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="loa_0" guid="00305892-cff4-542a-8fd4-c176261f8da1"><grammatical-info value="Noun"/><gloss lang="en"><text>praise</text></gloss></sense><sense id="loa_1" guid="19dcb28a-079d-5219-ab8b-eb06d0dab6a8"><grammatical-info value="Noun"/><gloss lang="en"><text>a river in Chile</text></gloss></sense></entry>
<entry id="loar" guid="d8ade3da-872c-58d2-80b7-ee5c579ce13d"><lexical-unit><form lang="es"><text>loar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="loar_0" guid="514061ac-96d1-5658-ab0a-0fa7f5adb77f"><grammatical-info value="Verb"/><gloss lang="en"><text>to praise</text></gloss></sense></entry>
<entry id="lobo" guid="5884d266-c4fb-57df-a02e-ffb65802f998"><lexical-unit><form lang="es"><text>lobo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lobo_0" guid="78cb3b34-17f8-537b-ab3d-cc0bc9fe9b48"><grammatical-info value="Noun"/><gloss lang="en"><text>wolf (wild Canis lupus)</text></gloss></sense><sense id="lobo_1" guid="6011b60d-d734-554e-ab4e-445b209c012e"><grammatical-info value="Noun"/><gloss lang="en"><text>drunkenness</text></gloss></sense></entry>
<entry id="loca" guid="9c9379e8-326b-541d-b9a2-f9d9416a5032"><lexical-unit><form lang="es"><text>loca</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="loca_0" guid="cde9ca49-3cd8-5e81-b85d-a9a56f9eb033"><grammatical-info value="Noun"/><gloss lang="en"><text>a madwoman, female equivalent of loco</text></gloss></sense><sense id="loca_1" guid="40dcd62a-f775-5e09-9a2f-4cf0e314c312"><grammatical-info value="Noun"/><gloss lang="en"><text>slut (usually said of a woman...)</text></gloss></sense><sense id="loca_2" guid="7d693f30-a7c2-5f71-8c2c-8829c5d313ea"><grammatical-info value="Noun"/><gloss lang="en"><text>an effeminate man or boy</text></gloss></sense><sense id="loca_3" guid="b18c836e-861d-5d18-9f3a-73d97b4cba34"><grammatical-info value="Noun"/><gloss lang="en"><text>a very flirtatious homosexual man or boy</text></gloss></sense></entry>
<entry id="locamente" guid="6c13c324-af1d-572e-93e5-f27a635c4575"><lexical-unit><form lang="es"><text>locamente</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="locamente_0" guid="3299397e-bce4-5c80-991c-2489793f9e8f"><grammatical-info value="Adverb"/><gloss lang="en"><text>madly, crazily</text></gloss></sense></entry>
<entry id="loco" guid="314fe8cb-dd1c-5e4d-8bf6-54653ecd9902"><lexical-unit><form lang="es"><text>loco</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="loco_0" guid="c57a9ff2-8fd8-5ee2-9a78-a8fc19a0ccbc"><grammatical-info value="Adjective"/><gloss lang="en"><text>crazy, insane, mad, nuts (asserting that something is out of place in the head)</text></gloss></sense><sense id="loco_1" guid="2ea0eaab-8667-5e61-8708-d182db274e7f"><grammatical-info value="Adjective"/><gloss lang="en"><text>rash, risky, imprudent</text></gloss></sense><sense id="loco_2" guid="75a6c7e1-67d6-5743-bc67-8c674ef7c7d8"><grammatical-info value="Adjective"/><gloss lang="en"><text>tremendous, terrific, huge, enormous</text></gloss></sense><sense id="loco_3" guid="4296b4f7-0e51-547e-abc5-ea8a123edca7"><grammatical-info value="Adjective"/><gloss lang="en"><text>malfunctioning, broken and working incorrectly (said of a machine)</text></gloss></sense><sense id="loco_4" guid="39091798-a490-5ea8-9620-91f05491ed01"><grammatical-info value="Adjective"/><gloss lang="en"><text>overgrown, rambling</text></gloss></sense><sense id="loco_5" guid="580d7fac-c45c-5b34-a6e3-05cff2e5b448"><grammatical-info value="Adjective"/><gloss lang="en"><text>loose (pipe fittings, pulley)</text></gloss></sense><sense id="loco_6" guid="c2214c7a-594b-5cf0-8ea9-92142de35c9b"><grammatical-info value="Adjective"/><gloss lang="en"><text>sexy (only with ser)</text></gloss></sense></entry>
<entry id="locura" guid="2c32517c-d1b7-5e4d-aa75-f1ed463a07e1"><lexical-unit><form lang="es"><text>locura</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="locura_0" guid="e67b16e4-626e-51a0-97d4-ca18efc325ae"><grammatical-info value="Noun"/><gloss lang="en"><text>madness, craziness</text></gloss></sense><sense id="locura_1" guid="d750f0f6-5454-5e77-b4b6-95a630be4641"><grammatical-info value="Noun"/><gloss lang="en"><text>an act of madness (i.e., an act based on a lack of judgement or reasoning; an act causing surprise due to its anomalous nature)</text></gloss></sense><sense id="locura_2" guid="5b9af702-0af2-5a9c-881a-d8b95f292723"><grammatical-info value="Noun"/><gloss lang="en"><text>nuts, crazy, insane (translatable as an interjection)</text></gloss></sense></entry>
