<entry id="requer" guid="60ce7eb1-42a7-51ae-9146-a40ce910dfa5"><lexical-unit><form lang="es"><text>requer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="requer_0" guid="bdbe7ea9-fdde-5e70-9f0e-41d65801b84b"></sense></entry>
<entry id="requerir" guid="c412c77b-2d36-56ac-9b94-a5caf17ac9f5"><lexical-unit><form lang="es"><text>requerir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="requerir_0" guid="c29c47bb-add3-520f-b227-9310e67cd094"><grammatical-info value="Verb"/><gloss lang="en"><text>to require, need</text></gloss></sense><sense id="requerir_1" guid="bc2edbd4-43d4-5034-90a1-7780e2dc0511"><grammatical-info value="Verb"/><gloss lang="en"><text>to ask for, send for, call for</text></gloss></sense></entry>
<entry id="res" guid="a61153cc-f82e-5211-ac88-3e60fc27c7b5"><lexical-unit><form lang="es"><text>res</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="res_0" guid="8218d312-3881-58e8-9c2b-5b547cb6d23d"><grammatical-info value="Noun"/><gloss lang="en"><text>head of quadrupedal livestock or game (e.g. cattle, sheep, deer)</text></gloss></sense><sense id="res_1" guid="1686c10c-8a5c-59a4-8853-f3dcc8c55cb4"><grammatical-info value="Noun"/><gloss lang="en"><text>cattle</text></gloss></sense></entry>
