<entry id="aderezar" guid="aa043a80-713b-5e99-aced-1219d17d7c13"><lexical-unit><form lang="es"><text>aderezar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aderezar_0" guid="ca105e1e-bea4-59ed-a347-11be78a08611"><grammatical-info value="Verb"/><gloss lang="en"><text>to dress, season (for cooking, etc.)</text></gloss></sense><sense id="aderezar_1" guid="98475dd5-bfff-50e3-8b50-35b4a7657c72"><grammatical-info value="Verb"/><gloss lang="en"><text>to spice up, adorn, bedeck</text></gloss></sense><sense id="aderezar_2" guid="d7dc7e26-6019-5802-a487-60e5ce7401f9"><grammatical-info value="Verb"/><gloss lang="en"><text>to address (“to prepare”)</text></gloss></sense><sense id="aderezar_3" guid="4256a4ec-ae29-5630-969f-35f50dc58e6a"><grammatical-info value="Verb"/><gloss lang="en"><text>to address (“to aim”)</text></gloss></sense></entry>
