<entry id="abastecer" guid="a6753adf-83e0-5098-aa0a-edf68337349d"><lexical-unit><form lang="es"><text>abastecer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abastecer_0" guid="082d3b83-70f4-5fec-ad73-fe60745acd76"><grammatical-info value="Verb"/><gloss lang="en"><text>[with de ‘something’] to supply with</text></gloss></sense></entry>
<entry id="abatido" guid="1e152f6f-ddc9-5d31-b4dc-426052808c82"><lexical-unit><form lang="es"><text>abatido</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abatido_0" guid="0f272705-4881-5d12-a2af-0b0dad148877"><grammatical-info value="Verb"/><gloss lang="en"><text>abject, discouraged</text></gloss></sense></entry>
<entry id="abatir" guid="daf89e22-813b-5faf-aa62-1f5f96e74e91"><lexical-unit><form lang="es"><text>abatir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abatir_0" guid="13a86e6a-24ad-5853-953c-315e7a512c76"><grammatical-info value="Verb"/><gloss lang="en"><text>to bring down, to shoot down</text></gloss></sense><sense id="abatir_1" guid="a2495c3c-996f-5064-887a-1674ce18229b"><grammatical-info value="Verb"/><gloss lang="en"><text>to swoop down</text></gloss></sense><sense id="abatir_2" guid="dd90fb25-d2bd-5541-81a5-a12826bc5cda"><grammatical-info value="Verb"/><gloss lang="en"><text>to demolish, to knock down, to defeat</text></gloss></sense><sense id="abatir_3" guid="f37367a6-d30b-5fba-8542-9a9ea331e83d"><grammatical-info value="Verb"/><gloss lang="en"><text>to depress (to make depressed) or discourage</text></gloss></sense><sense id="abatir_4" guid="2cb397ef-0405-581d-a1d5-62d431b74b61"><grammatical-info value="Verb"/><gloss lang="en"><text>to humble</text></gloss></sense></entry>
