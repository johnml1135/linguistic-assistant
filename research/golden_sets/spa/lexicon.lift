<entry id="abominar" guid="a67c6177-20ba-5160-9ba7-af1fd1852f4c"><lexical-unit><form lang="es"><text>abominar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abominar_0" guid="20a47f5b-6d7c-5a54-bf23-3d52ba49e9d5"><grammatical-info value="Verb"/><gloss lang="en"><text>to condemn, denounce</text></gloss></sense><sense id="abominar_1" guid="6f24da6c-7fdc-5167-997a-3ee033ca0afd"><grammatical-info value="Verb"/><gloss lang="en"><text>to abhor</text></gloss></sense></entry>
<entry id="aborrecer" guid="7ca1ce7e-c02f-575a-a14e-89762ba4661a"><lexical-unit><form lang="es"><text>aborrecer</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aborrecer_0" guid="8faad913-2c0e-5db3-834f-c1fc4462d36c"><grammatical-info value="Verb"/><gloss lang="en"><text>to hate, detest, loathe</text></gloss></sense><sense id="aborrecer_1" guid="48221ee4-85c4-51a4-9aba-23feeb8f24de"><grammatical-info value="Verb"/><gloss lang="en"><text>to abandon one's young</text></gloss></sense></entry>
