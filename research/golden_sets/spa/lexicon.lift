<entry id="abel" guid="c47c8afe-7918-5ee5-8a2d-64638b3a2c1d"><lexical-unit><form lang="es"><text>abel</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abel_0" guid="f37a00f5-cbae-5fdc-a60b-56164ac1ac36"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Abel</text></gloss></sense><sense id="abel_1" guid="aa88fbb1-2adf-5a16-9bf8-b42c8ef27bc2"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a male given name, equivalent to English Abel</text></gloss></sense></entry>
<entry id="abertura" guid="8caa676d-736d-59f4-b7a1-ed99277a15db"><lexical-unit><form lang="es"><text>abertura</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abertura_0" guid="d7fdc339-cd26-5439-a986-003cbc66fe99"><grammatical-info value="Noun"/><gloss lang="en"><text>opening (act of opening)</text></gloss></sense><sense id="abertura_1" guid="20d66b96-2ba5-55e3-9a1e-19f8cf9d266a"><grammatical-info value="Noun"/><gloss lang="en"><text>opening (something open)</text></gloss></sense><sense id="abertura_2" guid="2d881f59-6b4f-5576-8c08-f051e90a8705"><grammatical-info value="Noun"/><gloss lang="en"><text>aperture</text></gloss></sense></entry>
<entry id="abierta" guid="477eb96f-36d3-5b3b-b5be-4f5bc0b3014e"><lexical-unit><form lang="es"><text>abierta</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abierta_0" guid="d9f30e31-64bd-5386-993a-3715be83e28b"><grammatical-info value="Adjective"/><gloss lang="en"><text>the act of opening</text></gloss></sense><sense id="abierta_1" guid="47991061-ffc9-5e4a-a4f4-cd01712d1a6b"><grammatical-info value="Adjective"/><gloss lang="en"><text>an opening or aperture</text></gloss></sense></entry>
<entry id="abiertamente" guid="c8846f66-31af-5efc-a7de-6c4591c414ce"><lexical-unit><form lang="es"><text>abiertamente</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abiertamente_0" guid="cda01c20-7369-5452-aac9-d596ff689555"><grammatical-info value="Adverb"/><gloss lang="en"><text>openly, aboveboard</text></gloss></sense><sense id="abiertamente_1" guid="34d4b431-bbef-58f1-b2b9-f0aee6d9ebcd"><grammatical-info value="Adverb"/><gloss lang="en"><text>overtly, blatantly, outright, nakedly, avowedly</text></gloss></sense></entry>
<entry id="abierto" guid="cb93a89e-14b8-5e70-b743-3320651b83d2"><lexical-unit><form lang="es"><text>abierto</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abierto_0" guid="cd0a0a67-6211-538a-bb5b-8329591b5395"><grammatical-info value="Adjective"/><gloss lang="en"><text>open, unlocked (not closed, accessible)</text></gloss></sense><sense id="abierto_1" guid="d4171252-ac97-5a3c-b47d-79148aa201fd"><grammatical-info value="Adjective"/><gloss lang="en"><text>open (actively conducting business)</text></gloss></sense><sense id="abierto_2" guid="6e130e3e-b0f0-53bc-a02b-a294360db359"><grammatical-info value="Adjective"/><gloss lang="en"><text>open, open-minded (receptive)</text></gloss></sense><sense id="abierto_3" guid="4a62e1b7-2698-5c3b-a810-2188b4059a9d"><grammatical-info value="Adjective"/><gloss lang="en"><text>open, overt, outspoken, candid (not subtle in character)</text></gloss></sense><sense id="abierto_4" guid="b5948d45-3c08-5074-954f-06a2848b3526"><grammatical-info value="Adjective"/><gloss lang="en"><text>open-ended (i.e. unrestricted)</text></gloss></sense><sense id="abierto_5" guid="5757b3da-0de7-5630-af97-8cb9b87f38fe"><grammatical-info value="Adjective"/><gloss lang="en"><text>open (uttered with a wide opening of articulators)</text></gloss></sense><sense id="abierto_6" guid="2f07fd7f-5a38-5961-8aa9-9b27fc6c201f"><grammatical-info value="Adjective"/><gloss lang="en"><text>open (event in which anyone can compete)</text></gloss></sense></entry>
<entry id="abismar" guid="e304ae5d-335f-5fe5-b124-04fad53df17a"><lexical-unit><form lang="es"><text>abismar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="abismar_0" guid="6dff1b04-f224-5e98-8ddb-fb7fdab7009b"><grammatical-info value="Verb"/><gloss lang="en"><text>to plunge or sink into</text></gloss></sense><sense id="abismar_1" guid="7aff04c7-6257-5ca6-9743-e2e56c904f9f"><grammatical-info value="Verb"/><gloss lang="en"><text>to confuse</text></gloss></sense><sense id="abismar_2" guid="a012d595-c901-571e-88c8-d9b38b695af3"><grammatical-info value="Verb"/><gloss lang="en"><text>to be amazed</text></gloss></sense></entry>
