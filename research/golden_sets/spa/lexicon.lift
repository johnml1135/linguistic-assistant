<entry id="pecho" guid="1ee6c878-9ad2-5131-a054-08e23e0bb03d"><lexical-unit><form lang="es"><text>pecho</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pecho_0" guid="28e3553c-473c-5a64-9b1d-9b338f1e052d"><grammatical-info value="Noun"/><gloss lang="en"><text>thorax</text></gloss></sense><sense id="pecho_1" guid="81d3d6fa-9c13-5f64-a5a3-6b816f780e57"><grammatical-info value="Noun"/><gloss lang="en"><text>chest; the front of the thorax</text></gloss></sense><sense id="pecho_2" guid="f18c58af-24b3-5ccd-a3f9-2c56a0d00d18"><grammatical-info value="Noun"/><gloss lang="en"><text>breast (of a woman)</text></gloss></sense><sense id="pecho_3" guid="bf6d8841-cab5-5db3-9135-447b2ab6c238"><grammatical-info value="Noun"/><gloss lang="en"><text>breast, heart; seat of the emotions, feelings, etc.</text></gloss></sense><sense id="pecho_4" guid="be6f4ffa-053a-501f-8df6-022c78751977"><grammatical-info value="Noun"/><gloss lang="en"><text>valor, strength, fortitude</text></gloss></sense></entry>
<entry id="pedazo" guid="53d7eed3-ba6d-5517-b23b-4c7da9ec6d70"><lexical-unit><form lang="es"><text>pedazo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pedazo_0" guid="3eadcbc5-8855-51b1-a582-77f89d2da8de"><grammatical-info value="Noun"/><gloss lang="en"><text>piece, chunk, hunk, bit, bite (a part of a larger whole)</text></gloss></sense><sense id="pedazo_1" guid="fa98cc82-257e-5823-b53b-a9d4f33b6b1a"><grammatical-info value="Noun"/><gloss lang="en"><text>patch (e.g. of sky, cloth, skin, space)</text></gloss></sense><sense id="pedazo_2" guid="54d7b041-78e1-5940-87ac-870ce1864ee3"><grammatical-info value="Noun"/><gloss lang="en"><text>scrap (e.g. of paper, information)</text></gloss></sense><sense id="pedazo_3" guid="3dd07255-412e-5de4-9bc5-086c03a2206f"><grammatical-info value="Noun"/><gloss lang="en"><text>lump (e.g. of metal, rock, clay, wood)</text></gloss></sense><sense id="pedazo_4" guid="9d737efc-6fce-5754-9a2c-2ffa73a61481"><grammatical-info value="Noun"/><gloss lang="en"><text>slab (e.g. of meat, of cheese)</text></gloss></sense><sense id="pedazo_5" guid="925fa5fb-81cf-5b4f-ba59-e8e79f7e1753"><grammatical-info value="Noun"/><gloss lang="en"><text>shard (e.g. of glass, ice)</text></gloss></sense><sense id="pedazo_6" guid="49bead29-92dc-5efd-ba09-7524a0628874"><grammatical-info value="Noun"/><gloss lang="en"><text>augmentative of pedo</text></gloss></sense></entry>
