<entry id="tiempo" guid="bea2d621-a6c3-5084-b759-e4dc0872fe6a"><lexical-unit><form lang="es"><text>tiempo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tiempo_0" guid="5bfc2b1a-02f9-559e-be29-d1a4a973deb3"><grammatical-info value="Noun"/><gloss lang="en"><text>time</text></gloss></sense><sense id="tiempo_1" guid="198d11fc-8348-509d-ad1e-8a47d149d435"><grammatical-info value="Noun"/><gloss lang="en"><text>a while, period of time, long time, length of time, indeterminate amount of time</text></gloss></sense><sense id="tiempo_2" guid="68efd0b8-ce97-5e86-a371-87296e9a07d6"><grammatical-info value="Noun"/><gloss lang="en"><text>tense</text></gloss></sense><sense id="tiempo_3" guid="9007215b-39ab-5757-8fc3-927f6fe8a2f0"><grammatical-info value="Noun"/><gloss lang="en"><text>weather (the short-term state of the atmosphere at a specific time and place, including the temperature, relative humidity, cloud cover, precipitation, wind, etc)</text></gloss></sense></entry>
