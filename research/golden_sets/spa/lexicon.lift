<entry id="qu" guid="2a8ff89d-05bf-5094-a761-dd0104aa76d2"><lexical-unit><form lang="es"><text>qu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="qu_0" guid="f4780b2f-8fd9-58e3-8158-e4df74832e11"><grammatical-info value="Noun"/><gloss lang="en"><text>a digraph from the letters q and u</text></gloss></sense><sense id="qu_1" guid="5efdc0b1-8fa8-5d44-b4a2-52c526b67029"><grammatical-info value="Noun"/><gloss lang="en"><text>a digraph from the letters Q and U</text></gloss></sense></entry>
<entry id="que" guid="b0ee9130-51a8-52ab-adea-63a8b980979a"><lexical-unit><form lang="es"><text>que</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="que_0" guid="fafbb7c8-4d79-51b6-8dee-973bbf533cdf"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>that</text></gloss></sense><sense id="que_1" guid="671e470c-efdc-55ba-ba94-11cb2db6469e"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>than</text></gloss></sense><sense id="que_2" guid="c3f1281e-3090-5ed4-8607-bbd76c11c3b6"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>indicates reason; because, for</text></gloss></sense><sense id="que_3" guid="5a47d73b-7c72-5eef-afe0-afb8e48f2af3"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>indicates desire or permission; may</text></gloss></sense><sense id="que_4" guid="ac3f861f-1360-56f2-b28c-db1b27720ae9"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>indicates emphasis or repetitive answer</text></gloss></sense><sense id="que_5" guid="2566f9d3-28c7-5f0a-80c6-d192589c23f3"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>who; that</text></gloss></sense><sense id="que_6" guid="497081f5-5fc7-5bfb-8c43-d6dc1cb80b77"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>that; whom; which</text></gloss></sense></entry>
<entry id="quebrada" guid="62cf6e1a-05e3-5f79-acc5-1eeaee4f1648"><lexical-unit><form lang="es"><text>quebrada</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="quebrada_0" guid="730b1e98-74c4-51f4-aeac-815e4c103990"><grammatical-info value="Noun"/><gloss lang="en"><text>gorge, ravine</text></gloss></sense></entry>
<entry id="quebrantado" guid="fd4f4e10-0ed7-561d-9b41-b512edc62f4c"><lexical-unit><form lang="es"><text>quebrantado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="quebrantado_0" guid="8347e471-3dbe-5d5a-a839-923aab2c18f0"><grammatical-info value="Verb"/><gloss lang="en"><text>broken, shattered (often figuratively)</text></gloss></sense><sense id="quebrantado_1" guid="0dac2dd6-45fc-542f-8d0f-20e7f23817f0"><grammatical-info value="Verb"/><gloss lang="en"><text>downbeat</text></gloss></sense><sense id="quebrantado_2" guid="34d35c67-ce32-5825-a305-fa890cafdbf2"><grammatical-info value="Verb"/><gloss lang="en"><text>broken-hearted</text></gloss></sense></entry>
<entry id="quebrantamiento" guid="98893112-3b13-515f-8c12-87919458fced"><lexical-unit><form lang="es"><text>quebrantamiento</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="quebrantamiento_0" guid="ad7a4e9e-7bde-5b2d-8942-cf39caca9b88"><grammatical-info value="Noun"/><gloss lang="en"><text>brokenness, weakening</text></gloss></sense><sense id="quebrantamiento_1" guid="57dc139d-f59f-59c3-8cec-43626fb4d3d9"><grammatical-info value="Noun"/><gloss lang="en"><text>breaking, violation (e.g. of law or rules, of a covenant or pact)</text></gloss></sense><sense id="quebrantamiento_2" guid="4a0bbde4-96c7-52a3-b7fd-425595d0d8ee"><grammatical-info value="Noun"/><gloss lang="en"><text>breach, breaching (i.e. failure to perform some obligation)</text></gloss></sense><sense id="quebrantamiento_3" guid="b933f976-134b-56a8-8d0d-641957f32083"><grammatical-info value="Noun"/><gloss lang="en"><text>breakdown, disruption (of established social order)</text></gloss></sense><sense id="quebrantamiento_4" guid="b8941938-6df8-5230-8639-1ce91b5c708d"><grammatical-info value="Noun"/><gloss lang="en"><text>destruction</text></gloss></sense></entry>
<entry id="quebrantar" guid="2ec49d1f-435c-5f2c-81d5-62d4323421ab"><lexical-unit><form lang="es"><text>quebrantar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="quebrantar_0" guid="e4f769c6-41a8-569f-b260-1bdc610f9829"><grammatical-info value="Verb"/><gloss lang="en"><text>to break (physically)</text></gloss></sense><sense id="quebrantar_1" guid="f4f39d60-18e9-556f-b25a-2cae4c02453f"><grammatical-info value="Verb"/><gloss lang="en"><text>to break (e.g. someone's spirit, one's faith or trust, one's power)</text></gloss></sense><sense id="quebrantar_2" guid="99bd75da-41ad-516b-803a-cd5e4230f141"><grammatical-info value="Verb"/><gloss lang="en"><text>to break, to breach (e.g. peace, the rules, a policy, a principle)</text></gloss></sense><sense id="quebrantar_3" guid="2450048a-3b25-5c08-95bb-1e69d76d044d"><grammatical-info value="Verb"/><gloss lang="en"><text>to break down, to be broken (typically used figuratively)</text></gloss></sense></entry>
<entry id="quebrar" guid="cf34e3cf-ecc2-57f5-a9a6-7ed1f58bbd54"><lexical-unit><form lang="es"><text>quebrar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="quebrar_0" guid="36bb0267-c2e7-50c1-b86c-66ee1a548080"><grammatical-info value="Verb"/><gloss lang="en"><text>to break, to snap, to shatter (to smash or rupture)</text></gloss></sense><sense id="quebrar_1" guid="2122ee4f-bed8-5790-bacd-117434336567"><grammatical-info value="Verb"/><gloss lang="en"><text>to break (often in legal contexts), violate a law</text></gloss></sense><sense id="quebrar_2" guid="17597260-cc98-5e9c-8676-d09dd9e4d72c"><grammatical-info value="Verb"/><gloss lang="en"><text>to bend, flex or twist</text></gloss></sense><sense id="quebrar_3" guid="33c79f3e-d6e8-52d8-9984-ed63b2c7ddf6"><grammatical-info value="Verb"/><gloss lang="en"><text>to fail; to go broke; to become bankrupt; to go out of business; to crash, to go bust, to go under (used in political, economic and business/financial/investment contexts)</text></gloss></sense><sense id="quebrar_4" guid="8ef607b8-f49d-5f8e-9a93-3a993869ca55"><grammatical-info value="Verb"/><gloss lang="en"><text>to break up</text></gloss></sense><sense id="quebrar_5" guid="1d5b3f89-6228-5e2c-b96f-089b3d8ef3f1"><grammatical-info value="Verb"/><gloss lang="en"><text>to kill</text></gloss></sense><sense id="quebrar_6" guid="a984bc3b-a48c-526e-be58-6b7ed163e822"><grammatical-info value="Verb"/><gloss lang="en"><text>to crack, to break, to shatter (putting the onus on the thing cracking itself, absolving any sentient subject of responsibility)</text></gloss></sense><sense id="quebrar_7" guid="f6ec0d54-cb58-5fd5-a830-cbbbbf308226"><grammatical-info value="Verb"/><gloss lang="en"><text>to crack, to break (e.g. crack under pressure, break after interrogation)</text></gloss></sense></entry>
<entry id="queda" guid="f21118c2-62b5-533d-b70e-6123a69063cf"><lexical-unit><form lang="es"><text>queda</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="queda_0" guid="cc4b846c-78b5-561a-90c2-e7c52266b3fe"><grammatical-info value="Verb"/><gloss lang="en"><text>curfew</text></gloss></sense></entry>
<entry id="quedar" guid="da636ed7-38dc-5a42-9f19-fe1afac04a9d"><lexical-unit><form lang="es"><text>quedar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="quedar_0" guid="e2f0f9bb-0113-538d-83f7-287c1a65dfa4"><grammatical-info value="Verb"/><gloss lang="en"><text>to be (as a result of something), to end up</text></gloss></sense><sense id="quedar_1" guid="52fcb217-2d68-5fef-9aec-6ab4a6e32506"><grammatical-info value="Verb"/><gloss lang="en"><text>to be situated; to be located (used with only static objects, such as buildings)</text></gloss></sense><sense id="quedar_2" guid="de3b2c3f-c1b5-515a-9b44-f7efd8a06178"><grammatical-info value="Verb"/><gloss lang="en"><text>to be left; to remain</text></gloss></sense><sense id="quedar_3" guid="2dabca97-14ba-5d1e-8711-6b665148c5c7"><grammatical-info value="Verb"/><gloss lang="en"><text>to fit, to suit; to look good (clothes)</text></gloss></sense><sense id="quedar_4" guid="9de86750-37bd-51bf-883a-34423f559b93"><grammatical-info value="Verb"/><gloss lang="en"><text>to turn out, e.g. well or poorly</text></gloss></sense><sense id="quedar_5" guid="7358a8fa-28d1-5067-99c1-5a567741b2f1"><grammatical-info value="Verb"/><gloss lang="en"><text>to agree on</text></gloss></sense><sense id="quedar_6" guid="25f340de-63db-5612-87c7-b99864e3246c"><grammatical-info value="Verb"/><gloss lang="en"><text>to agree to meet up with someone</text></gloss></sense><sense id="quedar_7" guid="467b8022-26c6-5800-a2ab-250a29fd2082"><grammatical-info value="Verb"/><gloss lang="en"><text>to die</text></gloss></sense></entry>
<entry id="quejar" guid="ef023480-41f9-552e-abba-9680d4cbab3a"><lexical-unit><form lang="es"><text>quejar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="quejar_0" guid="662a7647-9a28-5b8e-9ad7-b83aa8dd96bf"><grammatical-info value="Verb"/><gloss lang="en"><text>to afflict</text></gloss></sense><sense id="quejar_1" guid="958c76e0-95c9-5e4c-a819-30b646542260"><grammatical-info value="Verb"/><gloss lang="en"><text>to complain</text></gloss></sense></entry>
<entry id="quema" guid="8508028f-50c2-5eb1-b805-f04614821471"><lexical-unit><form lang="es"><text>quema</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="quema_0" guid="f09e9daf-4b1a-5367-aa19-b781efb12692"><grammatical-info value="Verb"/><gloss lang="en"><text>fire; flame</text></gloss></sense><sense id="quema_1" guid="90d48568-283f-5aa5-9089-49b6090a9a42"><grammatical-info value="Verb"/><gloss lang="en"><text>burning</text></gloss></sense></entry>
