<entry id="encargar" guid="e7d7c4de-5d09-5180-b4a6-70f687e4c6ef"><lexical-unit><form lang="es"><text>encargar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="encargar_0" guid="fa9cc12f-26f2-515a-a6a2-d7c4523fc107"><grammatical-info value="Verb"/><gloss lang="en"><text>to entrust</text></gloss></sense><sense id="encargar_1" guid="149c4ca5-437f-57ff-b924-fbd70412bd42"><grammatical-info value="Verb"/><gloss lang="en"><text>to order (goods)</text></gloss></sense><sense id="encargar_2" guid="a26012b4-ad83-5c9b-b4e6-87ca35aaaab0"><grammatical-info value="Verb"/><gloss lang="en"><text>to handle, take care of, to deal with, to take charge of something</text></gloss></sense></entry>
<entry id="encargo" guid="56bcf3c1-75d3-5481-bde2-69a4bb80b406"><lexical-unit><form lang="es"><text>encargo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="encargo_0" guid="e0aac6fe-3ac4-5c09-8e48-fb1cb78a6f5f"><grammatical-info value="Noun"/><gloss lang="en"><text>order (a product that is ordered)</text></gloss></sense><sense id="encargo_1" guid="d74497ab-ef66-57f5-a93b-cb7022bdf23d"><grammatical-info value="Noun"/><gloss lang="en"><text>errand, task</text></gloss></sense><sense id="encargo_2" guid="a636feb3-9846-56ae-ba9a-edb9ee05728d"><grammatical-info value="Noun"/><gloss lang="en"><text>commission, assignment, job (an order at work from one's boss)</text></gloss></sense></entry>
<entry id="encender" guid="5fc514ea-5dc0-57a2-a570-86d984215097"><lexical-unit><form lang="es"><text>encender</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="encender_0" guid="202fb4ea-7b85-56c9-b300-632528590b35"><grammatical-info value="Verb"/><gloss lang="en"><text>to light, ignite</text></gloss></sense><sense id="encender_1" guid="fe892b58-ebe4-575f-8fd0-29fcd484450a"><grammatical-info value="Verb"/><gloss lang="en"><text>to turn on, switch on, power up</text></gloss></sense><sense id="encender_2" guid="aab4c4e7-c58d-5cb2-88ae-38ae0bc9d494"><grammatical-info value="Verb"/><gloss lang="en"><text>to burn, have a burning sensation</text></gloss></sense></entry>
<entry id="encendido" guid="f21f4984-7846-5ca5-af5c-bc7ce6f947cf"><lexical-unit><form lang="es"><text>encendido</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="encendido_0" guid="abe86833-9ed6-585c-952d-21022ad095fd"><grammatical-info value="Noun"/><gloss lang="en"><text>on, activated</text></gloss></sense><sense id="encendido_1" guid="c5c56b38-9c67-5403-a1f3-6c3fdf227051"><grammatical-info value="Noun"/><gloss lang="en"><text>burning</text></gloss></sense><sense id="encendido_2" guid="2e02bf69-5dde-5844-95b6-e85f12408b64"><grammatical-info value="Noun"/><gloss lang="en"><text>passionate</text></gloss></sense><sense id="encendido_3" guid="c9888d73-0a39-5f7e-99ac-e8c7fb814f74"><grammatical-info value="Noun"/><gloss lang="en"><text>turned on, switched on</text></gloss></sense><sense id="encendido_4" guid="73f86c74-6cff-5845-b1fc-350bb7df8d04"><grammatical-info value="Noun"/><gloss lang="en"><text>ignition (of a car)</text></gloss></sense></entry>
<entry id="encerrado" guid="343b6301-b989-5257-bf90-cf1f5b8ffd68"><lexical-unit><form lang="es"><text>encerrado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="encerrado_0" guid="60c0e7a2-2bea-54bf-ab68-33319d894056"><grammatical-info value="Verb"/><gloss lang="en"><text>pent, shut-in, cooped up, locked up, locked down confined, holed up, shut away</text></gloss></sense><sense id="encerrado_1" guid="524f6e24-fa20-5416-960f-2628ce103430"><grammatical-info value="Verb"/><gloss lang="en"><text>stuck, trapped (e.g. stuck in a room, office, elevator, etc.)</text></gloss></sense><sense id="encerrado_2" guid="2e9c2d9f-9b93-553a-afaa-a9219444aa6b"><grammatical-info value="Verb"/><gloss lang="en"><text>encased, enclosed, closed in, sealed</text></gloss></sense><sense id="encerrado_3" guid="c31ef9ae-9730-5fcc-88f6-8bdc0e1a8a91"><grammatical-info value="Verb"/><gloss lang="en"><text>no longer available, discontinued</text></gloss></sense></entry>
<entry id="encerrar" guid="ea96dbbf-c063-59d6-828a-304b32ac6efd"><lexical-unit><form lang="es"><text>encerrar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="encerrar_0" guid="1045b43f-d0d8-59e6-95fe-eb84da063313"><grammatical-info value="Verb"/><gloss lang="en"><text>to lock up, to coop up</text></gloss></sense><sense id="encerrar_1" guid="8a15910d-4f91-5b77-8b11-1fc99d2f910e"><grammatical-info value="Verb"/><gloss lang="en"><text>to lock away, put away, to imprison, to nail (in a prison or mental hospital)</text></gloss></sense><sense id="encerrar_2" guid="897f6cd4-62bd-5cf8-b661-e90ef068493e"><grammatical-info value="Verb"/><gloss lang="en"><text>to enclose, to confine, to immure</text></gloss></sense><sense id="encerrar_3" guid="39258314-def0-537e-93f9-b72b5d41549a"><grammatical-info value="Verb"/><gloss lang="en"><text>to contain, to hold, to include, to encapsulate, to entail</text></gloss></sense><sense id="encerrar_4" guid="f1c235dd-b7ec-5eb6-893a-b710308b51c8"><grammatical-info value="Verb"/><gloss lang="en"><text>to stalemate</text></gloss></sense><sense id="encerrar_5" guid="b4a1757e-bf75-59b8-ace0-30e9618ebb70"><grammatical-info value="Verb"/><gloss lang="en"><text>to separate (between brackets, commas)</text></gloss></sense><sense id="encerrar_6" guid="3b1685b6-0851-58fb-b603-9e1ad304f01e"><grammatical-info value="Verb"/><gloss lang="en"><text>to take over; occupy (a building)</text></gloss></sense><sense id="encerrar_7" guid="a72a526d-c215-54f1-a71c-724e7704a90b"><grammatical-info value="Verb"/><gloss lang="en"><text>to shut oneself up, to withdraw, to shut away oneself, to shut off oneself, to lock up or lock down oneself, to close off oneself</text></gloss></sense></entry>
<entry id="encimar" guid="29f6b8a4-79a9-5aeb-9f0b-9c9a3b81d1bb"><lexical-unit><form lang="es"><text>encimar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="encimar_0" guid="8de5e05a-a110-5be5-b45c-d0da3523cf94"><grammatical-info value="Verb"/><gloss lang="en"><text>to put up; to store high up</text></gloss></sense><sense id="encimar_1" guid="63c9dc94-8fd5-5559-af6f-221f38220787"><grammatical-info value="Verb"/><gloss lang="en"><text>to raise the stakes</text></gloss></sense><sense id="encimar_2" guid="4ca8e10b-fb0e-55e7-b6ad-f634a291c47e"><grammatical-info value="Verb"/><gloss lang="en"><text>to lie above; to be situated above</text></gloss></sense></entry>
