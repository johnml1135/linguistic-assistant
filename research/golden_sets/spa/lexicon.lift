<entry id="bueno" guid="8572b4a4-d7ea-5c62-9f5b-f722fdc0ceb1"><lexical-unit><form lang="es"><text>bueno</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bueno_0" guid="29d1c95d-5444-5daa-a89a-a7c15895794b"><grammatical-info value="Adjective"/><gloss lang="en"><text>good</text></gloss></sense><sense id="bueno_1" guid="3e950fe0-9d94-5d19-9771-095802e0292c"><grammatical-info value="Adjective"/><gloss lang="en"><text>fine</text></gloss></sense><sense id="bueno_2" guid="8d78b89b-45f4-510e-8bb0-ede20621ce5b"><grammatical-info value="Adjective"/><gloss lang="en"><text>okay; fine</text></gloss></sense><sense id="bueno_3" guid="4a0da46e-8562-56d5-8cd8-0a3737e4fe22"><grammatical-info value="Adjective"/><gloss lang="en"><text>well; a short pause in a sentence</text></gloss></sense><sense id="bueno_4" guid="5f73ccb0-eda3-581d-be31-757659137789"><grammatical-info value="Adjective"/><gloss lang="en"><text>expression used when answering the phone, often with the pronunciation /bweˈno/, rather than /ˈbweno/</text></gloss></sense><sense id="bueno_5" guid="a77c8017-466d-515e-84d8-ed1d009d6560"><grammatical-info value="Adjective"/><gloss lang="en"><text>Said when one is about to say goodbye/end a conversation.</text></gloss></sense><sense id="bueno_6" guid="7864aff2-f448-5790-86a3-2cd1d0f8b6c8"><grammatical-info value="Adjective"/><gloss lang="en"><text>hello</text></gloss></sense><sense id="bueno_7" guid="ca7979df-985b-513e-8d92-74f8bf96a8fa"><grammatical-info value="Adjective"/><gloss lang="en"><text>a surname</text></gloss></sense></entry>
<entry id="buey" guid="2e6c0e87-fd8e-5cf6-8949-870548136153"><lexical-unit><form lang="es"><text>buey</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="buey_0" guid="5dc78893-911a-5df4-bd9f-2cfa8e0289a3"><grammatical-info value="Noun"/><gloss lang="en"><text>ox, bullock, steer</text></gloss></sense><sense id="buey_1" guid="9e6d3c37-f13e-59c5-b216-d4f2a68fefe0"><grammatical-info value="Noun"/><gloss lang="en"><text>guy, dumb, dude (depends on context and intonation, also denotes surprise, colloquially pronounced güey)</text></gloss></sense><sense id="buey_2" guid="5c04c4d9-1e9c-5aee-8153-8883c60f07bb"><grammatical-info value="Noun"/><gloss lang="en"><text>cuckold</text></gloss></sense><sense id="buey_3" guid="5d90f10b-fc18-5523-9fd4-cc754a73d464"><grammatical-info value="Noun"/><gloss lang="en"><text>packet, arm and a leg (large amount of money)</text></gloss></sense></entry>
<entry id="bull" guid="2e73da84-e5d3-5fa8-85ce-e88ac8c820f2"><lexical-unit><form lang="es"><text>bull</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bull_0" guid="264574e4-1fda-5798-a5ba-5eb26cfcc0ef"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="bullicio" guid="acf67cbb-e2b8-5cff-b788-6469c61f2910"><lexical-unit><form lang="es"><text>bullicio</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bullicio_0" guid="01368947-e080-5eba-9c1e-c9321853375b"><grammatical-info value="Noun"/><gloss lang="en"><text>racket, clamor</text></gloss></sense></entry>
<entry id="bullir" guid="c25e8fa5-c1f9-52f7-b737-2023eb3436cf"><lexical-unit><form lang="es"><text>bullir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bullir_0" guid="9cdcb544-d55c-50b6-bd86-61e21e5bd410"><grammatical-info value="Verb"/><gloss lang="en"><text>to boil (to begin to turn into a gas)</text></gloss></sense><sense id="bullir_1" guid="c1ccb3ce-933c-5f04-bbfd-9e4759ffa386"><grammatical-info value="Verb"/><gloss lang="en"><text>to boil, to bubble, to churn (to be agitated like boiling water; to bubble; to effervesce)</text></gloss></sense><sense id="bullir_2" guid="cd57503b-fe1d-5520-b05d-a4bfc7020924"><grammatical-info value="Verb"/><gloss lang="en"><text>to bustle (to move busily and energetically)</text></gloss></sense><sense id="bullir_3" guid="4ba7d400-a658-5c7b-86a2-d1748049ea4e"><grammatical-info value="Verb"/><gloss lang="en"><text>to bubble, to bubble up, to well up (to churn or foment, as if wishing to rise to the surface)</text></gloss></sense><sense id="bullir_4" guid="2215b0fd-b69c-5196-ae08-5faa6fce6d59"><grammatical-info value="Verb"/><gloss lang="en"><text>to teem, to abound</text></gloss></sense><sense id="bullir_5" guid="4383b7c2-d704-5ede-b460-4a323512b29c"><grammatical-info value="Verb"/><gloss lang="en"><text>to move, to budge (part of one's body)</text></gloss></sense></entry>
<entry id="burla" guid="71aeb46c-0336-5d19-9472-55b2270d9f52"><lexical-unit><form lang="es"><text>burla</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="burla_0" guid="a202f50a-885e-5672-a574-f5bdaf487a32"><grammatical-info value="Noun"/><gloss lang="en"><text>mockery, taunt, ridicule</text></gloss></sense><sense id="burla_1" guid="e2a0356d-f361-5617-b360-5597fc00f2bb"><grammatical-info value="Noun"/><gloss lang="en"><text>prank</text></gloss></sense></entry>
<entry id="burlador" guid="7a12da90-3593-5e6e-abc9-e66b70f832a3"><lexical-unit><form lang="es"><text>burlador</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="burlador_0" guid="487ebc04-c609-5732-8128-0690cf9d36c8"><grammatical-info value="Proper noun"/><gloss lang="en"><text>teasing</text></gloss></sense><sense id="burlador_1" guid="97bd51a3-3593-515b-9e9d-c229a2752cbc"><grammatical-info value="Proper noun"/><gloss lang="en"><text>libertine (man with loose morals)</text></gloss></sense><sense id="burlador_2" guid="662626aa-e701-5306-a854-4a8d6459dad1"><grammatical-info value="Proper noun"/><gloss lang="en"><text>joker; teaser</text></gloss></sense></entry>
<entry id="burlar" guid="2a504685-90af-5f4a-9573-83c7494df1ad"><lexical-unit><form lang="es"><text>burlar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="burlar_0" guid="17098340-e242-53ba-be16-1b41a0290d08"><grammatical-info value="Verb"/><gloss lang="en"><text>to outwit, to outsmart, to circumvent, to trick, to deceive</text></gloss></sense><sense id="burlar_1" guid="5b04f29c-b7eb-5b54-8961-29a4a01c1327"><grammatical-info value="Verb"/><gloss lang="en"><text>to circumvent, to evade, to cheat</text></gloss></sense><sense id="burlar_2" guid="9fb3ecdb-2c70-53fb-a799-db42e45718a2"><grammatical-info value="Verb"/><gloss lang="en"><text>to make fun of, to poke fun at, to mock, to ridicule, to jeer (+ de)</text></gloss></sense><sense id="burlar_3" guid="3d8c3da2-b697-5c7e-bae2-f1a06b0e805e"><grammatical-info value="Verb"/><gloss lang="en"><text>to taunt, to tease (often uses de)</text></gloss></sense><sense id="burlar_4" guid="9831ddfc-6020-5f3e-abbb-5a7fb970f84e"><grammatical-info value="Verb"/><gloss lang="en"><text>to scoff, to scoff at (+ de)</text></gloss></sense><sense id="burlar_5" guid="0e42a672-0b27-5844-9a2c-c917053be458"><grammatical-info value="Verb"/><gloss lang="en"><text>to deceive oneself (+ de)</text></gloss></sense></entry>
<entry id="bus" guid="2ec9cd32-b953-51c3-8dbf-7a6c6fc2dcbe"><lexical-unit><form lang="es"><text>bus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bus_0" guid="d1d751bb-8511-5fbb-9e80-aa25ea9f0626"><grammatical-info value="Noun"/><gloss lang="en"><text>clipping of autobús; bus</text></gloss></sense><sense id="bus_1" guid="cfac0d74-96d9-5a54-953c-b09a285b33a5"><grammatical-info value="Noun"/><gloss lang="en"><text>bus</text></gloss></sense></entry>
<entry id="busca" guid="2b731774-4472-5b2d-bed4-c4b7cda29e3e"><lexical-unit><form lang="es"><text>busca</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="busca_0" guid="23aebe30-f42c-5d1d-8ee0-4b4f0b0e7d9d"><grammatical-info value="Verb"/><gloss lang="en"><text>search (an attempt to find something)</text></gloss></sense><sense id="busca_1" guid="c59213d0-ed42-546b-b41c-7247f6316738"><grammatical-info value="Verb"/><gloss lang="en"><text>pager (a wireless telecommunications device that receives text or voice messages)</text></gloss></sense></entry>
<entry id="buscar" guid="55286577-4513-5660-a07a-2907c60a47a6"><lexical-unit><form lang="es"><text>buscar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="buscar_0" guid="d81139b6-2145-51ec-9b18-5bd5aebdcf76"><grammatical-info value="Verb"/><gloss lang="en"><text>to seek, search for, look for, try to find, to scour</text></gloss></sense><sense id="buscar_1" guid="24e22be2-254d-5c11-ad97-8c1094378344"><grammatical-info value="Verb"/><gloss lang="en"><text>to look up (in a search engine, dictionary, etc.)</text></gloss></sense><sense id="buscar_2" guid="8f54737e-924b-5835-856b-fbeee6f0aca7"><grammatical-info value="Verb"/><gloss lang="en"><text>to fetch, get, pick up</text></gloss></sense><sense id="buscar_3" guid="be776370-63f4-57e9-9d4a-118aabe95254"><grammatical-info value="Verb"/><gloss lang="en"><text>to bring on (oneself), to ask for</text></gloss></sense></entry>
<entry id="báculo" guid="4c9bb5f8-ef12-5b65-a320-bb5129895dad"><lexical-unit><form lang="es"><text>báculo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="báculo_0" guid="3358a07d-8749-5d82-8c55-1fb97a889c22"><grammatical-info value="Noun"/><gloss lang="en"><text>staff (long, straight stick, especially one used to assist in walking)</text></gloss></sense></entry>
<entry id="bárbaro" guid="b9334dc3-f2c8-5ce4-b72b-429a83f83c93"><lexical-unit><form lang="es"><text>bárbaro</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bárbaro_0" guid="9a869350-6ffa-5278-a67a-a0777af9324f"><grammatical-info value="Adjective"/><gloss lang="en"><text>barbaric</text></gloss></sense><sense id="bárbaro_1" guid="ea710120-21ea-5d9d-9dd9-1761826cb934"><grammatical-info value="Adjective"/><gloss lang="en"><text>enormous</text></gloss></sense><sense id="bárbaro_2" guid="d4b2cae2-b971-5c6e-b077-2eecfd61d9af"><grammatical-info value="Adjective"/><gloss lang="en"><text>stupendous</text></gloss></sense><sense id="bárbaro_3" guid="4c2a1195-a46e-5652-9258-f7db2ea2f9b9"><grammatical-info value="Adjective"/><gloss lang="en"><text>cool</text></gloss></sense><sense id="bárbaro_4" guid="d9fd1bc3-0e40-5b9b-a92b-b344ef5f3df3"><grammatical-info value="Adjective"/><gloss lang="en"><text>barbarian</text></gloss></sense></entry>
<entry id="ca" guid="e73ac3a2-06c5-51a6-8d7c-b415a62fcbb3"><lexical-unit><form lang="es"><text>ca</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ca_0" guid="d08667f9-ea45-5be9-8480-72b1c1367f54"><grammatical-info value="Noun"/><gloss lang="en"><text>initialism of corriente alterna (“AC or alternating current”)</text></gloss></sense><sense id="ca_1" guid="2a8f512b-b5b4-55b2-b6e2-884a30685a2f"><grammatical-info value="Noun"/><gloss lang="en"><text>initialism of comunidad autónoma</text></gloss></sense><sense id="ca_2" guid="fa6a5d32-75fe-5094-a525-43ae311f7041"><grammatical-info value="Noun"/><gloss lang="en"><text>initialism of centro de alumnos</text></gloss></sense><sense id="ca_3" guid="c82b5574-6346-5306-a9d3-03b414c03cb8"><grammatical-info value="Noun"/><gloss lang="en"><text>because</text></gloss></sense><sense id="ca_4" guid="2efc3466-4804-5645-bf69-590d828bb0be"><grammatical-info value="Noun"/><gloss lang="en"><text>Denotes incredulity or negation; oh no!</text></gloss></sense><sense id="ca_5" guid="d14a749c-833b-5dc3-b05f-5cb60d6b3189"><grammatical-info value="Noun"/><gloss lang="en"><text>house</text></gloss></sense></entry>
<entry id="caba" guid="16badf0a-e263-518d-98b6-a6252a67487d"><lexical-unit><form lang="es"><text>caba</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="caba_0" guid="7d1edba6-fe7f-55b8-9cd1-7991a8c4fb5b"><grammatical-info value="Proper noun"/><gloss lang="en"><text>acronym of Ciudad Autónoma de Buenos Aires, the official name of Buenos Aires</text></gloss></sense></entry>
<entry id="cabal" guid="03b69576-c8ad-51c0-907c-27a02c0cce47"><lexical-unit><form lang="es"><text>cabal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cabal_0" guid="bde32584-c2dc-5cb4-a257-2ed534f1ac7d"><grammatical-info value="Adjective"/><gloss lang="en"><text>upright, honest</text></gloss></sense><sense id="cabal_1" guid="c87aa4e9-74c3-5394-a8ef-5e531bbb6b0b"><grammatical-info value="Adjective"/><gloss lang="en"><text>exact</text></gloss></sense><sense id="cabal_2" guid="cd764977-2e5d-5b6a-aea8-07a4dc2900d8"><grammatical-info value="Adjective"/><gloss lang="en"><text>complete, entire, full</text></gloss></sense><sense id="cabal_3" guid="e43fb1aa-2b68-5b1c-a4cd-fc04ff50d4ec"><grammatical-info value="Adjective"/><gloss lang="en"><text>exactly, exact, yes</text></gloss></sense></entry>
<entry id="cabales" guid="800f23e5-4d2a-5517-aa00-2916486ea5b5"><lexical-unit><form lang="es"><text>cabales</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cabales_0" guid="602da406-39cf-5fb5-ac16-a7df282b0ce4"><grammatical-info value="Noun"/><gloss lang="en"><text>normal mental state; right mind</text></gloss></sense></entry>
<entry id="cabalgadura" guid="c1067320-b297-5d91-8d55-53e4eebcaaa6"><lexical-unit><form lang="es"><text>cabalgadura</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cabalgadura_0" guid="73ba0171-c55c-5943-b432-edd45f1dbbed"><grammatical-info value="Noun"/><gloss lang="en"><text>mount (animal that is ridden on)</text></gloss></sense></entry>
<entry id="caballo" guid="526b31b9-24c2-53f7-ab0d-8729e2f54954"><lexical-unit><form lang="es"><text>caballo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="caballo_0" guid="25786371-f6dc-5e86-9ae9-51816b03e8ff"><grammatical-info value="Noun"/><gloss lang="en"><text>horse</text></gloss></sense><sense id="caballo_1" guid="825c890b-2f12-52bd-9e0b-e524ac0cd94c"><grammatical-info value="Noun"/><gloss lang="en"><text>knight</text></gloss></sense><sense id="caballo_2" guid="7c91d34c-6fd0-5200-95be-771690bcdad5"><grammatical-info value="Noun"/><gloss lang="en"><text>heroin</text></gloss></sense><sense id="caballo_3" guid="4a8531aa-598c-5cff-87bb-4e551eb6ec0e"><grammatical-info value="Noun"/><gloss lang="en"><text>master, hotshot</text></gloss></sense></entry>
<entry id="cabaña" guid="b2d08466-6b56-5c07-89ff-bd9447e75d85"><lexical-unit><form lang="es"><text>cabaña</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cabaña_0" guid="8b7bd3b5-bc92-5e6a-a2bd-9873716b9632"><grammatical-info value="Noun"/><gloss lang="en"><text>cabin, cottage, hut</text></gloss></sense><sense id="cabaña_1" guid="0247925a-bead-5ab4-9037-27479401c290"><grammatical-info value="Noun"/><gloss lang="en"><text>all the livestock of a farm, ranch, region, or country</text></gloss></sense></entry>
<entry id="cabe" guid="a54aa349-6706-51af-b0c7-36e22af0959b"><lexical-unit><form lang="es"><text>cabe</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cabe_0" guid="acdbb8f1-202f-5261-b0e5-c54f8d807e18"><grammatical-info value="Verb"/><gloss lang="en"><text>alongside, beside, next to</text></gloss></sense></entry>
<entry id="cabecear" guid="39f95e49-762d-5bd3-b073-5a8966ef135d"><lexical-unit><form lang="es"><text>cabecear</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cabecear_0" guid="0b1f69ab-c0b5-5941-b1d8-61bad0f9aa7f"><grammatical-info value="Verb"/><gloss lang="en"><text>to shake (one's head, especially in disagreement)</text></gloss></sense><sense id="cabecear_1" guid="caa537cd-8863-553c-a2ea-682e93f77626"><grammatical-info value="Verb"/><gloss lang="en"><text>to nod (as one gradually falls to sleep while seated or standing)</text></gloss></sense><sense id="cabecear_2" guid="d365a778-8b15-5a90-9068-dfc3ce21ace7"><grammatical-info value="Verb"/><gloss lang="en"><text>to rock, to pitch</text></gloss></sense><sense id="cabecear_3" guid="8c5ce10c-4705-5554-aa84-d8a00857a177"><grammatical-info value="Verb"/><gloss lang="en"><text>to head a ball</text></gloss></sense></entry>
<entry id="cabecera" guid="bb4558e9-9b60-5ba8-b38d-8b1f2db3ceda"><lexical-unit><form lang="es"><text>cabecera</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="cabecera_0" guid="5177e863-ebab-5343-9462-f489744d4bd7"><grammatical-info value="Noun"/><gloss lang="en"><text>headboard, bedhead</text></gloss></sense><sense id="cabecera_1" guid="ffbd6b4d-f3a9-5c92-aebb-bffce2e1209b"><grammatical-info value="Noun"/><gloss lang="en"><text>head (of company)</text></gloss></sense><sense id="cabecera_2" guid="2ef73bfb-8b98-562e-8ee3-433c898a27e4"><grammatical-info value="Noun"/><gloss lang="en"><text>seat of government</text></gloss></sense><sense id="cabecera_3" guid="14ebffff-e7e8-575e-817d-d79ba9ffef3a"><grammatical-info value="Noun"/><gloss lang="en"><text>headline, heading, top</text></gloss></sense><sense id="cabecera_4" guid="c711ad2e-50b7-5142-9bf1-65fd7e88d307"><grammatical-info value="Noun"/><gloss lang="en"><text>opening credits, intro, title sequence</text></gloss></sense><sense id="cabecera_5" guid="999bbbb1-3e48-56a4-822d-6e6c8d0c1146"><grammatical-info value="Noun"/><gloss lang="en"><text>headwaters</text></gloss></sense><sense id="cabecera_6" guid="4b45f1d8-4e51-582c-ba88-0b46b78b5ff5"><grammatical-info value="Noun"/><gloss lang="en"><text>header</text></gloss></sense></entry>
