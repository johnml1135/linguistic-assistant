<entry id="alegar" guid="b50cd51f-927e-5b2e-8141-45a7ce9e1a9b"><lexical-unit><form lang="es"><text>alegar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alegar_0" guid="53680b1e-c5c5-5be7-87fc-54fc4cfeb5cf"><grammatical-info value="Verb"/><gloss lang="en"><text>to cite as a defence or justification for one's actions</text></gloss></sense><sense id="alegar_1" guid="4e15caba-0103-54a0-abc6-c5b8977fcae2"><grammatical-info value="Verb"/><gloss lang="en"><text>to claim, to allege</text></gloss></sense><sense id="alegar_2" guid="bb2c42f2-8a4a-57e9-8f17-d1041d3e48e0"><grammatical-info value="Verb"/><gloss lang="en"><text>to complain</text></gloss></sense><sense id="alegar_3" guid="38271818-a772-5987-8e4b-451c6afe1abd"><grammatical-info value="Verb"/><gloss lang="en"><text>to speak in defence of the accused in a criminal proceeding; to defend</text></gloss></sense><sense id="alegar_4" guid="e394daa7-48d3-5504-acb0-8cb9a1de0b56"><grammatical-info value="Verb"/><gloss lang="en"><text>to converse, talk</text></gloss></sense></entry>
<entry id="alegoría" guid="88de444f-6e50-543d-9a3b-16508f599fae"><lexical-unit><form lang="es"><text>alegoría</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alegoría_0" guid="b085c3ad-8e17-5592-b048-40d754016f4a"><grammatical-info value="Noun"/><gloss lang="en"><text>allegory</text></gloss></sense></entry>
<entry id="alegrar" guid="bca25c3f-3199-5f39-95e6-83da68db2b86"><lexical-unit><form lang="es"><text>alegrar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alegrar_0" guid="69ac6ce9-2ac6-5b49-ae54-340601a7ed09"><grammatical-info value="Verb"/><gloss lang="en"><text>to make happy</text></gloss></sense><sense id="alegrar_1" guid="6dadfd3d-92b2-5100-8f29-c20416431a5a"><grammatical-info value="Verb"/><gloss lang="en"><text>to be happy</text></gloss></sense><sense id="alegrar_2" guid="f6a1dc7c-5f6b-5280-bb80-09afbbdb9415"><grammatical-info value="Verb"/><gloss lang="en"><text>to be glad</text></gloss></sense></entry>
<entry id="alegría" guid="15ded63d-0570-5fd6-abbc-9b754d7b41d8"><lexical-unit><form lang="es"><text>alegría</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alegría_0" guid="02472a7e-ad04-5b99-84f0-cc3e0944496e"><grammatical-info value="Noun"/><gloss lang="en"><text>joy, happiness</text></gloss></sense><sense id="alegría_1" guid="66f4a7a7-454b-5aff-90db-592cc524612a"><grammatical-info value="Noun"/><gloss lang="en"><text>Any of various amaranths</text></gloss></sense><sense id="alegría_2" guid="7ed03f4c-29ee-5171-bbb2-47cd367919f6"><grammatical-info value="Noun"/><gloss lang="en"><text>Mexican candy made from amaranth seeds with honey or sugar</text></gloss></sense><sense id="alegría_3" guid="005ad010-df81-522a-849c-db8aa66affce"><grammatical-info value="Noun"/><gloss lang="en"><text>a surname</text></gloss></sense><sense id="alegría_4" guid="336004e6-22b9-5c13-8f8a-76a254d91857"><grammatical-info value="Noun"/><gloss lang="en"><text>a town in Usulután department, El Salvador</text></gloss></sense></entry>
<entry id="aleja" guid="bb2a8ab4-daf3-5835-bffb-da86fe93ba59"><lexical-unit><form lang="es"><text>aleja</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aleja_0" guid="be9f1d33-be9e-55c2-90a7-46b5adb61d10"><grammatical-info value="Verb"/><gloss lang="en"><text>a diminutive of the female given name Alejandra, equivalent to English Alexa</text></gloss></sense></entry>
<entry id="alejado" guid="f8fd5252-548e-59ad-a046-bae8bdae8e5d"><lexical-unit><form lang="es"><text>alejado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alejado_0" guid="b73132dc-e529-5c2d-a8f5-ddef196b3730"><grammatical-info value="Adjective"/><gloss lang="en"><text>far, faraway, distant</text></gloss></sense></entry>
<entry id="alejandrino" guid="f63d25de-f136-553f-86e6-6b3a48e516cb"><lexical-unit><form lang="es"><text>alejandrino</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alejandrino_0" guid="91df1b72-5fbc-5920-85f2-48ee50200b6e"><grammatical-info value="Adjective"/><gloss lang="en"><text>Alexandrian, Alexandrine (of, from or relating to the city of Alexandria, Egypt or the city of Alexandria, Virginia, United States)</text></gloss></sense><sense id="alejandrino_1" guid="5ca1ed17-8c48-5b1a-a023-9794a6ad579f"><grammatical-info value="Adjective"/><gloss lang="en"><text>Alexandrian (of or relating to Alexander the Great)</text></gloss></sense><sense id="alejandrino_2" guid="04be2d9a-c14c-5003-b71c-05c2f1d08a3d"><grammatical-info value="Adjective"/><gloss lang="en"><text>Alexandrian</text></gloss></sense><sense id="alejandrino_3" guid="80caaff3-64d8-5edc-8c7c-0cb3e94e3ec2"><grammatical-info value="Adjective"/><gloss lang="en"><text>Alexandrian, Alexandrine (native or inhabitant of the city of Alexandria, Egypt or the city of Alexandria, Virginia, United States) (usually male)</text></gloss></sense><sense id="alejandrino_4" guid="21e46a76-3273-5af0-bf1c-26481f7b4187"><grammatical-info value="Adjective"/><gloss lang="en"><text>alexandrine</text></gloss></sense><sense id="alejandrino_5" guid="90f8c41b-b0dc-55e2-89ab-2007f9bb7648"><grammatical-info value="Adjective"/><gloss lang="en"><text>a male given name</text></gloss></sense><sense id="alejandrino_6" guid="5c826871-a174-5718-baf9-16696ae5b2dd"><grammatical-info value="Adjective"/><gloss lang="en"><text>a rare surname</text></gloss></sense></entry>
