<entry id="respiración" guid="9fd24e81-ae30-5625-877a-dae2a6687cdc"><lexical-unit><form lang="es"><text>respiración</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="respiración_0" guid="071eb24c-34c4-59b9-b036-c14024f47899"><grammatical-info value="Noun"/><gloss lang="en"><text>respiration</text></gloss></sense><sense id="respiración_1" guid="5d13cd3d-75c6-5001-b4b1-1f1a1ad1a915"><grammatical-info value="Noun"/><gloss lang="en"><text>breath</text></gloss></sense></entry>
