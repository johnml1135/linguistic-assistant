<entry id="sacudir" guid="e8b09cdb-2289-565b-85b8-3c3fa9688a1d"><lexical-unit><form lang="es"><text>sacudir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sacudir_0" guid="f7e7648e-5adc-544f-a2c2-ee7a269c7539"><grammatical-info value="Verb"/><gloss lang="en"><text>to shake off, dust</text></gloss></sense><sense id="sacudir_1" guid="c4e4f2f7-796d-5344-bd3e-a0392e816674"><grammatical-info value="Verb"/><gloss lang="en"><text>to shake</text></gloss></sense><sense id="sacudir_2" guid="24255a70-3500-5fe7-bee1-dc1119f290ba"><grammatical-info value="Verb"/><gloss lang="en"><text>to shake (the head, to give a negative response)</text></gloss></sense><sense id="sacudir_3" guid="2582bc3f-563b-53f0-9683-e57a29d72dda"><grammatical-info value="Verb"/><gloss lang="en"><text>to nod (the head, to give a positive response)</text></gloss></sense><sense id="sacudir_4" guid="cbf4c55a-8049-5ebe-bc39-942bde39a9b9"><grammatical-info value="Verb"/><gloss lang="en"><text>to jolt</text></gloss></sense><sense id="sacudir_5" guid="5224fe79-3337-50d5-8a06-e2d66c2b8edc"><grammatical-info value="Verb"/><gloss lang="en"><text>shake off, rid oneself of.</text></gloss></sense></entry>
