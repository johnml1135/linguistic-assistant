<entry id="adornar" guid="49cbd922-1129-5e78-a984-cb874fe926fd"><lexical-unit><form lang="es"><text>adornar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="adornar_0" guid="6bdcd95b-d3c0-5dcd-a11e-fc8a9670972f"><grammatical-info value="Verb"/><gloss lang="en"><text>to adorn, to ornament, to decorate, to garnish, to embellish, to dress, to bedeck, to deck</text></gloss></sense><sense id="adornar_1" guid="c3c079c6-6657-5375-953c-0a138f85bad0"><grammatical-info value="Verb"/><gloss lang="en"><text>to trim (e.g. a Christmas tree)</text></gloss></sense><sense id="adornar_2" guid="8edfdcb2-144c-5c50-b44f-77cd4b45169d"><grammatical-info value="Verb"/><gloss lang="en"><text>to cheat on someone</text></gloss></sense><sense id="adornar_3" guid="f32334b0-7731-58fb-af05-30601db72714"><grammatical-info value="Verb"/><gloss lang="en"><text>to buy off; to bribe</text></gloss></sense></entry>
