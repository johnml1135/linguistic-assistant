<entry id="aposentar" guid="8f73efca-f843-5ab9-bbee-98f38ccade41"><lexical-unit><form lang="es"><text>aposentar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aposentar_0" guid="8895ce29-9d05-5aa3-bf94-9fae46b6665a"><grammatical-info value="Verb"/><gloss lang="en"><text>to lodge, put up</text></gloss></sense><sense id="aposentar_1" guid="053efaa5-1e82-5fea-8b20-349011a3dbd9"><grammatical-info value="Verb"/><gloss lang="en"><text>to shack up; to stay as a guest; to lodge</text></gloss></sense><sense id="aposentar_2" guid="4e5583dd-77a8-5a89-84b6-81a441988ce7"><grammatical-info value="Verb"/><gloss lang="en"><text>to reside</text></gloss></sense></entry>
<entry id="apostasía" guid="84299350-7cd6-5ee4-aea7-ca72f29ea36f"><lexical-unit><form lang="es"><text>apostasía</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apostasía_0" guid="7ee4943d-d3e2-50fe-a0ba-bf5f5a0de2bf"><grammatical-info value="Noun"/><gloss lang="en"><text>apostasy</text></gloss></sense></entry>
<entry id="apostatar" guid="f0a77764-7847-5436-b89a-2b05cd73bfb2"><lexical-unit><form lang="es"><text>apostatar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apostatar_0" guid="c1dfd495-059b-5100-a695-b64f08db0b97"><grammatical-info value="Verb"/><gloss lang="en"><text>to apostatize</text></gloss></sense></entry>
<entry id="apostolado" guid="afba08bc-f618-51e4-bac1-1f99c12c2891"><lexical-unit><form lang="es"><text>apostolado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apostolado_0" guid="21e5e399-5694-5d82-9791-61cbb56dd16f"><grammatical-info value="Noun"/><gloss lang="en"><text>apostolate (group of religious apostles)</text></gloss></sense><sense id="apostolado_1" guid="74e1f18e-77fe-5fa9-957d-367b4c70ab75"><grammatical-info value="Noun"/><gloss lang="en"><text>apostleship (the position of being an apostle)</text></gloss></sense><sense id="apostolado_2" guid="465e2929-a35a-5a56-8209-527d357e9596"><grammatical-info value="Noun"/><gloss lang="en"><text>apostolado (series of portraits of the apostles)</text></gloss></sense></entry>
<entry id="apoyar" guid="632e5cd2-42fa-51c7-a0c2-04d613b02637"><lexical-unit><form lang="es"><text>apoyar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apoyar_0" guid="bf6ccf97-f123-5d5a-9df6-d5f88c5ffee6"><grammatical-info value="Verb"/><gloss lang="en"><text>to lean, to rest, to lie or lay</text></gloss></sense><sense id="apoyar_1" guid="4320162f-44e9-56b1-a39e-0b9301b07b76"><grammatical-info value="Verb"/><gloss lang="en"><text>to support, to get behind (to back a cause, party, etc., mentally or with concrete aid)</text></gloss></sense><sense id="apoyar_2" guid="6dda3805-5f4e-5bd8-a962-14edf52b4e6c"><grammatical-info value="Verb"/><gloss lang="en"><text>to support (to keep from falling)</text></gloss></sense><sense id="apoyar_3" guid="d80ce3cb-24ff-5062-8e9c-cbd12b5c7167"><grammatical-info value="Verb"/><gloss lang="en"><text>to lean, to rest, to be supported</text></gloss></sense><sense id="apoyar_4" guid="4b11ceee-d928-5068-b5fd-131c3bb18846"><grammatical-info value="Verb"/><gloss lang="en"><text>to lean on, to rely on</text></gloss></sense><sense id="apoyar_5" guid="5d00169a-2cff-5ffc-9803-963d3a0d481d"><grammatical-info value="Verb"/><gloss lang="en"><text>to be based, to be founded</text></gloss></sense></entry>
<entry id="app" guid="a384455f-2aa7-51ca-a8c1-1288d901a0a6"><lexical-unit><form lang="es"><text>app</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="app_0" guid="b4f5844d-5942-532b-810e-f6f6e7d0aceb"><grammatical-info value="Noun"/><gloss lang="en"><text>app</text></gloss></sense></entry>
<entry id="apreciar" guid="8585eaef-19e1-5c45-ad20-5411929683bb"><lexical-unit><form lang="es"><text>apreciar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apreciar_0" guid="af8c0b8b-23b6-5518-8d85-6aef91cc6f79"><grammatical-info value="Verb"/><gloss lang="en"><text>to appreciate (to view as valuable)</text></gloss></sense><sense id="apreciar_1" guid="f7aff01c-576b-595a-9504-b0a1e7e7ff77"><grammatical-info value="Verb"/><gloss lang="en"><text>to appreciate (to increase in value)</text></gloss></sense><sense id="apreciar_2" guid="465afcc2-6592-5b05-a583-624997af9fa3"><grammatical-info value="Verb"/><gloss lang="en"><text>to notice, to detect</text></gloss></sense></entry>
<entry id="aprehender" guid="1fd1726a-2513-5c47-8ebf-5cc8a45d7eb2"><lexical-unit><form lang="es"><text>aprehender</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aprehender_0" guid="65e469a3-38a1-5d3c-817f-d3e3c77a3bb9"><grammatical-info value="Verb"/><gloss lang="en"><text>to apprehend, to seize, to confiscate</text></gloss></sense><sense id="aprehender_1" guid="f0081d88-0637-527b-977c-632dccb8420b"><grammatical-info value="Verb"/><gloss lang="en"><text>to understand</text></gloss></sense></entry>
<entry id="apremiar" guid="8ec4277b-7c56-55c1-9e01-7534c9f472c1"><lexical-unit><form lang="es"><text>apremiar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apremiar_0" guid="5b632716-fbf3-5a16-bea6-af776a8ca6ff"><grammatical-info value="Verb"/><gloss lang="en"><text>to pressure, urge</text></gloss></sense></entry>
<entry id="aprender" guid="68948173-cfbb-564a-9e62-0049db0a81d6"><lexical-unit><form lang="es"><text>aprender</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aprender_0" guid="775e298f-f7f1-547f-9dec-1c5f8ad751d9"><grammatical-info value="Verb"/><gloss lang="en"><text>to learn (to acquire, or attempt to acquire knowledge or an ability to do something)</text></gloss></sense><sense id="aprender_1" guid="e086b30a-8ba7-5c6e-ab4c-ec855f7e1ae0"><grammatical-info value="Verb"/><gloss lang="en"><text>to teach</text></gloss></sense></entry>
<entry id="aprestar" guid="47bc6b85-5ae7-5886-9484-6365a6735747"><lexical-unit><form lang="es"><text>aprestar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aprestar_0" guid="000704bc-385a-5705-b5b0-771dcd0cc323"><grammatical-info value="Verb"/><gloss lang="en"><text>to prepare, to make ready</text></gloss></sense><sense id="aprestar_1" guid="5e0b5145-af5f-5f0b-838c-6879bbb4f7ca"><grammatical-info value="Verb"/><gloss lang="en"><text>to prepare oneself</text></gloss></sense></entry>
<entry id="apresurar" guid="a8a638e3-a629-582e-b27d-a2e1341cc552"><lexical-unit><form lang="es"><text>apresurar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apresurar_0" guid="114923bd-946e-59b7-b515-28de70b217f1"><grammatical-info value="Verb"/><gloss lang="en"><text>to quicken</text></gloss></sense><sense id="apresurar_1" guid="31adc0da-20cf-5ab5-a429-a6799ef8ecf4"><grammatical-info value="Verb"/><gloss lang="en"><text>to rush, to hasten</text></gloss></sense></entry>
<entry id="apretar" guid="b733e042-b3e9-596b-a8df-ee4f4dccbf55"><lexical-unit><form lang="es"><text>apretar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apretar_0" guid="7af19276-eba2-585e-a702-ea8ddf4e33ce"><grammatical-info value="Verb"/><gloss lang="en"><text>to squeeze</text></gloss></sense><sense id="apretar_1" guid="037c2296-2895-55c1-a339-32f4f2b0d414"><grammatical-info value="Verb"/><gloss lang="en"><text>to tighten, constrict or compress</text></gloss></sense><sense id="apretar_2" guid="58d5ca47-edd3-5d0a-a5e4-64c076cbc09a"><grammatical-info value="Verb"/><gloss lang="en"><text>to press (e.g., a button)</text></gloss></sense><sense id="apretar_3" guid="dfa1c540-ccee-57da-9d7a-3ffe590f048a"><grammatical-info value="Verb"/><gloss lang="en"><text>to pull (e.g., the trigger)</text></gloss></sense><sense id="apretar_4" guid="82782638-b625-549e-8b7f-7308672be921"><grammatical-info value="Verb"/><gloss lang="en"><text>to grit (e.g., one's teeth), to clench (e.g., one's fist)</text></gloss></sense><sense id="apretar_5" guid="8da38ba0-8de5-57c5-a778-4506cfaff601"><grammatical-info value="Verb"/><gloss lang="en"><text>to push down (e.g., a toilet plunger)</text></gloss></sense><sense id="apretar_6" guid="0760edcd-93a2-561b-9552-12b0c83c99cb"><grammatical-info value="Verb"/><gloss lang="en"><text>to hold back</text></gloss></sense><sense id="apretar_7" guid="6931bf98-198f-53ce-9f6a-6a4cd0a61e03"><grammatical-info value="Verb"/><gloss lang="en"><text>to hold on to something</text></gloss></sense></entry>
<entry id="apretura" guid="255f7978-b565-5a58-ba47-cd60c323c453"><lexical-unit><form lang="es"><text>apretura</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apretura_0" guid="54d18eb4-bc74-5ec4-b243-dd7f46c86fdc"><grammatical-info value="Noun"/><gloss lang="en"><text>squeeze (situation in which there are too many people, things, etc., in a small space)</text></gloss></sense><sense id="apretura_1" guid="25f86d34-2d92-5b4c-82d6-57135dc5e7db"><grammatical-info value="Noun"/><gloss lang="en"><text>fix; predicament (difficult situation)</text></gloss></sense><sense id="apretura_2" guid="0f4ecd56-95d2-5200-80a0-338e2f1baf8d"><grammatical-info value="Noun"/><gloss lang="en"><text>conflict</text></gloss></sense><sense id="apretura_3" guid="013826a4-77ce-5a70-bcda-eddb77264cda"><grammatical-info value="Noun"/><gloss lang="en"><text>poverty</text></gloss></sense></entry>
<entry id="apriesa" guid="08fac922-611a-568f-a0a5-e614d47bbf55"><lexical-unit><form lang="es"><text>apriesa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apriesa_0" guid="fc8fce81-984f-5c9f-87ca-45b37bfb4148"><grammatical-info value="Adverb"/><gloss lang="en"><text>obsolete form of aprisa (hurriedly)</text></gloss></sense></entry>
<entry id="aprisionar" guid="3585d679-dfb7-55a6-840d-e9d60ba9c40d"><lexical-unit><form lang="es"><text>aprisionar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aprisionar_0" guid="1afddcc8-3e8a-588f-98fc-a0b00b53d59d"><grammatical-info value="Verb"/><gloss lang="en"><text>to incarcerate, imprison</text></gloss></sense></entry>
<entry id="aprobado" guid="3cdab91e-3131-5173-8c97-a03ce48aecff"><lexical-unit><form lang="es"><text>aprobado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aprobado_0" guid="48855503-0285-5e9f-9aab-a25438c461fa"><grammatical-info value="Verb"/><gloss lang="en"><text>approved, confirmed</text></gloss></sense></entry>
<entry id="aprobar" guid="f93bbec9-93d5-57e8-9536-9a2b20a3c2e5"><lexical-unit><form lang="es"><text>aprobar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aprobar_0" guid="b869e141-a0d8-517a-aa1f-f43747952b00"><grammatical-info value="Verb"/><gloss lang="en"><text>to approve, to condone, to permit</text></gloss></sense><sense id="aprobar_1" guid="38f50ff1-2045-5511-bc40-84112de24b5b"><grammatical-info value="Verb"/><gloss lang="en"><text>to pass (succeed, e.g. on an exam)</text></gloss></sense></entry>
<entry id="apropiar" guid="03886684-75b6-5d5b-aa22-aac145b8bd4e"><lexical-unit><form lang="es"><text>apropiar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apropiar_0" guid="85f4502a-5003-59b5-ae4d-4b6b234f2f33"><grammatical-info value="Verb"/><gloss lang="en"><text>to give, bestow</text></gloss></sense><sense id="apropiar_1" guid="a649afc4-020f-5e70-aa6f-1bb854e9b459"><grammatical-info value="Verb"/><gloss lang="en"><text>to seize, take hold of</text></gloss></sense></entry>
<entry id="aprovechamiento" guid="ed6d512f-3916-5405-b055-9600a6786ca3"><lexical-unit><form lang="es"><text>aprovechamiento</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aprovechamiento_0" guid="a2669234-b4a0-518f-8b5a-dd3a8e1ccce0"><grammatical-info value="Noun"/><gloss lang="en"><text>use, exploitation</text></gloss></sense><sense id="aprovechamiento_1" guid="34aef1db-eaf8-58b5-93ad-adb6b556c9cb"><grammatical-info value="Noun"/><gloss lang="en"><text>improvement</text></gloss></sense><sense id="aprovechamiento_2" guid="7f52134b-cbd8-5122-9b12-4e471a6db0de"><grammatical-info value="Noun"/><gloss lang="en"><text>harnessing</text></gloss></sense></entry>
<entry id="aprovechar" guid="14260030-c97b-56c8-822e-863b54f0a77b"><lexical-unit><form lang="es"><text>aprovechar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aprovechar_0" guid="a08c311a-517e-5c7c-bedc-95338de48f39"><grammatical-info value="Verb"/><gloss lang="en"><text>to make use of, to make the most of, to get the most out of</text></gloss></sense><sense id="aprovechar_1" guid="c0f894ed-ac75-59d7-99d7-d5ac445efbbc"><grammatical-info value="Verb"/><gloss lang="en"><text>to take advantage of, to leverage</text></gloss></sense><sense id="aprovechar_2" guid="3aadfe0b-29e3-5db2-9702-4ef276f24017"><grammatical-info value="Verb"/><gloss lang="en"><text>to be useful, to profit (someone)</text></gloss></sense><sense id="aprovechar_3" guid="713696b5-c0ab-5073-9f93-4a70da03eba8"><grammatical-info value="Verb"/><gloss lang="en"><text>to improve</text></gloss></sense></entry>
<entry id="apt" guid="0eb2d507-c0b5-5777-bd31-65e130dc921a"><lexical-unit><form lang="es"><text>apt</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apt_0" guid="b8373f2a-5525-551d-b0f6-730cda22f39a"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="aptar" guid="2fcaaf52-4055-52d2-85ff-9e7d9a15137a"><lexical-unit><form lang="es"><text>aptar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aptar_0" guid="93b68320-8e35-512f-92e3-78cce06200cd"><grammatical-info value="Verb"/><gloss lang="en"><text>to adapt; fix; adjust</text></gloss></sense></entry>
<entry id="apto" guid="f9779a60-2dad-5a08-8068-c5203f75665b"><lexical-unit><form lang="es"><text>apto</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apto_0" guid="6c892f8f-0062-561a-bd8c-884fe842e23e"><grammatical-info value="Adjective"/><gloss lang="en"><text>suitable; capable, able; fit</text></gloss></sense></entry>
<entry id="apurar" guid="8f08c313-4285-56a9-862c-c01d6c991b35"><lexical-unit><form lang="es"><text>apurar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apurar_0" guid="395cfba5-0cdc-5e10-a507-8e2979867530"><grammatical-info value="Verb"/><gloss lang="en"><text>to drain, use up completely</text></gloss></sense><sense id="apurar_1" guid="46078d34-b312-57d4-8a9c-171fad357397"><grammatical-info value="Verb"/><gloss lang="en"><text>to hurry, to rush</text></gloss></sense><sense id="apurar_2" guid="cc27b7ec-08af-5ff6-ac0b-ac31e3b39507"><grammatical-info value="Verb"/><gloss lang="en"><text>to worry, bother</text></gloss></sense></entry>
<entry id="apuro" guid="4535b22c-8908-5b4d-bc7f-e6563bf2efb5"><lexical-unit><form lang="es"><text>apuro</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apuro_0" guid="649e9c3d-b144-5c9d-8b78-47bdb3870bd2"><grammatical-info value="Noun"/><gloss lang="en"><text>difficulty, predicament</text></gloss></sense><sense id="apuro_1" guid="e90ec366-249f-52bc-b9b6-ce99924962be"><grammatical-info value="Noun"/><gloss lang="en"><text>shortage</text></gloss></sense><sense id="apuro_2" guid="34b27882-40e4-57da-af7b-f057cfe268da"><grammatical-info value="Noun"/><gloss lang="en"><text>urgency, rush, hurry</text></gloss></sense><sense id="apuro_3" guid="698fe814-998e-5554-8c93-027001e228c3"><grammatical-info value="Noun"/><gloss lang="en"><text>embarrassment</text></gloss></sense></entry>
<entry id="apóstol" guid="cf4edb5b-6c4d-5a52-8793-8ab27599a578"><lexical-unit><form lang="es"><text>apóstol</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="apóstol_0" guid="525faac4-71e7-5a10-9e5e-49071387f6c2"><grammatical-info value="Noun"/><gloss lang="en"><text>apostle</text></gloss></sense><sense id="apóstol_1" guid="6d9b8a59-ac16-5947-b240-c86fbf9e2814"><grammatical-info value="Noun"/><gloss lang="en"><text>a surname</text></gloss></sense></entry>
<entry id="aquel" guid="c49e0579-8e22-5e41-aa6a-e7191890e415"><lexical-unit><form lang="es"><text>aquel</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aquel_0" guid="4bf27b20-4241-5794-ac55-d6f4a0b75cba"><grammatical-info value="Determiner"/><gloss lang="en"><text>that (over there; implying some distance)</text></gloss></sense><sense id="aquel_1" guid="ddca3c9e-7b0f-564f-b7f4-1d437d576023"><grammatical-info value="Determiner"/><gloss lang="en"><text>alternative spelling of aquél</text></gloss></sense></entry>
<entry id="aquella" guid="4ed31d3b-b801-5737-8925-efb140b483d3"><lexical-unit><form lang="es"><text>aquella</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aquella_0" guid="91368afd-b00a-5d32-9f71-f6442c724e6e"><grammatical-info value="Determiner"/><gloss lang="en"><text>alternative spelling of aquélla; that one</text></gloss></sense></entry>
<entry id="aquellar" guid="1e2f3c0d-47f0-52fe-b8d1-f426e261889c"><lexical-unit><form lang="es"><text>aquellar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aquellar_0" guid="d6068f3a-7bd8-5deb-97e1-8ce3b08884d7"><grammatical-info value="Verb"/><gloss lang="en"><text>Used as a placeholder for any verb, usually when the speaker doesn't remember it, doesn't know it, or attempts to avoid it.</text></gloss></sense><sense id="aquellar_1" guid="4d452e18-3725-5dd3-a2b5-a25d57eabeb8"><grammatical-info value="Verb"/><gloss lang="en"><text>Used as a subsitution of any verb, usually when the speaker doesn't remember it, doesn't know it, or attempts to avoid it.</text></gloss></sense></entry>
<entry id="aqueste" guid="63fcd5be-9379-5413-9bd4-f8c03552b963"><lexical-unit><form lang="es"><text>aqueste</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aqueste_0" guid="7e685d46-dd11-5257-92fe-a3b900d2e5e3"><grammatical-info value="Adjective"/><gloss lang="en"><text>alternative form of este</text></gloss></sense></entry>
