<entry id="i" guid="b240d665-d69d-5f01-81d7-26e126ac4fa4"><lexical-unit><form lang="tl"><text>i</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="i_0" guid="b433012f-3532-5536-af58-5fc5ee903ec5"><grammatical-info value="Noun"/><gloss lang="en"><text>the ninth letter of the Filipino alphabet, called ay and written in the Latin script</text></gloss></sense><sense id="i_1" guid="978c3308-4c73-501f-bdbe-4c1aae1d9fd0"><grammatical-info value="Noun"/><gloss lang="en"><text>the eighth letter of the Abakada alphabet, called i and written in the Latin script</text></gloss></sense><sense id="i_2" guid="2866c057-32ed-5356-84bb-7f1a2c66eaaf"><grammatical-info value="Noun"/><gloss lang="en"><text>the tenth letter of the Abecedario, called i and written in the Latin script</text></gloss></sense><sense id="i_3" guid="7ff3ac6d-1385-57d4-9890-e1d21a8ec417"><grammatical-info value="Noun"/><gloss lang="en"><text>the name of the Latin script letter I/i, in the Abakada alphabet</text></gloss></sense><sense id="i_4" guid="78a8c963-53f2-5de0-ae68-506162182f8f"><grammatical-info value="Noun"/><gloss lang="en"><text>the name of the Latin script letter I/i, in the Abecedario</text></gloss></sense><sense id="i_5" guid="bfc5b4e8-84bf-53a6-9c7c-32da9a8ab04a"><grammatical-info value="Noun"/><gloss lang="en"><text>the name of the Latin script letter E/e, in the Filipino alphabet</text></gloss></sense><sense id="i_6" guid="a95957ac-8e78-5855-b0c6-a877a365d848"><grammatical-info value="Noun"/><gloss lang="en"><text>mother of</text></gloss></sense></entry>
