<entry id="mumo" guid="6c61c224-8042-5759-a889-58082a28e639"><lexical-unit><form lang="tl"><text>mumo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mumo_0" guid="720e1d6a-5ec7-5bcd-8b95-34ff2e12f2cd"><grammatical-info value="Noun"/><gloss lang="en"><text>particles of cooked rice falling of the plate or table during a meal</text></gloss></sense><sense id="mumo_1" guid="b2ec613b-1f7f-5103-ae5c-06e9770a35cb"><grammatical-info value="Noun"/><gloss lang="en"><text>bogeyman; a monster causing fear in children's stories</text></gloss></sense><sense id="mumo_2" guid="f79ffb49-bb44-5cac-b928-2c4fd3ac0b14"><grammatical-info value="Noun"/><gloss lang="en"><text>ghost</text></gloss></sense></entry>
<entry id="muna" guid="3175b50b-b2c2-5081-88c4-bc0de09343c8"><lexical-unit><form lang="tl"><text>muna</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="muna_0" guid="6bf06cfc-3649-5bef-924c-ce93ebd6989a"><grammatical-info value="Adverb"/><gloss lang="en"><text>for a while; for a moment; for the time being; a minute (when the nature of the anticipated change is not expressed)</text></gloss></sense><sense id="muna_1" guid="ad9005f7-c627-5dd3-adbb-b8b181cc15f6"><grammatical-info value="Adverb"/><gloss lang="en"><text>first (when the nature of the anticipated change is expressed or clearly implied)</text></gloss></sense><sense id="muna_2" guid="34d68f8e-ef9a-5f3a-a567-1485227960c9"><grammatical-info value="Adverb"/><gloss lang="en"><text>alternative form of umuna: to go first; to go ahead</text></gloss></sense></entry>
<entry id="mundo" guid="b4031447-ad08-580e-94f4-42ecb3b1cda8"><lexical-unit><form lang="tl"><text>mundo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mundo_0" guid="d89ccfa9-ea1d-5c6e-8110-e411b6dd4af0"><grammatical-info value="Noun"/><gloss lang="en"><text>world; the earth</text></gloss></sense><sense id="mundo_1" guid="70c44f89-d7bf-5919-8f30-0db2a636f7b8"><grammatical-info value="Noun"/><gloss lang="en"><text>vagabondage; act of wandering around</text></gloss></sense></entry>
