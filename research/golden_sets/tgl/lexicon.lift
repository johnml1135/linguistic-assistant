<entry id="taon" guid="52102850-417c-5c89-b75a-9a3f2bd466ff"><lexical-unit><form lang="tl"><text>taon</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="taon_0" guid="73929ef9-05f6-56eb-81bf-d4ca06cec76b"><grammatical-info value="Noun"/><gloss lang="en"><text>year</text></gloss></sense><sense id="taon_1" guid="569fdf80-8805-5c84-b04b-3013310a15c8"><grammatical-info value="Noun"/><gloss lang="en"><text>chance happening; coincidence (especially in mataon and kataon)</text></gloss></sense><sense id="taon_2" guid="a1e5f5d4-6ab1-5dc0-bed9-501a4fe5c5ad"><grammatical-info value="Noun"/><gloss lang="en"><text>act of doing something to coincide with another</text></gloss></sense><sense id="taon_3" guid="a9a5abd7-ab68-547f-87f3-e9febacad91e"><grammatical-info value="Noun"/><gloss lang="en"><text>act of being a go-between for admitting guests in one's house</text></gloss></sense><sense id="taon_4" guid="6b8b5366-2fb0-5127-8571-8cbeb487e48b"><grammatical-info value="Noun"/><gloss lang="en"><text>catching in the act</text></gloss></sense><sense id="taon_5" guid="5a8b94f9-29b7-5063-8823-9a57340ae2ed"><grammatical-info value="Noun"/><gloss lang="en"><text>encounter of two people at some place (especially by chance)</text></gloss></sense><sense id="taon_6" guid="756788d3-22f8-5cc5-8182-67959bbc1fe9"><grammatical-info value="Noun"/><gloss lang="en"><text>finding someone being looked for by chance</text></gloss></sense><sense id="taon_7" guid="77f9e739-668b-5c57-8fc1-aa64ce386958"><grammatical-info value="Noun"/><gloss lang="en"><text>convulsion (especially in children and infants)</text></gloss></sense></entry>
<entry id="taong" guid="b2a540a1-c357-5601-b1cd-161d0e00049e"><lexical-unit><form lang="tl"><text>taong</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="taong_0" guid="1c3a0fed-2869-534f-bd8c-b85157d56379"><grammatical-info value="Noun"/><gloss lang="en"><text>black mourning veil or handkerchief</text></gloss></sense><sense id="taong_1" guid="d4e259d0-d264-5815-907c-d90858fca7bc"><grammatical-info value="Noun"/><gloss lang="en"><text>big, round metal or wooden container for carrying water across horseback (in the form of a bucket, pail, or a petroleum can)</text></gloss></sense></entry>
<entry id="taos" guid="8c153226-a2d9-506c-93cc-8a60b9508fb2"><lexical-unit><form lang="tl"><text>taos</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="taos_0" guid="5fc01401-9eae-5f9c-8f8f-d568c3dab722"><grammatical-info value="Adjective"/><gloss lang="en"><text>penetrating to the bottom or from one side to another</text></gloss></sense><sense id="taos_1" guid="1444d873-6b04-56e8-8c71-ecbc577c1e4b"><grammatical-info value="Adjective"/><gloss lang="en"><text>sincere; genuine; true; heartfelt</text></gloss></sense><sense id="taos_2" guid="19fa7a17-9057-5603-821f-b920235ca978"><grammatical-info value="Adjective"/><gloss lang="en"><text>sincerely; genuinely; truly</text></gloss></sense><sense id="taos_3" guid="77dd06ef-b39c-5ec6-ac7f-3e912c056a56"><grammatical-info value="Adjective"/><gloss lang="en"><text>condition of penetrating to the bottom or from one side to another</text></gloss></sense><sense id="taos_4" guid="b0cd4a75-a81e-5687-9d84-516cb8a2f5a0"><grammatical-info value="Adjective"/><gloss lang="en"><text>state of being genuine or sincere</text></gloss></sense></entry>
<entry id="tapakan" guid="63595e82-64ee-52f7-960e-85982aebd996"><lexical-unit><form lang="tl"><text>tapakan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tapakan_0" guid="40c957e5-5500-56b2-9cc2-e42ab4e3c967"></sense></entry>
<entry id="tapang" guid="3f48be76-2a51-5e42-a7d1-b1f76793a121"><lexical-unit><form lang="tl"><text>tapang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tapang_0" guid="be4e330f-2e63-56dc-b955-f60225388191"><grammatical-info value="Noun"/><gloss lang="en"><text>bravery; courage; valor; boldness</text></gloss></sense><sense id="tapang_1" guid="2cd36ce2-db7a-517d-9105-3d9a963a8adf"><grammatical-info value="Noun"/><gloss lang="en"><text>strength; potency (of wine, coffee, vinegar, etc.)</text></gloss></sense></entry>
<entry id="tapat" guid="bccfe529-f455-5ee1-9fac-c5740e2ed0d7"><lexical-unit><form lang="tl"><text>tapat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tapat_0" guid="d000fb27-473c-5f27-aabc-c2ff3c99ba6c"><grammatical-info value="Adjective"/><gloss lang="en"><text>facing the front; in front</text></gloss></sense><sense id="tapat_1" guid="ad304246-86b3-565c-86e0-9a1158f935ca"><grammatical-info value="Adjective"/><gloss lang="en"><text>direct; straight (as a route to a certain place)</text></gloss></sense><sense id="tapat_2" guid="3ba92d85-de3d-551f-a529-e2f8634cac92"><grammatical-info value="Adjective"/><gloss lang="en"><text>sincere; genuine; real</text></gloss></sense><sense id="tapat_3" guid="2bfec23b-e352-5248-b1cb-f073556f4d58"><grammatical-info value="Adjective"/><gloss lang="en"><text>loyal; faithful; devoted</text></gloss></sense><sense id="tapat_4" guid="eebfa0e3-c35b-5797-9854-a035caea4939"><grammatical-info value="Adjective"/><gloss lang="en"><text>honest; just; truthful</text></gloss></sense><sense id="tapat_5" guid="71549f4a-a842-5aeb-a467-7b927ec9663a"><grammatical-info value="Adjective"/><gloss lang="en"><text>upfront; frank; candid; straightforward; open</text></gloss></sense><sense id="tapat_6" guid="a43237dc-5595-5438-956b-4e5df0c9bf7a"><grammatical-info value="Adjective"/><gloss lang="en"><text>side opposite or fronting another</text></gloss></sense><sense id="tapat_7" guid="2dec543e-3bc1-5d81-b473-aff21f9edf9d"><grammatical-info value="Adjective"/><gloss lang="en"><text>act of staying or stopping in front</text></gloss></sense></entry>
<entry id="tapon" guid="9128655f-1ad2-5567-98d2-698742039c70"><lexical-unit><form lang="tl"><text>tapon</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tapon_0" guid="a67d84b5-45f6-56e2-a4b8-f249d75ef64e"><grammatical-info value="Noun"/><gloss lang="en"><text>act of throwing away something</text></gloss></sense><sense id="tapon_1" guid="e103d74b-b9c2-5273-8692-c86bfe2c219d"><grammatical-info value="Noun"/><gloss lang="en"><text>wasted material; anything thrown away or wasted</text></gloss></sense><sense id="tapon_2" guid="4509acfd-3b74-5fdf-a447-3b66132a60c3"><grammatical-info value="Noun"/><gloss lang="en"><text>act of spilling (of liquid in a container)</text></gloss></sense><sense id="tapon_3" guid="b5439819-1d8f-5646-b487-9a5b87a4f929"><grammatical-info value="Noun"/><gloss lang="en"><text>spilled liquid</text></gloss></sense><sense id="tapon_4" guid="901448c0-acba-5153-b758-75c9fe2afedf"><grammatical-info value="Noun"/><gloss lang="en"><text>banishment; deportation</text></gloss></sense><sense id="tapon_5" guid="1c28d063-8f09-5be1-bea4-0de7ff3693ae"><grammatical-info value="Noun"/><gloss lang="en"><text>deportee</text></gloss></sense><sense id="tapon_6" guid="e8103b82-8b69-5ccb-aa5f-f33a0777312c"><grammatical-info value="Noun"/><gloss lang="en"><text>thrown away for disposal; wasted</text></gloss></sense><sense id="tapon_7" guid="a3d697b9-545d-597e-920c-f60b1fd4b5cc"><grammatical-info value="Noun"/><gloss lang="en"><text>spilled (of liquid from a container)</text></gloss></sense></entry>
<entry id="tapos" guid="eef2b642-7ff8-5aa6-8ecf-4d5d0733aedd"><lexical-unit><form lang="tl"><text>tapos</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tapos_0" guid="efbac8ca-569e-523a-8a21-79b87a0ff0e9"><grammatical-info value="Adjective"/><gloss lang="en"><text>completed; finished</text></gloss></sense><sense id="tapos_1" guid="57ad31b2-fc52-51a0-8169-fe747cc2943b"><grammatical-info value="Adjective"/><gloss lang="en"><text>over; ended; concluded</text></gloss></sense><sense id="tapos_2" guid="1c8fe6ec-5396-5516-9d97-fa1fefe3badc"><grammatical-info value="Adjective"/><gloss lang="en"><text>graduated (of a student)</text></gloss></sense><sense id="tapos_3" guid="a91e0803-48de-55d0-b110-b3210ee2a65f"><grammatical-info value="Adjective"/><gloss lang="en"><text>last day of a novena</text></gloss></sense><sense id="tapos_4" guid="7b44ea2d-56d5-5f76-9686-e820f429ae70"><grammatical-info value="Adjective"/><gloss lang="en"><text>end of a mourning period of a departed relative</text></gloss></sense><sense id="tapos_5" guid="9532463a-1d04-55e6-869e-4b7a28ddf96a"><grammatical-info value="Adjective"/><gloss lang="en"><text>finishing; completion (of something being done)</text></gloss></sense><sense id="tapos_6" guid="b5c89fce-30ce-55ea-8473-a73390198f0d"><grammatical-info value="Adjective"/><gloss lang="en"><text>coming to an end; conclusion (of a program, meeting, etc.)</text></gloss></sense><sense id="tapos_7" guid="e396483e-dfc1-580c-a5f1-7272e1766736"><grammatical-info value="Adjective"/><gloss lang="en"><text>act of graduating (of a student)</text></gloss></sense></entry>
<entry id="tapusin" guid="8719962a-2192-5e1b-845f-677b15133e2c"><lexical-unit><form lang="tl"><text>tapusin</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tapusin_0" guid="efa0ac6c-4db5-539e-89fb-d22e4f46b12e"><grammatical-info value="Verb"/><gloss lang="en"><text>to complete; to finish</text></gloss></sense><sense id="tapusin_1" guid="ceedcbc7-8820-5775-82b4-3362d36994dc"><grammatical-info value="Verb"/><gloss lang="en"><text>to conclude; to put to an end</text></gloss></sense><sense id="tapusin_2" guid="b81f256f-f14a-5744-a710-6ddaf414cdeb"><grammatical-info value="Verb"/><gloss lang="en"><text>to finish making</text></gloss></sense><sense id="tapusin_3" guid="5477f5ae-e27a-50f7-9eb5-a3f16faa51f5"><grammatical-info value="Verb"/><gloss lang="en"><text>obligated to finish or complete (of a task, job, etc.)</text></gloss></sense><sense id="tapusin_4" guid="ae702ae4-3a31-5e3c-8805-22ace2526109"><grammatical-info value="Verb"/><gloss lang="en"><text>task or job that someone is obligated to finish or complete</text></gloss></sense></entry>
<entry id="tapyas" guid="3049c63f-9555-5a3b-ba8a-e3ef9704ae01"><lexical-unit><form lang="tl"><text>tapyas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tapyas_0" guid="744e5263-6926-5ec9-8c40-23765df1e548"><grammatical-info value="Adjective"/><gloss lang="en"><text>chipped or cut off obliquely; with a sloping or beveled surface</text></gloss></sense><sense id="tapyas_1" guid="18c43ddf-0323-58ac-b097-0550d6e17efd"><grammatical-info value="Adjective"/><gloss lang="en"><text>sloping part or surface; bevel (as of an angled plate, glass, frame, table, etc.)</text></gloss></sense><sense id="tapyas_2" guid="4986d68d-207d-518e-8aed-663e437236fc"><grammatical-info value="Adjective"/><gloss lang="en"><text>facet (any one of the flat surfaces cut into a gem)</text></gloss></sense><sense id="tapyas_3" guid="fbc7f264-8156-5211-80c9-5547cc006193"><grammatical-info value="Adjective"/><gloss lang="en"><text>slanting cut on the tip or end of a tenon, etc.</text></gloss></sense><sense id="tapyas_4" guid="9743900d-fc29-553f-9da4-344b86c7730d"><grammatical-info value="Adjective"/><gloss lang="en"><text>act of chipping or cutting off obliquely</text></gloss></sense></entry>
<entry id="tarangkahan" guid="37aebc78-6ec6-5cb9-929f-ccd3cdc34721"><lexical-unit><form lang="tl"><text>tarangkahan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tarangkahan_0" guid="d4ca9f79-1631-50ff-8f8a-830854324745"><grammatical-info value="Noun"/><gloss lang="en"><text>gate (with a latch)</text></gloss></sense><sense id="tarangkahan_1" guid="f9686b97-9a96-5365-b538-464e51fd540e"><grammatical-info value="Noun"/><gloss lang="en"><text>notch or hole for a latch</text></gloss></sense><sense id="tarangkahan_2" guid="53c69c12-ade4-52db-9d5c-bd04a16cd076"><grammatical-info value="Noun"/><gloss lang="en"><text>to fasten with a latch or bar (of a door, gate, or window)</text></gloss></sense></entry>
<entry id="tasa" guid="0348b1c3-a360-5405-a551-2e808d1be641"><lexical-unit><form lang="tl"><text>tasa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tasa_0" guid="76e3be12-52fc-5be5-9d23-361a0c6baec9"><grammatical-info value="Noun"/><gloss lang="en"><text>cup (especially with a holder)</text></gloss></sense><sense id="tasa_1" guid="7bfebe18-f107-5791-ac0b-30636cf54263"><grammatical-info value="Noun"/><gloss lang="en"><text>cup; cupful (unit of measurement)</text></gloss></sense><sense id="tasa_2" guid="85259ffa-426c-55af-91b3-3d01008fe0fd"><grammatical-info value="Noun"/><gloss lang="en"><text>act of sharpening (of something blunt, such as a blade, pencil, etc.)</text></gloss></sense><sense id="tasa_3" guid="6e9e5d5f-cf34-550d-a86a-8bb0bcc462cd"><grammatical-info value="Noun"/><gloss lang="en"><text>sharpened point (of something previously blunt, such as a blade, pencil, etc.)</text></gloss></sense><sense id="tasa_4" guid="1a8c2cdb-7faf-5b5f-8fb8-4112388082de"><grammatical-info value="Noun"/><gloss lang="en"><text>sharpened (of a pointed object that has become blunt)</text></gloss></sense><sense id="tasa_5" guid="1f560df1-0012-5400-b37b-dd14b3d9ce30"><grammatical-info value="Noun"/><gloss lang="en"><text>act of assessing or appraising (the value for taxation purposes)</text></gloss></sense><sense id="tasa_6" guid="104b7d48-1c99-5685-895f-4f04452e7932"><grammatical-info value="Noun"/><gloss lang="en"><text>assessed value of a property; assessment</text></gloss></sense><sense id="tasa_7" guid="ac34c649-cfd0-5d3e-a535-2a5e7ed25716"><grammatical-info value="Noun"/><gloss lang="en"><text>act of limiting to the minimum (as of expenses, supplies, etc.)</text></gloss></sense></entry>
