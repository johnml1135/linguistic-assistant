<entry id="tumayo" guid="6983f010-1609-5c0d-9433-84af350301fc"><lexical-unit><form lang="tl"><text>tumayo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tumayo_0" guid="73717f0a-ef4e-5430-b520-068459b3259e"><grammatical-info value="Verb"/><gloss lang="en"><text>to stand; to stand up</text></gloss></sense><sense id="tumayo_1" guid="b07bf4ce-d197-5562-aaab-c314a820f975"><grammatical-info value="Verb"/><gloss lang="en"><text>to stand on end (of hair, etc.)</text></gloss></sense><sense id="tumayo_2" guid="2b46b4b3-d9a9-5ee1-b7cf-66c761d385df"><grammatical-info value="Verb"/><gloss lang="en"><text>to take one's place (of a guard, etc.)</text></gloss></sense><sense id="tumayo_3" guid="04b9bfe7-4d77-51b3-9013-8b70c950f296"><grammatical-info value="Verb"/><gloss lang="en"><text>to take the place of someone as a substitute</text></gloss></sense><sense id="tumayo_4" guid="4cbf01fc-71ec-5256-a18d-30c15339b232"><grammatical-info value="Verb"/><gloss lang="en"><text>to become hard and erect (of the penis, etc.)</text></gloss></sense><sense id="tumayo_5" guid="d5c82218-9789-5ad8-b632-cfd933a38b2f"><grammatical-info value="Verb"/><gloss lang="en"><text>complete aspect of tumayo</text></gloss></sense></entry>
