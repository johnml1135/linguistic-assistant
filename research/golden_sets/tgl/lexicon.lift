<entry id="anak" guid="5f14ce12-8486-5c6f-967a-3cadbfbcc411"><lexical-unit><form lang="tl"><text>anak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="anak_0" guid="69762bec-63ff-57aa-a533-0595baf0c478"><grammatical-info value="Noun"/><gloss lang="en"><text>child; offspring</text></gloss></sense><sense id="anak_1" guid="571b0575-49ab-599b-9583-302841a7ccf8"><grammatical-info value="Noun"/><gloss lang="en"><text>native of (used in certain expressions)</text></gloss></sense><sense id="anak_2" guid="c977a3f6-d833-5a0a-9470-38c29ae7b923"><grammatical-info value="Noun"/><gloss lang="en"><text>term of address to a child, especially toward one's child</text></gloss></sense><sense id="anak_3" guid="e0536bed-6c38-500c-961a-d87272093dd5"><grammatical-info value="Noun"/><gloss lang="en"><text>kin; relative; relation</text></gloss></sense></entry>
<entry id="anas" guid="0a9b1e00-9011-519e-94f8-6e1c1a16e568"><lexical-unit><form lang="tl"><text>anas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="anas_0" guid="426ade29-d053-5ee2-9241-b6b69ebfffd1"><grammatical-info value="Noun"/><gloss lang="en"><text>low tone of speech</text></gloss></sense><sense id="anas_1" guid="f45b7c40-59dc-5526-996a-cf2116d7d48d"><grammatical-info value="Noun"/><gloss lang="en"><text>whisper</text></gloss></sense></entry>
