<entry id="tumama" guid="d607fb09-7681-5089-a39d-7c60dcae6ac2"><lexical-unit><form lang="tl"><text>tumama</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tumama_0" guid="1fb838fc-3918-5b0b-8d53-3411d3451e31"><grammatical-info value="Verb"/><gloss lang="en"><text>to hit the mark; to be successful in hitting or striking something</text></gloss></sense><sense id="tumama_1" guid="43212e39-134f-5de2-bbb8-474a917c28d1"><grammatical-info value="Verb"/><gloss lang="en"><text>to be able to answer correctly</text></gloss></sense><sense id="tumama_2" guid="7708568c-49cb-5f0c-b0ce-fb2f02e0e5d5"><grammatical-info value="Verb"/><gloss lang="en"><text>to be able to guess correctly</text></gloss></sense><sense id="tumama_3" guid="f2b798f6-0ff5-57f5-81d9-ef7d50cc231b"><grammatical-info value="Verb"/><gloss lang="en"><text>to win (in a lottery, etc.)</text></gloss></sense><sense id="tumama_4" guid="7ef9cc80-1466-5593-80c7-d6fe8fe96239"><grammatical-info value="Verb"/><gloss lang="en"><text>to fit; to be suited to</text></gloss></sense><sense id="tumama_5" guid="e4987d71-be45-5a21-9cc1-e6ae711518ec"><grammatical-info value="Verb"/><gloss lang="en"><text>to fit in size</text></gloss></sense><sense id="tumama_6" guid="681e3e43-764c-50df-ba6b-9791198321fb"><grammatical-info value="Verb"/><gloss lang="en"><text>complete aspect of tumama</text></gloss></sense></entry>
