<entry id="andres" guid="2725cf3b-8b71-5e21-84c0-7b0ad354a2a5"><lexical-unit><form lang="tl"><text>andres</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="andres_0" guid="f474bdf6-6404-5488-82bc-3ffc21f4361e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Andrew</text></gloss></sense><sense id="andres_1" guid="ea600bf4-a9bb-57d3-be36-08cfc649f4f4"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a male given name from Spanish, equivalent to English Andrew</text></gloss></sense><sense id="andres_2" guid="52f060ac-2ed0-5882-8ba9-749ae1dfcf90"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a surname from Spanish</text></gloss></sense></entry>
<entry id="ang" guid="ccce879b-ea01-5676-a50f-ba5fc6776073"><lexical-unit><form lang="tl"><text>ang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ang_0" guid="84b724dc-a3fb-5be1-85b3-a804a674035c"><grammatical-info value="Adposition"/><gloss lang="en"><text>marks a noun or noun phrase as the clause’s pivot or focused argument; in verbal clauses, the verb’s trigger/voice affix determines the semantic role of the marked phrase. In other words, it:</text></gloss></sense><sense id="ang_1" guid="0894bf86-24c5-57ea-8214-41fb20b4ea29"><grammatical-info value="Adposition"/><gloss lang="en"><text>marks the agent, doer, or experiencer of the action in actor-trigger verbs</text></gloss></sense><sense id="ang_2" guid="408b4cf4-266d-5196-9095-1f5b2a854cea"><grammatical-info value="Adposition"/><gloss lang="en"><text>marks the patient, undergoer, or theme of the action in patient-trigger verbs</text></gloss></sense><sense id="ang_3" guid="3e1edaf4-1fbf-5792-a47b-4e83f75668c7"><grammatical-info value="Adposition"/><gloss lang="en"><text>marks the recipient or beneficiary of the action in benefactive-trigger verbs</text></gloss></sense><sense id="ang_4" guid="34105c72-cf94-5bf0-809d-541e98152594"><grammatical-info value="Adposition"/><gloss lang="en"><text>marks the location or direction of the action in locative-trigger verbs</text></gloss></sense><sense id="ang_5" guid="765775c4-5e5c-531f-8a8f-0c89464e9dac"><grammatical-info value="Adposition"/><gloss lang="en"><text>marks the instrument or means of performing the action in instrumental-trigger verbs</text></gloss></sense><sense id="ang_6" guid="49d6eac0-0bdb-5271-a6d6-6ee1a6a4ea7d"><grammatical-info value="Adposition"/><gloss lang="en"><text>marks the reason or cause of the action in reason-trigger verbs</text></gloss></sense><sense id="ang_7" guid="494c51b3-b539-5f83-80b4-5aae75cf079e"><grammatical-info value="Adposition"/><gloss lang="en"><text>used with a quality for emphasis and to give it an adjectival meaning</text></gloss></sense></entry>
<entry id="angel" guid="68fed672-2eca-5bea-a21c-9ad26a63f256"><lexical-unit><form lang="tl"><text>angel</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="angel_0" guid="4f535b58-f46f-5132-8553-383d20fe23ed"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a female given name from English</text></gloss></sense><sense id="angel_1" guid="08e624af-2ed7-54ee-8f98-ae6898a1466f"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a male given name from Spanish</text></gloss></sense></entry>
