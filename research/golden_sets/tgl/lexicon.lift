<entry id="saduceo" guid="13494758-0713-5df1-b6a9-01e913183a18"><lexical-unit><form lang="tl"><text>saduceo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="saduceo_0" guid="76c88c6f-0af1-57ac-9d50-5fc90180b62e"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative spelling of Saduseo</text></gloss></sense></entry>
<entry id="saduseo" guid="bee96376-4ad8-5f4d-9f1d-8eac6198c181"><lexical-unit><form lang="tl"><text>saduseo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="saduseo_0" guid="0fd4fdb6-e8a7-55bb-9e31-2d6ca8c18b87"><grammatical-info value="Noun"/><gloss lang="en"><text>Sadducee</text></gloss></sense></entry>
