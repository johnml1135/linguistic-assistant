<entry id="iba" guid="d5677766-b5a8-55cf-af91-17d7aeeb83b4"><lexical-unit><form lang="tl"><text>iba</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="iba_0" guid="f89168c2-20ac-57da-9667-f68353c57fc0"><grammatical-info value="Adjective"/><gloss lang="en"><text>another; different one</text></gloss></sense><sense id="iba_1" guid="c1a714ea-19fc-5506-93aa-9dedad44d885"><grammatical-info value="Adjective"/><gloss lang="en"><text>different</text></gloss></sense><sense id="iba_2" guid="865b7e06-27d4-5736-8c48-214c260b9f16"><grammatical-info value="Adjective"/><gloss lang="en"><text>another; some other</text></gloss></sense><sense id="iba_3" guid="3647fca9-9290-5d3d-98a0-a2202a49df67"><grammatical-info value="Adjective"/><gloss lang="en"><text>new</text></gloss></sense><sense id="iba_4" guid="4ff78bae-c74b-58dc-ab2f-d41b7b19fe1f"><grammatical-info value="Adjective"/><gloss lang="en"><text>Otaheite gooseberry; Phyllanthus acidus (tree and fruit)</text></gloss></sense><sense id="iba_5" guid="3415334b-4e57-5096-88bd-3ad0593f243a"><grammatical-info value="Adjective"/><gloss lang="en"><text>bilimbi (tree and fruit)</text></gloss></sense><sense id="iba_6" guid="537551f3-8f3b-5ac3-81f8-7ae9f7074109"><grammatical-info value="Adjective"/><gloss lang="en"><text>Iba (a municipality, the capital of Zambales, Central Luzon, Philippines)</text></gloss></sense></entry>
<entry id="ibaba" guid="d61bccd3-0a74-50ee-a715-eb4eb1ae37fd"><lexical-unit><form lang="tl"><text>ibaba</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ibaba_0" guid="7b96c74d-070e-5792-ac01-47f7208b40ed"><grammatical-info value="Noun"/><gloss lang="en"><text>place under; underneath; under part</text></gloss></sense><sense id="ibaba_1" guid="2f390369-b5bb-57a7-a8b6-af03c32f544c"><grammatical-info value="Noun"/><gloss lang="en"><text>lower part</text></gloss></sense><sense id="ibaba_2" guid="7e5734dd-4d5a-5f44-b32b-88c7d00784e5"><grammatical-info value="Noun"/><gloss lang="en"><text>ground floor; basement; downstairs</text></gloss></sense><sense id="ibaba_3" guid="4bb48c90-8bc7-5823-9bb2-623b2b865d1a"><grammatical-info value="Noun"/><gloss lang="en"><text>base; foot (of a staircase, mountain, etc.)</text></gloss></sense><sense id="ibaba_4" guid="fa4c5fc9-a4fb-50f6-b02b-c06220dde11e"><grammatical-info value="Noun"/><gloss lang="en"><text>southern part of a district or town; opposite of the uptown district</text></gloss></sense><sense id="ibaba_5" guid="fba8111a-13be-5f24-a9ab-a7ac69c2c5e6"><grammatical-info value="Noun"/><gloss lang="en"><text>to bring downstairs</text></gloss></sense><sense id="ibaba_6" guid="015b4c16-bacf-5997-a44d-66352927a9d5"><grammatical-info value="Noun"/><gloss lang="en"><text>to put down a thing on something</text></gloss></sense><sense id="ibaba_7" guid="f41dba46-cc2d-5a09-987d-0c13e1d31131"><grammatical-info value="Noun"/><gloss lang="en"><text>to bring down (from a tree, pole, etc.)</text></gloss></sense></entry>
