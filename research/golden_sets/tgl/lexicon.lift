<entry id="muli" guid="f65711c2-f756-519b-9c28-af0ac7637fdc"><lexical-unit><form lang="tl"><text>muli</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="muli_0" guid="612261cd-9016-5231-be1b-87f887a12fdc"><grammatical-info value="Adverb"/><gloss lang="en"><text>again</text></gloss></sense><sense id="muli_1" guid="10951a5f-75a8-56fa-b410-c0fe9cb7bc78"><grammatical-info value="Adverb"/><gloss lang="en"><text>apheretic form of umuli (infinitive)</text></gloss></sense><sense id="muli_2" guid="a2abf66e-5a67-51f2-aebb-ae445b451dd8"><grammatical-info value="Adverb"/><gloss lang="en"><text>alternative form of mole</text></gloss></sense><sense id="muli_3" guid="eed6df86-838e-5f42-a2ad-3a74e3d9f6ac"><grammatical-info value="Adverb"/><gloss lang="en"><text>resemblance; similarity (especially by inheritance of the parents' traits)</text></gloss></sense><sense id="muli_4" guid="4939b319-f69d-5775-95a4-224897a67fbb"><grammatical-info value="Adverb"/><gloss lang="en"><text>looking like one's parents due to inheritance</text></gloss></sense><sense id="muli_5" guid="979bf461-4b53-57ce-b272-a6aaf4544990"><grammatical-info value="Adverb"/><gloss lang="en"><text>opening of one's eyes</text></gloss></sense><sense id="muli_6" guid="e745fbe7-a9b6-5527-bae4-83c390ddf33d"><grammatical-info value="Adverb"/><gloss lang="en"><text>examine something well to learn more about</text></gloss></sense><sense id="muli_7" guid="474ff8de-3321-5386-8ffc-f94c4d6245c1"><grammatical-info value="Adverb"/><gloss lang="en"><text>remembering; bringing to mind</text></gloss></sense></entry>
