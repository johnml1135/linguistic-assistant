<entry id="lobo" guid="5884d266-c4fb-57df-a02e-ffb65802f998"><lexical-unit><form lang="tl"><text>lobo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lobo_0" guid="78cb3b34-17f8-537b-ab3d-cc0bc9fe9b48"><grammatical-info value="Noun"/><gloss lang="en"><text>wolf</text></gloss></sense><sense id="lobo_1" guid="6011b60d-d734-554e-ab4e-445b209c012e"><grammatical-info value="Noun"/><gloss lang="en"><text>balloon</text></gloss></sense><sense id="lobo_2" guid="cd5611c6-1fd3-5663-a061-5d850c382ee0"><grammatical-info value="Noun"/><gloss lang="en"><text>Lobo (a municipality of Batangas, Philippines)</text></gloss></sense><sense id="lobo_3" guid="79f6ec9d-442a-58ba-a30b-4ba5b243d36a"><grammatical-info value="Noun"/><gloss lang="en"><text>Lobo River (A river that flows in the municipalities Lobo, Rosario, Taysan and San Juan that is located in the province of Batangas, Philippines)</text></gloss></sense></entry>
<entry id="lola" guid="100bef87-0579-58bc-bc37-f1f52dfa3e06"><lexical-unit><form lang="tl"><text>lola</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lola_0" guid="45d4f8d2-f555-5310-aa95-ebf133cf5dad"><grammatical-info value="Noun"/><gloss lang="en"><text>honorific used before the name of a grandmother: Grandma; Grandmama; Granny</text></gloss></sense><sense id="lola_1" guid="2b8544d1-e207-5ea8-b4c9-a5d85ae25123"><grammatical-info value="Noun"/><gloss lang="en"><text>grandmother</text></gloss></sense><sense id="lola_2" guid="96e07a95-56b3-564a-b76a-8ad901a0ec54"><grammatical-info value="Noun"/><gloss lang="en"><text>term of address for an old woman</text></gloss></sense><sense id="lola_3" guid="0e1113c6-804f-58dd-9858-af36d02ad743"><grammatical-info value="Noun"/><gloss lang="en"><text>obsolete spelling of lula (“dizzy”)</text></gloss></sense><sense id="lola_4" guid="c8a46a6a-6fdf-5455-be6f-30e5bb692fe9"><grammatical-info value="Noun"/><gloss lang="en"><text>obsolete spelling of lula (“diziness; seasickness; acrophobia”)</text></gloss></sense></entry>
<entry id="loob" guid="d885152c-4583-58f2-9f45-89ffd7678f07"><lexical-unit><form lang="tl"><text>loob</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="loob_0" guid="2389b6f8-10fd-5da9-9a84-32e8e414a123"><grammatical-info value="Noun"/><gloss lang="en"><text>inside; interior; inner part</text></gloss></sense><sense id="loob_1" guid="71f51a67-a301-5729-8b7e-ea313c2a1b3c"><grammatical-info value="Noun"/><gloss lang="en"><text>underside of clothing</text></gloss></sense><sense id="loob_2" guid="9226b748-de66-5661-be5c-2fe8f790456e"><grammatical-info value="Noun"/><gloss lang="en"><text>will; volition; disposition</text></gloss></sense><sense id="loob_3" guid="15335a50-ff8c-5ec6-943e-a8fd31f6dcb3"><grammatical-info value="Noun"/><gloss lang="en"><text>courage; valor</text></gloss></sense><sense id="loob_4" guid="4b1b0d55-0981-5949-bc54-1cd6d4b04c34"><grammatical-info value="Noun"/><gloss lang="en"><text>manners; behavior</text></gloss></sense><sense id="loob_5" guid="71f74832-d517-5ef6-9b76-d6bcc43a2a06"><grammatical-info value="Noun"/><gloss lang="en"><text>bowels; core; essence (used in expressions)</text></gloss></sense><sense id="loob_6" guid="fce7d152-42fa-5ee5-b903-7110e09d5ab4"><grammatical-info value="Noun"/><gloss lang="en"><text>act of allowing something</text></gloss></sense><sense id="loob_7" guid="183fb75a-995e-50cf-9d35-bf69e364b20f"><grammatical-info value="Noun"/><gloss lang="en"><text>want; desire</text></gloss></sense></entry>
<entry id="lubha" guid="2684dbed-c5c4-50fd-a538-84e394cbdda9"><lexical-unit><form lang="tl"><text>lubha</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lubha_0" guid="e210a3bb-e006-5ddb-8008-620a8eeee809"><grammatical-info value="Noun"/><gloss lang="en"><text>severity; seriousness; gravity (of sickness, etc.)</text></gloss></sense><sense id="lubha_1" guid="10b78c03-b876-5f34-b27d-fe7f1034676a"><grammatical-info value="Noun"/><gloss lang="en"><text>extremely; very; too</text></gloss></sense></entry>
<entry id="lubid" guid="9294ff19-d40e-5931-9905-54e4e6e450ae"><lexical-unit><form lang="tl"><text>lubid</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lubid_0" guid="9646ced9-2163-583c-8684-6335021626aa"><grammatical-info value="Noun"/><gloss lang="en"><text>rope</text></gloss></sense><sense id="lubid_1" guid="f0395e45-8287-5357-9b62-efae265788ed"><grammatical-info value="Noun"/><gloss lang="en"><text>making of rope</text></gloss></sense><sense id="lubid_2" guid="5f6e55cd-d119-5d44-ab40-7d2d9276946b"><grammatical-info value="Noun"/><gloss lang="en"><text>fabrication; invention (of lies, excuses, etc.)</text></gloss></sense><sense id="lubid_3" guid="f0f7d29f-2718-5422-a52e-2115652c5c62"><grammatical-info value="Noun"/><gloss lang="en"><text>made into a rope</text></gloss></sense></entry>
