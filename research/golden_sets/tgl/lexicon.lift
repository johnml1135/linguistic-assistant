<entry id="sagot" guid="6fc0fa50-225e-58b5-8dcb-bc04460969e2"><lexical-unit><form lang="tl"><text>sagot</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sagot_0" guid="39a5356d-5952-537b-b985-9645c272c31a"><grammatical-info value="Noun"/><gloss lang="en"><text>reply; response</text></gloss></sense><sense id="sagot_1" guid="b878534d-fd76-596d-bcbf-9ba63545e53a"><grammatical-info value="Noun"/><gloss lang="en"><text>answer; solution (to a problem)</text></gloss></sense><sense id="sagot_2" guid="ffe3e234-77c2-56a0-a3d5-844c288214af"><grammatical-info value="Noun"/><gloss lang="en"><text>backtalk (verbal impudence or argument especially to someone of authority)</text></gloss></sense><sense id="sagot_3" guid="28cf04f2-c7d7-50e5-bb6d-16d0ca8fb6d4"><grammatical-info value="Noun"/><gloss lang="en"><text>assumption of another's responsibility</text></gloss></sense><sense id="sagot_4" guid="e8069f56-0c9a-5df6-8240-2373e7059299"><grammatical-info value="Noun"/><gloss lang="en"><text>rebuttal</text></gloss></sense></entry>
<entry id="sagrado" guid="652172b6-27a1-5216-88bc-5b5ccf609842"><lexical-unit><form lang="tl"><text>sagrado</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sagrado_0" guid="550987b0-8f23-5fe0-98b1-63618bc41a93"><grammatical-info value="Adjective"/><gloss lang="en"><text>holy; sacred</text></gloss></sense></entry>
<entry id="sagutin" guid="ce47cf3a-2af8-5f7a-8866-faab8c24493a"><lexical-unit><form lang="tl"><text>sagutin</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sagutin_0" guid="b8fb3471-f970-53ad-b26c-03697d44f2c1"><grammatical-info value="Noun"/><gloss lang="en"><text>liabilities</text></gloss></sense><sense id="sagutin_1" guid="6b39320d-8fdc-521a-a5c3-de7b8d04bc02"><grammatical-info value="Noun"/><gloss lang="en"><text>to answer; to reply to (a letter, telephone call, etc.)</text></gloss></sense><sense id="sagutin_2" guid="4a621626-8422-52ce-a0e8-7cc745abbe21"><grammatical-info value="Noun"/><gloss lang="en"><text>to be responsible for; to answer for</text></gloss></sense><sense id="sagutin_3" guid="188cf29f-8bbd-5e9b-a46f-c26f1435c07a"><grammatical-info value="Noun"/><gloss lang="en"><text>to say yes to a suitor</text></gloss></sense></entry>
<entry id="sahod" guid="fa90fc48-10df-55d0-9772-09c39082792c"><lexical-unit><form lang="tl"><text>sahod</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sahod_0" guid="340902b9-9549-5b63-8350-46ec990a30bf"><grammatical-info value="Noun"/><gloss lang="en"><text>wage; salary</text></gloss></sense><sense id="sahod_1" guid="c6223d9b-dd0c-5fc6-b074-ad88c590edf5"><grammatical-info value="Noun"/><gloss lang="en"><text>receiving of one's salary</text></gloss></sense><sense id="sahod_2" guid="a863f0b0-2001-598a-96df-6d696d4371b7"><grammatical-info value="Noun"/><gloss lang="en"><text>payday</text></gloss></sense><sense id="sahod_3" guid="675908b9-3670-5e53-a4aa-4c3d8a0f678b"><grammatical-info value="Noun"/><gloss lang="en"><text>receptacle placed under something (to hold or catch flowing water, falling objects, etc.)</text></gloss></sense><sense id="sahod_4" guid="ff92f83e-21d5-5a0c-9c77-81c476cd744b"><grammatical-info value="Noun"/><gloss lang="en"><text>act of receiving something with open hand/s</text></gloss></sense><sense id="sahod_5" guid="e7c477bb-e7e9-5256-888a-ac8de3c87b02"><grammatical-info value="Noun"/><gloss lang="en"><text>position of an open hand in receiving something</text></gloss></sense><sense id="sahod_6" guid="dcf31e92-d13c-5ae3-bb95-0fa106e14ccd"><grammatical-info value="Noun"/><gloss lang="en"><text>setting aside some object falling from a high place</text></gloss></sense></entry>
<entry id="saka" guid="712e9dc4-1dd4-55f3-b356-751c6cb850d0"><lexical-unit><form lang="tl"><text>saka</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="saka_0" guid="163e3d62-4084-5fc6-85f7-5e327cd5746b"><grammatical-info value="Coordinating connective"/><gloss lang="en"><text>and</text></gloss></sense><sense id="saka_1" guid="e0d41035-0f5f-5286-be20-f3b74dc311c4"><grammatical-info value="Coordinating connective"/><gloss lang="en"><text>then; and then; afterwards</text></gloss></sense><sense id="saka_2" guid="048be8b1-cc64-5504-af06-699f71a9410e"><grammatical-info value="Coordinating connective"/><gloss lang="en"><text>besides; moreover</text></gloss></sense><sense id="saka_3" guid="b073296a-4d7a-5e14-92e3-a4f420c080e8"><grammatical-info value="Coordinating connective"/><gloss lang="en"><text>at another time</text></gloss></sense><sense id="saka_4" guid="f73b23fc-9b0f-5d94-beaa-e44e4656c46f"><grammatical-info value="Coordinating connective"/><gloss lang="en"><text>farming; cultivation of a piece of land</text></gloss></sense><sense id="saka_5" guid="500e6baa-f5ce-5226-88cc-1ba6db3476c2"><grammatical-info value="Coordinating connective"/><gloss lang="en"><text>farmland</text></gloss></sense><sense id="saka_6" guid="373b179a-bf26-5555-82d4-2bb903df3cb9"><grammatical-info value="Coordinating connective"/><gloss lang="en"><text>copying; tracing (of a drawing, figure, or design)</text></gloss></sense><sense id="saka_7" guid="a7c25f41-b455-5c6d-8a3f-ce6812137cf7"><grammatical-info value="Coordinating connective"/><gloss lang="en"><text>acquisition of goods by consignment</text></gloss></sense></entry>
<entry id="sakay" guid="8d373bc3-c93f-5e71-9099-a1d497f0bf6d"><lexical-unit><form lang="tl"><text>sakay</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sakay_0" guid="f888b26b-5442-5279-a543-1c6ac0992f23"><grammatical-info value="Noun"/><gloss lang="en"><text>ride; riding (of a vehicle, animal, etc.)</text></gloss></sense><sense id="sakay_1" guid="2d484efe-01cf-5e96-88db-19037b7a7275"><grammatical-info value="Noun"/><gloss lang="en"><text>rider; passenger</text></gloss></sense><sense id="sakay_2" guid="8d2bd391-1974-56c7-b7d4-b4fbc93cef3a"><grammatical-info value="Noun"/><gloss lang="en"><text>load; cargo</text></gloss></sense><sense id="sakay_3" guid="5efa9f58-595a-5118-b16b-fad995e43517"><grammatical-info value="Noun"/><gloss lang="en"><text>mounting of type composition on a printing machine</text></gloss></sense><sense id="sakay_4" guid="61484e69-0251-51b2-980b-8d3f8b79e2ee"><grammatical-info value="Noun"/><gloss lang="en"><text>number of type compositions needed (to complete printing of a publication on the machine)</text></gloss></sense><sense id="sakay_5" guid="8ac50a07-1048-5445-99e6-0cd5607872f2"><grammatical-info value="Noun"/><gloss lang="en"><text>act of mounting someone to have sexual intercourse</text></gloss></sense><sense id="sakay_6" guid="ea59e498-d5c3-5884-8ec6-58f5cc465990"><grammatical-info value="Noun"/><gloss lang="en"><text>conforming with others; going with the flow; playing along</text></gloss></sense><sense id="sakay_7" guid="df165c22-a889-54b8-b049-bd60e84b2d5f"><grammatical-info value="Noun"/><gloss lang="en"><text>riding (on a vehicle, animal, etc.)</text></gloss></sense></entry>
