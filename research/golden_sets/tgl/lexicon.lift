<entry id="sya" guid="b57bfae6-a0fb-5bb5-8765-025d572f35d5"><lexical-unit><form lang="tl"><text>sya</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sya_0" guid="21b60166-fd0f-568b-9307-7d9d837fc411"><grammatical-info value="Pronoun"/><gloss lang="en"><text>superseded, pre-2007 spelling of siya</text></gloss></sense></entry>
<entry id="taas" guid="b53c72b0-daeb-5f22-a9e5-d5f13f5b94f7"><lexical-unit><form lang="tl"><text>taas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="taas_0" guid="a1d63811-0d36-5ea1-91d0-00f396339fe8"><grammatical-info value="Noun"/><gloss lang="en"><text>height (distance from the base of something to the top)</text></gloss></sense><sense id="taas_1" guid="6a5dbd73-f639-56ab-9e49-461d1be9f56c"><grammatical-info value="Noun"/><gloss lang="en"><text>altitude; elevation above a given level</text></gloss></sense><sense id="taas_2" guid="55252d66-eba9-58e2-82ba-361e1e232a29"><grammatical-info value="Noun"/><gloss lang="en"><text>level; amount (of prices)</text></gloss></sense><sense id="taas_3" guid="b415146e-44fc-5761-a8e1-0b833bcecb8c"><grammatical-info value="Noun"/><gloss lang="en"><text>promotion (in one's position or office)</text></gloss></sense><sense id="taas_4" guid="3e3de94c-5260-5677-93d8-a2e4d8d61326"><grammatical-info value="Noun"/><gloss lang="en"><text>eminence; nobility</text></gloss></sense><sense id="taas_5" guid="033c3eec-6592-5a8c-9707-a2c166a8b13a"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative form of itaas</text></gloss></sense></entry>
