<entry id="sunggaban" guid="55248033-b7c3-534c-9463-0606a37a460e"><lexical-unit><form lang="tl"><text>sunggaban</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sunggaban_0" guid="18dc910e-e5be-53b7-82ec-80ff2d2a3461"><grammatical-info value="Verb"/><gloss lang="en"><text>to be seized or snatched suddenly</text></gloss></sense><sense id="sunggaban_1" guid="03db1e57-b510-59f6-88b7-1368f9399453"><grammatical-info value="Verb"/><gloss lang="en"><text>to be arrested suddenly</text></gloss></sense><sense id="sunggaban_2" guid="a8c1b044-d39e-5a0f-8406-3e13c0f38941"><grammatical-info value="Verb"/><gloss lang="en"><text>to be grabbed or accepted at once (as of an offer or opportunity)</text></gloss></sense></entry>
<entry id="sunod" guid="7013edd0-cb36-5f42-acd4-0168ab7ea03e"><lexical-unit><form lang="tl"><text>sunod</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sunod_0" guid="b5041590-8589-5476-9caf-17e8f1e31979"><grammatical-info value="Adjective"/><gloss lang="en"><text>following another; next; subsequent (of someone or something)</text></gloss></sense><sense id="sunod_1" guid="3cd115b6-0632-5a2d-84b3-36fa2c623e75"><grammatical-info value="Adjective"/><gloss lang="en"><text>based from (used with sa)</text></gloss></sense><sense id="sunod_2" guid="cbbf3507-f5aa-5c8a-9502-0f089b50290e"><grammatical-info value="Adjective"/><gloss lang="en"><text>one that follows another; the next</text></gloss></sense><sense id="sunod_3" guid="2038c372-bd6d-5887-91d7-d8b37f38c7b4"><grammatical-info value="Adjective"/><gloss lang="en"><text>act of obeying; act of following (orders, instructions, etc.)</text></gloss></sense><sense id="sunod_4" guid="a651a6f3-c725-55e1-a636-2b26e68525f0"><grammatical-info value="Adjective"/><gloss lang="en"><text>act of following someone</text></gloss></sense><sense id="sunod_5" guid="70d6ff36-f75b-559f-ad01-d11f90aa61e7"><grammatical-info value="Adjective"/><gloss lang="en"><text>act of following a model or plan (in making something)</text></gloss></sense></entry>
<entry id="sunugin" guid="d9832226-4e45-5af6-93d1-b072d0125fa0"><lexical-unit><form lang="tl"><text>sunugin</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sunugin_0" guid="f1cbc15d-ba59-5549-972e-736b09b47c18"><grammatical-info value="Verb"/><gloss lang="en"><text>to burn</text></gloss></sense><sense id="sunugin_1" guid="190f275c-7584-548c-b808-a88f9e7aeb98"><grammatical-info value="Verb"/><gloss lang="en"><text>to overcook</text></gloss></sense></entry>
<entry id="suot" guid="e840768e-8008-5912-8a99-891923c81462"><lexical-unit><form lang="tl"><text>suot</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="suot_0" guid="bacf0199-5d99-5ad2-9e6e-1f67c93115a0"><grammatical-info value="Noun"/><gloss lang="en"><text>clothing; clothes; what one is wearing</text></gloss></sense><sense id="suot_1" guid="eb36cd2d-4d4e-513c-9128-be27b001238d"><grammatical-info value="Noun"/><gloss lang="en"><text>entry into somewhere extremely tight or narrow (such as a hole, small opening, thick forest, etc.)</text></gloss></sense><sense id="suot_2" guid="44f96c05-36a1-55a3-b401-22086d8affe5"><grammatical-info value="Noun"/><gloss lang="en"><text>insertion into a hole (as into the eye of a needle)</text></gloss></sense><sense id="suot_3" guid="6c1fbbd2-ee98-58d7-9079-0fb2af040129"><grammatical-info value="Noun"/><gloss lang="en"><text>wearing of clothes, footwear, eyeglasses, etc.</text></gloss></sense><sense id="suot_4" guid="dea7f11f-363f-5ace-a557-2d99ae056333"><grammatical-info value="Noun"/><gloss lang="en"><text>presently worn (of clothes)</text></gloss></sense></entry>
<entry id="supot" guid="7555522a-1fa2-5f1e-a20f-829661e3cfef"><lexical-unit><form lang="tl"><text>supot</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="supot_0" guid="2e4e718c-7478-556a-9da5-3facaf7e2a6e"><grammatical-info value="Noun"/><gloss lang="en"><text>plastic bag</text></gloss></sense><sense id="supot_1" guid="a8bf7c53-1d9d-52bf-86cf-f641ddf742c7"><grammatical-info value="Noun"/><gloss lang="en"><text>bag (of paper, plastic, cloth, etc.)</text></gloss></sense><sense id="supot_2" guid="8f6e7517-2dc9-52dd-9acd-0775c4bb90a5"><grammatical-info value="Noun"/><gloss lang="en"><text>small money bag</text></gloss></sense><sense id="supot_3" guid="f9a2c572-27c8-5d0b-90a2-fa81e33eeb7b"><grammatical-info value="Noun"/><gloss lang="en"><text>pocket; small bag or pitch (especially on the holes of a billiards table)</text></gloss></sense><sense id="supot_4" guid="714ccf16-e588-5bd7-8873-816f12a12f9f"><grammatical-info value="Noun"/><gloss lang="en"><text>gall bladder</text></gloss></sense><sense id="supot_5" guid="a9cb728b-a0ee-54f5-9b80-d39c6543b556"><grammatical-info value="Noun"/><gloss lang="en"><text>sheath; scabbard</text></gloss></sense><sense id="supot_6" guid="d0666feb-a181-5e4c-8ef7-9d9208466b7f"><grammatical-info value="Noun"/><gloss lang="en"><text>pillowcase</text></gloss></sense><sense id="supot_7" guid="6b7e6d71-20b0-5b37-963b-faadc2edb579"><grammatical-info value="Noun"/><gloss lang="en"><text>uncircumcised</text></gloss></sense></entry>
