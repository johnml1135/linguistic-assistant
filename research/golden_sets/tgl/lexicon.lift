<entry id="isip" guid="9110ac4c-3ccd-5854-8f7f-117f7901a6ce"><lexical-unit><form lang="tl"><text>isip</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="isip_0" guid="8bdbe1c0-4b6d-5616-b1ee-ab0b05b1e619"><grammatical-info value="Noun"/><gloss lang="en"><text>thinking; thought</text></gloss></sense><sense id="isip_1" guid="ad0df544-8584-56bc-94e9-a1633a2ea175"><grammatical-info value="Noun"/><gloss lang="en"><text>mind; intellect</text></gloss></sense><sense id="isip_2" guid="168d8078-3974-508a-a308-a9bdfd9cd714"><grammatical-info value="Noun"/><gloss lang="en"><text>intelligence; talent</text></gloss></sense><sense id="isip_3" guid="78de205e-5259-54bb-9ed2-442f904630b8"><grammatical-info value="Noun"/><gloss lang="en"><text>idea; notion; understanding</text></gloss></sense><sense id="isip_4" guid="23017d4e-4f4d-5663-afd8-8e88f103799e"><grammatical-info value="Noun"/><gloss lang="en"><text>opinion</text></gloss></sense><sense id="isip_5" guid="7e11b9b6-ca73-5620-bc2a-a554bccde08d"><grammatical-info value="Noun"/><gloss lang="en"><text>common sense; judgement</text></gloss></sense><sense id="isip_6" guid="c634607c-43e3-5777-ace5-9e3e9af83fb3"><grammatical-info value="Noun"/><gloss lang="en"><text>counting; computation; calculation; reckoning</text></gloss></sense><sense id="isip_7" guid="03744d63-407d-54de-a972-2e29abf3087d"><grammatical-info value="Noun"/><gloss lang="en"><text>accounting, crediting, or attribution of something to someone</text></gloss></sense></entry>
<entry id="isipan" guid="cd41a29a-273b-5628-bd95-d0a3a9aed794"><lexical-unit><form lang="tl"><text>isipan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="isipan_0" guid="ae2c25e3-1e26-51da-ad9a-5b7f59b99f21"><grammatical-info value="Noun"/><gloss lang="en"><text>mind (ability for rational thought, to be aware of things, to remember things, and to focus the thoughts)</text></gloss></sense><sense id="isipan_1" guid="54c4fc77-7b13-5357-a54e-596b2510e729"><grammatical-info value="Noun"/><gloss lang="en"><text>to be presented with ideas or thoughts</text></gloss></sense><sense id="isipan_2" guid="b1c6f60a-a713-5eb4-bee1-5b4f5ce25c04"><grammatical-info value="Noun"/><gloss lang="en"><text>counting sticks</text></gloss></sense></entry>
<entry id="isipin" guid="e249bdc3-a1e4-507e-962f-934eecd41590"><lexical-unit><form lang="tl"><text>isipin</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="isipin_0" guid="d0c671f0-f7c1-5f29-b975-fb70f3f6c32c"><grammatical-info value="Noun"/><gloss lang="en"><text>things that need careful or deep thinking; something to think about</text></gloss></sense><sense id="isipin_1" guid="68c8e37a-efa3-5cfb-b0cb-26c775f6770c"><grammatical-info value="Noun"/><gloss lang="en"><text>problem</text></gloss></sense><sense id="isipin_2" guid="d7a29444-a035-5503-a324-615b9850b573"><grammatical-info value="Noun"/><gloss lang="en"><text>needing careful or deep thinking</text></gloss></sense><sense id="isipin_3" guid="e314d495-4b09-550c-8ee9-190e5940d2e3"><grammatical-info value="Noun"/><gloss lang="en"><text>to be thought of; to be thought about</text></gloss></sense><sense id="isipin_4" guid="058cacac-a48b-521a-b821-af271eace04c"><grammatical-info value="Noun"/><gloss lang="en"><text>to be attempted to be remembered</text></gloss></sense><sense id="isipin_5" guid="aa099b18-75c7-51d1-97e4-e7325576fc58"><grammatical-info value="Noun"/><gloss lang="en"><text>to be studied carefully before making a decision</text></gloss></sense><sense id="isipin_6" guid="a2276493-6824-505b-8119-83dbebf62628"><grammatical-info value="Noun"/><gloss lang="en"><text>to be counted; to be computed; to be reckoned</text></gloss></sense></entry>
