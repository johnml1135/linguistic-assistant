<entry id="basket" guid="65cb840a-3cfb-58e0-b5e2-8c7a769738b3"><lexical-unit><form lang="tl"><text>basket</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="basket_0" guid="f5af0614-613a-5e2a-a03a-e64aab1b9fcf"><grammatical-info value="Noun"/><gloss lang="en"><text>basket</text></gloss></sense><sense id="basket_1" guid="9caeb83c-1683-5df1-99d0-58d94dbc4eaa"><grammatical-info value="Noun"/><gloss lang="en"><text>shopping basket</text></gloss></sense><sense id="basket_2" guid="32053daa-0ab5-5c09-9ec4-9da65232e409"><grammatical-info value="Noun"/><gloss lang="en"><text>wastebasket</text></gloss></sense><sense id="basket_3" guid="11f02b87-6f35-5503-8206-6ede1b7d6324"><grammatical-info value="Noun"/><gloss lang="en"><text>basket (circular hoop from which a net is suspended)</text></gloss></sense><sense id="basket_4" guid="0a3f230a-96ee-5675-9e50-b46cc5be4201"><grammatical-info value="Noun"/><gloss lang="en"><text>rejection; disapproval; nonacceptance (in a submission, courtship, etc.)</text></gloss></sense><sense id="basket_5" guid="b85c0907-bf1b-5eba-8eed-a8f17c33fb9e"><grammatical-info value="Noun"/><gloss lang="en"><text>disapproved; rejected (in a submission, courtship, etc.)</text></gloss></sense></entry>
