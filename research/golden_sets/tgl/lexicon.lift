<entry id="tumpok" guid="f80848a8-47dd-5369-b668-5db362b0377c"><lexical-unit><form lang="tl"><text>tumpok</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tumpok_0" guid="3c173a89-54ac-58e1-81bb-6e2edae7c528"><grammatical-info value="Noun"/><gloss lang="en"><text>small heap; small mound; small pile (of fish, shrimp, grain, soil, etc.)</text></gloss></sense></entry>
