<entry id="yari" guid="30395335-693e-5587-a777-2b16b5dfc283"><lexical-unit><form lang="tl"><text>yari</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="yari_0" guid="5892e6ed-9f49-5690-b0e9-0e32cc4a6f8d"><grammatical-info value="Noun"/><gloss lang="en"><text>root of words meaning “event” or “occurrence”, such as mangyari or pangyayari</text></gloss></sense><sense id="yari_1" guid="e6d5d358-2f6a-5de2-b4fc-b8887af521b3"><grammatical-info value="Noun"/><gloss lang="en"><text>root of words meaning “power”, such as kapangyarihan</text></gloss></sense><sense id="yari_2" guid="6ab2adf4-987c-5987-8783-b2c14214d0a5"><grammatical-info value="Noun"/><gloss lang="en"><text>act or manner of making or manufacturing something</text></gloss></sense><sense id="yari_3" guid="e2a13328-175f-5dbe-9b09-1717ee16d6e3"><grammatical-info value="Noun"/><gloss lang="en"><text>product; thing manufactured or made</text></gloss></sense><sense id="yari_4" guid="df4bd214-e2d8-5775-a095-019b41d4c9b8"><grammatical-info value="Noun"/><gloss lang="en"><text>used with sa to mean "made of"</text></gloss></sense><sense id="yari_5" guid="510d847e-1e2c-58e6-8640-e417d7a5c6d5"><grammatical-info value="Noun"/><gloss lang="en"><text>completion or finishing of something being done, made, or manufactured</text></gloss></sense><sense id="yari_6" guid="39d7e5f0-fd5a-5e7d-9dbf-5f574f74831d"><grammatical-info value="Noun"/><gloss lang="en"><text>output; amount produced</text></gloss></sense><sense id="yari_7" guid="7696c042-268e-5b4d-9201-9b49fe4978f2"><grammatical-info value="Noun"/><gloss lang="en"><text>style; make; build</text></gloss></sense></entry>
<entry id="yayaman" guid="344f2bf5-aa4d-5526-b297-70340a38c1dc"><lexical-unit><form lang="tl"><text>yayaman</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="yayaman_0" guid="e3fc273b-20dc-54c7-b334-6643e1f78afa"><grammatical-info value="Coordinating connective"/><gloss lang="en"><text>alternative form of yamang</text></gloss></sense><sense id="yayaman_1" guid="e3edd1c6-f2e6-5a54-ac2e-e606e6919ded"><grammatical-info value="Coordinating connective"/><gloss lang="en"><text>contemplative aspect of yumaman</text></gloss></sense></entry>
<entry id="yayanig" guid="1491744a-d3ec-51c9-893d-74e830c07bd6"><lexical-unit><form lang="tl"><text>yayanig</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="yayanig_0" guid="348b0664-676f-5d1c-a5ea-a9374bd8c5b0"></sense></entry>
<entry id="yelo" guid="94268f4f-2684-5213-9963-3e706b7a5029"><lexical-unit><form lang="tl"><text>yelo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="yelo_0" guid="ca33bb21-6189-56a7-af2b-821cf31abd56"><grammatical-info value="Noun"/><gloss lang="en"><text>ice</text></gloss></sense><sense id="yelo_1" guid="5906ded6-558c-5c80-930f-8271fb9de801"><grammatical-info value="Noun"/><gloss lang="en"><text>hail</text></gloss></sense><sense id="yelo_2" guid="f849f4c7-1072-58c9-8af6-9a280f03c323"><grammatical-info value="Noun"/><gloss lang="en"><text>yellow (color)</text></gloss></sense></entry>
<entry id="yumakap" guid="76e75f05-a889-5e00-be0b-70fab1fddb90"><lexical-unit><form lang="tl"><text>yumakap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="yumakap_0" guid="dc6ae44a-0f50-5729-b1a8-51125c443117"><grammatical-info value="Verb"/><gloss lang="en"><text>to hug; to embrace; to fold; to enfold or infold in the arms to show love</text></gloss></sense><sense id="yumakap_1" guid="53d21b31-3b73-5197-88f9-f346609bec02"><grammatical-info value="Verb"/><gloss lang="en"><text>to clasp to the breast</text></gloss></sense><sense id="yumakap_2" guid="266b0f12-ecbe-514c-85db-b0532c523edc"><grammatical-info value="Verb"/><gloss lang="en"><text>to espouse; to take up or make one's own</text></gloss></sense><sense id="yumakap_3" guid="c659603a-51d3-5d35-9cfc-b89231b5079c"><grammatical-info value="Verb"/><gloss lang="en"><text>complete aspect of yumakap</text></gloss></sense></entry>
<entry id="yumaman" guid="f91378bf-bbf1-5049-8808-704cf7985003"><lexical-unit><form lang="tl"><text>yumaman</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="yumaman_0" guid="77db87c7-ec20-547a-85a5-4a72268511e6"><grammatical-info value="Verb"/><gloss lang="en"><text>to become rich or wealthy</text></gloss></sense><sense id="yumaman_1" guid="750708aa-2330-5b3e-ba9b-a6036687116a"><grammatical-info value="Verb"/><gloss lang="en"><text>complete aspect of yumaman</text></gloss></sense></entry>
<entry id="yumuko" guid="d586f5ce-4c86-58ec-a950-77e5f64718bc"><lexical-unit><form lang="tl"><text>yumuko</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="yumuko_0" guid="dabe5728-8897-598f-be7a-569eb81ad677"><grammatical-info value="Verb"/><gloss lang="en"><text>to bend; to stoop; to bend down</text></gloss></sense><sense id="yumuko_1" guid="b5ddf409-315c-5ca3-8137-5a144c536011"><grammatical-info value="Verb"/><gloss lang="en"><text>to bow one's head (in respect or greeting)</text></gloss></sense><sense id="yumuko_2" guid="f639be47-2a27-5691-b2b0-82c88963cc2e"><grammatical-info value="Verb"/><gloss lang="en"><text>to respect (someone)</text></gloss></sense><sense id="yumuko_3" guid="4ea1ffde-397c-5e54-a3bc-330bb5d0d6d6"><grammatical-info value="Verb"/><gloss lang="en"><text>complete aspect of yumuko</text></gloss></sense></entry>
<entry id="yumurak" guid="2d2ce6c6-ae50-552c-b7ed-eb3437411abe"><lexical-unit><form lang="tl"><text>yumurak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="yumurak_0" guid="7ea3ab12-a147-5407-a437-6663756eb69f"><grammatical-info value="Verb"/><gloss lang="en"><text>to tread on; to trample on; to crush</text></gloss></sense><sense id="yumurak_1" guid="e12b82eb-0f16-54d3-9129-875ca2ac3714"><grammatical-info value="Verb"/><gloss lang="en"><text>to disregard; to scorn</text></gloss></sense><sense id="yumurak_2" guid="6c3eb079-cbcf-555a-9cee-2fe81477e6c5"><grammatical-info value="Verb"/><gloss lang="en"><text>to violate; to infringe or breach someone's right, etc.</text></gloss></sense><sense id="yumurak_3" guid="20dcd9b6-084a-5be6-a9e1-8736255c542d"><grammatical-info value="Verb"/><gloss lang="en"><text>complete aspect of yumurak</text></gloss></sense></entry>
<entry id="yun" guid="e5fe3f10-4cd7-55fb-ba55-35a446e1d467"><lexical-unit><form lang="tl"><text>yun</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="yun_0" guid="289d7dbb-1510-56ae-a95d-e2107f968b54"><grammatical-info value="Pronoun"/><gloss lang="en"><text>alternative spelling of 'yun</text></gloss></sense></entry>
