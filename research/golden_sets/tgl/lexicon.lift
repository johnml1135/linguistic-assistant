<entry id="isakay" guid="3bf301f8-51b3-5ebd-975c-08c368576e48"><lexical-unit><form lang="tl"><text>isakay</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="isakay_0" guid="6f50ac89-c7fc-5f3a-ab3a-745fa35a44aa"><grammatical-info value="Verb"/><gloss lang="en"><text>to take in as a passenger</text></gloss></sense><sense id="isakay_1" guid="7ade1b87-9ab7-5464-991b-b477923450a7"><grammatical-info value="Verb"/><gloss lang="en"><text>to load (on an animal or a vehicle)</text></gloss></sense><sense id="isakay_2" guid="e1add3ac-b0e3-586b-be86-9c5e20425060"><grammatical-info value="Verb"/><gloss lang="en"><text>to help (someone) in getting (on an animal or vehicle)</text></gloss></sense><sense id="isakay_3" guid="d2ee36da-26ab-5eb9-ab31-0e4d38652cfb"><grammatical-info value="Verb"/><gloss lang="en"><text>to mount (a set of compound types) on a printing press for running or operation</text></gloss></sense><sense id="isakay_4" guid="d2a71540-5140-5741-886c-44c58f13dfb9"><grammatical-info value="Verb"/><gloss lang="en"><text>monomial</text></gloss></sense></entry>
