<entry id="taimtim" guid="46b663b9-0119-5ecd-b959-f44807c8467d"><lexical-unit><form lang="tl"><text>taimtim</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="taimtim_0" guid="86842693-77e6-5fce-9c19-d96296bc1764"><grammatical-info value="Adjective"/><gloss lang="en"><text>sincere; heartfelt; fervent</text></gloss></sense><sense id="taimtim_1" guid="49d2dff7-1de7-5441-aab1-6709f36e7939"><grammatical-info value="Adjective"/><gloss lang="en"><text>sincerely; fervently; deeply</text></gloss></sense></entry>
<entry id="tainga" guid="a69203c4-7f50-5ced-b1fa-fc348dd538b7"><lexical-unit><form lang="tl"><text>tainga</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tainga_0" guid="1bb32d0b-4d9d-548a-b207-f573c2feebe2"><grammatical-info value="Noun"/><gloss lang="en"><text>ear (organ of hearing)</text></gloss></sense><sense id="tainga_1" guid="2efcc253-ef31-58f0-b172-aee29f26d958"><grammatical-info value="Noun"/><gloss lang="en"><text>handle shaped like an ear (of a jar, pitcher, box, etc.)</text></gloss></sense><sense id="tainga_2" guid="31494af8-3128-5cad-88b4-1cc1b4ecea6f"><grammatical-info value="Noun"/><gloss lang="en"><text>hangnail</text></gloss></sense></entry>
<entry id="takal" guid="3655b9b1-2394-5e75-8a50-ea830cfc1b9f"><lexical-unit><form lang="tl"><text>takal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="takal_0" guid="378d4c6e-d0a7-5dcf-9437-35192ef23ed3"><grammatical-info value="Noun"/><gloss lang="en"><text>measurement by volume of grain, powder, liquid, etc. (by liter, gallon, etc.)</text></gloss></sense><sense id="takal_1" guid="efcbd93a-b56a-5346-ab06-a9a273bda05a"><grammatical-info value="Noun"/><gloss lang="en"><text>sale of merchandise at a certain rate by unit of measurement</text></gloss></sense><sense id="takal_2" guid="1396e068-6840-5cb7-b023-8e8d8f79d24b"><grammatical-info value="Noun"/><gloss lang="en"><text>rate of charge by unit of measurement (for merchandise sold)</text></gloss></sense><sense id="takal_3" guid="7adc2323-908e-5a8c-b0a6-02238115ac4b"><grammatical-info value="Noun"/><gloss lang="en"><text>hitting of prisoners as punishment</text></gloss></sense><sense id="takal_4" guid="4ed2874a-860b-5923-af29-8374bf6396d5"><grammatical-info value="Noun"/><gloss lang="en"><text>already measured by a certain unit of measurement (used with na)</text></gloss></sense><sense id="takal_5" guid="2d67a4d3-bedc-57d2-a3d4-fa298eecffc3"><grammatical-info value="Noun"/><gloss lang="en"><text>a kind of vessel (different from gusi)</text></gloss></sense></entry>
<entry id="takbuhan" guid="c148968b-c17c-5285-8bf5-b62077c67249"><lexical-unit><form lang="tl"><text>takbuhan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="takbuhan_0" guid="74579b58-35d0-5523-94ef-44268108e5d2"><grammatical-info value="Noun"/><gloss lang="en"><text>running competition</text></gloss></sense><sense id="takbuhan_1" guid="9b2f6c50-150b-5246-b661-0df693e3c527"><grammatical-info value="Noun"/><gloss lang="en"><text>place for running</text></gloss></sense><sense id="takbuhan_2" guid="203323fc-8116-547e-8b9d-1db2c7a86a0c"><grammatical-info value="Noun"/><gloss lang="en"><text>running track</text></gloss></sense><sense id="takbuhan_3" guid="fe157580-e821-57a4-9122-d4f32d538e76"><grammatical-info value="Noun"/><gloss lang="en"><text>place to run to; go-to place; resort; refuge; fallback</text></gloss></sense><sense id="takbuhan_4" guid="e508c062-cd14-5136-aeff-e97c38042ffd"><grammatical-info value="Noun"/><gloss lang="en"><text>to be run away from</text></gloss></sense><sense id="takbuhan_5" guid="70f2ae83-1857-59d0-bec0-f2476081613f"><grammatical-info value="Noun"/><gloss lang="en"><text>to be escaped from</text></gloss></sense></entry>
<entry id="takbuhin" guid="72cf159b-1445-579d-8990-7d5067fdb0e1"><lexical-unit><form lang="tl"><text>takbuhin</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="takbuhin_0" guid="5f68c791-d121-5225-a4ea-a6999458ffa7"><grammatical-info value="Verb"/><gloss lang="en"><text>to run and get (something)</text></gloss></sense><sense id="takbuhin_1" guid="07a38843-c335-583f-90e4-a76b4ef8bea6"><grammatical-info value="Verb"/><gloss lang="en"><text>to go by running to (a certain place)</text></gloss></sense><sense id="takbuhin_2" guid="43969bd0-0736-5246-913b-a8b5ea4f15b3"><grammatical-info value="Verb"/><gloss lang="en"><text>to run or negotiate (a certain distance at a certain time limit)</text></gloss></sense><sense id="takbuhin_3" guid="f985c09e-7347-5d59-8dfa-44d5eabe7d06"><grammatical-info value="Verb"/><gloss lang="en"><text>required or supposed to run (of a certain distance)</text></gloss></sense><sense id="takbuhin_4" guid="bae11128-ecab-5155-979b-98e57a6b3c72"><grammatical-info value="Verb"/><gloss lang="en"><text>running away from a fight (of a fighting cock)</text></gloss></sense><sense id="takbuhin_5" guid="a5131fab-d705-5397-a649-058abd3ce6bb"><grammatical-info value="Verb"/><gloss lang="en"><text>defeatist; someone who runs away from a challenge</text></gloss></sense><sense id="takbuhin_6" guid="56c66ea4-d80d-5e48-a195-d4deb0f86a93"><grammatical-info value="Verb"/><gloss lang="en"><text>the one who can pull somebody at a time</text></gloss></sense></entry>
