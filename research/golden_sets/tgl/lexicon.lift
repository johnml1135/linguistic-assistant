<entry id="sumunod" guid="db9a4ee0-9c5c-529b-bde2-e70b2ad231d2"><lexical-unit><form lang="tl"><text>sumunod</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sumunod_0" guid="8845bd3f-87a2-5905-ab9f-c0f2561eda78"><grammatical-info value="Verb"/><gloss lang="en"><text>to follow; to obey (a command, order, rule, law, etc.)</text></gloss></sense><sense id="sumunod_1" guid="49d15a7c-db97-54f5-aaf0-e4d6eed063b2"><grammatical-info value="Verb"/><gloss lang="en"><text>to go after another; to follow</text></gloss></sense><sense id="sumunod_2" guid="dd291476-d107-5dfe-89a1-f8f5634f4cca"><grammatical-info value="Verb"/><gloss lang="en"><text>to be next; to follow one immediately ahead</text></gloss></sense><sense id="sumunod_3" guid="bd430a07-6069-5019-998b-db54baa24036"><grammatical-info value="Verb"/><gloss lang="en"><text>complete aspect of sumunod</text></gloss></sense><sense id="sumunod_4" guid="a404bc62-f12a-5715-b826-426c7f340c04"><grammatical-info value="Verb"/><gloss lang="en"><text>the next</text></gloss></sense><sense id="sumunod_5" guid="4ca4f0ce-d90a-51af-b000-b9b5ae3c3d12"><grammatical-info value="Verb"/><gloss lang="en"><text>older sibling besides the eldest (when talking about family line)</text></gloss></sense></entry>
