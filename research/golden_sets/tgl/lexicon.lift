<entry id="yungib" guid="83d55b9f-3ca5-562c-8b28-06c47b572ffc"><lexical-unit><form lang="tl"><text>yungib</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="yungib_0" guid="b234ef02-7717-55a0-a37a-ba623d1ecd5e"><grammatical-info value="Noun"/><gloss lang="en"><text>cave; cavern</text></gloss></sense></entry>
