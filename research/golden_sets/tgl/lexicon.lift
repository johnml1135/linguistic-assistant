<entry id="sabsaban" guid="bbf89a13-58d5-5895-93af-770b2c784b23"><lexical-unit><form lang="tl"><text>sabsaban</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sabsaban_0" guid="e11f789a-cffe-5c72-a331-a92de71fe6fc"><grammatical-info value="Noun"/><gloss lang="en"><text>feeding trough (for hogs, horses, etc.)</text></gloss></sense><sense id="sabsaban_1" guid="fa5ddcee-6405-5dc6-8c13-8c1e076fcbc9"><grammatical-info value="Noun"/><gloss lang="en"><text>manger (especially of the infant Jesus)</text></gloss></sense><sense id="sabsaban_2" guid="77422286-2939-5c83-a074-3324f2e3d4fd"><grammatical-info value="Noun"/><gloss lang="en"><text>meadow; pasture</text></gloss></sense></entry>
