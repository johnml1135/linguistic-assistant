<entry id="tabernakulo" guid="053aba5e-a69f-5c35-a7c3-8c3ec6ecbfe0"><lexical-unit><form lang="tl"><text>tabernakulo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tabernakulo_0" guid="dc06d005-e3a2-594a-a61d-df21f4fda066"><grammatical-info value="Noun"/><gloss lang="en"><text>tabernacle (small ornamented box used for the reserved sacrament of the Eucharist)</text></gloss></sense><sense id="tabernakulo_1" guid="7e72ae13-2d6a-54ca-a62e-df75e458d756"><grammatical-info value="Noun"/><gloss lang="en"><text>tabernacle (portable tent used before the construction of the temple)</text></gloss></sense></entry>
<entry id="tabi" guid="45a2939f-dd9d-5238-9f33-aaa07d557cac"><lexical-unit><form lang="tl"><text>tabi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tabi_0" guid="67a88def-1b33-51c1-808c-edf24fa8d9fb"><grammatical-info value="Noun"/><gloss lang="en"><text>act of staying adjacent to another</text></gloss></sense><sense id="tabi_1" guid="e4042ffc-8768-5865-9b83-25ee1a421955"><grammatical-info value="Noun"/><gloss lang="en"><text>act of staying or passing along the side or border (of a road, river, etc.)</text></gloss></sense><sense id="tabi_2" guid="c2ffaab1-0bdc-55c4-8102-37b43998bb8a"><grammatical-info value="Noun"/><gloss lang="en"><text>edge; border</text></gloss></sense><sense id="tabi_3" guid="481dc27c-a0ec-5010-b54d-60f75fb43eaa"><grammatical-info value="Noun"/><gloss lang="en"><text>condition of being adjacent or being close together</text></gloss></sense><sense id="tabi_4" guid="613222c8-0d8a-5e1d-8147-dcc19cc8c463"><grammatical-info value="Noun"/><gloss lang="en"><text>act of keeping something in a safe place</text></gloss></sense><sense id="tabi_5" guid="6eff33ac-8b56-5c76-a432-fff4a1fc5741"><grammatical-info value="Noun"/><gloss lang="en"><text>act of saving for the future (especially of money)</text></gloss></sense><sense id="tabi_6" guid="3ef282b6-b590-5199-bec8-28294450fdb4"><grammatical-info value="Noun"/><gloss lang="en"><text>savings; anything saved for the future</text></gloss></sense></entry>
<entry id="tabing" guid="5c2b492c-770b-546d-89fd-0f6f370f2504"><lexical-unit><form lang="tl"><text>tabing</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tabing_0" guid="57945bb6-a425-5e9e-ae09-af2d77947af6"><grammatical-info value="Noun"/><gloss lang="en"><text>screen; curtain</text></gloss></sense><sense id="tabing_1" guid="a5fd3978-78d4-59d7-9c65-41ef805de5c0"><grammatical-info value="Noun"/><gloss lang="en"><text>temporary screen or curtain used to conceal something on the other side</text></gloss></sense><sense id="tabing_2" guid="5a183e62-8c0a-508b-88be-61af0ef0c719"><grammatical-info value="Noun"/><gloss lang="en"><text>manner of how a curtain or screen was placed</text></gloss></sense></entry>
