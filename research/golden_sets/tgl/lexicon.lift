<entry id="humawak" guid="a168449e-2de0-59db-a112-b252982685d6"><lexical-unit><form lang="tl"><text>humawak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="humawak_0" guid="589d4976-13bb-5306-b2c5-16d8c105c448"><grammatical-info value="Verb"/><gloss lang="en"><text>to hold (something); to take (something) in one's hand</text></gloss></sense><sense id="humawak_1" guid="2fed5e32-024a-5be9-943f-08a7a9759860"><grammatical-info value="Verb"/><gloss lang="en"><text>to hold on to; to grasp tightly</text></gloss></sense><sense id="humawak_2" guid="1c2e4a8a-b06f-58a4-9513-723b1aec4de9"><grammatical-info value="Verb"/><gloss lang="en"><text>to occupy; to hold (an office or position)</text></gloss></sense><sense id="humawak_3" guid="a6926eba-e266-5708-9354-d252faf60705"><grammatical-info value="Verb"/><gloss lang="en"><text>to manage (a business)</text></gloss></sense><sense id="humawak_4" guid="19702110-c571-5a8a-b59f-f7d11d785287"><grammatical-info value="Verb"/><gloss lang="en"><text>complete aspect of humawak</text></gloss></sense></entry>
