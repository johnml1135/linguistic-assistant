<entry id="luma" guid="fd32e2bc-04a7-512b-8f85-fa91d81912a9"><lexical-unit><form lang="tl"><text>luma</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="luma_0" guid="88196e60-0581-5ee9-a61e-041e0bd3e448"><grammatical-info value="Adjective"/><gloss lang="en"><text>old (of objects)</text></gloss></sense><sense id="luma_1" guid="7e1a2e93-3b19-57bf-8dc1-849f014728f0"><grammatical-info value="Adjective"/><gloss lang="en"><text>worn; used; second-hand</text></gloss></sense><sense id="luma_2" guid="d2db154a-7575-585f-8e7d-a823ded1ea63"><grammatical-info value="Adjective"/><gloss lang="en"><text>out of date; old-fashioned; antiquated</text></gloss></sense><sense id="luma_3" guid="09e4753b-b224-5358-a75e-56b0eddbc763"><grammatical-info value="Adjective"/><gloss lang="en"><text>remaining from the previous year (of harvested crops)</text></gloss></sense><sense id="luma_4" guid="fe35a1c2-a841-508a-98f3-7890f4286f59"><grammatical-info value="Adjective"/><gloss lang="en"><text>reduced in volume or quantity (by pounding, chewing, grinding, etc.)</text></gloss></sense></entry>
<entry id="lumabag" guid="c1325228-c03e-5536-9c5c-193f923bb615"><lexical-unit><form lang="tl"><text>lumabag</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lumabag_0" guid="8f041aef-a1d0-538e-84f4-28e7c541588a"><grammatical-info value="Verb"/><gloss lang="en"><text>to violate; to disobey (a rule, ordinance, law, etc.)</text></gloss></sense><sense id="lumabag_1" guid="ff7175e7-3dd6-51ea-bee8-a6731b6a1a88"><grammatical-info value="Verb"/><gloss lang="en"><text>to break; to fail to follow (one's promise, agreement, etc)</text></gloss></sense><sense id="lumabag_2" guid="8ee5745f-6887-5749-9c37-0ad6df753603"><grammatical-info value="Verb"/><gloss lang="en"><text>complete aspect of lumabag</text></gloss></sense></entry>
<entry id="lumaban" guid="d28ea311-f0ba-59e3-83cc-ca0f2e1023cd"><lexical-unit><form lang="tl"><text>lumaban</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lumaban_0" guid="006c7b9a-d83a-5bd0-98d2-8bb3161ff274"><grammatical-info value="Verb"/><gloss lang="en"><text>to fight</text></gloss></sense><sense id="lumaban_1" guid="af6779aa-7148-5f1a-8b3b-68b715b40205"><grammatical-info value="Verb"/><gloss lang="en"><text>to oppose; to go against</text></gloss></sense><sense id="lumaban_2" guid="337f1a38-76ef-5bc8-ac53-f9d6d549513d"><grammatical-info value="Verb"/><gloss lang="en"><text>complete aspect of lumaban</text></gloss></sense></entry>
<entry id="lumabas" guid="feb06aab-84df-59c7-af5f-9169a1026695"><lexical-unit><form lang="tl"><text>lumabas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lumabas_0" guid="10a88362-fef0-5900-92b5-6ab8a5d0e3c9"><grammatical-info value="Verb"/><gloss lang="en"><text>to leave; to exit; to go out</text></gloss></sense><sense id="lumabas_1" guid="7f531fcf-707e-562e-8b3c-ccf107ec2a32"><grammatical-info value="Verb"/><gloss lang="en"><text>to appear</text></gloss></sense><sense id="lumabas_2" guid="291a2d31-a8b2-5eac-9af9-72ec9063f045"><grammatical-info value="Verb"/><gloss lang="en"><text>to show up (from hiding)</text></gloss></sense><sense id="lumabas_3" guid="bdf73146-b556-542d-ada2-47462ae0fe05"><grammatical-info value="Verb"/><gloss lang="en"><text>to result in; to come out as a result</text></gloss></sense><sense id="lumabas_4" guid="57783054-e5de-5b9c-8245-b9ffe1500ef2"><grammatical-info value="Verb"/><gloss lang="en"><text>to play the role of (in a play, movie, etc.)</text></gloss></sense><sense id="lumabas_5" guid="3c610419-3916-5fe1-bcbc-068066ad659a"><grammatical-info value="Verb"/><gloss lang="en"><text>to be published (of a book, article, etc.)</text></gloss></sense><sense id="lumabas_6" guid="1e6de875-d617-52e0-b957-5cf3229d823b"><grammatical-info value="Verb"/><gloss lang="en"><text>to emerge victorious; to win (of an election)</text></gloss></sense><sense id="lumabas_7" guid="d2fb3f02-d2b0-50fc-8b08-55d2bdec68f8"><grammatical-info value="Verb"/><gloss lang="en"><text>complete aspect of lumabas</text></gloss></sense></entry>
<entry id="lumaganap" guid="c6883742-2fd3-5aef-aea6-7f2a982296e4"><lexical-unit><form lang="tl"><text>lumaganap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lumaganap_0" guid="101bf9f0-ef97-5b7f-bc7a-b9a820161b6c"><grammatical-info value="Verb"/><gloss lang="en"><text>to be distributed or dispersed widely; to spread over a wide area</text></gloss></sense><sense id="lumaganap_1" guid="cf4e59f4-b2e4-5f03-8d51-e6618eb44bbb"><grammatical-info value="Verb"/><gloss lang="en"><text>to become popular; to become well-known all over</text></gloss></sense><sense id="lumaganap_2" guid="a1ebdb6d-97ba-5150-9266-d43bf0ae4175"><grammatical-info value="Verb"/><gloss lang="en"><text>complete aspect of lumaganap</text></gloss></sense></entry>
