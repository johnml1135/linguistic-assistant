<entry id="tala" guid="d6c73c92-729d-56eb-9102-f3238a12f21c"><lexical-unit><form lang="tl"><text>tala</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tala_0" guid="51ccef7f-d5f9-5b16-a1b9-37c4407f4154"><grammatical-info value="Noun"/><gloss lang="en"><text>morning star; any bright star (except the Sun)</text></gloss></sense><sense id="tala_1" guid="62ea0457-5a6c-57a7-899d-3684cb176d5e"><grammatical-info value="Noun"/><gloss lang="en"><text>star</text></gloss></sense><sense id="tala_2" guid="53716cbc-7e88-576d-853a-5ada31dd4e78"><grammatical-info value="Noun"/><gloss lang="en"><text>any astronomical body (such as a star, a planet, or a comet)</text></gloss></sense><sense id="tala_3" guid="6bd59058-1f66-572b-9b45-3c0f07c0ce07"><grammatical-info value="Noun"/><gloss lang="en"><text>beautiful woman</text></gloss></sense><sense id="tala_4" guid="7bd3cab6-1012-52f7-8686-69e26108fbd5"><grammatical-info value="Noun"/><gloss lang="en"><text>celebrity (artist, actor, etc.)</text></gloss></sense><sense id="tala_5" guid="e3866725-f9f0-547f-a6b7-2c11c59ce36a"><grammatical-info value="Noun"/><gloss lang="en"><text>record; notes</text></gloss></sense><sense id="tala_6" guid="14af3221-ea91-5690-94ad-fda52497730f"><grammatical-info value="Noun"/><gloss lang="en"><text>listing; jotting down on a list</text></gloss></sense><sense id="tala_7" guid="522e4166-f28c-5fa9-9b3a-c9a0bb0d49bc"><grammatical-info value="Noun"/><gloss lang="en"><text>Limnophila rugosa (a type of marshweed used for cooking as an aromatic)</text></gloss></sense></entry>
