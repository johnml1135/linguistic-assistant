<entry id="sundan" guid="ac5d8d61-6b18-5dd0-963f-2dce52ce57e8"><lexical-unit><form lang="tl"><text>sundan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sundan_0" guid="91d87263-978f-5a57-ab06-3ac1748a5134"><grammatical-info value="Verb"/><gloss lang="en"><text>to follow; to trail</text></gloss></sense><sense id="sundan_1" guid="be74f312-122b-59b1-94eb-df5d0eb28107"><grammatical-info value="Verb"/><gloss lang="en"><text>to be followed by another (as in a succession)</text></gloss></sense><sense id="sundan_2" guid="84a84706-5bf3-549f-a457-d75daeeaf199"><grammatical-info value="Verb"/><gloss lang="en"><text>to pursue; to run after</text></gloss></sense></entry>
