<entry id="islang" guid="53c0b9e2-b4ef-5975-a921-fcf5e573c125"><lexical-unit><form lang="tl"><text>islang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="islang_0" guid="9d257b04-61f3-5333-bf64-2dcd42e18eca"><grammatical-info value="Noun"/><gloss lang="en"><text>slang (words or expression)</text></gloss></sense><sense id="islang_1" guid="afa3d894-4d56-5738-8169-048e48b0fed0"><grammatical-info value="Noun"/><gloss lang="en"><text>with a distinctively native English accent (especially an American accent like pronouncing /æ/ instead of /a/ or /e/ sounds)</text></gloss></sense></entry>
