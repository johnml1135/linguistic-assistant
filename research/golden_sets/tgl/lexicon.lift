<entry id="amo" guid="5989aaa5-d48f-5c19-b49d-caef51428ccb"><lexical-unit><form lang="tl"><text>amo</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="amo_0" guid="3d484c97-e808-51b8-a9f3-4854f486ed58"><grammatical-info value="Noun"/><gloss lang="en"><text>master; employer; boss</text></gloss></sense><sense id="amo_1" guid="b2665d19-1494-5a12-901f-e5f49cd3fbb3"><grammatical-info value="Noun"/><gloss lang="en"><text>pet owner; caretaker (of an animal)</text></gloss></sense><sense id="amo_2" guid="18b4dd64-fa81-53aa-84ae-2f78a1276e82"><grammatical-info value="Noun"/><gloss lang="en"><text>gentleness; docility</text></gloss></sense><sense id="amo_3" guid="4dc4499f-e59c-51b1-8dba-1c8973d43fc2"><grammatical-info value="Noun"/><gloss lang="en"><text>tameness (of animals)</text></gloss></sense><sense id="amo_4" guid="48805dfd-8297-5fb3-9527-c1ff034e5aa9"><grammatical-info value="Noun"/><gloss lang="en"><text>supplication; coaxing</text></gloss></sense><sense id="amo_5" guid="315d77e0-27bc-52ed-b98b-46e422dff3fd"><grammatical-info value="Noun"/><gloss lang="en"><text>a type of small monkey</text></gloss></sense><sense id="amo_6" guid="e48768e7-c307-5532-aad4-e545bf1541a9"><grammatical-info value="Noun"/><gloss lang="en"><text>monkey</text></gloss></sense></entry>
