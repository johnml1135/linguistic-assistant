<entry id="romano" guid="2abfc8c5-5457-5389-9a0a-9a5390acfd7a"><lexical-unit><form lang="tl"><text>romano</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="romano_0" guid="a9bbf404-bab9-54d5-ae91-ae69e985d154"><grammatical-info value="Noun"/><gloss lang="en"><text>Roman (people)</text></gloss></sense><sense id="romano_1" guid="03f47d6a-8511-5c91-b713-a18c3eda592d"><grammatical-info value="Noun"/><gloss lang="en"><text>Roman (pertaining to Rome)</text></gloss></sense></entry>
<entry id="roon" guid="d44ecf31-75d7-589b-a493-8aa835c3cf74"><lexical-unit><form lang="tl"><text>roon</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="roon_0" guid="d1dfbd5f-fbf8-5368-b1cc-d2f931b91c2b"><grammatical-info value="Adverb"/></sense></entry>
<entry id="sa" guid="b094727d-c185-5c5a-8c99-bdea4b0f4960"><lexical-unit><form lang="tl"><text>sa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sa_0" guid="cb328ddf-a269-5e3a-a573-630deb5e1597"><grammatical-info value="Adposition"/><gloss lang="en"><text>marks oblique participant/s within a clause that are not otherwise focused using the case marker "ang." This includes:</text></gloss></sense><sense id="sa_1" guid="e08567cd-777c-50d9-9dee-a639897afbb1"><grammatical-info value="Adposition"/><gloss lang="en"><text>the recipient or beneficiary of an action: to, for</text></gloss></sense><sense id="sa_2" guid="003e014b-b163-5041-818b-71dc9cf3c4ff"><grammatical-info value="Adposition"/><gloss lang="en"><text>the location of an entity or action: in; at; on (not used in a positive equational sentence)</text></gloss></sense><sense id="sa_3" guid="7ab8dfc0-f4dc-57ae-9725-5863edc0be72"><grammatical-info value="Adposition"/><gloss lang="en"><text>the place of origin or where one is a native of: from, of (usually with galing or tubo)</text></gloss></sense><sense id="sa_4" guid="1fa79529-52fe-5c49-9b43-4c5389b8656b"><grammatical-info value="Adposition"/><gloss lang="en"><text>the time of occurence: at; on; in; during (of a year, month, day of the week, time of day, etc.)</text></gloss></sense><sense id="sa_5" guid="969e6a0a-14f4-5eb3-90f8-c8d187de1707"><grammatical-info value="Adposition"/><gloss lang="en"><text>movement or direction towards a location: to, toward</text></gloss></sense><sense id="sa_6" guid="6903bb7d-b97b-55dd-ab31-54b11ebdbe62"><grammatical-info value="Adposition"/><gloss lang="en"><text>accompaniment or association: with; together with; in company with</text></gloss></sense><sense id="sa_7" guid="dd92ef5f-ea40-5db1-aac7-7be3d5b6a357"><grammatical-info value="Adposition"/><gloss lang="en"><text>a prescribed point in time when something occurred: upon; on; at the time of</text></gloss></sense></entry>
<entry id="saan" guid="66cb3a44-e013-5ee5-865a-70caaa037610"><lexical-unit><form lang="tl"><text>saan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="saan_0" guid="940bd289-842e-5ae7-911e-5067bafdf9ff"><grammatical-info value="Pronoun"/><gloss lang="en"><text>where (not used in equational sentences)</text></gloss></sense></entry>
<entry id="saanman" guid="1bd85617-123f-5f1b-b4e9-9be96ddae649"><lexical-unit><form lang="tl"><text>saanman</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="saanman_0" guid="52efe66f-06f8-5a7a-9359-4a31bba0de21"><grammatical-info value="Adverb"/><gloss lang="en"><text>wherever</text></gloss></sense></entry>
<entry id="sabay" guid="d91fd9f9-f64b-52a7-8840-ae5e41dec205"><lexical-unit><form lang="tl"><text>sabay</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sabay_0" guid="4a1a10e8-e08a-5088-a811-5ea3ea90db74"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>at the same time; simultaneous</text></gloss></sense><sense id="sabay_1" guid="9b8a1551-9825-5625-b439-07764d319896"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>travelling together (of people to the same place)</text></gloss></sense><sense id="sabay_2" guid="5cd60f1c-bd28-5447-b8d7-8144a068a978"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>at the same time; simultaneously</text></gloss></sense><sense id="sabay_3" guid="54b3c9aa-4236-564c-9f4b-3b5acc826c2f"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>together (of people travelling to the same place)</text></gloss></sense><sense id="sabay_4" guid="48ec6426-7a70-5d89-b8be-8f89a3ef20ac"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>then (soon afterward)</text></gloss></sense><sense id="sabay_5" guid="9a68828e-1844-5184-8456-46e4bcfaff5f"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>act of travelling to the same place together</text></gloss></sense><sense id="sabay_6" guid="7e6508c2-97e8-5ccd-b2bf-7780fc37eae7"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>act of doing something at the same time</text></gloss></sense><sense id="sabay_7" guid="d378a2ff-10d1-5e73-b232-27de6d726cfc"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>simultaneous occurrence</text></gloss></sense></entry>
<entry id="sabayan" guid="8d0e6180-cbd6-59e2-b64d-33a2aba31cfc"><lexical-unit><form lang="tl"><text>sabayan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sabayan_0" guid="90ecd970-507d-5e98-8e36-d76f811a99ba"></sense></entry>
<entry id="sabi" guid="1d63993f-58db-5485-a946-9dc05d669582"><lexical-unit><form lang="tl"><text>sabi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sabi_0" guid="e8967123-7eb5-5246-a600-6fe5214d0cd4"><grammatical-info value="Verb"/><gloss lang="en"><text>something said; statement</text></gloss></sense><sense id="sabi_1" guid="2c1587ad-db8e-5e2c-bccd-c6aede7807f5"><grammatical-info value="Verb"/><gloss lang="en"><text>act of saying something (to someone)</text></gloss></sense><sense id="sabi_2" guid="73f3e024-bd0a-5235-a8b4-cd0404950db0"><grammatical-info value="Verb"/><gloss lang="en"><text>act of telling something (to someone)</text></gloss></sense><sense id="sabi_3" guid="f3bd365b-0aae-5839-bb8e-c39d96143899"><grammatical-info value="Verb"/><gloss lang="en"><text>words; expressions</text></gloss></sense></entry>
<entry id="sabihin" guid="994df71f-40d0-5b81-b73e-0ec674fd2978"><lexical-unit><form lang="tl"><text>sabihin</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sabihin_0" guid="ec4883de-f11d-5a4f-ae8d-523d930bb0b1"><grammatical-info value="Verb"/><gloss lang="en"><text>to be said (of something, such as words, to someone)</text></gloss></sense><sense id="sabihin_1" guid="656fa5f3-3593-5038-916d-60c542631ed6"><grammatical-info value="Verb"/><gloss lang="en"><text>to be pronounced (of words)</text></gloss></sense><sense id="sabihin_2" guid="754e2adf-c5ff-5cff-ad2a-fab65444713d"><grammatical-info value="Verb"/><gloss lang="en"><text>to be told; to be made known (of something to someone)</text></gloss></sense></entry>
<entry id="sabik" guid="d5ab3af8-410b-58f6-aeae-244a563cda4d"><lexical-unit><form lang="tl"><text>sabik</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sabik_0" guid="41d9ad2f-b97d-59be-bc8c-cfb79bbbed1d"><grammatical-info value="Adjective"/><gloss lang="en"><text>eager; keenly desirous; wanting very much</text></gloss></sense><sense id="sabik_1" guid="ce215e4b-daf1-5ec8-a156-76de0668ae17"><grammatical-info value="Adjective"/><gloss lang="en"><text>keen desire; eagerness</text></gloss></sense></entry>
