<entry id="itaas" guid="e4d6f529-8ce8-5fd9-95ad-25d6909ab777"><lexical-unit><form lang="tl"><text>itaas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="itaas_0" guid="ffc37c26-fd7e-5a70-99ee-aaf179f8b6bd"><grammatical-info value="Noun"/><gloss lang="en"><text>upstairs</text></gloss></sense><sense id="itaas_1" guid="3c1a9a48-e942-5cac-be72-81f6aa15e288"><grammatical-info value="Noun"/><gloss lang="en"><text>top (of a hill, mountain, etc.)</text></gloss></sense><sense id="itaas_2" guid="7aec0ebb-a8e8-5d3c-bfe6-a5a242813e45"><grammatical-info value="Noun"/><gloss lang="en"><text>vast space above</text></gloss></sense><sense id="itaas_3" guid="c2fb0b37-e8e8-5f99-87ff-375671ff6b09"><grammatical-info value="Noun"/><gloss lang="en"><text>heaven</text></gloss></sense><sense id="itaas_4" guid="a9891d06-b66a-574a-9184-9eab8527a1e1"><grammatical-info value="Noun"/><gloss lang="en"><text>high position (in an organization, etc.)</text></gloss></sense><sense id="itaas_5" guid="168d52d0-2ffb-5328-a315-7836a222c158"><grammatical-info value="Noun"/><gloss lang="en"><text>to raise; to lift</text></gloss></sense><sense id="itaas_6" guid="2a29d42a-95d7-57dc-9324-4a814c141134"><grammatical-info value="Noun"/><gloss lang="en"><text>to increase; to raise (of prices)</text></gloss></sense><sense id="itaas_7" guid="2e8ff398-790f-50a6-9550-98e09e062c72"><grammatical-info value="Noun"/><gloss lang="en"><text>to promote (of an employee)</text></gloss></sense></entry>
