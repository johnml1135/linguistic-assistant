<entry id="hala" guid="e9d7329d-f804-52dd-965b-60c639a5ee83"><lexical-unit><form lang="id"><text>hala</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="hala_0" guid="36497466-ffd2-540a-857c-09593f8e69d4"><grammatical-info value="Noun"/><gloss lang="en"><text>direction</text></gloss></sense><sense id="hala_1" guid="525426af-a2dc-522b-9459-b26d7abf629c"><grammatical-info value="Noun"/><gloss lang="en"><text>a bird's nest made in the ground, in the form of a deep hole, usually covered with twigs and leaves</text></gloss></sense></entry>
