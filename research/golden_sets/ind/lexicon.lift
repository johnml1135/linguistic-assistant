<entry id="ah" guid="54d1c35b-e73f-5a24-b846-246a901d075b"><lexical-unit><form lang="id"><text>ah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ah_0" guid="bab162c5-ed65-5e90-886b-1d441bdfed78"><grammatical-info value="Proper noun"/><gloss lang="en"><text>oh, expresses compassion, surprise and dismay</text></gloss></sense></entry>
<entry id="ahli" guid="b0c41a02-e307-5cd1-9392-d7529876d148"><lexical-unit><form lang="id"><text>ahli</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ahli_0" guid="ca70bf7a-1723-5feb-b598-ee1fd40fb7b3"><grammatical-info value="Noun"/><gloss lang="en"><text>expert</text></gloss></sense><sense id="ahli_1" guid="6d190396-14aa-577d-8f78-cf3638c0c488"><grammatical-info value="Noun"/><gloss lang="en"><text>the title of four-years vocational degree (1993-2001), currently sarjana terapan (since 2001)</text></gloss></sense><sense id="ahli_2" guid="107fc10e-2f41-507c-86d2-c734ffa0a712"><grammatical-info value="Noun"/><gloss lang="en"><text>member</text></gloss></sense><sense id="ahli_3" guid="c761bf30-24ca-5292-a55e-5e00e2aac396"><grammatical-info value="Noun"/><gloss lang="en"><text>inhabitant</text></gloss></sense><sense id="ahli_4" guid="d4a2138b-b941-5dec-822c-b427687a5038"><grammatical-info value="Noun"/><gloss lang="en"><text>adherent</text></gloss></sense><sense id="ahli_5" guid="44be834f-340e-521b-87ca-d8414a198899"><grammatical-info value="Noun"/><gloss lang="en"><text>family</text></gloss></sense></entry>
<entry id="ai" guid="ff6ce1f7-502e-5605-bbeb-dc2b0d30d20b"><lexical-unit><form lang="id"><text>ai</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ai_0" guid="23c791e1-e3d2-531d-b2e4-2bd2a2d9da68"><grammatical-info value="Proper noun"/><gloss lang="en"><text>exclamation to express surprise and so on</text></gloss></sense><sense id="ai_1" guid="41483a15-fa2d-5039-b078-2b22abf08898"><grammatical-info value="Proper noun"/><gloss lang="en"><text>really miss</text></gloss></sense><sense id="ai_2" guid="4650818e-7049-5d36-bd8e-a1b712a51d5b"><grammatical-info value="Proper noun"/><gloss lang="en"><text>breadfruit bark, which has sparse fibers, the surface is not smooth, has a lot of sap, is light brown in color</text></gloss></sense><sense id="ai_3" guid="dbbd5f74-22f2-5ad7-b831-104a10a96a8d"><grammatical-info value="Proper noun"/><gloss lang="en"><text>dirt, that is usually found in well water, rivers, lakes, and so on</text></gloss></sense><sense id="ai_4" guid="acf01901-dab4-5cde-ab62-93db8d968d16"><grammatical-info value="Proper noun"/><gloss lang="en"><text>initialism of akal imitasi (“artificial intelligence”)</text></gloss></sense></entry>
<entry id="aib" guid="d5809a0b-b988-5f41-8d05-cdf442377091"><lexical-unit><form lang="id"><text>aib</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aib_0" guid="896d30ab-9e3c-5224-8894-f75749bc39c5"><grammatical-info value="Noun"/><gloss lang="en"><text>ashamed</text></gloss></sense><sense id="aib_1" guid="252fe4a7-9deb-5b46-a691-0e8966c55e92"><grammatical-info value="Noun"/><gloss lang="en"><text>disgrace</text></gloss></sense><sense id="aib_2" guid="32e99ae6-b5bb-5d0c-a2bd-e7e5d8b04691"><grammatical-info value="Noun"/><gloss lang="en"><text>shame</text></gloss></sense></entry>
