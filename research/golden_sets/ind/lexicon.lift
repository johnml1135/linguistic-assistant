<entry id="bila" guid="e990d252-8abd-5dca-bafe-29fe391e7c76"><lexical-unit><form lang="id"><text>bila</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bila_0" guid="29077d68-22d0-54d3-b2c8-0a006a5bb6ef"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>when</text></gloss></sense><sense id="bila_1" guid="5c2910b1-555b-5186-a233-2bb7c3ab26f0"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>if</text></gloss></sense><sense id="bila_2" guid="8f507dbe-e43d-5f58-83ca-4cad3f7f1d74"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>to take revenge</text></gloss></sense><sense id="bila_3" guid="67815944-fd22-54d9-853b-1554e8b6ee33"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>calabash (Crescentia cujete)</text></gloss></sense><sense id="bila_4" guid="f7642c38-74d8-5f8a-9594-14f8e8da7758"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>floor made of loosely woven bamboo slats</text></gloss></sense><sense id="bila_5" guid="e573fe0a-8965-5801-8ad7-325bdb3557c2"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>bael, Bengal quince, golden apple, Japanese bitter orange, stone apple, or wood apple (Aegle marmelos)</text></gloss></sense><sense id="bila_6" guid="b9c2b668-93a8-556a-ab63-c0cdffff32a5"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>pest repellent made from the fruit which is pounded and fermented to become a pesticide</text></gloss></sense><sense id="bila_7" guid="3eb28fd3-205c-5da9-acac-c7675479a601"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>water container made from the fruit shell</text></gloss></sense></entry>
