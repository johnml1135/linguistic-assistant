<entry id="urut" guid="8c4de60b-eb30-5776-8175-5f6818e312cd"><lexical-unit><form lang="id"><text>urut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="urut_0" guid="411b3ea9-0209-59ab-ac35-f445b843d112"><grammatical-info value="Verb"/><gloss lang="en"><text>to massage</text></gloss></sense></entry>
<entry id="us" guid="ce988e0e-778f-5108-950b-efdd350acadf"><lexical-unit><form lang="id"><text>us</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="us_0" guid="4a20919e-d884-52bd-8024-d38dbab6d28c"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="usah" guid="d23c7fbb-7f8b-58e4-a0c4-8c4ed848bdab"><lexical-unit><form lang="id"><text>usah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="usah_0" guid="9b08f070-3b1a-5b83-b0e1-41c7ed11ed44"><grammatical-info value="Verb"/><gloss lang="en"><text>necessary, obligatory</text></gloss></sense><sense id="usah_1" guid="56d99325-c044-54a8-a0cf-cb5382a61324"><grammatical-info value="Verb"/><gloss lang="en"><text>it is not necessary</text></gloss></sense></entry>
<entry id="usaha" guid="731a7688-edfa-5f18-8527-ef37a4467948"><lexical-unit><form lang="id"><text>usaha</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="usaha_0" guid="63b456c4-b79e-5abd-a65b-76b2dde58bd7"><grammatical-info value="Noun"/><gloss lang="en"><text>action: something done so as to accomplish a purpose</text></gloss></sense><sense id="usaha_1" guid="072d5ac6-6e75-5119-a25e-1b4604bc83e3"><grammatical-info value="Noun"/><gloss lang="en"><text>attempt, try</text></gloss></sense><sense id="usaha_2" guid="fee0c8f0-7d49-5acc-b0e8-e0e8f201106c"><grammatical-info value="Noun"/><gloss lang="en"><text>business</text></gloss></sense><sense id="usaha_3" guid="97b64c59-4305-59f3-9b36-76fe793b8be9"><grammatical-info value="Noun"/><gloss lang="en"><text>business:</text></gloss></sense><sense id="usaha_4" guid="e404639b-4b5e-5ec0-9853-99b1e894eacc"><grammatical-info value="Noun"/><gloss lang="en"><text>a specific commercial enterprise or establishment</text></gloss></sense><sense id="usaha_5" guid="0742f6ee-dd0c-5a2b-96cc-3f6def0868cd"><grammatical-info value="Noun"/><gloss lang="en"><text>commercial, industrial, or professional activity</text></gloss></sense><sense id="usaha_6" guid="77f04226-c458-5ba4-92f8-0b94ea21b50b"><grammatical-info value="Noun"/><gloss lang="en"><text>company: any business, whether incorporated or not, that manufactures or sells products (also known as goods), or provides services as a commercial venture</text></gloss></sense></entry>
<entry id="usang" guid="63bf6201-4604-5751-8827-ce9630d93714"><lexical-unit><form lang="id"><text>usang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="usang_0" guid="585df911-cb4e-5a39-b65e-2b0279a9a218"><grammatical-info value="Noun"/><gloss lang="en"><text>withered</text></gloss></sense><sense id="usang_1" guid="b60fe8aa-0ce6-515a-bf24-3bae79fb4eef"><grammatical-info value="Noun"/><gloss lang="en"><text>out of date, outdated</text></gloss></sense><sense id="usang_2" guid="d67bfb1f-fbe8-5626-be8f-f0b09cdc7de8"><grammatical-info value="Noun"/><gloss lang="en"><text>obsolete</text></gloss></sense><sense id="usang_3" guid="e844bb6b-567a-55a4-a6fd-584d7ed23a16"><grammatical-info value="Noun"/><gloss lang="en"><text>worn down</text></gloss></sense></entry>
