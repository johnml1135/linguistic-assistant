<entry id="bilang" guid="807b1e67-8da7-5cfb-aa6d-27c909ae9099"><lexical-unit><form lang="id"><text>bilang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bilang_0" guid="84f8533b-6dbe-5db5-a54e-2f38680a8e63"><grammatical-info value="Verb"/><gloss lang="en"><text>to say</text></gloss></sense><sense id="bilang_1" guid="2cebe85f-5723-52aa-b372-298b72888801"><grammatical-info value="Verb"/><gloss lang="en"><text>synonym of hitung (“to count”)</text></gloss></sense></entry>
