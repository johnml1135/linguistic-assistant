<entry id="tetes" guid="f2c73606-af41-5f4f-9190-b98e78e00741"><lexical-unit><form lang="id"><text>tetes</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tetes_0" guid="ac13af37-bd33-5ce5-8c72-e3de635e0be8"><grammatical-info value="Verb"/><gloss lang="en"><text>drop, drip</text></gloss></sense></entry>
<entry id="tetua" guid="cdd25880-2cdb-526b-a5b3-0d44da310a0f"><lexical-unit><form lang="id"><text>tetua</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tetua_0" guid="58b4fbaa-555c-54f0-abe5-ccc314cc35d9"><grammatical-info value="Noun"/><gloss lang="en"><text>parent, an organism from which a plant or animal is immediately biologically descended</text></gloss></sense></entry>
<entry id="thomas" guid="82ffd18e-0f81-5d84-ac81-32e9d0f79874"><lexical-unit><form lang="id"><text>thomas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="thomas_0" guid="e3b2401e-29ef-5d1d-a3c7-52be060a2f23"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="ti" guid="37e5c547-2d30-58c0-970a-b0bcbb785531"><lexical-unit><form lang="id"><text>ti</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ti_0" guid="7bcd3a59-5655-5537-949c-18a19c7632da"><grammatical-info value="Noun"/><gloss lang="en"><text>ti (a syllable used in solfège to represent the seventh note of a major scale)</text></gloss></sense></entry>
<entry id="tia" guid="b2693779-256f-53f1-b33e-f02b1859c297"><lexical-unit><form lang="id"><text>tia</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tia_0" guid="5c378078-ce88-5be2-8e74-034d8a04a22b"><grammatical-info value="Proper noun"/><gloss lang="en"><text>faithful</text></gloss></sense></entry>
<entry id="tiada" guid="3345c0a6-b8b0-53c3-8bfd-1ef2237845b5"><lexical-unit><form lang="id"><text>tiada</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tiada_0" guid="14acf8ac-4b2f-5bae-b8c2-c553b741df2e"><grammatical-info value="Particle"/><gloss lang="en"><text>there is no, there are no</text></gloss></sense><sense id="tiada_1" guid="e26a359a-8567-5be7-9959-ac694c88fa85"><grammatical-info value="Particle"/><gloss lang="en"><text>nothing</text></gloss></sense><sense id="tiada_2" guid="363549dd-cef4-5c96-bf31-aaf503fba3b1"><grammatical-info value="Particle"/><gloss lang="en"><text>synonym of tidak</text></gloss></sense></entry>
<entry id="tiang" guid="14e1554e-7c26-52cd-b81e-88c0d49765f9"><lexical-unit><form lang="id"><text>tiang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tiang_0" guid="de578d45-b5bd-59ac-afe5-72e070746d52"><grammatical-info value="Noun"/><gloss lang="en"><text>mast; pole; tower; pile; pier; staff; pillar; post; peg; column</text></gloss></sense><sense id="tiang_1" guid="34d70e9a-0a02-5d89-9d7c-33700859b532"><grammatical-info value="Noun"/><gloss lang="en"><text>main source; backbone</text></gloss></sense></entry>
<entry id="tiap" guid="4fe9dc1e-bd33-5d1e-8899-b87d1f9562e8"><lexical-unit><form lang="id"><text>tiap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tiap_0" guid="63be0328-8cb7-59aa-9887-e0aa20fc5a7c"><grammatical-info value="Determiner"/><gloss lang="en"><text>each</text></gloss></sense><sense id="tiap_1" guid="a94bb5f6-5722-5354-88b8-f768effca86d"><grammatical-info value="Determiner"/><gloss lang="en"><text>every</text></gloss></sense><sense id="tiap_2" guid="abb6b108-33c6-53e4-bba3-9b9728b50899"><grammatical-info value="Determiner"/><gloss lang="en"><text>dose of medicine</text></gloss></sense><sense id="tiap_3" guid="1b0bbb8f-0536-53f4-9bc0-c321ddd7a3ec"><grammatical-info value="Determiner"/><gloss lang="en"><text>rent: a payment made by a tenant at intervals in order to occupy a property</text></gloss></sense></entry>
<entry id="tiba" guid="fac1a665-8800-5d87-8bf7-25bcdacb77fc"><lexical-unit><form lang="id"><text>tiba</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tiba_0" guid="4fdd5d08-e7ba-5780-9626-de4bb9a0d8af"><grammatical-info value="Verb"/><gloss lang="en"><text>synonym of datang (“to arrive; to come”)</text></gloss></sense></entry>
<entry id="tiberius" guid="85e123ed-2bfb-571c-a4f0-072eaf2d460e"><lexical-unit><form lang="id"><text>tiberius</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tiberius_0" guid="f221e339-8e53-5e61-8294-5999c358fdab"><grammatical-info value="Proper noun"/><gloss lang="en"><text>tiberias</text></gloss></sense></entry>
<entry id="tidak" guid="cb77563c-2cb5-59af-85d2-72a081b6e931"><lexical-unit><form lang="id"><text>tidak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tidak_0" guid="5f0bcf02-cbb6-5b6c-8911-e6bb33e19481"><grammatical-info value="Particle"/><gloss lang="en"><text>a negative marker used for negating the meanings of verbs, adverbs, and adjectives: not</text></gloss></sense><sense id="tidak_1" guid="2e7ec96f-e7e6-5488-a925-129c4b3c0387"><grammatical-info value="Particle"/><gloss lang="en"><text>no; used to show disagreement, negation, denial, refusal, or prohibition</text></gloss></sense></entry>
<entry id="tidur" guid="9c65704f-2f01-5803-81ea-dbc897ae87a1"><lexical-unit><form lang="id"><text>tidur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tidur_0" guid="e6378d5b-f84f-58d9-8532-4cfe863b4d95"><grammatical-info value="Verb"/><gloss lang="en"><text>to sleep</text></gloss></sense><sense id="tidur_1" guid="352e0e1c-5039-56dd-b1fd-e7e10e349354"><grammatical-info value="Verb"/><gloss lang="en"><text>to rest in a state of reduced consciousness</text></gloss></sense><sense id="tidur_2" guid="a16b321c-21e5-5440-b39c-094f69d6f803"><grammatical-info value="Verb"/><gloss lang="en"><text>to have sexual intercourse</text></gloss></sense><sense id="tidur_3" guid="62ecf09a-8feb-56b3-b9e8-b25a291d7022"><grammatical-info value="Verb"/><gloss lang="en"><text>to lie down (to take on a horizontal position)</text></gloss></sense><sense id="tidur_4" guid="b0107b7f-3226-5d29-8bde-0210decabb92"><grammatical-info value="Verb"/><gloss lang="en"><text>to be unactive (to be not active, temporarily or permanently)</text></gloss></sense><sense id="tidur_5" guid="6e94a4e2-a257-5146-b4a9-0c234a4fe8f0"><grammatical-info value="Verb"/><gloss lang="en"><text>sleep:</text></gloss></sense><sense id="tidur_6" guid="e98a2a90-d640-5444-bcab-34dd2e1ceeac"><grammatical-info value="Verb"/><gloss lang="en"><text>the state of reduced consciousness during which a human or animal rests in a daily rhythm</text></gloss></sense><sense id="tidur_7" guid="23027cda-4ac0-52b6-9837-c529d467c861"><grammatical-info value="Verb"/><gloss lang="en"><text>an act or instance of sleeping</text></gloss></sense></entry>
<entry id="tidurlah" guid="8ce9e01b-a8e5-5e2a-acc5-5edbcbce0ba6"><lexical-unit><form lang="id"><text>tidurlah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tidurlah_0" guid="ae498955-815b-572a-b4ff-7308d0a41ba3"><grammatical-info value="Verb"/><gloss lang="en"><text>jussive of tidur</text></gloss></sense></entry>
<entry id="tiga" guid="9ca240f4-86b9-5e93-9b4a-0e68f6c6a487"><lexical-unit><form lang="id"><text>tiga</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tiga_0" guid="2453ce89-e277-5c23-a1e9-bf94032e2904"><grammatical-info value="Numeral"/><gloss lang="en"><text>three</text></gloss></sense></entry>
<entry id="tika" guid="b4407d32-2150-5028-ae7b-1bba3c6497cf"><lexical-unit><form lang="id"><text>tika</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tika_0" guid="2e4ae5b1-e1fd-5ae4-b50a-edbba0382666"><grammatical-info value="Noun"/><gloss lang="en"><text>reel</text></gloss></sense><sense id="tika_1" guid="12f0803c-195a-5585-879a-8717e79a36a2"><grammatical-info value="Noun"/><gloss lang="en"><text>spool</text></gloss></sense><sense id="tika_2" guid="8739b288-9376-501e-9f5f-693414a9ddcf"><grammatical-info value="Noun"/><gloss lang="en"><text>large boil on neck</text></gloss></sense><sense id="tika_3" guid="9eeaf5c2-babb-587f-bec5-2120f36acff0"><grammatical-info value="Noun"/><gloss lang="en"><text>tikka (a marinade made from various aromatic spices usually with a yoghurt base; often used in Indian cuisine prior to grilling in a tandoor)</text></gloss></sense><sense id="tika_4" guid="dc810c09-b139-52b4-b49e-679e78292d63"><grammatical-info value="Noun"/><gloss lang="en"><text>the basis of traditional day calculations, containing pictures and symbols</text></gloss></sense></entry>
