<entry id="tertidur" guid="19c4f679-db19-5961-9457-b579c18e8af3"><lexical-unit><form lang="id"><text>tertidur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tertidur_0" guid="986fdfa1-b2be-5306-8e7d-6d50ea7537cf"><grammatical-info value="Verb"/><gloss lang="en"><text>to fall asleep (to pass from a state of wakefulness into sleep)</text></gloss></sense><sense id="tertidur_1" guid="7b804782-a63b-5ea1-ab54-c7a9faa3ecd2"><grammatical-info value="Verb"/><gloss lang="en"><text>to accidentally fall asleep</text></gloss></sense><sense id="tertidur_2" guid="8f27d6b3-3ff2-56b7-b841-b11d3354cb8f"><grammatical-info value="Verb"/><gloss lang="en"><text>asleep (in a state of sleep; also, broadly, resting)</text></gloss></sense></entry>
