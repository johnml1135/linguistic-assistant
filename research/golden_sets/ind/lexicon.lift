<entry id="peras" guid="6508bc41-976d-5636-a3a3-e48b0221fec2"><lexical-unit><form lang="id"><text>peras</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="peras_0" guid="41933776-0714-5faf-98bc-17e5d3e58fa1"><grammatical-info value="Verb"/><gloss lang="en"><text>to squeeze out, to juice, to milk, to press</text></gloss></sense><sense id="peras_1" guid="b12271a8-8cd4-5ac1-aa3c-33d94637f568"><grammatical-info value="Verb"/><gloss lang="en"><text>to extort, to blackmail, to exploit</text></gloss></sense><sense id="peras_2" guid="ba5cac01-c64b-5172-8afe-617a4d6615e1"><grammatical-info value="Verb"/><gloss lang="en"><text>smooth</text></gloss></sense><sense id="peras_3" guid="57a687ec-f281-598a-9109-ae6abb493705"><grammatical-info value="Verb"/><gloss lang="en"><text>flat</text></gloss></sense><sense id="peras_4" guid="bbe2205a-9559-5b48-86d6-ca2a98f371b3"><grammatical-info value="Verb"/><gloss lang="en"><text>offerings from the Seblang dance performance, in the form of woven coconut leaves or bamboo, containing coconuts peeled from the shell, decorated with lawe thread and Javanese sugar</text></gloss></sense></entry>
