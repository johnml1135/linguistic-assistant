<entry id="benderang" guid="90642b04-6584-578a-97e0-3a33f21e8f07"><lexical-unit><form lang="id"><text>benderang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="benderang_0" guid="e2d4b791-9e0e-5740-974e-7603e4287dfb"><grammatical-info value="Adjective"/><gloss lang="en"><text>bright</text></gloss></sense></entry>
