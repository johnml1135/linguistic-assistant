<entry id="akhir" guid="767b31a0-1c02-5f65-939e-52d622618454"><lexical-unit><form lang="id"><text>akhir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="akhir_0" guid="7d9a95e2-5a42-538b-8f18-ab95df4dcf90"><grammatical-info value="Noun"/><gloss lang="en"><text>end</text></gloss></sense></entry>
