<entry id="standar" guid="18a15887-56df-5b84-a351-eddec0825814"><lexical-unit><form lang="id"><text>standar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="standar_0" guid="3ed92f8e-1037-5a03-93de-d559f811815a"><grammatical-info value="Adjective"/><gloss lang="en"><text>standard,</text></gloss></sense><sense id="standar_1" guid="cf1acb82-a1f0-576e-9f35-1acc74add7c7"><grammatical-info value="Adjective"/><gloss lang="en"><text>the flag or ensign carried</text></gloss></sense><sense id="standar_2" guid="e0def4ad-1f16-5ead-8cee-00e03dce7a62"><grammatical-info value="Adjective"/><gloss lang="en"><text>an object supported in an upright position</text></gloss></sense><sense id="standar_3" guid="0f509064-75c4-5ecb-b3a8-20ba0b8df814"><grammatical-info value="Adjective"/><gloss lang="en"><text>a principle or example or measure used for comparison</text></gloss></sense><sense id="standar_4" guid="38bd979d-a7c1-5f23-b7d5-8d8aa977f3dd"><grammatical-info value="Adjective"/><gloss lang="en"><text>stand, support: a device to hold something upright or aloft</text></gloss></sense><sense id="standar_5" guid="d29d13ea-227c-5b99-bcd8-6aba9a641e4d"><grammatical-info value="Adjective"/><gloss lang="en"><text>standard, falling within an accepted range of size, amount, power, quality, etc</text></gloss></sense></entry>
<entry id="status" guid="94849e4e-07f3-58fe-81b0-6820e3ab2935"><lexical-unit><form lang="id"><text>status</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="status_0" guid="a9700101-ca20-595e-a7f2-ffd1b593dfd4"><grammatical-info value="Noun"/><gloss lang="en"><text>status:</text></gloss></sense><sense id="status_1" guid="f983b587-0a0a-5361-8ea3-ad52ca6d70d0"><grammatical-info value="Noun"/><gloss lang="en"><text>a situation or state of affairs</text></gloss></sense><sense id="status_2" guid="d3353414-3b4b-5a9a-8e72-b4a1fa4a322c"><grammatical-info value="Noun"/><gloss lang="en"><text>a function of some instant messaging applications, whereby a user may post a message that appears automatically to other users, if they attempt to make contact</text></gloss></sense><sense id="status_3" guid="7cd90b1d-24c9-567c-aff2-0988e287ff03"><grammatical-info value="Noun"/><gloss lang="en"><text>a medical file, medical record</text></gloss></sense></entry>
