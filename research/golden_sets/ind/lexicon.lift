<entry id="tumbuh" guid="b117050d-96ed-5cb7-9634-2d3a4e3bcad1"><lexical-unit><form lang="id"><text>tumbuh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tumbuh_0" guid="243678d1-7913-59a7-bd50-7a67bbf9b8b5"><grammatical-info value="Verb"/><gloss lang="en"><text>to grow (to become bigger)</text></gloss></sense></entry>
<entry id="tumpah" guid="91727ee9-c6d6-56dd-8934-4bc7d70e914e"><lexical-unit><form lang="id"><text>tumpah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tumpah_0" guid="98fa0398-bae3-5122-88de-3e277a4f9169"><grammatical-info value="Verb"/><gloss lang="en"><text>to spill; to shed</text></gloss></sense></entry>
<entry id="tumpang" guid="eb590a99-9a5d-5579-9c06-661fd984773a"><lexical-unit><form lang="id"><text>tumpang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tumpang_0" guid="8a68a3c3-ca00-57bc-926e-e51f38c85ce6"><grammatical-info value="Verb"/><gloss lang="en"><text>to carry</text></gloss></sense><sense id="tumpang_1" guid="180898eb-1698-5f26-b757-342101ac9d21"><grammatical-info value="Verb"/><gloss lang="en"><text>to hitch a ride</text></gloss></sense><sense id="tumpang_2" guid="6936dbc2-32f2-5d34-9102-96f80df3e67d"><grammatical-info value="Verb"/><gloss lang="en"><text>to join</text></gloss></sense><sense id="tumpang_3" guid="0b83e5a8-cbde-570f-b594-fd330567d644"><grammatical-info value="Verb"/><gloss lang="en"><text>an arrangement of wooden blocks that form an inverted pyramid, the higher up they are, the wider they become</text></gloss></sense><sense id="tumpang_4" guid="0ba1bea8-d76a-5657-be31-7cfc813c8d26"><grammatical-info value="Verb"/><gloss lang="en"><text>beams arranged in tiers on the roof of a traditional Javanese house, usually in odd numbers</text></gloss></sense></entry>
<entry id="tumpu" guid="56489ccc-00ff-5a9e-8569-95fa879afcff"><lexical-unit><form lang="id"><text>tumpu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tumpu_0" guid="a09cea54-b560-5871-91da-16368030554f"><grammatical-info value="Verb"/><gloss lang="en"><text>footing</text></gloss></sense><sense id="tumpu_1" guid="0f0b8d64-c1da-5d85-86f1-d7f2be58f34d"><grammatical-info value="Verb"/><gloss lang="en"><text>foothold</text></gloss></sense><sense id="tumpu_2" guid="ac297477-95f4-5849-8437-c5fa6f3db780"><grammatical-info value="Verb"/><gloss lang="en"><text>springboard</text></gloss></sense><sense id="tumpu_3" guid="adfd42c6-6be5-5c9f-b696-82348eab63cf"><grammatical-info value="Verb"/><gloss lang="en"><text>abutment, butt</text></gloss></sense></entry>
<entry id="tumpuk" guid="e4c02fdb-14ab-52b9-b3bc-52925ddc931a"><lexical-unit><form lang="id"><text>tumpuk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tumpuk_0" guid="a236d08c-c142-54cc-be40-405fd2731be9"><grammatical-info value="Verb"/><gloss lang="en"><text>stack</text></gloss></sense></entry>
<entry id="tumpul" guid="b3afc3fa-bc36-50e5-8706-5f2286d9122f"><lexical-unit><form lang="id"><text>tumpul</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tumpul_0" guid="33fce50d-14dc-5ea1-8e13-89a8995efd30"><grammatical-info value="Verb"/><gloss lang="en"><text>blunt, dull</text></gloss></sense><sense id="tumpul_1" guid="27bb3d7f-9913-5bac-946f-679d91244440"><grammatical-info value="Verb"/><gloss lang="en"><text>stupid, dull, slow of understanding</text></gloss></sense></entry>
<entry id="tuna" guid="389c8b08-e9f1-5d95-bdd5-889d559308d4"><lexical-unit><form lang="id"><text>tuna</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tuna_0" guid="d3785ebb-27ae-5aae-8a29-46e6934905f5"><grammatical-info value="Noun"/><gloss lang="en"><text>tuna, any of several species of fish of the genus Thunnus in the family Scombridae</text></gloss></sense><sense id="tuna_1" guid="4ba7c842-7e7e-54a8-917b-6747eec082de"><grammatical-info value="Noun"/><gloss lang="en"><text>The name of a mudsnake or eel with a yellowish body, possibly the marbled eel, Anguilla marmorata.</text></gloss></sense><sense id="tuna_2" guid="c19e2cac-a698-5bba-a1a7-e6bc7e0fba8f"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative form of tuna-</text></gloss></sense></entry>
<entry id="tunang" guid="c161825d-2c5b-54c3-be06-a98ec778bc79"><lexical-unit><form lang="id"><text>tunang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tunang_0" guid="48c5a0ad-2d6e-57f8-a3c5-5257126c3c62"><grammatical-info value="Verb"/><gloss lang="en"><text>fiancé, fiancée</text></gloss></sense><sense id="tunang_1" guid="debd4f09-3dd4-5972-b57d-50737c2b0c6f"><grammatical-info value="Verb"/><gloss lang="en"><text>bluntnose snake eel (Ophichthus apicalis)</text></gloss></sense></entry>
<entry id="tunas" guid="c4b2a161-1889-5b9b-8b4b-ba87c25e9479"><lexical-unit><form lang="id"><text>tunas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tunas_0" guid="d779534c-8585-5f3b-955d-1bcbc671a48c"><grammatical-info value="Noun"/><gloss lang="en"><text>A shoot of a tree or other plant</text></gloss></sense></entry>
<entry id="tunda" guid="8d7394ac-a15e-5696-bfb3-b91a480013d5"><lexical-unit><form lang="id"><text>tunda</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tunda_0" guid="0c310c37-a9e9-5fe1-947b-6904a17b444a"><grammatical-info value="Verb"/><gloss lang="en"><text>something towed</text></gloss></sense><sense id="tunda_1" guid="ceef5c37-30fe-56c4-b395-7caf94f37577"><grammatical-info value="Verb"/><gloss lang="en"><text>horses used to pull carts containing postal items in ancient times</text></gloss></sense><sense id="tunda_2" guid="e450063d-c17a-54e9-a1c5-7368fb941ab3"><grammatical-info value="Verb"/><gloss lang="en"><text>to defer</text></gloss></sense><sense id="tunda_3" guid="134ca7ea-0f91-5828-9945-5f7b300648c0"><grammatical-info value="Verb"/><gloss lang="en"><text>to delay, to postpone</text></gloss></sense><sense id="tunda_4" guid="fb953b55-42d9-5659-9129-d070f3c11ddf"><grammatical-info value="Verb"/><gloss lang="en"><text>to put off</text></gloss></sense><sense id="tunda_5" guid="9c045ce5-f002-5168-8713-5d7ffb09565c"><grammatical-info value="Verb"/><gloss lang="en"><text>unpaid coolies</text></gloss></sense><sense id="tunda_6" guid="5925fa3a-aa97-540d-b802-8602e3c16d4e"><grammatical-info value="Verb"/><gloss lang="en"><text>to shove</text></gloss></sense><sense id="tunda_7" guid="48fb06e1-a5c2-5116-8584-43dde3e19c98"><grammatical-info value="Verb"/><gloss lang="en"><text>to push forward</text></gloss></sense></entry>
<entry id="tunduk" guid="6f66450e-2be0-58d6-b27f-c550916663c9"><lexical-unit><form lang="id"><text>tunduk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tunduk_0" guid="19db57e9-3e20-5b10-a19d-380a51d819ff"><grammatical-info value="Verb"/><gloss lang="en"><text>to bow (to bend oneself as a gesture of respect or deference)</text></gloss></sense><sense id="tunduk_1" guid="4df2d6ac-dd96-5255-b0ea-aa41631d4056"><grammatical-info value="Verb"/><gloss lang="en"><text>to surrender; to yield (to give up into the power, control, or possession of another)</text></gloss></sense><sense id="tunduk_2" guid="1d345d1d-24de-5f7e-a1e9-fb733eaaf576"><grammatical-info value="Verb"/><gloss lang="en"><text>to submit (to yield or give way to another)</text></gloss></sense><sense id="tunduk_3" guid="82aba03b-309c-55cc-936a-003597d92da8"><grammatical-info value="Verb"/><gloss lang="en"><text>the traditional calendar of the Sumedang people to determine auspicious days for activities such as weddings, circumcisions, or rice field cultivation, in the form of a flat wooden surface, measuring 27 cm long and 13.5 cm wide.</text></gloss></sense></entry>
<entry id="tunggal" guid="3de73423-cf70-5d28-b741-cc56306a2d98"><lexical-unit><form lang="id"><text>tunggal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tunggal_0" guid="6f51b250-64e3-5d9a-b445-ee9650cc6eaf"><grammatical-info value="Adjective"/><gloss lang="en"><text>single (not accompanied by anything else)</text></gloss></sense><sense id="tunggal_1" guid="515b3c5c-2ed4-5f94-8676-9ca3676186cc"><grammatical-info value="Adjective"/><gloss lang="en"><text>unique</text></gloss></sense><sense id="tunggal_2" guid="7eba62a9-1eb5-5794-9399-111179d95bfc"><grammatical-info value="Adjective"/><gloss lang="en"><text>one: only, sole; entire, whole (general conception of God)</text></gloss></sense><sense id="tunggal_3" guid="f33b22e3-f94d-5c38-8811-e259b8053289"><grammatical-info value="Adjective"/><gloss lang="en"><text>one</text></gloss></sense></entry>
<entry id="tunggang" guid="11270332-2bdf-505d-a5cc-89699b2047d1"><lexical-unit><form lang="id"><text>tunggang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tunggang_0" guid="8fdd4451-1b8d-5702-9570-9d81cb8ddc86"><grammatical-info value="Noun"/><gloss lang="en"><text>untie</text></gloss></sense></entry>
<entry id="tunggu" guid="2aa178d0-55eb-53cb-91d2-fc5727fd8863"><lexical-unit><form lang="id"><text>tunggu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tunggu_0" guid="a964d987-6360-5b5f-baae-a0e73fa369ce"><grammatical-info value="Verb"/><gloss lang="en"><text>to wait</text></gloss></sense><sense id="tunggu_1" guid="691cf4b3-2916-582b-88a6-4048f1ac5eec"><grammatical-info value="Verb"/><gloss lang="en"><text>to wait for, await (to wait until the specified event occurs)</text></gloss></sense><sense id="tunggu_2" guid="760dca59-f189-520e-9ba7-86b04a2212b4"><grammatical-info value="Verb"/><gloss lang="en"><text>to take care of</text></gloss></sense><sense id="tunggu_3" guid="1cec9296-9724-593c-a74d-86219f1eb83d"><grammatical-info value="Verb"/><gloss lang="en"><text>to dwell, live, reside</text></gloss></sense></entry>
<entry id="tungku" guid="62c57dc5-0e8d-5d78-953e-1e054fa99f1f"><lexical-unit><form lang="id"><text>tungku</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tungku_0" guid="eeeacc3b-33b5-597c-8f2c-e6eb6c684935"><grammatical-info value="Noun"/><gloss lang="en"><text>hearth</text></gloss></sense><sense id="tungku_1" guid="9e2cb6bf-2b0e-531a-ab35-e8df70caadf7"><grammatical-info value="Noun"/><gloss lang="en"><text>brazier</text></gloss></sense><sense id="tungku_2" guid="6bf1183e-fd47-5c36-b28a-31d70000c7de"><grammatical-info value="Noun"/><gloss lang="en"><text>oven, stove</text></gloss></sense><sense id="tungku_3" guid="16a29545-e907-5685-ab9f-9c1e3bde0bc7"><grammatical-info value="Noun"/><gloss lang="en"><text>kiln</text></gloss></sense><sense id="tungku_4" guid="3a26d103-c0a8-5d26-b58b-f752599fcd16"><grammatical-info value="Noun"/><gloss lang="en"><text>Malay royal title</text></gloss></sense></entry>
<entry id="tunjuk" guid="a76fe918-535d-5234-a0bc-11d5c6a56132"><lexical-unit><form lang="id"><text>tunjuk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tunjuk_0" guid="884e5241-8d91-51fc-aaec-77101c53edb2"><grammatical-info value="Verb"/><gloss lang="en"><text>to show</text></gloss></sense></entry>
<entry id="tuntun" guid="61586a57-4dfb-5326-8c75-85326ec1718e"><lexical-unit><form lang="id"><text>tuntun</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tuntun_0" guid="56787f5d-7bcf-5efb-94d1-3e9e8d92f2a3"><grammatical-info value="Verb"/><gloss lang="en"><text>to guide, to lead</text></gloss></sense><sense id="tuntun_1" guid="17c9482d-7190-5f25-8f35-0d2be99018e1"><grammatical-info value="Verb"/><gloss lang="en"><text>blinker, blindfold</text></gloss></sense></entry>
<entry id="tuntut" guid="77b5c54a-2950-58ea-a384-3fca675a6d11"><lexical-unit><form lang="id"><text>tuntut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tuntut_0" guid="3c90fbc6-3aea-5a0e-957d-1e67d6f19952"><grammatical-info value="Verb"/><gloss lang="en"><text>to sue</text></gloss></sense><sense id="tuntut_1" guid="4ede581e-7e74-557b-b412-3230757326b9"><grammatical-info value="Verb"/><gloss lang="en"><text>to demand</text></gloss></sense><sense id="tuntut_2" guid="1ca39dbe-6e37-5666-8acc-2caa5c2ed0bb"><grammatical-info value="Verb"/><gloss lang="en"><text>banana flower</text></gloss></sense></entry>
<entry id="turun" guid="56315a82-fb47-5b1d-96f0-35a38960f807"><lexical-unit><form lang="id"><text>turun</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="turun_0" guid="081acef5-1739-5405-b2ac-6afd430b5050"><grammatical-info value="Verb"/><gloss lang="en"><text>to go down; to alight; to descend</text></gloss></sense><sense id="turun_1" guid="a52680cc-743e-59b4-9401-0b957c037abe"><grammatical-info value="Verb"/><gloss lang="en"><text>to decrease, to decline</text></gloss></sense><sense id="turun_2" guid="cd71f4fe-78d0-5b43-8d92-350aa478bb5e"><grammatical-info value="Verb"/><gloss lang="en"><text>to get off</text></gloss></sense><sense id="turun_3" guid="eac72a0a-f3d0-5a48-9860-b7b623fb2814"><grammatical-info value="Verb"/><gloss lang="en"><text>to end</text></gloss></sense><sense id="turun_4" guid="5d451f6d-e3ac-5af1-8cbc-20eac63b5a92"><grammatical-info value="Verb"/><gloss lang="en"><text>to fall</text></gloss></sense><sense id="turun_5" guid="e73c3174-4478-5499-be33-08d654cb6b21"><grammatical-info value="Verb"/><gloss lang="en"><text>to be received</text></gloss></sense><sense id="turun_6" guid="9cb089c7-d676-57c6-9c1f-ff86cf9ac3da"><grammatical-info value="Verb"/><gloss lang="en"><text>to take to the dance floor; to take to the stage</text></gloss></sense><sense id="turun_7" guid="ff7c2887-1340-53b0-b41d-acfe3fcea68d"><grammatical-info value="Verb"/><gloss lang="en"><text>to copy</text></gloss></sense></entry>
<entry id="turunkan" guid="b51229f7-2adc-5295-9fc5-673a05a1255b"><lexical-unit><form lang="id"><text>turunkan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="turunkan_0" guid="1d1e0df1-ccb2-5526-8391-6a6e106597f4"><grammatical-info value="Verb"/></sense></entry>
<entry id="turut" guid="3660f98f-eec1-5772-9156-350d56f95964"><lexical-unit><form lang="id"><text>turut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="turut_0" guid="7de69a4d-a4e6-54ab-8b16-7acc237aa720"><grammatical-info value="Verb"/><gloss lang="en"><text>to join in; to take part in (doing something with others)</text></gloss></sense><sense id="turut_1" guid="5f2b40b7-23c3-562b-8a85-4d61534f4fdd"><grammatical-info value="Verb"/><gloss lang="en"><text>to obey</text></gloss></sense></entry>
<entry id="tutul" guid="32226d85-5d93-549a-978e-06182f83abb1"><lexical-unit><form lang="id"><text>tutul</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tutul_0" guid="5d34edfd-61cf-5818-a2fb-966b46fb57c5"><grammatical-info value="Noun"/><gloss lang="en"><text>spot</text></gloss></sense><sense id="tutul_1" guid="7875bbc8-bba5-540d-8c58-1dd5f030a415"><grammatical-info value="Noun"/><gloss lang="en"><text>a kind of children's games.</text></gloss></sense></entry>
