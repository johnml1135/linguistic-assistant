<entry id="sekeliling" guid="5e6a9b4c-a52e-581e-ac28-7e6d2c31dfb5"><lexical-unit><form lang="id"><text>sekeliling</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sekeliling_0" guid="e0054c84-b6f3-5570-b315-284fdace6939"><grammatical-info value="Noun"/><gloss lang="en"><text>noon</text></gloss></sense></entry>
<entry id="sekitar" guid="d9102bb2-3ced-55a8-a277-e981e2b48571"><lexical-unit><form lang="id"><text>sekitar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sekitar_0" guid="d4d70219-e2e6-5a6a-b5c3-a1aff252ef20"><grammatical-info value="Adposition"/><gloss lang="en"><text>around</text></gloss></sense><sense id="sekitar_1" guid="a17de72e-61f7-574b-84ba-56eeea1233b8"><grammatical-info value="Adposition"/><gloss lang="en"><text>roughly, about (in giving numbers)</text></gloss></sense><sense id="sekitar_2" guid="c4c8a25b-cf78-5b40-aaeb-3f3ec829842b"><grammatical-info value="Adposition"/><gloss lang="en"><text>vicinity</text></gloss></sense></entry>
<entry id="seko" guid="a70645b0-ac04-5780-84d9-d11b3ac23d25"><lexical-unit><form lang="id"><text>seko</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="seko_0" guid="2d69cc12-ceb4-5d6f-991d-be07655fc50c"><grammatical-info value="Noun"/><gloss lang="en"><text>observer, scout, spy</text></gloss></sense><sense id="seko_1" guid="8fd0a02e-a3a8-5600-ae11-e50dc8c284ff"><grammatical-info value="Noun"/><gloss lang="en"><text>to wipe bruised part after falling with cloth</text></gloss></sense><sense id="seko_2" guid="e69ee76f-c6d3-53d0-857a-b725b82430a5"><grammatical-info value="Noun"/><gloss lang="en"><text>a tribe in South Sulawesi, Indonesia</text></gloss></sense></entry>
<entry id="sekoci" guid="d54756be-af99-5b38-b929-eb98acd1a223"><lexical-unit><form lang="id"><text>sekoci</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sekoci_0" guid="d9380620-2156-5b24-82b8-13f1eff04dd3"><grammatical-info value="Proper noun"/><gloss lang="en"><text>craft; sloop.</text></gloss></sense><sense id="sekoci_1" guid="690e2a05-fbd0-5d82-9530-ec398bb90a59"><grammatical-info value="Proper noun"/><gloss lang="en"><text>lifeboat ("a boat to save shipwrecked people").</text></gloss></sense><sense id="sekoci_2" guid="1ca6a02e-8ccf-52ea-b34f-f76381408654"><grammatical-info value="Proper noun"/><gloss lang="en"><text>shuttle, bobbin case (container in a sewing machine which holds the bobbin or reel)</text></gloss></sense></entry>
<entry id="sekongkol" guid="d8d4bb75-be87-5084-a6c9-36e9bf725197"><lexical-unit><form lang="id"><text>sekongkol</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sekongkol_0" guid="d39f1cb4-3744-5566-86a5-6b2579b3adf4"><grammatical-info value="Noun"/><gloss lang="en"><text>abetment</text></gloss></sense></entry>
<entry id="sekretaris" guid="c87d6318-d4be-5853-ad8e-cc1df21697e0"><lexical-unit><form lang="id"><text>sekretaris</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sekretaris_0" guid="40b60fef-9062-5285-b4e0-c9794083764d"><grammatical-info value="Noun"/></sense></entry>
<entry id="seks" guid="fcb9850e-dece-5912-8d21-3f3c31ef7d0a"><lexical-unit><form lang="id"><text>seks</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="seks_0" guid="ad3f2af9-6ed1-5827-b46a-42964d0b2b13"><grammatical-info value="Noun"/><gloss lang="en"><text>sex</text></gloss></sense><sense id="seks_1" guid="07e7ff41-d428-58f7-b206-3deb91a1c059"><grammatical-info value="Noun"/><gloss lang="en"><text>a category into which sexually-reproducing organisms are divided on the basis of their reproductive roles in their species</text></gloss></sense><sense id="seks_2" guid="e26f9666-cf79-5264-a381-c9d73a766e6f"><grammatical-info value="Noun"/><gloss lang="en"><text>sexual activity</text></gloss></sense><sense id="seks_3" guid="6f2417c5-f652-5250-bea9-2af7d0b987aa"><grammatical-info value="Noun"/><gloss lang="en"><text>lust, passion, sexual desire</text></gloss></sense></entry>
<entry id="seksama" guid="e3f0a61f-3e56-50f8-91a0-a6fa44cb63cc"><lexical-unit><form lang="id"><text>seksama</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="seksama_0" guid="7c905b52-0120-5b5e-8ec0-de4695cb639c"><grammatical-info value="Adjective"/><gloss lang="en"><text>unveiled</text></gloss></sense></entry>
<entry id="seksual" guid="23319c4c-94e2-5e4d-96cc-9aacb3866c71"><lexical-unit><form lang="id"><text>seksual</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="seksual_0" guid="95e4514b-bfcf-5c08-b53b-751548afcd09"><grammatical-info value="Adjective"/><gloss lang="en"><text>sexual:</text></gloss></sense><sense id="seksual_1" guid="fed16b3b-d478-557a-bd50-5c0d112d2208"><grammatical-info value="Adjective"/><gloss lang="en"><text>arising from the fact of being male or female; pertaining to sex or gender, or to the social relations between the sexes</text></gloss></sense><sense id="seksual_2" guid="dfd305b0-32a2-5add-90aa-8763c387be33"><grammatical-info value="Adjective"/><gloss lang="en"><text>pertaining to sexual intercourse or other intimate physical contact</text></gloss></sense></entry>
<entry id="sekutu" guid="775134f2-7239-5e01-8d25-3a4a44e16032"><lexical-unit><form lang="id"><text>sekutu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sekutu_0" guid="ee1c1929-dd33-5d9f-9db6-5d1a86f661f6"><grammatical-info value="Noun"/><gloss lang="en"><text>member of a company</text></gloss></sense><sense id="sekutu_1" guid="3b7992ee-84f3-5772-9b26-bbed0132b25b"><grammatical-info value="Noun"/><gloss lang="en"><text>partner</text></gloss></sense><sense id="sekutu_2" guid="42e8baaf-2a7e-5b15-a082-d43fa721775f"><grammatical-info value="Noun"/><gloss lang="en"><text>partner in crime</text></gloss></sense><sense id="sekutu_3" guid="5a849795-c56c-543a-a0d4-cf9261b95c39"><grammatical-info value="Noun"/><gloss lang="en"><text>union, federation</text></gloss></sense></entry>
<entry id="sel" guid="13940772-68a9-595f-a41f-1c6f4bd121a5"><lexical-unit><form lang="id"><text>sel</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sel_0" guid="88dc1957-6317-5b9c-a8f2-41da2a98f07f"><grammatical-info value="Noun"/><gloss lang="en"><text>cell</text></gloss></sense><sense id="sel_1" guid="921d8f1e-5ef4-5c33-9822-25f548a4a3cb"><grammatical-info value="Noun"/><gloss lang="en"><text>a small room or compartment</text></gloss></sense><sense id="sel_2" guid="52afe06d-065e-5a79-b118-b98031ba7f56"><grammatical-info value="Noun"/><gloss lang="en"><text>prison cell</text></gloss></sense><sense id="sel_3" guid="2982243a-4605-53d7-b760-064a37886717"><grammatical-info value="Noun"/><gloss lang="en"><text>cloister cell</text></gloss></sense><sense id="sel_4" guid="ee2b55db-528c-56bb-84cb-88bf3b3b374b"><grammatical-info value="Noun"/><gloss lang="en"><text>basic unit of a living organism</text></gloss></sense><sense id="sel_5" guid="e26b4b61-6f16-519f-ad07-c307d061b896"><grammatical-info value="Noun"/><gloss lang="en"><text>the basic unit of a battery</text></gloss></sense><sense id="sel_6" guid="4a95734e-6f89-5c5f-8b38-00b1098d8d7e"><grammatical-info value="Noun"/><gloss lang="en"><text>cel: a piece of celluloid on which has been drawn a frame of an animated film</text></gloss></sense></entry>
<entry id="sela" guid="1ab654a1-224c-5d5d-a274-864dd03d2b74"><lexical-unit><form lang="id"><text>sela</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sela_0" guid="6878926e-23da-5808-9233-23af97960590"><grammatical-info value="Verb"/><gloss lang="en"><text>interval, break (time in between two events)</text></gloss></sense><sense id="sela_1" guid="0d6ba6d2-a0be-545b-96f7-2e835a2d2af4"><grammatical-info value="Verb"/><gloss lang="en"><text>cleft, crack, crevice</text></gloss></sense><sense id="sela_2" guid="b5df155f-6b50-519d-b2a9-2db8a9f10e59"><grammatical-info value="Verb"/><gloss lang="en"><text>interim, provisional</text></gloss></sense><sense id="sela_3" guid="5dc74024-63f8-536f-8516-ee1c5495aa3a"><grammatical-info value="Verb"/><gloss lang="en"><text>saddle (a seat for a rider placed on the back of a horse or other animal)</text></gloss></sense><sense id="sela_4" guid="ef632ab9-9cab-553d-96b0-7abcd57d9369"><grammatical-info value="Verb"/><gloss lang="en"><text>alternative form of sila (“to sit cross-legged”)</text></gloss></sense></entry>
<entry id="selama" guid="4c0bacac-30ea-5d93-8a09-8fc35f65e321"><lexical-unit><form lang="id"><text>selama</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="selama_0" guid="666dae40-d71d-5c75-8521-04a7f2546931"><grammatical-info value="Adposition"/><gloss lang="en"><text>during</text></gloss></sense><sense id="selama_1" guid="4bdeab47-747f-5ecb-aa82-b0879f285163"><grammatical-info value="Adposition"/><gloss lang="en"><text>as long as</text></gloss></sense></entry>
<entry id="selamat" guid="f7622b74-8f53-54e5-be9a-716c6acd10de"><lexical-unit><form lang="id"><text>selamat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="selamat_0" guid="7d6709d1-8a39-53eb-ad00-8ab991e79272"><grammatical-info value="Adjective"/><gloss lang="en"><text>congratulations!</text></gloss></sense><sense id="selamat_1" guid="0f0b5ff1-534f-5ee8-b861-0a1e12504f03"><grammatical-info value="Adjective"/><gloss lang="en"><text>safety</text></gloss></sense><sense id="selamat_2" guid="e1a6727e-6235-546d-acb7-8cac1f0322b0"><grammatical-info value="Adjective"/><gloss lang="en"><text>wholeness</text></gloss></sense><sense id="selamat_3" guid="b507fd29-11a1-5d53-87f0-dff4929cd5a9"><grammatical-info value="Adjective"/><gloss lang="en"><text>safe</text></gloss></sense><sense id="selamat_4" guid="3d927479-8017-57fd-bb7c-a981b31bd375"><grammatical-info value="Adjective"/><gloss lang="en"><text>healthy</text></gloss></sense><sense id="selamat_5" guid="51b0e8f7-34f3-5d74-985f-b6023990ef02"><grammatical-info value="Adjective"/><gloss lang="en"><text>successful</text></gloss></sense><sense id="selamat_6" guid="dcf8844d-0068-5638-ba3d-a8cf35a28ce0"><grammatical-info value="Adjective"/><gloss lang="en"><text>happy, merry</text></gloss></sense><sense id="selamat_7" guid="b3f68077-a716-5d75-9f9f-060c117432e3"><grammatical-info value="Adjective"/><gloss lang="en"><text>good</text></gloss></sense></entry>
<entry id="selamatan" guid="160d6360-50fa-5ab6-b215-03a8fd0624f3"><lexical-unit><form lang="id"><text>selamatan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="selamatan_0" guid="1e9f27d1-d50b-5c88-aff0-046c75b66e55"><grammatical-info value="Noun"/><gloss lang="en"><text>slametan: a (Javanese) communal feast, held to celebrate numerous types of event</text></gloss></sense></entry>
<entry id="selamatkan" guid="d3ab70a4-b9b3-56f6-9efc-28427b6f6dd8"><lexical-unit><form lang="id"><text>selamatkan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="selamatkan_0" guid="d8d74029-a0c7-53c7-9954-a1d0b72e8ac1"><grammatical-info value="Verb"/><gloss lang="en"><text>to save</text></gloss></sense><sense id="selamatkan_1" guid="339e8487-9c12-54db-b3d2-17dc76503c17"><grammatical-info value="Verb"/><gloss lang="en"><text>to help someone survive, or rescue someone</text></gloss></sense><sense id="selamatkan_2" guid="693398b9-4d30-5d08-ad5a-84ad6659588b"><grammatical-info value="Verb"/><gloss lang="en"><text>to redeem or protect someone from eternal damnation</text></gloss></sense></entry>
<entry id="selang" guid="a693068b-ab4e-5710-85f1-99227115c0c7"><lexical-unit><form lang="id"><text>selang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="selang_0" guid="5efe4e9c-3890-5fcd-a6cb-e033dff990fe"><grammatical-info value="Noun"/><gloss lang="en"><text>gap, interval</text></gloss></sense><sense id="selang_1" guid="d814ef96-ab03-5e70-b4eb-eda41ae45df4"><grammatical-info value="Noun"/><gloss lang="en"><text>place next to the staircase leading to the serambi, place to wash one's feet and put on one's footwear before house</text></gloss></sense><sense id="selang_2" guid="f29b5ae1-537f-527b-9da3-08362e0461bb"><grammatical-info value="Noun"/><gloss lang="en"><text>during; all through</text></gloss></sense><sense id="selang_3" guid="6c7a4a72-99a8-5d81-8fa2-294ea26ee34b"><grammatical-info value="Noun"/><gloss lang="en"><text>to borrow</text></gloss></sense><sense id="selang_4" guid="01126145-b225-52ba-9f89-d6257eb05dc5"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative spelling of slang (“hose (flexible tube)”)</text></gloss></sense></entry>
<entry id="selanjutnya" guid="b5d4f51e-78aa-557c-9885-1cb47eda5220"><lexical-unit><form lang="id"><text>selanjutnya</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="selanjutnya_0" guid="d14dd3f8-c12c-5355-a31e-496f5ee6f31b"><grammatical-info value="Adverb"/></sense></entry>
<entry id="selat" guid="9de8b236-be2f-5efa-9254-cbc1fbb1ef95"><lexical-unit><form lang="id"><text>selat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="selat_0" guid="5b0467f2-c83e-5467-bd48-3a64945d614c"><grammatical-info value="Proper noun"/><gloss lang="en"><text>strait (narrow channel of water)</text></gloss></sense><sense id="selat_1" guid="a3b42ece-adb6-5784-976c-d60e68ba4153"><grammatical-info value="Proper noun"/><gloss lang="en"><text>synonym of celah (“gap; fissure”)</text></gloss></sense><sense id="selat_2" guid="ce45b88d-079b-5f2a-977e-c085596acfe1"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a Javanese dish influenced by Western cuisine; consists of braised beef tenderloin served in thin watery sauce made from a mixture of garlic, vinegar, sweet soy sauce, Worcestershire sauce, water, and spiced with nutmeg and black pepper</text></gloss></sense></entry>
<entry id="selayak" guid="ac3dbf20-b6d5-504e-b15c-8cd4f98f1f46"><lexical-unit><form lang="id"><text>selayak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="selayak_0" guid="b5bbb713-cebd-5513-a305-86f07951a5a5"></sense></entry>
<entry id="selesai" guid="34fa4a4a-1b7c-5799-ab28-9205b43ccbec"><lexical-unit><form lang="id"><text>selesai</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="selesai_0" guid="b58b3611-8f91-514a-ab0c-f3d310d815af"><grammatical-info value="Verb"/><gloss lang="en"><text>to be finished; to be completed; to be done</text></gloss></sense><sense id="selesai_1" guid="72bae812-2123-57a9-9255-a8bbe875df1d"><grammatical-info value="Verb"/><gloss lang="en"><text>to end</text></gloss></sense><sense id="selesai_2" guid="ba2b3a44-cb34-5925-8a68-0817f3249915"><grammatical-info value="Verb"/><gloss lang="en"><text>to be settled</text></gloss></sense></entry>
<entry id="selesaikan" guid="6563c015-afd5-5fec-a893-d5fd955d933d"><lexical-unit><form lang="id"><text>selesaikan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="selesaikan_0" guid="a65b3aae-45a8-5c30-812f-8b57ef9dcd0a"><grammatical-info value="Verb"/><gloss lang="en"><text>to finish; to complete; to done (to bring to a successful completion)</text></gloss></sense><sense id="selesaikan_1" guid="c29ebb56-b77b-531d-9ef8-a7b6cc03c572"><grammatical-info value="Verb"/><gloss lang="en"><text>to end, to terminate (to put to an end)</text></gloss></sense><sense id="selesaikan_2" guid="133c91c0-cf0b-5d98-ae0b-20281ccd4f0d"><grammatical-info value="Verb"/><gloss lang="en"><text>to settle, to resolve (to conclude; to address a problem etc.)</text></gloss></sense><sense id="selesaikan_3" guid="bee1a7fe-a723-53f6-8db9-ae5b99ae4eaf"><grammatical-info value="Verb"/><gloss lang="en"><text>to arrange (to put in order)</text></gloss></sense></entry>
