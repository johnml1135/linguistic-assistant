<entry id="kepala" guid="9d2a3e7c-c845-5066-bb77-4df1953d1adc"><lexical-unit><form lang="id"><text>kepala</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kepala_0" guid="6b1eedac-0ff6-5780-859a-a19d73bab844"><grammatical-info value="Noun"/><gloss lang="en"><text>head: the part of the body of an animal or human which contains the brain, mouth and main sense organs</text></gloss></sense><sense id="kepala_1" guid="1c49dd48-35f7-546f-9fe1-2fa34c54281a"><grammatical-info value="Noun"/><gloss lang="en"><text>leader, chief, head</text></gloss></sense><sense id="kepala_2" guid="6a21a547-5cfd-5f31-bb78-1207fb59ff26"><grammatical-info value="Noun"/><gloss lang="en"><text>head: part of a disk drive responsible for reading and writing data</text></gloss></sense><sense id="kepala_3" guid="6987bc4b-ffef-5c42-bffb-9d3a0e41cc0e"><grammatical-info value="Noun"/><gloss lang="en"><text>short for kepala surat</text></gloss></sense></entry>
