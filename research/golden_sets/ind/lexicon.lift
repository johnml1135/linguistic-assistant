<entry id="musuh" guid="f7a8ec05-210c-5849-ad48-d421fc53323a"><lexical-unit><form lang="id"><text>musuh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="musuh_0" guid="4d3f87ac-202f-5b64-93e4-3c088c1e0f52"><grammatical-info value="Noun"/><gloss lang="en"><text>enemy, foe</text></gloss></sense><sense id="musuh_1" guid="8b04fa56-39cb-506f-8c82-6a3814dfa124"><grammatical-info value="Noun"/><gloss lang="en"><text>opponent, rival, competitor</text></gloss></sense></entry>
