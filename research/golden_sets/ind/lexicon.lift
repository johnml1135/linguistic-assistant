<entry id="teliti" guid="1c77e2f6-e9c5-558d-95f3-bd4b2b53376b"><lexical-unit><form lang="id"><text>teliti</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="teliti_0" guid="509f17cb-631b-5dc5-b6a4-cf511f97154d"><grammatical-info value="Adjective"/><gloss lang="en"><text>thorough (painstaking and careful not to miss or omit any detail)</text></gloss></sense><sense id="teliti_1" guid="6639fea2-54fd-58ea-918a-9278e2e4a068"><grammatical-info value="Adjective"/><gloss lang="en"><text>conscientious (thorough, careful, or vigilant in one’s task performance)</text></gloss></sense><sense id="teliti_2" guid="72d18f76-19d8-52e7-b27c-57e4212b692c"><grammatical-info value="Adjective"/><gloss lang="en"><text>to research (to search or examine with continued care; to seek diligently)</text></gloss></sense><sense id="teliti_3" guid="c0f7cc8d-857f-5dd0-8f4c-2e4c44cd1693"><grammatical-info value="Adjective"/><gloss lang="en"><text>to research (to make an extensive investigation into)</text></gloss></sense></entry>
<entry id="teluk" guid="da01cfc8-7bd8-528e-b192-1362dc163b1b"><lexical-unit><form lang="id"><text>teluk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="teluk_0" guid="30817099-96c3-5ab8-9bd0-7d43e611628a"><grammatical-info value="Proper noun"/><gloss lang="en"><text>bay (a body of water more-or-less three-quarters surrounded by land)</text></gloss></sense><sense id="teluk_1" guid="b865f289-3080-50d8-a98e-cb1d207e07ce"><grammatical-info value="Proper noun"/><gloss lang="en"><text>gulf (a portion of an ocean or sea extending into the land; a partially landlocked sea)</text></gloss></sense></entry>
<entry id="telur" guid="106f00de-b4ff-585d-846b-33161fe79ed0"><lexical-unit><form lang="id"><text>telur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="telur_0" guid="269e1a97-5271-5d56-bda7-7de6c9bf2dac"><grammatical-info value="Noun"/><gloss lang="en"><text>egg (object produced by various animals to house an embryo)</text></gloss></sense><sense id="telur_1" guid="5276a1e7-e1ce-544f-b56b-848601535ae9"><grammatical-info value="Noun"/><gloss lang="en"><text>egg (of a bird, especially a chicken, considered food)</text></gloss></sense><sense id="telur_2" guid="c9143733-b2dd-584e-93f9-b678d08ab9a4"><grammatical-info value="Noun"/><gloss lang="en"><text>ovum, egg cell</text></gloss></sense><sense id="telur_3" guid="43229e7f-9aad-57d7-afac-be9444c77116"><grammatical-info value="Noun"/><gloss lang="en"><text>something egg-shaped, ovate</text></gloss></sense></entry>
<entry id="teman" guid="95166564-612f-5fd8-b7af-dc6a0a3534aa"><lexical-unit><form lang="id"><text>teman</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="teman_0" guid="d56854c3-c709-5a01-8e8c-23da12e0e507"><grammatical-info value="Noun"/><gloss lang="en"><text>friend</text></gloss></sense><sense id="teman_1" guid="bded4924-ac24-5371-a278-2a31832d9fd3"><grammatical-info value="Noun"/><gloss lang="en"><text>associate, partner: someone who is associated with another in a common activity</text></gloss></sense><sense id="teman_2" guid="08748edf-d24b-577f-b5da-2d9cc2eec86b"><grammatical-info value="Noun"/><gloss lang="en"><text>complement, supplement</text></gloss></sense></entry>
<entry id="tembaga" guid="eb282120-c351-51c7-9879-798f0592e8d5"><lexical-unit><form lang="id"><text>tembaga</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tembaga_0" guid="814e1c57-9a82-5a9f-b1a6-58f113fdf71b"><grammatical-info value="Noun"/><gloss lang="en"><text>copper (chemical element)</text></gloss></sense></entry>
<entry id="tembok" guid="a9448d61-c586-5b2a-8c08-39c903c3d04b"><lexical-unit><form lang="id"><text>tembok</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tembok_0" guid="fb3eba88-cdf0-5d72-a160-15506d59ab66"><grammatical-info value="Noun"/><gloss lang="en"><text>synonym of dinding (“wall”)</text></gloss></sense></entry>
<entry id="tembus" guid="a14c8c0c-4419-5832-90e2-ec2daadf5ec5"><lexical-unit><form lang="id"><text>tembus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tembus_0" guid="0cf1d7e0-933b-520c-9d74-1b08758b211d"><grammatical-info value="Verb"/></sense></entry>
<entry id="tempat" guid="89c681b2-538a-5df3-a4db-b3f092970df6"><lexical-unit><form lang="id"><text>tempat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tempat_0" guid="40cd1a88-c11c-547d-b15c-55562a0a86d5"><grammatical-info value="Noun"/><gloss lang="en"><text>place (location, position)</text></gloss></sense></entry>
<entry id="tempel" guid="0c4183c4-234f-5cd4-abe8-8b1e669f2bbe"><lexical-unit><form lang="id"><text>tempel</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tempel_0" guid="ec179332-3e99-5016-81f4-82e521484931"><grammatical-info value="Verb"/><gloss lang="en"><text>to stick; to adhere</text></gloss></sense><sense id="tempel_1" guid="6b9e0c40-5986-592e-a192-610834a2e682"><grammatical-info value="Verb"/><gloss lang="en"><text>to paste</text></gloss></sense><sense id="tempel_2" guid="e5a81b13-4901-55b8-a402-25949b2b41fb"><grammatical-info value="Verb"/><gloss lang="en"><text>to cause to stick, to adhere</text></gloss></sense><sense id="tempel_3" guid="09fd94ac-53a9-5e4f-b39f-2407623142e0"><grammatical-info value="Verb"/><gloss lang="en"><text>to insert a piece of media</text></gloss></sense><sense id="tempel_4" guid="64d7832a-d816-5a3c-b1ef-2623ed6b65f8"><grammatical-info value="Verb"/><gloss lang="en"><text>to stick, to adhere to, to cling, to hang on</text></gloss></sense><sense id="tempel_5" guid="57db2845-ee0d-57b4-af85-1948632b8ec1"><grammatical-info value="Verb"/><gloss lang="en"><text>to lodge in, to be implanted in.</text></gloss></sense><sense id="tempel_6" guid="e8747139-661a-53dd-b0c5-72742babeae7"><grammatical-info value="Verb"/><gloss lang="en"><text>to patch.</text></gloss></sense><sense id="tempel_7" guid="e0645ce2-4d34-520a-80b2-fba7c2d35988"><grammatical-info value="Verb"/><gloss lang="en"><text>to be right next (to), to stick (to), to hang out</text></gloss></sense></entry>
<entry id="tempur" guid="f1bcc03a-3854-57ef-bf33-6f4235785d13"><lexical-unit><form lang="id"><text>tempur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tempur_0" guid="b93cfcf5-d826-5e0d-a623-1bcfc4aa5d2d"><grammatical-info value="Verb"/><gloss lang="en"><text>alternative form of menempur (“to attack, to violate”)</text></gloss></sense><sense id="tempur_1" guid="acefe808-bfee-5417-9395-7a52caeb5d61"><grammatical-info value="Verb"/><gloss lang="en"><text>alternative form of menempur (“to buy daily rice; to buy paddy for selling rice”)</text></gloss></sense><sense id="tempur_2" guid="b21455c0-6118-53e4-b007-9ae0975cf9b4"><grammatical-info value="Verb"/><gloss lang="en"><text>alternative form of tempuran (“confluence: the place where two rivers, streams, or other continuously flowing bodies of water meet and become one, especially where a tributary joins a river”)</text></gloss></sense></entry>
<entry id="temu" guid="233095eb-8da4-547f-893e-9aca59a884f2"><lexical-unit><form lang="id"><text>temu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="temu_0" guid="49eb3ccc-6987-5580-b382-166be766127a"><grammatical-info value="Verb"/><gloss lang="en"><text>to meet, to encounter</text></gloss></sense><sense id="temu_1" guid="dc54e0f5-ca37-50f4-b60c-fa273a735308"><grammatical-info value="Verb"/><gloss lang="en"><text>curcuma: a plant which the bulb used as (traditional) medical potion</text></gloss></sense></entry>
<entry id="tenaga" guid="dae348c8-9f65-5e40-ac15-8f410d5f878f"><lexical-unit><form lang="id"><text>tenaga</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tenaga_0" guid="fb6e63ae-86b5-5b28-8d6e-a712e8777a4c"><grammatical-info value="Noun"/><gloss lang="en"><text>energy:</text></gloss></sense><sense id="tenaga_1" guid="e8b9b1ec-607c-5ce5-aae3-69edcc8d98c3"><grammatical-info value="Noun"/><gloss lang="en"><text>the capacity to do work</text></gloss></sense><sense id="tenaga_2" guid="aad52751-70a6-5338-8766-1934d9d47f11"><grammatical-info value="Noun"/><gloss lang="en"><text>a quantity that denotes the ability to do work and is measured in a unit dimensioned in mass × distance²/time² (ML²/T²) or the equivalent</text></gloss></sense><sense id="tenaga_3" guid="c814f897-2f99-597c-89e5-2b84f5c9e691"><grammatical-info value="Noun"/><gloss lang="en"><text>worker</text></gloss></sense></entry>
<entry id="tenang" guid="39909d03-1845-50b9-948b-53286915f6b5"><lexical-unit><form lang="id"><text>tenang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tenang_0" guid="deda5025-66f5-5df6-bfae-f8a1225bfa39"><grammatical-info value="Adjective"/><gloss lang="en"><text>calm, motionless (of water, etc.)</text></gloss></sense><sense id="tenang_1" guid="2a4cf70f-7450-5212-98c0-0c0bcabd223c"><grammatical-info value="Adjective"/><gloss lang="en"><text>calm, composed, still, collected, imperturbable</text></gloss></sense></entry>
<entry id="tenda" guid="f6c30ce1-6d6e-5628-a293-52f7464223ba"><lexical-unit><form lang="id"><text>tenda</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tenda_0" guid="5de4fde3-981d-5fa0-8b4a-a126c54c30b5"><grammatical-info value="Noun"/><gloss lang="en"><text>tent: a pavilion or portable lodge consisting of skins, canvas, or some strong cloth, stretched and sustained by poles, used for sheltering people from the weather</text></gloss></sense><sense id="tenda_1" guid="5c0c26aa-3cf1-5b5f-8f6c-b32e148723a0"><grammatical-info value="Noun"/><gloss lang="en"><text>ceiling</text></gloss></sense><sense id="tenda_2" guid="84f23f22-9799-5dab-88dc-e286eea5a0b5"><grammatical-info value="Noun"/><gloss lang="en"><text>hood, bonnet: the hinged cover over the engine of a motor vehicle</text></gloss></sense></entry>
<entry id="tengah" guid="c5537dac-dcb1-5e14-889f-27b83325e138"><lexical-unit><form lang="id"><text>tengah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tengah_0" guid="8a4828ad-7af3-5d10-8324-db51b81ec706"><grammatical-info value="Proper noun"/><gloss lang="en"><text>middle</text></gloss></sense><sense id="tengah_1" guid="05d4aeed-f1f3-55f5-8a9f-4321cd21b125"><grammatical-info value="Proper noun"/><gloss lang="en"><text>centre, center</text></gloss></sense><sense id="tengah_2" guid="ea4e2a99-b315-59a0-844b-406f63651986"><grammatical-info value="Proper noun"/><gloss lang="en"><text>half</text></gloss></sense><sense id="tengah_3" guid="e56c7e3e-102a-5ee5-a6c2-b1e28e9431c4"><grammatical-info value="Proper noun"/><gloss lang="en"><text>while: during the same time that</text></gloss></sense><sense id="tengah_4" guid="3190fd4a-cac2-5868-a85c-b6f5afc6b7cf"><grammatical-info value="Proper noun"/><gloss lang="en"><text>progressive aspect without necessarily a final perspective.</text></gloss></sense></entry>
<entry id="tenggelam" guid="928d3618-bab7-5184-91c5-f1ab3c9965a7"><lexical-unit><form lang="id"><text>tenggelam</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tenggelam_0" guid="a0659c51-02eb-53b2-a0f9-0dcb2dcb49bb"><grammatical-info value="Verb"/><gloss lang="en"><text>to submerge, to sink, to be immersed</text></gloss></sense><sense id="tenggelam_1" guid="c1508d23-7739-5c2c-93ad-1ba5b46f0232"><grammatical-info value="Verb"/><gloss lang="en"><text>to set (of sun)</text></gloss></sense><sense id="tenggelam_2" guid="07136e9e-7212-54e3-95e0-526c88d8ecef"><grammatical-info value="Verb"/><gloss lang="en"><text>to lose oneself</text></gloss></sense><sense id="tenggelam_3" guid="4fc39ed9-ce3c-54aa-a930-c78a5c74e1b3"><grammatical-info value="Verb"/><gloss lang="en"><text>to fall</text></gloss></sense><sense id="tenggelam_4" guid="ff721230-cfdb-5c57-b585-0ef4ab94ccc5"><grammatical-info value="Verb"/><gloss lang="en"><text>to lost, to disappear, to miss</text></gloss></sense><sense id="tenggelam_5" guid="767e336c-53a5-57da-8068-a457596c21cd"><grammatical-info value="Verb"/><gloss lang="en"><text>to be absorbed, to be engrossed</text></gloss></sense></entry>
<entry id="tengger" guid="0c7959b7-5b44-5e3a-9b30-c4af410e3f6a"><lexical-unit><form lang="id"><text>tengger</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tengger_0" guid="2cb8b4e8-3d44-5488-8589-6c9dce7e8615"><grammatical-info value="Noun"/><gloss lang="en"><text>perch (a place used as a roost or stand by a bird)</text></gloss></sense></entry>
<entry id="tengkar" guid="0153d1e5-77c4-55e7-9694-f53367e61386"><lexical-unit><form lang="id"><text>tengkar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tengkar_0" guid="5712ec70-96b5-53a8-a4a4-458ee3a151f8"><grammatical-info value="Verb"/><gloss lang="en"><text>to fight</text></gloss></sense></entry>
<entry id="tengkorak" guid="3bfa7289-ff90-5ec7-8277-bb3736b87411"><lexical-unit><form lang="id"><text>tengkorak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tengkorak_0" guid="c8c43d3b-e710-5829-abf8-d9a1faa591e0"><grammatical-info value="Noun"/><gloss lang="en"><text>skull</text></gloss></sense></entry>
<entry id="tengok" guid="af13b19c-81b8-5174-8f55-caebfe5ee77d"><lexical-unit><form lang="id"><text>tengok</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tengok_0" guid="708d66a1-7ffb-5f1f-a2e9-d9b13d7eb8a5"><grammatical-info value="Verb"/><gloss lang="en"><text>to see</text></gloss></sense><sense id="tengok_1" guid="d0af016a-50ee-5f19-bc7e-40f923f4a754"><grammatical-info value="Verb"/><gloss lang="en"><text>to visit</text></gloss></sense></entry>
<entry id="tentang" guid="84b3aeb2-6a1f-5eac-9112-ea5899bb9a82"><lexical-unit><form lang="id"><text>tentang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tentang_0" guid="79aeadb1-4f1b-5775-9f21-2dc6a0928268"><grammatical-info value="Adposition"/><gloss lang="en"><text>of; about; on; regarding (with regard to; on account of; on the subject of)</text></gloss></sense><sense id="tentang_1" guid="7468ce14-1a8f-5e61-97c2-fcdb279862c2"><grammatical-info value="Adposition"/><gloss lang="en"><text>as to (with reference or regard to)</text></gloss></sense><sense id="tentang_2" guid="eb7a2eeb-14b1-554a-8818-0ceaf05fdc0e"><grammatical-info value="Adposition"/><gloss lang="en"><text>toward (in relation to someone or something)</text></gloss></sense><sense id="tentang_3" guid="65dad698-d0a3-5d30-9aca-4af06e48d1df"><grammatical-info value="Adposition"/><gloss lang="en"><text>near (physically close to, in close proximity to)</text></gloss></sense><sense id="tentang_4" guid="f7f54733-caea-5c47-910c-7f8a981e193e"><grammatical-info value="Adposition"/><gloss lang="en"><text>above (physically over; on top of; worn on top of, said of clothing)</text></gloss></sense><sense id="tentang_5" guid="176d6524-0f1d-5784-8261-c6b86d5e9517"><grammatical-info value="Adposition"/><gloss lang="en"><text>around (forming a circle or closed curve containing something)</text></gloss></sense></entry>
<entry id="tentara" guid="d77e5800-819b-51a1-8dff-467d3e3c2a3c"><lexical-unit><form lang="id"><text>tentara</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tentara_0" guid="1cb335c7-ae49-5877-9733-2c66cf73a7a2"><grammatical-info value="Noun"/><gloss lang="en"><text>armed forces; army</text></gloss></sense><sense id="tentara_1" guid="b2cea19b-b222-571e-86ee-09edb8dfce15"><grammatical-info value="Noun"/><gloss lang="en"><text>soldier</text></gloss></sense></entry>
<entry id="tentu" guid="4b94974b-c33f-5f0d-ac1f-f90c603bda2d"><lexical-unit><form lang="id"><text>tentu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tentu_0" guid="6ecfdc7c-c9e8-59ba-a9e7-6eeda8e0a070"><grammatical-info value="Adverb"/><gloss lang="en"><text>certain, definite, sure</text></gloss></sense><sense id="tentu_1" guid="7d00d857-b74b-502c-a642-2e7e711e8edc"><grammatical-info value="Adverb"/><gloss lang="en"><text>bright</text></gloss></sense><sense id="tentu_2" guid="b488718f-c179-5c63-8a1c-61700d46adf6"><grammatical-info value="Adverb"/><gloss lang="en"><text>positive</text></gloss></sense><sense id="tentu_3" guid="9374a937-b47b-59fe-be6e-c464f6322bc8"><grammatical-info value="Adverb"/><gloss lang="en"><text>assertive, clear, decisive, firm, resolute</text></gloss></sense><sense id="tentu_4" guid="f5184702-0d1a-5116-95c7-8132e634908c"><grammatical-info value="Adverb"/><gloss lang="en"><text>of course</text></gloss></sense></entry>
<entry id="tenun" guid="76b17af3-3d3e-5c04-93b8-80725336ff41"><lexical-unit><form lang="id"><text>tenun</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tenun_0" guid="cc4127f5-e43a-5d7b-808f-bc4076fc481d"><grammatical-info value="Verb"/><gloss lang="en"><text>to weave</text></gloss></sense><sense id="tenun_1" guid="1275c3db-974b-5709-92a7-27aeaf5dff6c"><grammatical-info value="Verb"/><gloss lang="en"><text>A traditional ceremony that aims to commemorate the beginning of the existence of the Pelauw Village community, Maluku, held every three years.</text></gloss></sense></entry>
<entry id="tenung" guid="3dc5958b-639d-54f8-8d61-4ae30bb0730b"><lexical-unit><form lang="id"><text>tenung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tenung_0" guid="0cce52d3-491d-5df8-8d19-dd4fdf41cee3"><grammatical-info value="Verb"/></sense></entry>
<entry id="tepat" guid="9c621454-7772-53fb-bcfc-8dfb77ced87b"><lexical-unit><form lang="id"><text>tepat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tepat_0" guid="ba586c6f-67e7-5bef-9f22-91c31f03d7d0"><grammatical-info value="Adjective"/><gloss lang="en"><text>correct</text></gloss></sense><sense id="tepat_1" guid="a13391d0-48ef-58dc-8a47-b80fddc96019"><grammatical-info value="Adjective"/><gloss lang="en"><text>accurate (exact or careful conformity to truth)</text></gloss></sense></entry>
<entry id="tepi" guid="eeb1559e-41d4-5c1d-85c1-31b6cf7681eb"><lexical-unit><form lang="id"><text>tepi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tepi_0" guid="cb968bfb-742e-5d5d-9d6c-0f5cffeef9b5"><grammatical-info value="Noun"/><gloss lang="en"><text>edge</text></gloss></sense><sense id="tepi_1" guid="6fdcc38a-5566-542b-8342-bed10ada63cb"><grammatical-info value="Noun"/><gloss lang="en"><text>rim: an edge around something, especially when circular</text></gloss></sense><sense id="tepi_2" guid="d0689501-c9ec-5360-b412-6269ad39aef7"><grammatical-info value="Noun"/><gloss lang="en"><text>side: a bounding straight edge of a two-dimensional shape</text></gloss></sense><sense id="tepi_3" guid="cac2248d-2c05-55fc-979f-d069c3345e56"><grammatical-info value="Noun"/><gloss lang="en"><text>bank, shore (of watercourse, body of water)</text></gloss></sense><sense id="tepi_4" guid="8533ed99-abf9-523a-84c8-79555ad0dd94"><grammatical-info value="Noun"/><gloss lang="en"><text>border:</text></gloss></sense><sense id="tepi_5" guid="e18b5967-9928-5f3a-a8b0-91a416535577"><grammatical-info value="Noun"/><gloss lang="en"><text>the line or frontier area separating political or geographical regions</text></gloss></sense><sense id="tepi_6" guid="d1badb86-2802-5597-b0fc-c4477dde3a3b"><grammatical-info value="Noun"/><gloss lang="en"><text>the outer edge of something</text></gloss></sense><sense id="tepi_7" guid="91ef885c-48e5-5e92-95b3-c87a3b074dbb"><grammatical-info value="Noun"/><gloss lang="en"><text>a decorative strip around the edge of something</text></gloss></sense></entry>
<entry id="tepung" guid="bb2297bf-3ff9-54d3-8cc9-d15336300835"><lexical-unit><form lang="id"><text>tepung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tepung_0" guid="f294af52-661b-5b93-8ec0-455f615ce41d"><grammatical-info value="Noun"/><gloss lang="en"><text>flour (ground cereal grains)</text></gloss></sense><sense id="tepung_1" guid="dd36eea2-8c94-5475-b770-37815a8aef87"><grammatical-info value="Noun"/><gloss lang="en"><text>mash</text></gloss></sense></entry>
<entry id="ter" guid="38122d86-95ba-5aef-acb8-5a0d1a1d6fcf"><lexical-unit><form lang="id"><text>ter</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ter_0" guid="6faa6954-4a98-5501-891b-88249d352d4f"><grammatical-info value="Verb"/><gloss lang="en"><text>tar, the black, oily, sticky, viscous substance, consisting mainly of hydrocarbons derived from organic materials such as wood, peat, or coal</text></gloss></sense><sense id="ter_1" guid="ef81059f-00a5-54ed-ac24-126ca8b90879"><grammatical-info value="Verb"/><gloss lang="en"><text>thrice, following bis (“second”)</text></gloss></sense><sense id="ter_2" guid="6b9adaec-bf62-5d9a-9867-fe7bf24a4ff8"><grammatical-info value="Verb"/><gloss lang="en"><text>alternative spelling of tir</text></gloss></sense></entry>
<entry id="terakhir" guid="ca86d871-91c4-550d-bd81-fc0f7b8ba86c"><lexical-unit><form lang="id"><text>terakhir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="terakhir_0" guid="e70c8fd7-e805-57e8-9364-3243a6ee7024"><grammatical-info value="Adjective"/><gloss lang="en"><text>Final; latest, last, ultimate.</text></gloss></sense></entry>
<entry id="terang" guid="61b447fb-fe69-5c7a-a573-32473aa5a637"><lexical-unit><form lang="id"><text>terang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="terang_0" guid="851e4959-14f4-52a3-97f3-2a11c7c01251"><grammatical-info value="Verb"/><gloss lang="en"><text>bright, clear</text></gloss></sense><sense id="terang_1" guid="89e0debc-eef3-5d7e-a6ac-095d66e36af7"><grammatical-info value="Verb"/><gloss lang="en"><text>clear</text></gloss></sense><sense id="terang_2" guid="66febdef-fb0b-5838-81d6-0e0f280e592e"><grammatical-info value="Verb"/><gloss lang="en"><text>easily or distinctly heard; audible</text></gloss></sense><sense id="terang_3" guid="4cc2d6da-03ce-5942-ae47-384ba3fb4158"><grammatical-info value="Verb"/><gloss lang="en"><text>without clouds</text></gloss></sense><sense id="terang_4" guid="b69cbf0e-c34e-56c2-87a4-02980a2299c2"><grammatical-info value="Verb"/><gloss lang="en"><text>free of guilt, or suspicion</text></gloss></sense><sense id="terang_5" guid="5476c3d8-0cce-5f86-a799-143ddfece741"><grammatical-info value="Verb"/><gloss lang="en"><text>evident, obvious</text></gloss></sense></entry>
