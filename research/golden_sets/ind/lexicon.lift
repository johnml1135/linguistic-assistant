<entry id="mengabdi" guid="cb525a2e-3d1d-5070-9a04-9f0c51c624b7"><lexical-unit><form lang="id"><text>mengabdi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mengabdi_0" guid="bd11af71-903f-5298-9678-4ada97314d3a"><grammatical-info value="Verb"/><gloss lang="en"><text>To be a slave.</text></gloss></sense><sense id="mengabdi_1" guid="c5019ff6-edf5-5b31-af07-8fc32216199d"><grammatical-info value="Verb"/><gloss lang="en"><text>To serve.</text></gloss></sense></entry>
<entry id="mengadili" guid="48765533-d37f-5f80-8f59-01b32bab6efa"><lexical-unit><form lang="id"><text>mengadili</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mengadili_0" guid="ed3887bf-de1b-5c81-ada1-bd9af4ca9e7c"><grammatical-info value="Verb"/><gloss lang="en"><text>to adjudicate</text></gloss></sense></entry>
