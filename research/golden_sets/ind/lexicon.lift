<entry id="besar" guid="fd6cb857-5f95-5847-a8af-f5c7c9fd368e"><lexical-unit><form lang="id"><text>besar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="besar_0" guid="328c029e-7b88-50bc-ae55-fb3b98c05e2c"><grammatical-info value="Adjective"/><gloss lang="en"><text>big, large</text></gloss></sense><sense id="besar_1" guid="eaf782de-9cdf-5ff8-b15b-7f431a97e789"><grammatical-info value="Adjective"/><gloss lang="en"><text>big, great</text></gloss></sense><sense id="besar_2" guid="6a24d936-f5be-5469-af1a-ff6ce33ef301"><grammatical-info value="Adjective"/><gloss lang="en"><text>big, grown up</text></gloss></sense><sense id="besar_3" guid="69b3de5b-c5d4-5e3a-899c-0319431114d4"><grammatical-info value="Adjective"/><gloss lang="en"><text>big, important</text></gloss></sense><sense id="besar_4" guid="4e936a79-09a3-5a24-84f8-b0a15e6b3684"><grammatical-info value="Adjective"/><gloss lang="en"><text>area, large, size</text></gloss></sense><sense id="besar_5" guid="2fc620ef-b5fb-56b6-b47f-0ba54016ffac"><grammatical-info value="Adjective"/><gloss lang="en"><text>magnitude</text></gloss></sense><sense id="besar_6" guid="83fa8f9d-e5ce-5c77-9b9a-be93addd9c49"><grammatical-info value="Adjective"/><gloss lang="en"><text>synonym of murbei (“mulberry”)</text></gloss></sense></entry>
<entry id="besarkan" guid="2ec2de3f-cd2e-507e-9181-07c815f8c6d3"><lexical-unit><form lang="id"><text>besarkan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="besarkan_0" guid="dea8781f-c354-5e84-ad81-0305803dc6d4"><grammatical-info value="Verb"/><gloss lang="en"><text>to raise; to bring up; to grow (to take care of something from small until it's large)</text></gloss></sense><sense id="besarkan_1" guid="6437b858-1399-5c91-9c21-3310540ab2ed"><grammatical-info value="Verb"/><gloss lang="en"><text>to turn up (to increase the amount of something by means of a control, such as the volume, heat, or light)</text></gloss></sense></entry>
<entry id="beserta" guid="436d143c-a911-56f5-90a5-1762ffcd9a27"><lexical-unit><form lang="id"><text>beserta</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="beserta_0" guid="66ab0bc7-9cd8-5801-807a-a60503ae9b43"><grammatical-info value="Adposition"/></sense></entry>
<entry id="besok" guid="e036b7bc-2eb9-513d-ad90-60b1b41cb3fa"><lexical-unit><form lang="id"><text>besok</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="besok_0" guid="e03a3b24-f1c0-508c-a2d7-919b55685e55"><grammatical-info value="Noun"/><gloss lang="en"><text>tomorrow: the day after the present day</text></gloss></sense><sense id="besok_1" guid="e88bb224-b05b-5574-bce1-cf78e3adfd05"><grammatical-info value="Noun"/><gloss lang="en"><text>some point in the future</text></gloss></sense><sense id="besok_2" guid="c84f0d83-b619-51b2-8afa-97acd78b72da"><grammatical-info value="Noun"/><gloss lang="en"><text>tomorrow:</text></gloss></sense><sense id="besok_3" guid="66dfc161-f664-512c-80fd-f5d3848a522c"><grammatical-info value="Noun"/><gloss lang="en"><text>on the day after the present day</text></gloss></sense><sense id="besok_4" guid="e676bec0-d3c3-5bdb-b75e-744ab1766224"><grammatical-info value="Noun"/><gloss lang="en"><text>at some point in the future; later on</text></gloss></sense></entry>
