<entry id="akses" guid="2f5cbed1-efe4-5844-a0b5-9652492e8bbe"><lexical-unit><form lang="id"><text>akses</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="akses_0" guid="ce0aa5b0-2886-5e0b-8303-eda424968d82"><grammatical-info value="Noun"/><gloss lang="en"><text>access (a way or means of approaching or entering; an entrance; a passage)</text></gloss></sense><sense id="akses_1" guid="987e1a00-891b-51ce-9624-8f7cf495e636"><grammatical-info value="Noun"/><gloss lang="en"><text>access (the process of locating data in memory)</text></gloss></sense><sense id="akses_2" guid="877466e2-f901-5b9c-8752-ac6db48b4526"><grammatical-info value="Noun"/><gloss lang="en"><text>access (connection to or communication with a computer program or to the Internet)</text></gloss></sense></entry>
<entry id="akta" guid="44b9584a-fcc1-50fb-a58a-e0eabacfc957"><lexical-unit><form lang="id"><text>akta</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="akta_0" guid="e462f125-cd0b-559a-919a-8ec894ef13ce"><grammatical-info value="Noun"/><gloss lang="en"><text>certificate</text></gloss></sense><sense id="akta_1" guid="5599f30c-4a7a-51c9-a079-9cdb7e341201"><grammatical-info value="Noun"/><gloss lang="en"><text>a deed; a legal contract</text></gloss></sense></entry>
<entry id="aku" guid="6568bf68-7ec4-50ec-be55-4e46f63c6057"><lexical-unit><form lang="id"><text>aku</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aku_0" guid="8f19f528-a104-5a8a-8790-7555f9d586bd"><grammatical-info value="Pronoun"/><gloss lang="en"><text>pomegranate flower</text></gloss></sense><sense id="aku_1" guid="cf49eba3-dc53-58f2-ae71-81370f005afe"><grammatical-info value="Pronoun"/><gloss lang="en"><text>syllabic abbreviation of anggaran dan keuangan (“budgeting and finance”)</text></gloss></sense></entry>
<entry id="akun" guid="3f3a80e9-1ff6-5472-b0d9-542f29a21e71"><lexical-unit><form lang="id"><text>akun</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="akun_0" guid="daa79436-2fdc-5fd2-8b72-af46e9142fd6"><grammatical-info value="Noun"/><gloss lang="en"><text>account,</text></gloss></sense><sense id="akun_1" guid="b8d9dd5d-3636-5144-af46-b460016119ee"><grammatical-info value="Noun"/><gloss lang="en"><text>a subscription or an authorization to an electronic service</text></gloss></sense><sense id="akun_2" guid="f8d7b352-75f9-566a-9e8e-d8bd224718a4"><grammatical-info value="Noun"/><gloss lang="en"><text>a registry of pecuniary transactions</text></gloss></sense><sense id="akun_3" guid="0c867cba-bec8-56ed-ad2d-6fdb46708505"><grammatical-info value="Noun"/><gloss lang="en"><text>a written or printed statement of business dealings or debts and credits, and also of other things subjected to a reckoning or review</text></gloss></sense></entry>
<entry id="akurat" guid="9c1dbe9f-378e-597e-87a0-7f3a5900f4ab"><lexical-unit><form lang="id"><text>akurat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="akurat_0" guid="00d87f15-a855-5af8-a582-4a491e76cb30"><grammatical-info value="Adjective"/><gloss lang="en"><text>accurate (exact or careful conformity to truth)</text></gloss></sense></entry>
<entry id="al" guid="37b0b61b-ac3e-5ff2-9d62-b7fe86fe5f41"><lexical-unit><form lang="id"><text>al</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="al_0" guid="26753b30-4019-5c8d-997e-b4ea110ad049"><grammatical-info value="Proper noun"/><gloss lang="en"><text>abbreviation of angkatan laut</text></gloss></sense></entry>
<entry id="ala" guid="15a12ed0-16fa-5afa-9df5-b6705e7aee79"><lexical-unit><form lang="id"><text>ala</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ala_0" guid="07b7aaef-542a-5156-9493-c15886340d02"><grammatical-info value="Noun"/><gloss lang="en"><text>a la, in the style or manner of</text></gloss></sense><sense id="ala_1" guid="48f6e58b-85d2-58aa-9f93-e9feeb0c9ad2"><grammatical-info value="Noun"/><gloss lang="en"><text>exalted, high</text></gloss></sense><sense id="ala_2" guid="c9a3b187-ab88-58bc-93c2-5e17d3db853a"><grammatical-info value="Noun"/><gloss lang="en"><text>land, with the owner or descendants still have the main rights in that land</text></gloss></sense><sense id="ala_3" guid="3311feee-e524-5acb-b9b8-bb63409a9260"><grammatical-info value="Noun"/><gloss lang="en"><text>outrigger</text></gloss></sense><sense id="ala_4" guid="8b81e9d0-1d0c-5902-bd3d-24ea7bb90cbc"><grammatical-info value="Noun"/><gloss lang="en"><text>ala</text></gloss></sense><sense id="ala_5" guid="f7467891-9324-5436-95d7-0d74f1c6a661"><grammatical-info value="Noun"/><gloss lang="en"><text>a wing or winglike anatomic process or part, especially of bone.</text></gloss></sense><sense id="ala_6" guid="664f36b3-d89f-52b0-8ea6-bfe4f11214c9"><grammatical-info value="Noun"/><gloss lang="en"><text>the flattened border of some stems, fruits, and seeds, or one of the two side petals of certain flowers in the pea family.</text></gloss></sense><sense id="ala_7" guid="03f1ebc4-18fe-5d9a-a2ef-645a2c36ef95"><grammatical-info value="Noun"/><gloss lang="en"><text>small rivers flowing into the sea</text></gloss></sense></entry>
<entry id="alah" guid="dc6f3af5-ea86-5867-9bd9-1e825aa70952"><lexical-unit><form lang="id"><text>alah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alah_0" guid="6824ba71-74dc-5342-8fc1-4fedcfba40f6"><grammatical-info value="Adjective"/><gloss lang="en"><text>defeated</text></gloss></sense><sense id="alah_1" guid="43b4d751-9b9c-5cf3-a135-a4b1d0053bf2"><grammatical-info value="Adjective"/><gloss lang="en"><text>to die</text></gloss></sense><sense id="alah_2" guid="77a7baae-a41d-5ff6-9230-59a210b695c8"><grammatical-info value="Adjective"/><gloss lang="en"><text>to dam (to block the flow of water)</text></gloss></sense><sense id="alah_3" guid="42b28c7f-de04-586d-b1f9-45db1eb9aa16"><grammatical-info value="Adjective"/><gloss lang="en"><text>huh (an interjection to express unconcerned chalence)</text></gloss></sense></entry>
<entry id="alam" guid="4732b237-44dc-5683-a899-11fe9435726a"><lexical-unit><form lang="id"><text>alam</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alam_0" guid="a973d1e9-e1a6-554f-a8be-f2db5ece5a18"><grammatical-info value="Noun"/><gloss lang="en"><text>universe: the sum of everything that exists in the cosmos, including time and space itself</text></gloss></sense><sense id="alam_1" guid="18bc46a4-d4c2-5cf0-983b-ecd8d8095074"><grammatical-info value="Noun"/><gloss lang="en"><text>nature: the natural world; that which consists of all things unaffected by or predating human technology, production, and design</text></gloss></sense><sense id="alam_2" guid="2b633b69-69be-5907-89e0-8aab7de4db95"><grammatical-info value="Noun"/><gloss lang="en"><text>world</text></gloss></sense><sense id="alam_3" guid="827de01a-e482-5c98-b782-b400522f5ad4"><grammatical-info value="Noun"/><gloss lang="en"><text>realm: a territory or state, as ruled by a specific power, especially by a king</text></gloss></sense><sense id="alam_4" guid="fcb60e30-88a5-5c77-9e9b-636cb8359e41"><grammatical-info value="Noun"/><gloss lang="en"><text>banner, standard</text></gloss></sense><sense id="alam_5" guid="0f6bc94f-6ff3-5de6-862c-076b262be0b1"><grammatical-info value="Noun"/><gloss lang="en"><text>an official of religious affairs in Banten and Madura</text></gloss></sense></entry>
<entry id="alamat" guid="48bcee46-52cc-5322-a9b4-7606fb011e38"><lexical-unit><form lang="id"><text>alamat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alamat_0" guid="4798d75d-0626-555e-948b-c6ef5c995d8f"><grammatical-info value="Noun"/><gloss lang="en"><text>sign</text></gloss></sense><sense id="alamat_1" guid="982147d1-7c29-5911-9d9d-4e2c2c0d3421"><grammatical-info value="Noun"/><gloss lang="en"><text>address</text></gloss></sense><sense id="alamat_2" guid="7ffcffee-991d-59b6-8ff3-ed6e1436a7f1"><grammatical-info value="Noun"/><gloss lang="en"><text>target</text></gloss></sense></entry>
