<entry id="bisu" guid="9b957022-b83f-55cb-a4ad-c12fcd43edcb"><lexical-unit><form lang="id"><text>bisu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bisu_0" guid="6085f94f-e328-52bd-9399-7c0250f5ff38"><grammatical-info value="Noun"/><gloss lang="en"><text>dumb, mute</text></gloss></sense></entry>
<entry id="bit" guid="5b1a3b5e-e485-5b64-b840-3f4ef436f18c"><lexical-unit><form lang="id"><text>bit</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bit_0" guid="2961b545-bd69-5c30-97e9-e1db02443b15"><grammatical-info value="Numeral"/><gloss lang="en"><text>bit, smallest unit of storage</text></gloss></sense><sense id="bit_1" guid="a9e42251-c6df-5126-8a66-db58b6f4aa62"><grammatical-info value="Numeral"/><gloss lang="en"><text>common beet, beetroot, sugar beet, and chard (Beta vulgaris)</text></gloss></sense><sense id="bit_2" guid="d4b095ed-6123-521f-9145-cfff858d0757"><grammatical-info value="Numeral"/><gloss lang="en"><text>bit</text></gloss></sense><sense id="bit_3" guid="7bc861b9-2414-527b-8ab9-e53674c18f64"><grammatical-info value="Numeral"/><gloss lang="en"><text>an excerpt of material making up part of a show, comedy routine, etc.</text></gloss></sense><sense id="bit_4" guid="fbc5b14d-3285-5262-ac41-42ccee768d7f"><grammatical-info value="Numeral"/><gloss lang="en"><text>a gag or put-on; a humorous conceit, especially when insistently presented as true</text></gloss></sense></entry>
<entry id="bobol" guid="b3bf3c7c-3765-5c0c-be42-40e776460f40"><lexical-unit><form lang="id"><text>bobol</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bobol_0" guid="aa8afc86-dbea-578b-99af-dcaf3ea84689"><grammatical-info value="Verb"/></sense></entry>
