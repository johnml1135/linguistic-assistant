<entry id="bingung" guid="32de7290-522d-5590-9abb-d945a1a49eae"><lexical-unit><form lang="id"><text>bingung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bingung_0" guid="6a402fb5-58f7-5c69-b7b6-007a11f254ba"><grammatical-info value="Adjective"/><gloss lang="en"><text>bewildered, confused</text></gloss></sense><sense id="bingung_1" guid="978ab5ca-f4f5-5773-855e-3d44be426b43"><grammatical-info value="Adjective"/><gloss lang="en"><text>lost (of mind)</text></gloss></sense><sense id="bingung_2" guid="291644f0-2632-57bd-9fd7-1f3a344d996a"><grammatical-info value="Adjective"/><gloss lang="en"><text>amazed, mixed up</text></gloss></sense><sense id="bingung_3" guid="d3ad50ae-d956-589a-ba61-05791fcd928d"><grammatical-info value="Adjective"/><gloss lang="en"><text>panicky</text></gloss></sense><sense id="bingung_4" guid="04e597ee-54e3-5ce0-978d-17519108b0e3"><grammatical-info value="Adjective"/><gloss lang="en"><text>upset</text></gloss></sense><sense id="bingung_5" guid="0ca02263-1b97-551f-8024-c86752a552be"><grammatical-info value="Adjective"/><gloss lang="en"><text>puzzled</text></gloss></sense><sense id="bingung_6" guid="9b2e96f2-d8bc-58a0-b3c7-e6d7b0a5bdb6"><grammatical-info value="Adjective"/><gloss lang="en"><text>perplexed</text></gloss></sense><sense id="bingung_7" guid="cc27ae06-0e5f-52fc-8a98-488d01da8595"><grammatical-info value="Adjective"/><gloss lang="en"><text>to lose one's bearings</text></gloss></sense></entry>
<entry id="bintang" guid="a640c87f-d0b9-52ab-9924-e3b52caba96e"><lexical-unit><form lang="id"><text>bintang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bintang_0" guid="046a4c62-3352-5a5c-82d1-a2ac2b10a2fd"><grammatical-info value="Noun"/><gloss lang="en"><text>star</text></gloss></sense><sense id="bintang_1" guid="c1039a7c-15dd-562f-ba53-643ae6986601"><grammatical-info value="Noun"/><gloss lang="en"><text>star (a planet supposed to influence one's destiny)</text></gloss></sense><sense id="bintang_2" guid="fe1e1975-0909-5c5f-a9ef-d23878ddf87b"><grammatical-info value="Noun"/><gloss lang="en"><text>star; a star-shaped ornament worn on the breast to indicate rank or honour</text></gloss></sense><sense id="bintang_3" guid="44eeb8f1-875f-59ea-addc-145ba0e6ff9e"><grammatical-info value="Noun"/><gloss lang="en"><text>star, celebrity, actor</text></gloss></sense><sense id="bintang_4" guid="43e1cb85-98f5-539f-9b69-05c4053e1125"><grammatical-info value="Noun"/><gloss lang="en"><text>star, asterisk (*)</text></gloss></sense><sense id="bintang_5" guid="7ff2af62-c1e3-51d1-88aa-3b850c085efe"><grammatical-info value="Noun"/><gloss lang="en"><text>fate, luck, fortune</text></gloss></sense></entry>
<entry id="birahi" guid="f1473431-23f1-54c7-b58d-82bc4de6ea75"><lexical-unit><form lang="id"><text>birahi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="birahi_0" guid="5c9040eb-21ee-5996-b19a-0470e32b2bfc"><grammatical-info value="Noun"/><gloss lang="en"><text>inappropriate</text></gloss></sense></entry>
<entry id="biri" guid="67eb4263-3135-5fca-bcb8-12fa0d6dfcb3"><lexical-unit><form lang="id"><text>biri</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="biri_0" guid="26a33eb0-b026-53a2-a700-5ba91293e4bf"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative form of biri-biri (“sheep”)</text></gloss></sense></entry>
<entry id="biru" guid="8efeb3fd-5276-5abe-98a7-9eca6ce70e16"><lexical-unit><form lang="id"><text>biru</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="biru_0" guid="748e3a9c-6794-5470-b232-bfcaae478809"><grammatical-info value="Adjective"/><gloss lang="en"><text>blue (blue-colored)</text></gloss></sense><sense id="biru_1" guid="dd0e681a-2220-5bf6-8c5c-a8bd55f7b8c8"><grammatical-info value="Adjective"/><gloss lang="en"><text>blue (colour)</text></gloss></sense><sense id="biru_2" guid="afbf3244-ad33-5437-a828-543dd2a3a548"><grammatical-info value="Adjective"/><gloss lang="en"><text>folds on the edges of clothes, cloth, and so on as decoration</text></gloss></sense><sense id="biru_3" guid="5b263d28-9d8c-5bdd-a1c8-c239fcbe5ace"><grammatical-info value="Adjective"/><gloss lang="en"><text>red mouth from eating areca nut</text></gloss></sense></entry>
<entry id="bis" guid="7c07ab2f-e4a9-5d3a-a5aa-ab322ecc2a73"><lexical-unit><form lang="id"><text>bis</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bis_0" guid="4ca2c649-cccf-58e2-80f5-59adac4dc2fb"><grammatical-info value="Noun"/><gloss lang="en"><text>letterbox; mailbox; post box</text></gloss></sense><sense id="bis_1" guid="ff1144a7-692d-5e76-9969-c096d9d42767"><grammatical-info value="Noun"/><gloss lang="en"><text>nonstandard form of bus (“bus”)</text></gloss></sense><sense id="bis_2" guid="655430ff-400c-565b-9607-a8220cbd0152"><grammatical-info value="Noun"/><gloss lang="en"><text>twice</text></gloss></sense><sense id="bis_3" guid="139ba203-0c50-5ba6-9f8e-5fd328fd3a5b"><grammatical-info value="Noun"/><gloss lang="en"><text>pipe; piping</text></gloss></sense><sense id="bis_4" guid="ba30cf10-87e0-5b94-b85b-7d18b521cd87"><grammatical-info value="Noun"/><gloss lang="en"><text>a hollow conduit or something resembling a tube</text></gloss></sense><sense id="bis_5" guid="931b3d2d-b2b7-5e47-ad7f-10ef810037db"><grammatical-info value="Noun"/><gloss lang="en"><text>decorative edging stitched to the hems or seams of an object made of fabric</text></gloss></sense><sense id="bis_6" guid="3f760862-c9ae-5704-a661-9d907ec2f601"><grammatical-info value="Noun"/><gloss lang="en"><text>vessel, tube, duct</text></gloss></sense><sense id="bis_7" guid="8ee509e0-5372-5d2c-93ef-49f9ecefe815"><grammatical-info value="Noun"/><gloss lang="en"><text>pipe, duct</text></gloss></sense></entry>
<entry id="bisa" guid="ceced436-f39d-5ef1-a4b7-63b70ab47037"><lexical-unit><form lang="id"><text>bisa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bisa_0" guid="0f823f96-212f-53ea-a942-f1c2c88e5802"><grammatical-info value="Auxiliary verb"/><gloss lang="en"><text>venom: a poison carried by an animal, usually injected into an enemy or prey by biting or stinging</text></gloss></sense><sense id="bisa_1" guid="309b1129-0d74-5013-ae20-dc3d7944ff9f"><grammatical-info value="Auxiliary verb"/><gloss lang="en"><text>bad: unfavorable, negative, evil, unhealthy</text></gloss></sense><sense id="bisa_2" guid="0a79996e-7871-5d57-9117-28f7f22fedac"><grammatical-info value="Auxiliary verb"/><gloss lang="en"><text>can, be able</text></gloss></sense></entry>
<entry id="bisi" guid="b5c38b1e-cc1a-5e62-b6f9-ac192c81fb50"><lexical-unit><form lang="id"><text>bisi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bisi_0" guid="b600711f-841c-51c5-8cb8-8eceb5831552"><grammatical-info value="Adverb"/><gloss lang="en"><text>an expression to express concern about the possibility of something; in case, lest</text></gloss></sense></entry>
<entry id="bisik" guid="d0f9dd46-6183-5116-b76b-116528f27fc9"><lexical-unit><form lang="id"><text>bisik</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bisik_0" guid="8f6b30da-c68d-598b-b88d-b982564ac69e"><grammatical-info value="Verb"/><gloss lang="en"><text>whisper</text></gloss></sense></entry>
