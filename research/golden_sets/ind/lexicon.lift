<entry id="mundur" guid="81bbf7eb-4dcd-504f-8c83-cda197783a4d"><lexical-unit><form lang="id"><text>mundur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mundur_0" guid="74152812-9992-50a9-abd4-87d8221d22a3"><grammatical-info value="Verb"/><gloss lang="en"><text>to retreat, to retire, to withdraw, to recede, to back up, to go backward, to turn back</text></gloss></sense><sense id="mundur_1" guid="6880d7a4-8544-55e5-9c26-42eca1a4dbb3"><grammatical-info value="Verb"/><gloss lang="en"><text>to decline</text></gloss></sense><sense id="mundur_2" guid="7d15927b-e3df-5078-886f-7597b5529c51"><grammatical-info value="Verb"/><gloss lang="en"><text>to decrease</text></gloss></sense><sense id="mundur_3" guid="36bc0137-b549-5676-a607-65f1a6aa80b4"><grammatical-info value="Verb"/><gloss lang="en"><text>to deteriorate</text></gloss></sense></entry>
