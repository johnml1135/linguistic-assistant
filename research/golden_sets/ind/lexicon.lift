<entry id="mengajar" guid="49bbbc7b-968d-57ad-b285-57fbbb52d4f7"><lexical-unit><form lang="id"><text>mengajar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mengajar_0" guid="b4c3523f-0d45-5554-a9fc-f0fc8cc8b5f5"><grammatical-info value="Verb"/><gloss lang="en"><text>to teach</text></gloss></sense><sense id="mengajar_1" guid="908da207-fb4d-5e56-95ba-0dc6f032cd79"><grammatical-info value="Verb"/><gloss lang="en"><text>to drill, to train</text></gloss></sense><sense id="mengajar_2" guid="e3435aaf-5e78-539d-9df4-38db54605f30"><grammatical-info value="Verb"/><gloss lang="en"><text>to reproach someone, to blame someone</text></gloss></sense></entry>
<entry id="mengaku" guid="a5be33e3-ca4a-56e0-8912-dd9adb0b96d8"><lexical-unit><form lang="id"><text>mengaku</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mengaku_0" guid="17d8ebba-034b-5724-9971-30a256471bfc"><grammatical-info value="Verb"/><gloss lang="en"><text>to claim, to identify, to consider</text></gloss></sense><sense id="mengaku_1" guid="b8213e82-b0cf-5840-a209-d483d199591d"><grammatical-info value="Verb"/><gloss lang="en"><text>to admit, to confess, to concede, to acknowledge</text></gloss></sense><sense id="mengaku_2" guid="1bc333a0-0807-5078-95a6-6bf4f6d41686"><grammatical-info value="Verb"/><gloss lang="en"><text>to be responsible</text></gloss></sense><sense id="mengaku_3" guid="246e11c5-e438-5123-bbad-8a6da70cbdd6"><grammatical-info value="Verb"/><gloss lang="en"><text>to feel proud of one's self</text></gloss></sense><sense id="mengaku_4" guid="e056858f-5605-52a2-96f3-e262de74b159"><grammatical-info value="Verb"/><gloss lang="en"><text>to be stiff, to stiff</text></gloss></sense></entry>
<entry id="mengakui" guid="f8d48da3-a1f6-538c-a28f-9df53ecdd0eb"><lexical-unit><form lang="id"><text>mengakui</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mengakui_0" guid="5d9efe4e-28da-5be0-8b52-43dbe03c8408"><grammatical-info value="Verb"/><gloss lang="en"><text>to admit, to confess, to concede, to acknowledge</text></gloss></sense><sense id="mengakui_1" guid="54c4019f-b99a-50c5-b2b4-5ffcf3ace3cf"><grammatical-info value="Verb"/><gloss lang="en"><text>to validate</text></gloss></sense><sense id="mengakui_2" guid="66e45ec2-ec44-5740-bdc4-a25ff43856ea"><grammatical-info value="Verb"/><gloss lang="en"><text>to possess:</text></gloss></sense><sense id="mengakui_3" guid="cc51190e-e96c-58c4-b060-db6b1e6453fd"><grammatical-info value="Verb"/><gloss lang="en"><text>to have, to own (a right)</text></gloss></sense><sense id="mengakui_4" guid="ef024e3d-5312-5902-9adb-d7068a0cd3a7"><grammatical-info value="Verb"/><gloss lang="en"><text>of a supernatural entity, especially one regarded as evil: to take control of</text></gloss></sense></entry>
