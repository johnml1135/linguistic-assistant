<entry id="benteng" guid="b1e192be-2026-5475-afcc-1246fdf272d9"><lexical-unit><form lang="id"><text>benteng</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="benteng_0" guid="6d366dc2-41cd-5826-8cdb-385c0646290f"><grammatical-info value="Noun"/><gloss lang="en"><text>fort (a fortified defensive structure stationed with troops)</text></gloss></sense><sense id="benteng_1" guid="a742c9b7-f73a-5b29-b9b2-83527c6eb83c"><grammatical-info value="Noun"/><gloss lang="en"><text>bulwark a defensive wall or rampart</text></gloss></sense><sense id="benteng_2" guid="e2fbcdf4-7c0c-53b3-ab2c-16726cffab61"><grammatical-info value="Noun"/><gloss lang="en"><text>rook; castle</text></gloss></sense><sense id="benteng_3" guid="d92e4f8d-b23e-5dd4-b4a2-3cb007bdf307"><grammatical-info value="Noun"/><gloss lang="en"><text>something that is used to strengthen or maintain a position and so on</text></gloss></sense><sense id="benteng_4" guid="839f6783-7120-5e04-8c05-1200d64669b0"><grammatical-info value="Noun"/><gloss lang="en"><text>children's games are carried out in two groups by each group forming a fort (in the form of poles, stones, etc.) and trying to protect the fort from enemy attacks</text></gloss></sense></entry>
<entry id="bentuk" guid="97a68247-0a05-5813-b2f7-8494786c135a"><lexical-unit><form lang="id"><text>bentuk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bentuk_0" guid="a88661ac-571c-5cf5-9e78-00468625691a"><grammatical-info value="Noun"/><gloss lang="en"><text>form; shape; type</text></gloss></sense><sense id="bentuk_1" guid="ef0bcb3a-b526-5732-a0e2-8c702a946066"><grammatical-info value="Noun"/><gloss lang="en"><text>bend; curve</text></gloss></sense><sense id="bentuk_2" guid="d0582fb5-7f8b-51c0-84d1-91d991cb41bb"><grammatical-info value="Noun"/><gloss lang="en"><text>system</text></gloss></sense><sense id="bentuk_3" guid="8b3f1206-c899-50ee-9d62-e3f376758b84"><grammatical-info value="Noun"/><gloss lang="en"><text>arrangement</text></gloss></sense></entry>
<entry id="bentur" guid="18606fd2-ad07-5629-a96d-f25872395062"><lexical-unit><form lang="id"><text>bentur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bentur_0" guid="a8a48ab4-7972-536c-b8f4-6df3f4c3800f"><grammatical-info value="Noun"/><gloss lang="en"><text>to bend down, to be flexible, to flex</text></gloss></sense><sense id="bentur_1" guid="9b1d2902-39a0-5835-a579-e91f67233388"><grammatical-info value="Noun"/><gloss lang="en"><text>to bump, to collide</text></gloss></sense></entry>
