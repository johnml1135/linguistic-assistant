<entry id="gairah" guid="7ee5e9e5-ca61-5af8-a746-6a0b088b1177"><lexical-unit><form lang="id"><text>gairah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gairah_0" guid="b646c30e-01f2-5f46-8fdb-bc7be1100b08"><grammatical-info value="Noun"/><gloss lang="en"><text>passion, strong desire</text></gloss></sense></entry>
<entry id="gaji" guid="a1bd21e7-faf4-5f15-b5c2-69b5904e803a"><lexical-unit><form lang="id"><text>gaji</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gaji_0" guid="26152c0a-0974-5bdb-bca3-efa971da2601"><grammatical-info value="Noun"/><gloss lang="en"><text>salary (fixed amount of money paid on monthly or annual basis)</text></gloss></sense><sense id="gaji_1" guid="68d97908-392c-5504-bb23-c21170aa8aca"><grammatical-info value="Noun"/><gloss lang="en"><text>wage, an amount of money paid to a worker for a specified quantity of work, usually calculated on an hourly basis and expressed in an amount of money per hour</text></gloss></sense></entry>
