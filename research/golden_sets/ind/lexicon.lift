<entry id="berapa" guid="fc6939cd-ae62-5a96-b605-f5a5b7cd4654"><lexical-unit><form lang="id"><text>berapa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berapa_0" guid="c433870b-5d23-5b7b-9fa1-89413eee7e6e"><grammatical-info value="Adverb"/><gloss lang="en"><text>how many, how much</text></gloss></sense></entry>
