<entry id="huruf" guid="2176c85a-d0f3-51c9-ac9e-7955b7491b34"><lexical-unit><form lang="id"><text>huruf</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="huruf_0" guid="02d8562d-deb8-5b5e-8b7c-b7bc564c6fc3"><grammatical-info value="Noun"/><gloss lang="en"><text>letter (letter of the alphabet)</text></gloss></sense><sense id="huruf_1" guid="63f819c2-69a0-5e10-9783-f90fe348cc49"><grammatical-info value="Noun"/><gloss lang="en"><text>point</text></gloss></sense><sense id="huruf_2" guid="6319be31-3e28-5784-b56d-9d1819fb25a7"><grammatical-info value="Noun"/><gloss lang="en"><text>graph: A graphical unit on the token-level, the abstracted fundamental shape of a character or letter as distinct from its ductus (realization in a particular typeface or handwriting on the instance-level) and as distinct by a grapheme on the type-level by not fundamentally distinguishing meaning</text></gloss></sense></entry>
<entry id="hut" guid="b05e7480-9b0a-5827-a2da-526e3ed85bdc"><lexical-unit><form lang="id"><text>hut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="hut_0" guid="6698edd8-4d1f-5b64-af19-be0457abc7ae"><grammatical-info value="Proper noun"/><gloss lang="en"><text>acronym of hari ulang tahun (“anniversary”)</text></gloss></sense></entry>
