<entry id="syria" guid="75ab329e-21f2-5813-b40b-a900739a8dc2"><lexical-unit><form lang="id"><text>syria</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="syria_0" guid="b2471d64-8b6f-540e-81f8-108d7a650033"><grammatical-info value="Proper noun"/></sense></entry>
