<entry id="kepercayaan" guid="75618b5d-bb99-5750-aea4-13ac032b7c3e"><lexical-unit><form lang="id"><text>kepercayaan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kepercayaan_0" guid="93af9c74-8922-548e-ae66-3c14a2d15235"><grammatical-info value="Noun"/><gloss lang="en"><text>belief (most senses)</text></gloss></sense><sense id="kepercayaan_1" guid="3719fdd8-c8da-5e54-a96c-9325d547510a"><grammatical-info value="Noun"/><gloss lang="en"><text>religion or faith outside the five official religions in Indonesia (Buddhism, Catholic, Confucianism, Islam and Protestant) in general, specifically Indonesian folk religions</text></gloss></sense><sense id="kepercayaan_2" guid="75f3b591-e271-5db2-b113-81e1792db669"><grammatical-info value="Noun"/><gloss lang="en"><text>credence</text></gloss></sense><sense id="kepercayaan_3" guid="2c475ef9-d524-5aae-8ac8-7a0993b2eea8"><grammatical-info value="Noun"/><gloss lang="en"><text>confidence</text></gloss></sense><sense id="kepercayaan_4" guid="68b4a3c7-b528-5e24-b84e-dce22c03a4d7"><grammatical-info value="Noun"/><gloss lang="en"><text>right-hand, trusted</text></gloss></sense></entry>
<entry id="kepung" guid="900905d2-3e95-52ea-8949-5912279d1797"><lexical-unit><form lang="id"><text>kepung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kepung_0" guid="785512d5-e10d-540c-8215-fc1a7b4024ba"><grammatical-info value="Verb"/><gloss lang="en"><text>to besiege (to surround with armed forces)</text></gloss></sense><sense id="kepung_1" guid="337b069d-d32e-5d2d-a4cb-5e477d85c202"><grammatical-info value="Verb"/><gloss lang="en"><text>to encircle, surround</text></gloss></sense></entry>
