<entry id="membantu" guid="39460dc5-c1b0-504b-865b-233573e1e009"><lexical-unit><form lang="id"><text>membantu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="membantu_0" guid="9a897646-3d74-5b1d-a5e6-9ee85539eb8e"><grammatical-info value="Verb"/><gloss lang="en"><text>to help, to assist, to aid</text></gloss></sense><sense id="membantu_1" guid="f9b9495e-ca85-5f8f-9529-a8d06e4c8ecf"><grammatical-info value="Verb"/><gloss lang="en"><text>to oblige</text></gloss></sense></entry>
