<entry id="luas" guid="51ec684c-a840-5014-85db-798757cd216e"><lexical-unit><form lang="id"><text>luas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="luas_0" guid="622a7e0c-64c2-5ae4-9ac4-c81533ca67ac"><grammatical-info value="Noun"/><gloss lang="en"><text>vast:</text></gloss></sense><sense id="luas_1" guid="1d0f2f4e-1ca6-575f-8685-67f5b1cd1690"><grammatical-info value="Noun"/><gloss lang="en"><text>very large or wide</text></gloss></sense><sense id="luas_2" guid="cfbcbdd6-468c-54d9-836d-1919d87f4902"><grammatical-info value="Noun"/><gloss lang="en"><text>very great in size, amount, degree, intensity, or especially extent</text></gloss></sense><sense id="luas_3" guid="67e697e0-02e0-5609-a892-ea7d1729b69d"><grammatical-info value="Noun"/><gloss lang="en"><text>wide:</text></gloss></sense><sense id="luas_4" guid="37b2836f-64ab-5895-b051-8d5ce1aa67b7"><grammatical-info value="Noun"/><gloss lang="en"><text>having a large physical extent from side to side</text></gloss></sense><sense id="luas_5" guid="d71e7ae6-dfc5-58e0-8e76-7d01da1d99f0"><grammatical-info value="Noun"/><gloss lang="en"><text>large in scope</text></gloss></sense><sense id="luas_6" guid="aa088fbf-3abc-5bbf-afab-013ab99174dd"><grammatical-info value="Noun"/><gloss lang="en"><text>broad:</text></gloss></sense><sense id="luas_7" guid="8fe009ec-6065-5d3b-a0a3-b09ba58b0ee9"><grammatical-info value="Noun"/><gloss lang="en"><text>wide in extent or scope</text></gloss></sense></entry>
<entry id="lubang" guid="da3070e4-23e0-5f35-bd87-a2612af37893"><lexical-unit><form lang="id"><text>lubang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lubang_0" guid="37e7c795-c000-512d-8da6-c3ff451e6864"><grammatical-info value="Noun"/><gloss lang="en"><text>hole</text></gloss></sense><sense id="lubang_1" guid="81fbdd73-8903-51d4-87f4-c9013910d7d6"><grammatical-info value="Noun"/><gloss lang="en"><text>hole:</text></gloss></sense><sense id="lubang_2" guid="ea33fc9c-d9d4-58cb-b2b9-69737e8ddf9f"><grammatical-info value="Noun"/><gloss lang="en"><text>opening in a solid</text></gloss></sense><sense id="lubang_3" guid="b9a0c953-06b8-5189-a9cc-837706640059"><grammatical-info value="Noun"/><gloss lang="en"><text>in semiconductors, a lack of an electron in an occupied band behaving like a positively charged particle</text></gloss></sense><sense id="lubang_4" guid="5fe2deeb-20c4-5015-b8ab-76653dda188c"><grammatical-info value="Noun"/><gloss lang="en"><text>perforation</text></gloss></sense><sense id="lubang_5" guid="2d28559a-905e-5c6a-b34c-1d6fef05b567"><grammatical-info value="Noun"/><gloss lang="en"><text>big eel</text></gloss></sense></entry>
<entry id="lucut" guid="eac9ca28-95af-5262-97e0-0f58b37edef7"><lexical-unit><form lang="id"><text>lucut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lucut_0" guid="654c67ee-2d82-5645-99e9-3a70e795db29"><grammatical-info value="Noun"/><gloss lang="en"><text>off: not fitted; not being worn</text></gloss></sense><sense id="lucut_1" guid="69b786f8-a50a-55bc-902f-cded8bdcd645"><grammatical-info value="Noun"/><gloss lang="en"><text>exfoliated, peeled off</text></gloss></sense><sense id="lucut_2" guid="ea1b461f-d521-548e-bc2b-6e877e0d25cf"><grammatical-info value="Noun"/><gloss lang="en"><text>lost</text></gloss></sense><sense id="lucut_3" guid="a1538042-3c2c-565b-b652-58828768200e"><grammatical-info value="Noun"/><gloss lang="en"><text>vanished</text></gloss></sense></entry>
<entry id="ludah" guid="10fe1ecc-0f9a-5ef9-a81c-d5a46d4f1df1"><lexical-unit><form lang="id"><text>ludah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ludah_0" guid="00c1c002-89b3-510d-955c-53c27db01d48"><grammatical-info value="Noun"/><gloss lang="en"><text>spit, saliva</text></gloss></sense></entry>
<entry id="ludahi" guid="51824338-78b6-522d-8d65-1c0939fe69bf"><lexical-unit><form lang="id"><text>ludahi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ludahi_0" guid="7b73e2ca-87e8-52ec-a4f9-985277aa8f0c"><grammatical-info value="Verb"/><gloss lang="en"><text>spit</text></gloss></sense></entry>
<entry id="luka" guid="a4b57636-963c-52d3-b3bf-db3ac38f3c3a"><lexical-unit><form lang="id"><text>luka</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="luka_0" guid="16253bd0-f142-50d2-92b6-39454a6ab73d"><grammatical-info value="Noun"/><gloss lang="en"><text>wound:</text></gloss></sense><sense id="luka_1" guid="0b182fb6-7650-5484-86a6-b19ada76e453"><grammatical-info value="Noun"/><gloss lang="en"><text>an injury, such as a cut, stab, or tear, to a (usually external) part of the body</text></gloss></sense><sense id="luka_2" guid="af9d88c1-6359-5eb3-90da-f991b9bd4275"><grammatical-info value="Noun"/><gloss lang="en"><text>wounded:</text></gloss></sense><sense id="luka_3" guid="3fa89015-58f4-5d8d-97d8-1c04c1e70c7c"><grammatical-info value="Noun"/><gloss lang="en"><text>suffering from a wound, especially one acquired in battle from a weapon, such as a gun or a knife</text></gloss></sense><sense id="luka_4" guid="995473cc-97d6-555d-9a85-4ba26aa1ad36"><grammatical-info value="Noun"/><gloss lang="en"><text>suffering from an emotional injury</text></gloss></sense></entry>
<entry id="lukas" guid="046b73a7-7565-5671-8101-5262df3bed7b"><lexical-unit><form lang="id"><text>lukas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lukas_0" guid="6e276b10-0429-5cae-90d7-ee684b16b0cc"><grammatical-info value="Noun"/><gloss lang="en"><text>Luke:</text></gloss></sense><sense id="lukas_1" guid="6abc5a22-d456-5f3c-b6c4-61742c433c6c"><grammatical-info value="Noun"/><gloss lang="en"><text>Luke the Evangelist, an early Christian credited with the authorship of the Gospel of Luke and the Acts of the Apostles</text></gloss></sense><sense id="lukas_2" guid="1bcad978-8b5a-5a07-841b-59e72cfe66d2"><grammatical-info value="Noun"/><gloss lang="en"><text>the Gospel of St. Luke, a book of the New Testament of the Bible. Traditionally the third of the four gospels</text></gloss></sense><sense id="lukas_3" guid="e278b886-6b22-56e6-82f8-46d7412a7bbf"><grammatical-info value="Noun"/><gloss lang="en"><text>Siamese algae-eater, a fish of species Crossocheilus oblongus</text></gloss></sense></entry>
<entry id="lukis" guid="0bca7cdd-0680-55f5-8dfe-538121e29c23"><lexical-unit><form lang="id"><text>lukis</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lukis_0" guid="13b013a9-869c-5dc1-8fdf-f18460c5c5cd"><grammatical-info value="Verb"/><gloss lang="en"><text>to paint (to apply paint to or in the similar manner)</text></gloss></sense><sense id="lukis_1" guid="8f3dba94-9eaa-53d3-bf02-b5d7e8040b3d"><grammatical-info value="Verb"/><gloss lang="en"><text>to paint (to create an image)</text></gloss></sense><sense id="lukis_2" guid="386a1387-3983-5736-bac2-6e525376e469"><grammatical-info value="Verb"/><gloss lang="en"><text>to construct</text></gloss></sense></entry>
<entry id="lukiskan" guid="57842526-7307-5f1b-8404-d1e6e5b70ca9"><lexical-unit><form lang="id"><text>lukiskan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lukiskan_0" guid="cf196878-f2d0-514b-a63b-30b874b09f31"><grammatical-info value="Verb"/><gloss lang="en"><text>to paint for</text></gloss></sense><sense id="lukiskan_1" guid="ff4604e4-9ff4-567d-867f-b0c4f4eadc0d"><grammatical-info value="Verb"/><gloss lang="en"><text>to describe (to represent in words)</text></gloss></sense></entry>
<entry id="lulus" guid="9cae48fe-9191-5035-a88d-4a528fafef5b"><lexical-unit><form lang="id"><text>lulus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lulus_0" guid="33bdb533-50b4-5c7b-9921-ec8c92b733fd"><grammatical-info value="Verb"/><gloss lang="en"><text>to go/get through, to penetrate</text></gloss></sense><sense id="lulus_1" guid="c4d0bc77-cb60-55f7-bd8b-a3984b52e9c1"><grammatical-info value="Verb"/><gloss lang="en"><text>to slip off (a ring from the finger)</text></gloss></sense><sense id="lulus_2" guid="0d047cd8-8b7a-5f20-ac09-fe47bd20bac7"><grammatical-info value="Verb"/><gloss lang="en"><text>to stumble (into a hole)</text></gloss></sense><sense id="lulus_3" guid="6c5f7815-9018-500f-9be1-5c4d39a2532a"><grammatical-info value="Verb"/><gloss lang="en"><text>to sink (into the mud)</text></gloss></sense><sense id="lulus_4" guid="24ff43eb-5a9a-58b4-8e1c-f6a5569e9787"><grammatical-info value="Verb"/><gloss lang="en"><text>to pass (an examination, etc.)</text></gloss></sense><sense id="lulus_5" guid="100aaa8e-b7be-56f3-8186-d4525330ff71"><grammatical-info value="Verb"/><gloss lang="en"><text>to be succeed</text></gloss></sense><sense id="lulus_6" guid="5645a5ed-6626-54da-b552-99111d8c9555"><grammatical-info value="Verb"/><gloss lang="en"><text>to be permitted/allowed</text></gloss></sense><sense id="lulus_7" guid="debc523d-0ddf-5885-be23-8e377741a46e"><grammatical-info value="Verb"/><gloss lang="en"><text>to be vanished, to be disappeared, to be gone</text></gloss></sense></entry>
<entry id="lumbung" guid="6b3b931a-5c3a-5549-9961-bd7ab1e90ffa"><lexical-unit><form lang="id"><text>lumbung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lumbung_0" guid="d73b2186-6dd1-5c74-a1c4-c24e0f043387"><grammatical-info value="Proper noun"/><gloss lang="en"><text>rice barn, granary</text></gloss></sense></entry>
<entry id="lumpuh" guid="c55be7f2-8fcd-529e-a7ff-873187d28fd9"><lexical-unit><form lang="id"><text>lumpuh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lumpuh_0" guid="c484c5b9-129e-56c7-a44e-62b7791f00d4"><grammatical-info value="Verb"/><gloss lang="en"><text>paralyzed, crippled, lame</text></gloss></sense><sense id="lumpuh_1" guid="78cf78a5-eb82-55f4-9bed-2722f7a302a4"><grammatical-info value="Verb"/><gloss lang="en"><text>neutralized, crippled</text></gloss></sense></entry>
<entry id="lumpur" guid="1dcaf1cd-0f8c-57c2-b081-a94f4d41ed66"><lexical-unit><form lang="id"><text>lumpur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lumpur_0" guid="d682e0c5-718b-5036-bdb9-4da98433f60d"><grammatical-info value="Noun"/><gloss lang="en"><text>mud</text></gloss></sense></entry>
<entry id="lunak" guid="adfb0a10-6b81-5891-865b-b6b5d1624926"><lexical-unit><form lang="id"><text>lunak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lunak_0" guid="751d9f50-05fd-5415-8b48-f092d3f7e07a"><grammatical-info value="Adjective"/><gloss lang="en"><text>soft, tender</text></gloss></sense><sense id="lunak_1" guid="b6a29617-535d-5669-8e17-bce5bcab3805"><grammatical-info value="Adjective"/><gloss lang="en"><text>moderate</text></gloss></sense></entry>
<entry id="lunas" guid="2ae17036-6028-51d7-8085-9eab70135276"><lexical-unit><form lang="id"><text>lunas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lunas_0" guid="21df9555-2be2-50fe-9bd4-c539730a1c31"><grammatical-info value="Verb"/><gloss lang="en"><text>to be paid off</text></gloss></sense><sense id="lunas_1" guid="e4b4b973-2d6c-5665-a95b-9da88b851e5c"><grammatical-info value="Verb"/><gloss lang="en"><text>paid in full</text></gloss></sense><sense id="lunas_2" guid="7d190c89-912f-5176-97e0-8e5a4af04477"><grammatical-info value="Verb"/><gloss lang="en"><text>keel:</text></gloss></sense><sense id="lunas_3" guid="25931742-fa23-586a-ae78-ef4a40f3bf1e"><grammatical-info value="Verb"/><gloss lang="en"><text>beam along the underside of a ship’s hull</text></gloss></sense><sense id="lunas_4" guid="58585b65-d10a-5684-ac47-22198e307cb6"><grammatical-info value="Verb"/><gloss lang="en"><text>rigid flat piece of material giving a ship greater control and stability</text></gloss></sense><sense id="lunas_5" guid="5668fbc8-2f6d-54f8-b99b-66045c30d63e"><grammatical-info value="Verb"/><gloss lang="en"><text>petals of the corolla of a papilionaceous flower</text></gloss></sense><sense id="lunas_6" guid="ad22e856-96c5-5f8f-82f5-f7ed670cfd5d"><grammatical-info value="Verb"/><gloss lang="en"><text>hollow, porous, rotten</text></gloss></sense></entry>
<entry id="lupa" guid="e2d78141-3eb3-5985-95ab-a30accff6e9a"><lexical-unit><form lang="id"><text>lupa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lupa_0" guid="f9388fb9-d33a-5b95-87ff-dd640ab337a8"><grammatical-info value="Verb"/><gloss lang="en"><text>to forget</text></gloss></sense></entry>
<entry id="lupakan" guid="4f62c664-5fdd-5e9e-b785-61f111301dee"><lexical-unit><form lang="id"><text>lupakan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lupakan_0" guid="91f69a9d-21a5-5fe9-8e1f-1b7f81313fb1"><grammatical-info value="Verb"/><gloss lang="en"><text>to forget</text></gloss></sense></entry>
<entry id="luput" guid="69ba0077-9ebf-5922-9602-5598ac37e5d6"><lexical-unit><form lang="id"><text>luput</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="luput_0" guid="bfb0074e-ff24-5f36-9b3b-9ed29e927b99"><grammatical-info value="Verb"/><gloss lang="en"><text>to be disappeared, to be gone, to be vanished</text></gloss></sense><sense id="luput_1" guid="8efa7291-8487-5f36-a4d8-d403d7830dcb"><grammatical-info value="Verb"/><gloss lang="en"><text>to be cleared, to escape, to got away</text></gloss></sense><sense id="luput_2" guid="60687a3d-d0a2-5f82-8166-5639bf8ad473"><grammatical-info value="Verb"/><gloss lang="en"><text>to avoid, to dodge, to evade</text></gloss></sense><sense id="luput_3" guid="32051178-3992-54f0-b5e6-04e899669a69"><grammatical-info value="Verb"/><gloss lang="en"><text>to be lost</text></gloss></sense><sense id="luput_4" guid="41749037-9bab-5d9b-9807-9d633bd9a319"><grammatical-info value="Verb"/><gloss lang="en"><text>to be out of sight</text></gloss></sense><sense id="luput_5" guid="8f3e8beb-c92f-5322-bfe0-1fe308a68e1e"><grammatical-info value="Verb"/><gloss lang="en"><text>to be out of mind</text></gloss></sense><sense id="luput_6" guid="792842ee-2d87-5ad3-bb93-aa0b92605013"><grammatical-info value="Verb"/><gloss lang="en"><text>to be out of reach</text></gloss></sense><sense id="luput_7" guid="cbbb0721-c15a-5d03-ad64-ece2b28328f6"><grammatical-info value="Verb"/><gloss lang="en"><text>the farmer's signal to the buffalo to walk down, so that the land is plowed well</text></gloss></sense></entry>
<entry id="luruh" guid="6df7b6cf-331d-52d3-b2f0-934ca6dd0f60"><lexical-unit><form lang="id"><text>luruh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="luruh_0" guid="9a0b009b-7de0-5e66-b9f7-8b2c8d2311a2"><grammatical-info value="Noun"/><gloss lang="en"><text>to fall because the time has come</text></gloss></sense><sense id="luruh_1" guid="385bb1b8-7d63-54c5-aa0a-ceafa2438ba9"><grammatical-info value="Noun"/><gloss lang="en"><text>to drop, to fall, to fall out, to molt, to scale off.</text></gloss></sense><sense id="luruh_2" guid="3e9cb90e-2f67-5dfe-bfc0-4d2e208dacb2"><grammatical-info value="Noun"/><gloss lang="en"><text>to withdraw (retreat) from the original intention</text></gloss></sense><sense id="luruh_3" guid="916057c2-77cc-550f-b6cf-f492408b07d6"><grammatical-info value="Noun"/><gloss lang="en"><text>deciduous.</text></gloss></sense><sense id="luruh_4" guid="ebeb6cd3-fd2a-5da0-97b9-26678f04cc57"><grammatical-info value="Noun"/><gloss lang="en"><text>touched (of feelings).</text></gloss></sense><sense id="luruh_5" guid="08de8a2f-b935-5e6c-bd60-9209f4dd77fb"><grammatical-info value="Noun"/><gloss lang="en"><text>breaking (of voice).</text></gloss></sense><sense id="luruh_6" guid="211186c5-764a-529d-b95a-a26ea5fcc5ac"><grammatical-info value="Noun"/><gloss lang="en"><text>conquered area</text></gloss></sense></entry>
<entry id="lurus" guid="9ba904ae-0ce8-5bbf-a3ac-7b21b6bba18e"><lexical-unit><form lang="id"><text>lurus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lurus_0" guid="4d5b831e-e1e0-506e-8f73-b818378168ea"><grammatical-info value="Adjective"/><gloss lang="en"><text>straight</text></gloss></sense><sense id="lurus_1" guid="c84254f6-6bf4-56b9-b0e4-30dd98663df6"><grammatical-info value="Adjective"/><gloss lang="en"><text>upright</text></gloss></sense><sense id="lurus_2" guid="9cda2847-e374-5d65-8c05-12a7a969b377"><grammatical-info value="Adjective"/><gloss lang="en"><text>being honest, innocent, guiltless</text></gloss></sense><sense id="lurus_3" guid="cc410832-462c-58d2-ad29-0c69200ab88e"><grammatical-info value="Adjective"/><gloss lang="en"><text>parallel</text></gloss></sense></entry>
<entry id="lusa" guid="0e6d360e-6ca8-546d-b2e4-635dd76652f9"><lexical-unit><form lang="id"><text>lusa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lusa_0" guid="fe83ae68-f857-5df5-91e3-97e1b3a92ba2"><grammatical-info value="Noun"/><gloss lang="en"><text>day after tomorrow</text></gloss></sense></entry>
<entry id="lutut" guid="d0c14498-b62a-574a-ab52-b5f16b931428"><lexical-unit><form lang="id"><text>lutut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lutut_0" guid="4683e9b4-b9ab-5da3-80f5-995efac79718"><grammatical-info value="Verb"/><gloss lang="en"><text>knee</text></gloss></sense><sense id="lutut_1" guid="c23dccc3-6455-51e4-ac7e-a967cd1b2c9e"><grammatical-info value="Verb"/><gloss lang="en"><text>rice spoon</text></gloss></sense><sense id="lutut_2" guid="6682aecc-7a75-5fa4-8d28-c1d32da35d68"><grammatical-info value="Verb"/><gloss lang="en"><text>food made from turtle meat that is cut into pieces, put into bamboo, mixed with salt, then grilled</text></gloss></sense></entry>
<entry id="ma" guid="93374e8f-67e2-5a39-9414-07bf841dcd0e"><lexical-unit><form lang="id"><text>ma</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ma_0" guid="ce877443-d79e-5230-a165-b8eb0fdbe1d1"><grammatical-info value="Proper noun"/><gloss lang="en"><text>initialism of madrasah aliah</text></gloss></sense><sense id="ma_1" guid="bee9445b-5020-5e98-bc05-df4990012d80"><grammatical-info value="Proper noun"/><gloss lang="en"><text>initialism of mata anggaran</text></gloss></sense><sense id="ma_2" guid="603ea860-21e9-5c28-9462-1465f9fc6b93"><grammatical-info value="Proper noun"/><gloss lang="en"><text>initialism of mahkamah agung (“supreme court”)</text></gloss></sense><sense id="ma_3" guid="40d03e47-481e-5880-89bc-44e2b2b7848e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a surname from Hakka</text></gloss></sense></entry>
<entry id="maaf" guid="bc571d74-12fe-5579-89df-da2040b5850c"><lexical-unit><form lang="id"><text>maaf</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="maaf_0" guid="7037cce1-0d8c-5d46-b578-5bafd5f6c9ca"><grammatical-info value="Verb"/><gloss lang="en"><text>sorry</text></gloss></sense><sense id="maaf_1" guid="106f6617-f6af-58e9-8f6d-910155332e91"><grammatical-info value="Verb"/><gloss lang="en"><text>pardon</text></gloss></sense><sense id="maaf_2" guid="2bd3c6a2-5b5d-54e6-95c0-776b9f3b035a"><grammatical-info value="Verb"/><gloss lang="en"><text>apology</text></gloss></sense></entry>
