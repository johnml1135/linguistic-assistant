<entry id="tali" guid="dcf23cec-4b08-5d1e-90cd-acc9dbbe78ef"><lexical-unit><form lang="id"><text>tali</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tali_0" guid="a171e61a-c166-5796-856d-bf962da824ca"><grammatical-info value="Noun"/><gloss lang="en"><text>rope (thick, strong string)</text></gloss></sense><sense id="tali_1" guid="1b61f31a-7cfb-5160-bc29-0eaafa0e7172"><grammatical-info value="Noun"/><gloss lang="en"><text>kinship, blood ties</text></gloss></sense><sense id="tali_2" guid="b52fca5a-2cd5-5b62-ae1f-c0e335e0407d"><grammatical-info value="Noun"/><gloss lang="en"><text>coin worth 25 cents</text></gloss></sense></entry>
