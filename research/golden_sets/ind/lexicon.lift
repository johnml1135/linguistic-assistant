<entry id="tuliskan" guid="f9985e75-aa43-5339-a5d4-0f9caab3e2e3"><lexical-unit><form lang="id"><text>tuliskan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tuliskan_0" guid="6426f60c-8d3e-5f0d-8cdd-7399df6f63f8"><grammatical-info value="Verb"/><gloss lang="en"><text>to write down, record</text></gloss></sense></entry>
