<entry id="komentar" guid="02bd37c9-310d-5e25-aed0-f03a9b2928f3"><lexical-unit><form lang="id"><text>komentar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="komentar_0" guid="11439567-97c4-5fb6-bfef-62cdefd5f595"><grammatical-info value="Noun"/><gloss lang="en"><text>comment (spoken or written remark)</text></gloss></sense><sense id="komentar_1" guid="048613ca-3d26-53f1-9c97-ac14bb02255b"><grammatical-info value="Noun"/><gloss lang="en"><text>commentary</text></gloss></sense></entry>
<entry id="komitmen" guid="551fdfc8-ca99-59b3-be3d-8f35fda67506"><lexical-unit><form lang="id"><text>komitmen</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="komitmen_0" guid="f04fa180-979f-55fb-a0e2-49b46470d1bb"><grammatical-info value="Noun"/><gloss lang="en"><text>commitment,</text></gloss></sense><sense id="komitmen_1" guid="7e48e69d-b33c-5f78-984e-26862a9de6ce"><grammatical-info value="Noun"/><gloss lang="en"><text>the act or an instance of committing, putting in charge, keeping, or trust</text></gloss></sense><sense id="komitmen_2" guid="ab1a0874-7fbd-5be8-bdbc-9f75f6bd5180"><grammatical-info value="Noun"/><gloss lang="en"><text>promise or agreement to do something in the future</text></gloss></sense></entry>
<entry id="kompromi" guid="b194b501-260e-584d-8cbc-956916123312"><lexical-unit><form lang="id"><text>kompromi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kompromi_0" guid="896ca448-4c03-5f0b-93d7-31a82cf015b7"><grammatical-info value="Noun"/><gloss lang="en"><text>compromise</text></gloss></sense></entry>
<entry id="komunitas" guid="7585c365-26fd-5b69-9005-b37069a9b1e0"><lexical-unit><form lang="id"><text>komunitas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="komunitas_0" guid="89bdf377-eaa4-56a8-b9e6-712dd7773afe"><grammatical-info value="Noun"/><gloss lang="en"><text>community:</text></gloss></sense><sense id="komunitas_1" guid="7701b75e-3808-538f-a973-e5ec8d39a2e5"><grammatical-info value="Noun"/><gloss lang="en"><text>a group sharing common characteristics, such as the same language, law, religion, or tradition.</text></gloss></sense><sense id="komunitas_2" guid="d27c0a21-e7da-5ebe-b6ba-d57b99f8361d"><grammatical-info value="Noun"/><gloss lang="en"><text>a group of interdependent organisms inhabiting the same region and interacting with each other.</text></gloss></sense><sense id="komunitas_3" guid="0571113a-312a-5da8-817a-514e94a5f643"><grammatical-info value="Noun"/><gloss lang="en"><text>a group of people interacting by electronic means for educational, professional, social, or other purposes; a virtual community.</text></gloss></sense></entry>
<entry id="kondisi" guid="71c45331-e76c-590a-ab3f-e539f406db58"><lexical-unit><form lang="id"><text>kondisi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kondisi_0" guid="7671c2f9-ed8f-5782-8167-997c7dd8c616"><grammatical-info value="Noun"/><gloss lang="en"><text>condition (the requirement or requisite)</text></gloss></sense><sense id="kondisi_1" guid="b63eabc3-351d-5430-8db6-1519e9adb7cb"><grammatical-info value="Noun"/><gloss lang="en"><text>condition (the state or quality)</text></gloss></sense></entry>
