<entry id="bereskan" guid="0b1b5564-d8f6-598e-bade-a4d7ea7839ae"><lexical-unit><form lang="id"><text>bereskan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bereskan_0" guid="27df8966-b149-5fb0-b06e-787cc5b87267"><grammatical-info value="Verb"/><gloss lang="en"><text>to arrange (to put in order)</text></gloss></sense><sense id="bereskan_1" guid="6bd4c8cd-be8b-5930-b4f0-7024dbcb578e"><grammatical-info value="Verb"/><gloss lang="en"><text>to settle, to resolve (to conclude; to address a problem etc.)</text></gloss></sense></entry>
<entry id="bergilir" guid="5abf0b9c-33a1-55d0-9ba7-819f4824f3d3"><lexical-unit><form lang="id"><text>bergilir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bergilir_0" guid="02ee9e16-1f8d-5ec7-83f9-c66c3123205a"><grammatical-info value="Verb"/><gloss lang="en"><text>take turns</text></gloss></sense></entry>
