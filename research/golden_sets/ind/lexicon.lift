<entry id="kerajaan" guid="db970a46-c756-5046-87e9-a17b5ef7c95a"><lexical-unit><form lang="id"><text>kerajaan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kerajaan_0" guid="f88a5616-9389-57ce-819b-9dd1042071b2"><grammatical-info value="Noun"/><gloss lang="en"><text>kingdom</text></gloss></sense><sense id="kerajaan_1" guid="14bf11fa-badd-53d7-bcb5-918fec17bf48"><grammatical-info value="Noun"/><gloss lang="en"><text>a realm having a king and/or queen as its actual or nominal sovereign</text></gloss></sense><sense id="kerajaan_2" guid="66247d50-8977-5e30-8a1f-c45ba6d59e7d"><grammatical-info value="Noun"/><gloss lang="en"><text>a rank in the classification of organisms, below domain and above phylum; a taxon at that rank</text></gloss></sense><sense id="kerajaan_3" guid="44c51781-0674-5f1a-8577-2e765b0b19fe"><grammatical-info value="Noun"/><gloss lang="en"><text>monarchy: a government in which sovereignty is embodied within a single, today usually hereditary head of state (whether as a figurehead or as a powerful ruler)</text></gloss></sense><sense id="kerajaan_4" guid="aed9e06b-e8f8-516a-954c-4b977c9309c2"><grammatical-info value="Noun"/><gloss lang="en"><text>kingship</text></gloss></sense><sense id="kerajaan_5" guid="017a16d7-b440-5eff-9ce8-d20e9dda33cc"><grammatical-info value="Noun"/><gloss lang="en"><text>royal: of or relating to a monarch or their family</text></gloss></sense><sense id="kerajaan_6" guid="0edd97d8-4c0b-50d3-b5c5-199bfb903e8a"><grammatical-info value="Noun"/><gloss lang="en"><text>to become a king</text></gloss></sense></entry>
