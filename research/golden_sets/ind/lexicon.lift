<entry id="konsekuensi" guid="b67b8791-aaba-5ea7-8fea-53c50cd97882"><lexical-unit><form lang="id"><text>konsekuensi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="konsekuensi_0" guid="0d3c2994-7e5b-546a-9c91-ab70e0733480"><grammatical-info value="Noun"/><gloss lang="en"><text>consequence, result</text></gloss></sense></entry>
<entry id="konsisten" guid="abcacf14-864f-5512-8750-3e8e290bc393"><lexical-unit><form lang="id"><text>konsisten</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="konsisten_0" guid="560c0744-c7e7-50ef-8808-e95ea4b68427"><grammatical-info value="Adjective"/><gloss lang="en"><text>consistent:</text></gloss></sense><sense id="konsisten_1" guid="80115f29-8046-5b04-81d6-3ce855c12983"><grammatical-info value="Adjective"/><gloss lang="en"><text>of a regularly occurring, dependable nature</text></gloss></sense><sense id="konsisten_2" guid="4ac783b9-ab66-58c7-a6ae-5f7d3491b500"><grammatical-info value="Adjective"/><gloss lang="en"><text>compatible, accordant</text></gloss></sense></entry>
<entry id="kontaminasi" guid="5bc4a177-56f0-5d99-8538-65efb31746db"><lexical-unit><form lang="id"><text>kontaminasi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kontaminasi_0" guid="2d1f43cc-a660-5fe2-9460-c34253ea153d"><grammatical-info value="Noun"/><gloss lang="en"><text>contamination:</text></gloss></sense><sense id="kontaminasi_1" guid="6b36f4a2-20e9-5ac9-b776-32d3968ccc36"><grammatical-info value="Noun"/><gloss lang="en"><text>the act or process of contaminating</text></gloss></sense><sense id="kontaminasi_2" guid="cef83750-e904-5c26-a857-6021a3355b1c"><grammatical-info value="Noun"/><gloss lang="en"><text>the influence of one form (often from a foreign language) on the historical development of another form to which it may be related in meaning</text></gloss></sense></entry>
<entry id="kontrak" guid="ee847971-0810-5097-9972-45546fb27970"><lexical-unit><form lang="id"><text>kontrak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kontrak_0" guid="a18b5937-5dae-5cb8-9c97-5f057fdd411a"><grammatical-info value="Noun"/><gloss lang="en"><text>contract</text></gloss></sense></entry>
<entry id="korban" guid="a47f939f-7291-53a5-b040-66aa47a0ce34"><lexical-unit><form lang="id"><text>korban</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="korban_0" guid="10fd5548-8fd5-5ee0-a9e0-58b140c6a1b8"><grammatical-info value="Noun"/><gloss lang="en"><text>victim, casualty</text></gloss></sense><sense id="korban_1" guid="086b4911-ddf0-5e89-b55a-397514e100e6"><grammatical-info value="Noun"/><gloss lang="en"><text>a living being slain and offered as a sacrifice, usually in a religious rite</text></gloss></sense><sense id="korban_2" guid="48d07b48-5de6-5645-85af-26cd7666431a"><grammatical-info value="Noun"/><gloss lang="en"><text>one who is harmed</text></gloss></sense></entry>
<entry id="koreksi" guid="aed34845-c900-55fc-8b9e-44b72d39dbc6"><lexical-unit><form lang="id"><text>koreksi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="koreksi_0" guid="0af4f035-0bdc-5d7c-946e-e23c95f45b88"><grammatical-info value="Noun"/><gloss lang="en"><text>correction, rectification</text></gloss></sense><sense id="koreksi_1" guid="82e3e0d7-964f-5312-b9dd-8fe0f335eba2"><grammatical-info value="Noun"/><gloss lang="en"><text>the act of correcting</text></gloss></sense><sense id="koreksi_2" guid="2a7b7855-5d51-575a-be29-8c1ef2d4b4ef"><grammatical-info value="Noun"/><gloss lang="en"><text>a decline in a stock market price after a large rise</text></gloss></sense><sense id="koreksi_3" guid="80d96607-6cfb-5f2f-a159-747211edba67"><grammatical-info value="Noun"/><gloss lang="en"><text>test scoring, test grading</text></gloss></sense><sense id="koreksi_4" guid="629a0f3b-6a3a-5983-8d40-f259c9143db2"><grammatical-info value="Noun"/><gloss lang="en"><text>proofing (the process of creating a preliminary version of a printed piece by creating a preliminary sample (a "proof") of a design to check for errors in text, layout, images, and color before the full production run, ensuring the final printed piece matches the client's vision and catching costly mistakes early)</text></gloss></sense></entry>
<entry id="korintus" guid="3262589e-85a7-5c73-b440-5920094fc354"><lexical-unit><form lang="id"><text>korintus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="korintus_0" guid="5a92a647-3427-53f0-b233-c1a7ebc6eb9c"><grammatical-info value="Proper noun"/><gloss lang="en"><text>corinth</text></gloss></sense></entry>
<entry id="kornelius" guid="45350081-5a15-5590-b2cd-b03ae9c5895f"><lexical-unit><form lang="id"><text>kornelius</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kornelius_0" guid="1959e30b-5845-5f51-b148-af0f25b8bb36"><grammatical-info value="Proper noun"/><gloss lang="en"><text>cornelius</text></gloss></sense></entry>
<entry id="kos" guid="ebb360a0-e733-5f2c-bb1e-5b7f81576549"><lexical-unit><form lang="id"><text>kos</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kos_0" guid="4cce487a-dd8c-5181-a1ea-2f408f6049f5"><grammatical-info value="Noun"/><gloss lang="en"><text>lodging</text></gloss></sense><sense id="kos_1" guid="046c5106-6732-5e1a-be64-94e3d93a7456"><grammatical-info value="Noun"/><gloss lang="en"><text>to rent a place to live or lodge</text></gloss></sense></entry>
<entry id="kosong" guid="49b07f61-1ed2-5dcd-9973-8dc12c9cfad3"><lexical-unit><form lang="id"><text>kosong</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kosong_0" guid="53aa8484-261f-5694-8414-b00535610c9d"><grammatical-info value="Adjective"/><gloss lang="en"><text>empty (literally or figuratively)</text></gloss></sense><sense id="kosong_1" guid="c43c7bf1-7217-5b08-bc15-c40c132c9836"><grammatical-info value="Adjective"/><gloss lang="en"><text>vacant:</text></gloss></sense><sense id="kosong_2" guid="230f6a82-09df-53ab-9ec6-426a40ace683"><grammatical-info value="Adjective"/><gloss lang="en"><text>containing nothing</text></gloss></sense><sense id="kosong_3" guid="d9da394c-5e8e-586f-9508-f71bcc3158e5"><grammatical-info value="Adjective"/><gloss lang="en"><text>empty, not occupied.</text></gloss></sense><sense id="kosong_4" guid="f09dbec2-853c-597d-aa61-2e55644cbc2f"><grammatical-info value="Adjective"/><gloss lang="en"><text>vacant (not occupied)</text></gloss></sense><sense id="kosong_5" guid="fe0f8645-b219-5f8c-a5eb-6a05e98dad57"><grammatical-info value="Adjective"/><gloss lang="en"><text>empty, meaningless</text></gloss></sense><sense id="kosong_6" guid="a36806c3-7d6f-51fc-942a-c42fb941e263"><grammatical-info value="Adjective"/><gloss lang="en"><text>unavailable</text></gloss></sense><sense id="kosong_7" guid="8842d67e-620e-5f40-9a0a-ce5a813e7780"><grammatical-info value="Adjective"/><gloss lang="en"><text>hollow (having an empty space or cavity inside)</text></gloss></sense></entry>
<entry id="kota" guid="09b8073d-c5d8-5fb2-af80-204ea257a7e7"><lexical-unit><form lang="id"><text>kota</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kota_0" guid="7188c53e-9088-55ca-b427-bb8191b5e24b"><grammatical-info value="Noun"/><gloss lang="en"><text>city,</text></gloss></sense><sense id="kota_1" guid="5ffdf1cb-1097-506e-bc08-17b78d47ca9c"><grammatical-info value="Noun"/><gloss lang="en"><text>a large settlement, bigger than a town; sometimes with a specific legal definition, depending on the place</text></gloss></sense><sense id="kota_2" guid="9b62679e-bbbd-5bdf-a492-35be4d307218"><grammatical-info value="Noun"/><gloss lang="en"><text>the second-level urban administrative division in Indonesia</text></gloss></sense><sense id="kota_3" guid="c1be7c56-4d92-50f7-ad17-f79314bcd228"><grammatical-info value="Noun"/><gloss lang="en"><text>urbs (walled city)</text></gloss></sense><sense id="kota_4" guid="8a667629-2e6b-5942-9c9f-a401c38d6efc"><grammatical-info value="Noun"/><gloss lang="en"><text>to keep, to fullfill, to hold, to honor</text></gloss></sense><sense id="kota_5" guid="277724a4-2e4b-56b8-bee2-264aed2125fd"><grammatical-info value="Noun"/><gloss lang="en"><text>a small box made of pandan leaves, a place to store valuables, usually carried by the Serua indigenous people</text></gloss></sense><sense id="kota_6" guid="e972c137-6e5e-5858-b8e3-392226dd4dcd"><grammatical-info value="Noun"/><gloss lang="en"><text>a garden that has been fenced with a stone fence</text></gloss></sense><sense id="kota_7" guid="7609b7c6-2b78-5ec5-9b03-81ccb233a949"><grammatical-info value="Noun"/><gloss lang="en"><text>fence made of coral piles</text></gloss></sense></entry>
<entry id="kotak" guid="c7b810ed-a396-588b-a41d-fa74c39f65c5"><lexical-unit><form lang="id"><text>kotak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kotak_0" guid="5d304e5c-4211-5ee8-ad0a-aeaabd0df775"><grammatical-info value="Noun"/><gloss lang="en"><text>box; case (cuboid container)</text></gloss></sense><sense id="kotak_1" guid="563b7770-a569-53ae-a637-1d6e60d6a52d"><grammatical-info value="Noun"/><gloss lang="en"><text>pack</text></gloss></sense></entry>
<entry id="kotor" guid="cd87380e-d43d-5fc5-ba1b-4b2a8b8a5c34"><lexical-unit><form lang="id"><text>kotor</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kotor_0" guid="44cde51c-addf-548d-9afc-86449e3f718a"><grammatical-info value="Adjective"/><gloss lang="en"><text>dirty</text></gloss></sense><sense id="kotor_1" guid="762f30ce-15f7-58b2-a0e3-494b2eb2f785"><grammatical-info value="Adjective"/><gloss lang="en"><text>gross</text></gloss></sense><sense id="kotor_2" guid="10a0ee6b-f487-5682-b38b-60977c0375dd"><grammatical-info value="Adjective"/><gloss lang="en"><text>dirty, dishonest, bad, evil</text></gloss></sense></entry>
<entry id="koyak" guid="0ff095a3-3c22-5d73-bae9-982244489bb5"><lexical-unit><form lang="id"><text>koyak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="koyak_0" guid="9a5ad87f-2951-5147-84ed-2c455d41ed04"><grammatical-info value="Verb"/><gloss lang="en"><text>torn</text></gloss></sense></entry>
<entry id="kredit" guid="78dffc91-9d6e-58f8-a6bb-caeb4a50930f"><lexical-unit><form lang="id"><text>kredit</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kredit_0" guid="4007edd5-152d-5aa5-a568-4afab0a42cbc"><grammatical-info value="Noun"/><gloss lang="en"><text>liabilities</text></gloss></sense><sense id="kredit_1" guid="071e4d94-d804-5c84-ac45-45db324a7651"><grammatical-info value="Noun"/><gloss lang="en"><text>an amount of money in a company that is owed to someone and has to be paid in the future, such as tax, debt, interest, and mortgage payments</text></gloss></sense><sense id="kredit_2" guid="b87fa183-a0d4-57f1-bae4-29bbe230eacc"><grammatical-info value="Noun"/><gloss lang="en"><text>the right side of a balance sheet</text></gloss></sense><sense id="kredit_3" guid="047baeef-820b-5064-8f71-6bd6e5284c3f"><grammatical-info value="Noun"/><gloss lang="en"><text>credit:</text></gloss></sense><sense id="kredit_4" guid="822e39e0-5463-58c6-b1b6-5f46c37ff985"><grammatical-info value="Noun"/><gloss lang="en"><text>a privilege of delayed payment extended to a buyer or borrower on the seller's or lender's belief that what is given will be repaid</text></gloss></sense><sense id="kredit_5" guid="103311e7-4ce9-5ac9-98c7-ef1e07257fd0"><grammatical-info value="Noun"/><gloss lang="en"><text>an addition to certain accounts; the side of an account on which payments received are entered</text></gloss></sense><sense id="kredit_6" guid="b0140c10-c343-5ce8-82b4-0d3c632e5c56"><grammatical-info value="Noun"/><gloss lang="en"><text>a source of value, distinction or honour</text></gloss></sense><sense id="kredit_7" guid="36eb4947-b28c-5dd9-867b-2d49f5747671"><grammatical-info value="Noun"/><gloss lang="en"><text>a course credit, a credit hour – used as measure if enough courses have been taken for graduation</text></gloss></sense></entry>
<entry id="kriminal" guid="c7d10afd-f219-5ded-bb69-b2a73f705dc0"><lexical-unit><form lang="id"><text>kriminal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kriminal_0" guid="f284bd87-ae47-5e20-bf90-876467b0996d"><grammatical-info value="Noun"/><gloss lang="en"><text>criminal</text></gloss></sense><sense id="kriminal_1" guid="13e011bb-6650-5838-aab5-0ce20c1b684b"><grammatical-info value="Noun"/><gloss lang="en"><text>crime</text></gloss></sense></entry>
<entry id="kristal" guid="c21d799f-041b-5fcf-b3b8-0ab0b5f97168"><lexical-unit><form lang="id"><text>kristal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kristal_0" guid="df6dfcb1-b51b-5da5-a591-c73f98d9cacb"><grammatical-info value="Noun"/><gloss lang="en"><text>crystal</text></gloss></sense><sense id="kristal_1" guid="701019e8-d7e6-531b-a7ea-d2a9745719f4"><grammatical-info value="Noun"/><gloss lang="en"><text>clear, easily or distinctly heard; audible</text></gloss></sense></entry>
<entry id="kristen" guid="512b2c74-d1f2-5047-8b46-811d7a62e2e5"><lexical-unit><form lang="id"><text>kristen</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kristen_0" guid="9c6b86a0-8ebe-50eb-bd9a-c6a0010613d5"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Christianity</text></gloss></sense><sense id="kristen_1" guid="479b6e2a-76fa-5386-acff-10890907da1e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Christian</text></gloss></sense></entry>
<entry id="kristiani" guid="fb50b73c-1a3f-520f-a659-ad24b319dbfe"><lexical-unit><form lang="id"><text>kristiani</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kristiani_0" guid="868720a1-e818-55af-a4e9-c82de93dad4d"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="kristus" guid="ed129d2b-67cf-5eca-b7b4-6515b39d983b"><lexical-unit><form lang="id"><text>kristus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kristus_0" guid="0cb47ae5-0154-55a9-81be-632539d46d3c"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the Christ</text></gloss></sense></entry>
<entry id="kritik" guid="dd88df2e-7abf-5711-8963-399abaa809c3"><lexical-unit><form lang="id"><text>kritik</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kritik_0" guid="0eb83c31-be40-510c-86ea-58284346a8a6"><grammatical-info value="Noun"/><gloss lang="en"><text>critique (the art of criticism)</text></gloss></sense><sense id="kritik_1" guid="bded824b-ed5f-52e8-a251-5d36d69f0c94"><grammatical-info value="Noun"/><gloss lang="en"><text>critique (an essay or point in which another piece of work is criticised, reviewed)</text></gloss></sense><sense id="kritik_2" guid="ae1b6caf-5995-56c3-ad61-5b434731c7e6"><grammatical-info value="Noun"/><gloss lang="en"><text>to criticize</text></gloss></sense></entry>
