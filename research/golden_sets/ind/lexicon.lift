<entry id="kinerja" guid="6b61f182-55d2-53be-9850-d3984a365c62"><lexical-unit><form lang="id"><text>kinerja</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kinerja_0" guid="da63fac1-b4bf-5ac2-9f3c-1f6934366e5e"><grammatical-info value="Noun"/><gloss lang="en"><text>performance: the amount of useful work accomplished estimated in terms of time needed, resources used, etc</text></gloss></sense><sense id="kinerja_1" guid="3a0ff4a2-df54-5810-ac5d-f4d4b748da8e"><grammatical-info value="Noun"/><gloss lang="en"><text>accomplishment, achievement</text></gloss></sense></entry>
<entry id="kini" guid="cba0ad4e-2e90-5759-a05c-88f2beaa73ee"><lexical-unit><form lang="id"><text>kini</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kini_0" guid="530fa16e-40ae-5978-8231-7bef71a7110d"><grammatical-info value="Adverb"/><gloss lang="en"><text>current, present</text></gloss></sense><sense id="kini_1" guid="95fd8609-5e81-54bf-bed0-37c6ce499d54"><grammatical-info value="Adverb"/><gloss lang="en"><text>now, today</text></gloss></sense></entry>
<entry id="kios" guid="24142ccf-a461-531c-8998-68858defaa3c"><lexical-unit><form lang="id"><text>kios</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kios_0" guid="3d4cc114-ecca-5d84-b1d6-1b5a5d7afe54"><grammatical-info value="Noun"/><gloss lang="en"><text>kiosk,</text></gloss></sense><sense id="kios_1" guid="75000074-fce8-5f2b-92e1-f05007911321"><grammatical-info value="Noun"/><gloss lang="en"><text>a small enclosed structure, often freestanding, open on one side or with a window, used as a booth to sell newspapers, cigarettes, etc.</text></gloss></sense><sense id="kios_2" guid="bc3520c6-2fc4-50a2-b123-653454dce3d5"><grammatical-info value="Noun"/><gloss lang="en"><text>a similar unattended stand for the automatic dispensing of tickets, etc.</text></gloss></sense><sense id="kios_3" guid="c258c7b7-dae8-58b1-a9fa-63d8b379a4a6"><grammatical-info value="Noun"/><gloss lang="en"><text>interactive kiosk</text></gloss></sense></entry>
<entry id="kir" guid="e5c97a63-38a6-57aa-aa4b-dbaa4a049919"><lexical-unit><form lang="id"><text>kir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kir_0" guid="48b6deea-f973-5484-b591-9118e792ca75"><grammatical-info value="Noun"/><gloss lang="en"><text>examination</text></gloss></sense></entry>
<entry id="kira" guid="dfefc314-1320-56b3-b88c-20092221d6f2"><lexical-unit><form lang="id"><text>kira</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kira_0" guid="3702880c-0e1b-53fc-9fc3-6499564507c7"><grammatical-info value="Verb"/><gloss lang="en"><text>to assume, think that, suspect, guess, imagine</text></gloss></sense><sense id="kira_1" guid="1365e577-9f89-5740-a3f9-2fdd9dc5194e"><grammatical-info value="Verb"/><gloss lang="en"><text>to be of the opinion that</text></gloss></sense><sense id="kira_2" guid="1230e6a7-380b-51d1-a8bc-8ff53823efba"><grammatical-info value="Verb"/><gloss lang="en"><text>be left out of consideration, get no consideration</text></gloss></sense><sense id="kira_3" guid="4a9b7058-727e-5861-b827-e00cfda837be"><grammatical-info value="Verb"/><gloss lang="en"><text>to compute, calculate</text></gloss></sense><sense id="kira_4" guid="cad78d33-b277-5283-b165-354a17a97046"><grammatical-info value="Verb"/><gloss lang="en"><text>feeling, opinion, supposition, presumption (not based on concrete evidence)</text></gloss></sense><sense id="kira_5" guid="ed9c2e91-b9d8-5fc5-ad7f-cb918ad5afdb"><grammatical-info value="Verb"/><gloss lang="en"><text>guess, estimate, estimation, calculation, count, conjecture</text></gloss></sense><sense id="kira_6" guid="8c471080-1a32-57b3-9002-f79c93de16ec"><grammatical-info value="Verb"/><gloss lang="en"><text>would have thought</text></gloss></sense></entry>
<entry id="kiri" guid="d45e4f3b-3650-5880-b2fd-f777e6d21ce3"><lexical-unit><form lang="id"><text>kiri</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kiri_0" guid="2759a552-35bc-587f-9543-f77525fa129b"><grammatical-info value="Noun"/><gloss lang="en"><text>left (the west side of the body when one is facing north)</text></gloss></sense><sense id="kiri_1" guid="cf570164-1175-5010-96c5-53bcde67ef3f"><grammatical-info value="Noun"/><gloss lang="en"><text>left-wing</text></gloss></sense></entry>
