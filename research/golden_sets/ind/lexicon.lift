<entry id="benci" guid="70b99edf-1a4e-5479-a28e-9f1bb785af9b"><lexical-unit><form lang="id"><text>benci</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="benci_0" guid="f300a712-a73d-524e-97d7-2fabce999f42"><grammatical-info value="Adjective"/><gloss lang="en"><text>hatred</text></gloss></sense><sense id="benci_1" guid="66163449-49c2-535a-81da-7b564565ee8d"><grammatical-info value="Adjective"/><gloss lang="en"><text>to hate</text></gloss></sense><sense id="benci_2" guid="3eaa16f6-4a0d-590e-8827-db12e00e193a"><grammatical-info value="Adjective"/><gloss lang="en"><text>really love</text></gloss></sense></entry>
