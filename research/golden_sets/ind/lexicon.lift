<entry id="kadar" guid="142a4669-8c9d-5bfc-a302-e0e0f46fcf3b"><lexical-unit><form lang="id"><text>kadar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kadar_0" guid="dddd8c91-7153-5971-a68f-25f8a418b284"><grammatical-info value="Noun"/><gloss lang="en"><text>nature (of a being), character</text></gloss></sense><sense id="kadar_1" guid="e355ed5c-0a82-5ea1-a4ab-1549a459953e"><grammatical-info value="Noun"/><gloss lang="en"><text>might, God's will</text></gloss></sense><sense id="kadar_2" guid="a5e4f9bc-6232-51c3-b234-4b5192f6670f"><grammatical-info value="Noun"/><gloss lang="en"><text>power</text></gloss></sense><sense id="kadar_3" guid="9662b5d6-16b5-5aeb-a097-0ad25d4252ce"><grammatical-info value="Noun"/><gloss lang="en"><text>luck</text></gloss></sense><sense id="kadar_4" guid="89e4e9c9-ac37-5687-8715-22338c3e3979"><grammatical-info value="Noun"/><gloss lang="en"><text>measure, a prescribed quantity or extent:</text></gloss></sense><sense id="kadar_5" guid="7b0e6dba-4350-571b-ae51-054c9d80f508"><grammatical-info value="Noun"/><gloss lang="en"><text>a limit that cannot be exceeded; a bound</text></gloss></sense><sense id="kadar_6" guid="6ae7cc4a-7534-50c9-9fb2-967fdae0cba5"><grammatical-info value="Noun"/><gloss lang="en"><text>an (unspecified) portion or quantity</text></gloss></sense><sense id="kadar_7" guid="768ead06-b1f7-5100-8a71-09b57654fdf1"><grammatical-info value="Noun"/><gloss lang="en"><text>content: the amount of material contained</text></gloss></sense></entry>
<entry id="kaf" guid="a624f572-f979-500a-b373-8a0d7ddb6d70"><lexical-unit><form lang="id"><text>kaf</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kaf_0" guid="0f107756-ec09-58c9-bb8b-39ccf50c10fa"><grammatical-info value="Noun"/><gloss lang="en"><text>the twenty-second letter of the Arabic alphabet. ك (k)</text></gloss></sense><sense id="kaf_1" guid="e039f502-5ff5-55cb-bce1-ca566b72f579"><grammatical-info value="Noun"/><gloss lang="en"><text>cover (book)</text></gloss></sense></entry>
<entry id="kafir" guid="c0469301-f51b-5724-b101-bde1dd077b22"><lexical-unit><form lang="id"><text>kafir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kafir_0" guid="cf4d2ae8-56c7-586c-9883-5642582aaa59"><grammatical-info value="Noun"/><gloss lang="en"><text>unbeliever, non-believer, infidel</text></gloss></sense><sense id="kafir_1" guid="9e80751d-75bf-5482-add1-f52e8addc36b"><grammatical-info value="Noun"/><gloss lang="en"><text>a kafir, a disbeliever, a denier, someone who denies the truths from Allah; or more broadly any non-Muslim</text></gloss></sense><sense id="kafir_2" guid="9956e973-bb85-5684-85bc-02293d55111d"><grammatical-info value="Noun"/><gloss lang="en"><text>non-Christian</text></gloss></sense><sense id="kafir_3" guid="fbf41047-f366-5ab2-ab0e-6eee119fae05"><grammatical-info value="Noun"/><gloss lang="en"><text>gentile, non-Jew</text></gloss></sense></entry>
