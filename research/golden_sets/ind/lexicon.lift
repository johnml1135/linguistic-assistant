<entry id="paham" guid="29c64b0c-d5f1-546c-8cfc-e69561f703a0"><lexical-unit><form lang="id"><text>paham</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="paham_0" guid="afa3d2e0-ed77-58ad-b336-49045ee103e0"><grammatical-info value="Verb"/><gloss lang="en"><text>understanding</text></gloss></sense><sense id="paham_1" guid="11081faf-117a-52e7-a2d3-8542feb45742"><grammatical-info value="Verb"/><gloss lang="en"><text>the act of understanding or comprehension</text></gloss></sense><sense id="paham_2" guid="59b8b7b5-1ed5-5417-8671-01fed6c0d1df"><grammatical-info value="Verb"/><gloss lang="en"><text>Reason or intelligence; ability to grasp the full meaning of knowledge; ability to infer</text></gloss></sense><sense id="paham_3" guid="9cc6bc3c-38ff-5c15-a7d5-1d6d406d79b1"><grammatical-info value="Verb"/><gloss lang="en"><text>Opinion, judgement, or outlook</text></gloss></sense><sense id="paham_4" guid="30ea954c-3d6b-5283-86fe-ddf4a97665d3"><grammatical-info value="Verb"/><gloss lang="en"><text>view (a way of understanding something)</text></gloss></sense><sense id="paham_5" guid="e81a07a9-dfa0-5a26-9319-3896711e7c97"><grammatical-info value="Verb"/><gloss lang="en"><text>to understand</text></gloss></sense><sense id="paham_6" guid="6def18af-8eff-5388-84db-d617892839d6"><grammatical-info value="Verb"/><gloss lang="en"><text>(of communication, language, or other means of communication: words, statements, signs, etc.) To know the meaning of; to parse or have parsed correctly; to comprehend</text></gloss></sense><sense id="paham_7" guid="e500770f-54a1-5617-8203-4c4732f84a55"><grammatical-info value="Verb"/><gloss lang="en"><text>to be thoroughly familiar with; to be able to undertake properly</text></gloss></sense></entry>
<entry id="pahami" guid="49308481-e246-5c39-8385-62cf4c1dd00d"><lexical-unit><form lang="id"><text>pahami</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pahami_0" guid="b8bf687a-e3c2-5989-bde4-70d0647a17ec"><grammatical-info value="Verb"/><gloss lang="en"><text>to understand</text></gloss></sense></entry>
<entry id="pahat" guid="ddf97b2e-ac71-522d-842d-46d8292a1758"><lexical-unit><form lang="id"><text>pahat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pahat_0" guid="4d8db0b3-9d20-5285-a463-cd2e0ec8008a"><grammatical-info value="Verb"/><gloss lang="en"><text>chisel: a cutting tool used to remove parts of stone, wood or metal by pushing or pounding the back when the sharp edge is against the material. It consists of a slim, oblong block of metal with a sharp wedge or bevel formed on one end and sometimes a handle at the other end</text></gloss></sense></entry>
