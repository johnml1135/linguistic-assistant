<entry id="terdapat" guid="646bb249-69a3-532a-a2c6-34087b059add"><lexical-unit><form lang="id"><text>terdapat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="terdapat_0" guid="ee250812-d4f6-5518-a11a-86aae0e24f92"><grammatical-info value="Verb"/><gloss lang="en"><text>to be found</text></gloss></sense><sense id="terdapat_1" guid="b750c0e1-fe6f-53a2-a9ac-c530b9f9f2d5"><grammatical-info value="Verb"/><gloss lang="en"><text>to exist</text></gloss></sense></entry>
<entry id="terdengar" guid="cb51de80-9a25-5265-af5f-7b0b70e68505"><lexical-unit><form lang="id"><text>terdengar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="terdengar_0" guid="5b6f9113-dd95-5e3a-af4f-2dfe34a88aeb"><grammatical-info value="Verb"/><gloss lang="en"><text>hearable (can be heard)</text></gloss></sense><sense id="terdengar_1" guid="eaa26895-6d02-5b90-b24a-3e4456416c9d"><grammatical-info value="Verb"/><gloss lang="en"><text>to sound (to convey an impression by one's sound)</text></gloss></sense></entry>
<entry id="terhadap" guid="4564034a-4ce5-5f0e-8947-e0f5b9c3fb8f"><lexical-unit><form lang="id"><text>terhadap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="terhadap_0" guid="b351c132-fde4-58c8-b16a-3ca34a704ed2"><grammatical-info value="Adposition"/><gloss lang="en"><text>toward; towards (in relation to someone or something)</text></gloss></sense><sense id="terhadap_1" guid="fe007948-76a9-5fac-8185-3215ef8b0c7d"><grammatical-info value="Adposition"/><gloss lang="en"><text>in relation to (concerning; in reference to)</text></gloss></sense></entry>
<entry id="teri" guid="e7bf2ad9-6fa6-5fc7-8f13-fa7479b79022"><lexical-unit><form lang="id"><text>teri</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="teri_0" guid="3bbf9465-df0e-52a1-860d-f291aed10f7b"><grammatical-info value="Noun"/><gloss lang="en"><text>spined anchovy (Stolephorus tri)</text></gloss></sense><sense id="teri_1" guid="a7739a8e-3a61-52db-940f-3e9b53e49f51"><grammatical-info value="Noun"/><gloss lang="en"><text>anchovy</text></gloss></sense><sense id="teri_2" guid="41009089-b6b1-5aa3-987b-1a6b75a467aa"><grammatical-info value="Noun"/><gloss lang="en"><text>small fry (things or people of little importance)</text></gloss></sense><sense id="teri_3" guid="b17ddc41-95c9-5fc4-b5dc-477802bc85cb"><grammatical-info value="Noun"/><gloss lang="en"><text>terry, terrycloth, terry cloth</text></gloss></sense></entry>
<entry id="teriak" guid="f803ea1d-0630-54e1-b4f8-2aefd16bb9f3"><lexical-unit><form lang="id"><text>teriak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="teriak_0" guid="db25f010-eb0b-5f80-b3d7-20b7350c1da2"><grammatical-info value="Verb"/><gloss lang="en"><text>scream</text></gloss></sense><sense id="teriak_1" guid="a3398945-4d6f-5217-b62e-eba8f6e59b1a"><grammatical-info value="Verb"/><gloss lang="en"><text>a loud, emphatic, exclamation of extreme emotion, especially horror, fear, excitement, or anger; it may comprise a word or a sustained, high-pitched vowel sound</text></gloss></sense><sense id="teriak_2" guid="ea3bc992-6d80-586e-8533-fd299835956b"><grammatical-info value="Verb"/><gloss lang="en"><text>a loud vocalisation of many animals, especially in response to pain or fear</text></gloss></sense><sense id="teriak_3" guid="b8e481f4-0586-5038-9570-242e88ce20bd"><grammatical-info value="Verb"/><gloss lang="en"><text>shout (a loud burst of voice or voices; a violent and sudden outcry, especially that of a multitude expressing joy, triumph, exultation, anger, or great effort)</text></gloss></sense></entry>
