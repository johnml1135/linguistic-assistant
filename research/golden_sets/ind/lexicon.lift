<entry id="gua" guid="1042a088-4166-5c33-b4fb-2916a144b260"><lexical-unit><form lang="id"><text>gua</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gua_0" guid="e3d2a937-acae-5a71-89b6-eb4c49244b17"><grammatical-info value="Noun"/><gloss lang="en"><text>cave</text></gloss></sense></entry>
<entry id="gubernur" guid="fcc571f9-ee47-588a-abce-0f4a0f0351c1"><lexical-unit><form lang="id"><text>gubernur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gubernur_0" guid="0730a781-d7a9-57d7-b40a-22a4b187441c"><grammatical-info value="Noun"/><gloss lang="en"><text>governor</text></gloss></sense><sense id="gubernur_1" guid="6825b5ac-2aae-582a-b3f4-6a752f18a1b9"><grammatical-info value="Noun"/><gloss lang="en"><text>the chief executive officer of a province or provincial-level division known as a provinsi in Indonesia</text></gloss></sense><sense id="gubernur_2" guid="b44ca595-f8f9-57aa-897a-a39c7864f253"><grammatical-info value="Noun"/><gloss lang="en"><text>the head of military education institution</text></gloss></sense></entry>
<entry id="gudang" guid="57a9c3a6-11e8-58bd-a41a-587d17d50318"><lexical-unit><form lang="id"><text>gudang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gudang_0" guid="3ec75f13-603a-5c6f-99a2-c86d7c7f0429"><grammatical-info value="Noun"/><gloss lang="en"><text>warehouse (a place for storing large amounts of products. In logistics, a place where products go to from the manufacturer before going to the retailer)</text></gloss></sense></entry>
<entry id="gugat" guid="5f4ad08a-8f0f-5fe4-9739-9548d5465450"><lexical-unit><form lang="id"><text>gugat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gugat_0" guid="34e1491f-8951-53e5-a341-3d61932f586f"><grammatical-info value="Verb"/><gloss lang="en"><text>to complaint, to claim</text></gloss></sense><sense id="gugat_1" guid="9a60b7e7-d16d-5879-95d1-5ee3c51f87c2"><grammatical-info value="Verb"/><gloss lang="en"><text>to sue</text></gloss></sense><sense id="gugat_2" guid="8ddb8019-e176-503f-9f51-3d97c6f53ef2"><grammatical-info value="Verb"/><gloss lang="en"><text>shaking, shock</text></gloss></sense></entry>
<entry id="gugur" guid="ecb07b83-9aab-5b42-a6d1-f35ef048f213"><lexical-unit><form lang="id"><text>gugur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gugur_0" guid="fde199e5-e8d8-5f4c-b4fa-abb837aa3723"><grammatical-info value="Verb"/><gloss lang="en"><text>to fall</text></gloss></sense><sense id="gugur_1" guid="c44cdad0-8ab1-565f-9ab2-1ecf34f5729b"><grammatical-info value="Verb"/><gloss lang="en"><text>to be moved downwards</text></gloss></sense><sense id="gugur_2" guid="1819fb48-27fb-5042-aee9-7c0eed7bc2d7"><grammatical-info value="Verb"/><gloss lang="en"><text>to move downwards</text></gloss></sense><sense id="gugur_3" guid="06522012-5a92-5586-8546-d196177e49d1"><grammatical-info value="Verb"/><gloss lang="en"><text>to collapse; to be overthrown or defeated</text></gloss></sense><sense id="gugur_4" guid="fe240fa5-c1ff-52da-a4bb-9466870cb9a3"><grammatical-info value="Verb"/><gloss lang="en"><text>to perish, to succumb; to die, especially in battle or by disease</text></gloss></sense><sense id="gugur_5" guid="b2154488-446b-5a94-9b54-e1b3026fd0f7"><grammatical-info value="Verb"/><gloss lang="en"><text>to be born prematurely</text></gloss></sense><sense id="gugur_6" guid="5cd7ce9f-0340-595e-b53f-f7fdee8ef433"><grammatical-info value="Verb"/><gloss lang="en"><text>to be null and void, to fail, to lapse</text></gloss></sense><sense id="gugur_7" guid="e94d3f7a-dc28-5ccc-bc53-3f7f3fc37881"><grammatical-info value="Verb"/><gloss lang="en"><text>to be eliminated</text></gloss></sense></entry>
<entry id="guling" guid="2290cc07-39c8-54dd-997c-18be4a9563d8"><lexical-unit><form lang="id"><text>guling</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="guling_0" guid="a64d3cad-fbb2-5150-b483-690358ba1913"><grammatical-info value="Verb"/><gloss lang="en"><text>roll</text></gloss></sense><sense id="guling_1" guid="15392351-216e-5bd9-8aed-0a5a0f634bb2"><grammatical-info value="Verb"/><gloss lang="en"><text>bolster</text></gloss></sense><sense id="guling_2" guid="793b07d0-4ebf-5e3d-8d4b-d1501761b58d"><grammatical-info value="Verb"/><gloss lang="en"><text>dishes that are completely grilled</text></gloss></sense><sense id="guling_3" guid="8a28e94d-0aee-5950-ae0e-966463de8233"><grammatical-info value="Verb"/><gloss lang="en"><text>the movement of an object on a surface in translation and rotation at the same time</text></gloss></sense><sense id="guling_4" guid="60bde877-2715-59ce-bcf6-f34d7f81682d"><grammatical-info value="Verb"/><gloss lang="en"><text>to roll</text></gloss></sense><sense id="guling_5" guid="f9192abd-bef1-52f4-814a-5b8b829b5acc"><grammatical-info value="Verb"/><gloss lang="en"><text>to overthrow (of governments etc)</text></gloss></sense></entry>
<entry id="gulung" guid="71bb467a-0f6d-564a-8c95-aa1dd1232dc7"><lexical-unit><form lang="id"><text>gulung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gulung_0" guid="aef47ad7-a904-58a7-b699-54755b6631c1"><grammatical-info value="Verb"/><gloss lang="en"><text>roll</text></gloss></sense><sense id="gulung_1" guid="2c0e9974-1458-5d34-8ecb-2b0709cb32f2"><grammatical-info value="Verb"/><gloss lang="en"><text>a snack made from sticky rice, wrapped in banana leaves or sugar cane leaves, usually eaten with grated coconut and kinca</text></gloss></sense></entry>
<entry id="gumpal" guid="52c6a1c9-1aa9-589d-8132-9f13f1c68ef1"><lexical-unit><form lang="id"><text>gumpal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gumpal_0" guid="911b63c5-afbc-5215-a3a6-94364ec010f5"><grammatical-info value="Noun"/><gloss lang="en"><text>clod, lump</text></gloss></sense><sense id="gumpal_1" guid="69275b86-cbc8-593f-ad00-e63a65cf7fa6"><grammatical-info value="Noun"/><gloss lang="en"><text>a snack made from mashed steamed cassava, mixed with grated coconut, sugar, salt and vanilla, shaped into balls the size of a fist, then dipped in flour batter, then fried</text></gloss></sense></entry>
<entry id="gumul" guid="24dd3e32-feb5-5368-bc1b-c30467788dd1"><lexical-unit><form lang="id"><text>gumul</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gumul_0" guid="bf0ad5e3-0d10-593b-b943-baf8b7dbd4f0"><grammatical-info value="Verb"/><gloss lang="en"><text>heavily</text></gloss></sense></entry>
