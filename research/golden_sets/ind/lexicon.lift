<entry id="membalas" guid="fd483931-3c9d-501d-86a5-f618134cad5c"><lexical-unit><form lang="id"><text>membalas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="membalas_0" guid="79ce919f-fd08-5bd9-bf79-59755c9e9aa8"><grammatical-info value="Verb"/><gloss lang="en"><text>to respond, to reply</text></gloss></sense><sense id="membalas_1" guid="8180e7f4-a322-51a4-b036-35c9368720b4"><grammatical-info value="Verb"/><gloss lang="en"><text>to repay, to reciprocate</text></gloss></sense><sense id="membalas_2" guid="1acdc000-3bc2-5ca5-9d9a-3532adf57faf"><grammatical-info value="Verb"/><gloss lang="en"><text>to retaliate, to counter</text></gloss></sense><sense id="membalas_3" guid="0b03ce32-6c51-57e9-915e-796e0146d328"><grammatical-info value="Verb"/><gloss lang="en"><text>to countersteer; steering (a vehicle) in the opposite direction at the beginning of a turn, in order to adjust the rider's center of gravity.</text></gloss></sense></entry>
<entry id="membalik" guid="af1b8e94-b88c-5640-b729-63e7c17b0776"><lexical-unit><form lang="id"><text>membalik</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="membalik_0" guid="2643a3d5-ed04-526c-b575-9e3dd813f88b"><grammatical-info value="Verb"/><gloss lang="en"><text>to rebound, to ricochet, to bound back, to strike back.</text></gloss></sense><sense id="membalik_1" guid="b235e3fe-ea4e-5799-aa19-3eff66df7c0b"><grammatical-info value="Verb"/><gloss lang="en"><text>to change position, to turn.</text></gloss></sense><sense id="membalik_2" guid="d960c3f1-d5cd-53ea-8e1d-46b2826a64e3"><grammatical-info value="Verb"/><gloss lang="en"><text>to reverse, to turn in the opposite direction</text></gloss></sense><sense id="membalik_3" guid="e9e67f07-f6e7-58fd-b29f-76a46d64a754"><grammatical-info value="Verb"/><gloss lang="en"><text>to alter/change direction.</text></gloss></sense><sense id="membalik_4" guid="48ec39ee-3757-5f40-a2ca-27c24e3856a1"><grammatical-info value="Verb"/><gloss lang="en"><text>to contradict one's self.</text></gloss></sense><sense id="membalik_5" guid="786f6321-64f1-5be4-99bd-983a115df000"><grammatical-info value="Verb"/><gloss lang="en"><text>to turn something over.</text></gloss></sense><sense id="membalik_6" guid="d29a9e4e-9afb-5c8f-a66c-cc978eaa8655"><grammatical-info value="Verb"/><gloss lang="en"><text>to flip</text></gloss></sense><sense id="membalik_7" guid="eb6acc55-f5e7-55b9-870a-269a29b58d6f"><grammatical-info value="Verb"/><gloss lang="en"><text>to capsize</text></gloss></sense></entry>
