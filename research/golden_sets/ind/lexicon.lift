<entry id="rama" guid="9f45e175-9f06-5519-bacd-d65cb63b0d27"><lexical-unit><form lang="id"><text>rama</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="rama_0" guid="91236919-ed54-5f48-8445-42ea36325308"><grammatical-info value="Proper noun"/><gloss lang="en"><text>father</text></gloss></sense><sense id="rama_1" guid="a0cd9225-e066-5426-8359-80f2c1792930"><grammatical-info value="Proper noun"/><gloss lang="en"><text>title conferred on an adult male</text></gloss></sense><sense id="rama_2" guid="d18a6951-9611-5efd-8ec0-acb8e45ea46a"><grammatical-info value="Proper noun"/><gloss lang="en"><text>priest</text></gloss></sense></entry>
