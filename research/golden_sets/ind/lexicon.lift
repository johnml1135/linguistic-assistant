<entry id="sa" guid="b094727d-c185-5c5a-8c99-bdea4b0f4960"><lexical-unit><form lang="id"><text>sa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sa_0" guid="cb328ddf-a269-5e3a-a573-630deb5e1597"><grammatical-info value="Proper noun"/><gloss lang="en"><text>apocopic form of saja</text></gloss></sense><sense id="sa_1" guid="e08567cd-777c-50d9-9dee-a639897afbb1"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a pile of coral reefs that looks like a mountain and is located in the middle of the sea</text></gloss></sense><sense id="sa_2" guid="003e014b-b163-5041-818b-71dc9cf3c4ff"><grammatical-info value="Proper noun"/><gloss lang="en"><text>abbreviation of satuan astronomi</text></gloss></sense></entry>
<entry id="saat" guid="28a7cfac-b0d9-5c0a-9ea0-cd96a96d79ed"><lexical-unit><form lang="id"><text>saat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="saat_0" guid="74ecb488-0dab-5333-9622-46f585f38a90"><grammatical-info value="Noun"/><gloss lang="en"><text>moment, (point in) time</text></gloss></sense><sense id="saat_1" guid="aca8a7ff-d2ba-5a1b-a675-ce946136b7e1"><grammatical-info value="Noun"/><gloss lang="en"><text>moment, time</text></gloss></sense><sense id="saat_2" guid="1f5b03cf-540d-526f-ad52-bad159ea3db9"><grammatical-info value="Noun"/><gloss lang="en"><text>when, while, or referring to an occurrence that happened in the past</text></gloss></sense><sense id="saat_3" guid="d1927a15-12ce-5ffb-b3c8-b60f4f4b6e18"><grammatical-info value="Noun"/><gloss lang="en"><text>during</text></gloss></sense></entry>
