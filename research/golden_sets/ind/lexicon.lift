<entry id="memilih" guid="2f1a8126-d491-5a88-9706-5930429d3235"><lexical-unit><form lang="id"><text>memilih</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="memilih_0" guid="46186d13-db78-5106-abda-430bb595edd6"><grammatical-info value="Verb"/><gloss lang="en"><text>to choose (to pick; to make the choice)</text></gloss></sense><sense id="memilih_1" guid="5547b357-efd2-504e-a177-75135796ad63"><grammatical-info value="Verb"/><gloss lang="en"><text>to choose (to elect)</text></gloss></sense></entry>
