<entry id="bayi" guid="8ec93d7c-1dfe-5947-a27e-ec503ab0fc95"><lexical-unit><form lang="id"><text>bayi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bayi_0" guid="1b3a6a98-814d-5bc5-bc0c-7695a8eb3c2f"><grammatical-info value="Noun"/><gloss lang="en"><text>baby (young human being)</text></gloss></sense><sense id="bayi_1" guid="94bb237f-5115-5cfa-8e63-4aa7ad7c7f00"><grammatical-info value="Noun"/><gloss lang="en"><text>infant</text></gloss></sense><sense id="bayi_2" guid="ae1c1ac4-f817-511d-8b5b-826176bc93bb"><grammatical-info value="Noun"/><gloss lang="en"><text>holes to support the mast foundation on a boat</text></gloss></sense></entry>
<entry id="be" guid="4f9bad60-e252-527a-b2b5-61c1622b9c0d"><lexical-unit><form lang="id"><text>be</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="be_0" guid="cb8cd23e-0e52-52eb-8078-f858af1be108"><grammatical-info value="Proper noun"/><gloss lang="en"><text>The name of the Latin script letter B/b.</text></gloss></sense></entry>
<entry id="bea" guid="c974119c-a0e5-5bf0-90d6-4cdd208374c5"><lexical-unit><form lang="id"><text>bea</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bea_0" guid="58a4d537-b887-5fc0-b102-cb85ca7cf18b"><grammatical-info value="Proper noun"/><gloss lang="en"><text>tax, custom duty</text></gloss></sense><sense id="bea_1" guid="d5e692b5-2545-5b39-9962-7fb941aa5a6a"><grammatical-info value="Proper noun"/><gloss lang="en"><text>customs: the duties or taxes imposed on imported or exported goods</text></gloss></sense><sense id="bea_2" guid="43204052-26ac-5b44-ae69-52590c66d1d2"><grammatical-info value="Proper noun"/><gloss lang="en"><text>expense</text></gloss></sense></entry>
<entry id="beban" guid="2f666da9-79f5-547a-9487-fde0d91000d9"><lexical-unit><form lang="id"><text>beban</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="beban_0" guid="96765f30-5902-5f4c-b222-bcfe6df6f556"><grammatical-info value="Noun"/><gloss lang="en"><text>load:</text></gloss></sense><sense id="beban_1" guid="0dfe611e-043f-5c24-bc69-4e84bdf4802f"><grammatical-info value="Noun"/><gloss lang="en"><text>a burden; a weight to be carried</text></gloss></sense><sense id="beban_2" guid="ccdc250f-1483-5059-8366-6c3748817113"><grammatical-info value="Noun"/><gloss lang="en"><text>the force exerted on a structural component such as a beam, girder, cable etc.</text></gloss></sense><sense id="beban_3" guid="3c0c8715-48de-5ae8-ad31-6ffeb1022ed8"><grammatical-info value="Noun"/><gloss lang="en"><text>the electrical current or power delivered by a device</text></gloss></sense><sense id="beban_4" guid="f8ed80fe-24c4-540a-bebc-5f7046fc8d54"><grammatical-info value="Noun"/><gloss lang="en"><text>any component that draws current or power from an electrical circuit</text></gloss></sense><sense id="beban_5" guid="2dcc2506-687c-5cde-af9e-b5c8b38df2b7"><grammatical-info value="Noun"/><gloss lang="en"><text>the process of loading something, i.e. transferring it into memory or over a network, etc.</text></gloss></sense><sense id="beban_6" guid="ffc1d043-2997-5508-a00d-aae3dd8c9450"><grammatical-info value="Noun"/><gloss lang="en"><text>burden:</text></gloss></sense><sense id="beban_7" guid="88f0e617-a8d4-5ac9-b0ba-bb9c433ee228"><grammatical-info value="Noun"/><gloss lang="en"><text>the total indirect costs—such as taxes, benefits, insurance, and overhead—added to direct expenses like base wages or raw materials.</text></gloss></sense></entry>
<entry id="bebas" guid="ff841de0-d4bc-5bc7-81b8-4abbc14c1a72"><lexical-unit><form lang="id"><text>bebas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bebas_0" guid="6def33a3-2704-503f-bb10-26430b1997ea"><grammatical-info value="Adjective"/><gloss lang="en"><text>free (not imprisoned)</text></gloss></sense><sense id="bebas_1" guid="e3c19e5f-1be5-52c1-b17d-318394b586ba"><grammatical-info value="Adjective"/><gloss lang="en"><text>free (unconstrained)</text></gloss></sense><sense id="bebas_2" guid="fd6fa9e4-2646-515d-aed6-b4dde797c54c"><grammatical-info value="Adjective"/><gloss lang="en"><text>free (without obligations)</text></gloss></sense><sense id="bebas_3" guid="fc8e6314-0b26-569f-affe-c6597a9b73ba"><grammatical-info value="Adjective"/><gloss lang="en"><text>free, libre (with very few limitations on distribution or improvement)</text></gloss></sense><sense id="bebas_4" guid="771d17b9-d882-5c4d-9cbc-992a072dda53"><grammatical-info value="Adjective"/><gloss lang="en"><text>free, independent</text></gloss></sense><sense id="bebas_5" guid="702f3720-3785-591b-8504-5115f4c118a7"><grammatical-info value="Adjective"/><gloss lang="en"><text>acquitted, discharged, dismissed, released</text></gloss></sense><sense id="bebas_6" guid="f2853a9d-e768-503a-812d-ca30f3b62c4d"><grammatical-info value="Adjective"/><gloss lang="en"><text>land in a forest that has been cleared for timber</text></gloss></sense></entry>
<entry id="beberapa" guid="03cb57e1-38c6-5676-9307-80875895839a"><lexical-unit><form lang="id"><text>beberapa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="beberapa_0" guid="71fff8cd-0726-5669-98d6-567fa99ca592"><grammatical-info value="Determiner"/><gloss lang="en"><text>any, some, several, certain, few, various, divers</text></gloss></sense><sense id="beberapa_1" guid="bf2aff91-d5fd-5b9d-8ea8-446e927659d1"><grammatical-info value="Determiner"/><gloss lang="en"><text>a few</text></gloss></sense><sense id="beberapa_2" guid="02bb89d0-380c-5eaa-87a1-54464debc991"><grammatical-info value="Determiner"/><gloss lang="en"><text>some</text></gloss></sense></entry>
