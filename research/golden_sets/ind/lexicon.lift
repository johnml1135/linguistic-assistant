<entry id="sapa" guid="e0763118-316d-5a67-8079-83f635c77c46"><lexical-unit><form lang="id"><text>sapa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sapa_0" guid="af2b29e5-9c6d-51b7-a2ae-81b7eff81b4e"><grammatical-info value="Verb"/><gloss lang="en"><text>greeting</text></gloss></sense><sense id="sapa_1" guid="9df94080-ae0c-547f-8721-00b2c555af0b"><grammatical-info value="Verb"/><gloss lang="en"><text>who</text></gloss></sense><sense id="sapa_2" guid="2f4cc64b-1a22-5a73-887a-3b861a4d65b8"><grammatical-info value="Verb"/><gloss lang="en"><text>nonstandard form of safa (“white”)</text></gloss></sense></entry>
<entry id="sapu" guid="adb64968-5cf6-5648-bb8a-b9b9349bb237"><lexical-unit><form lang="id"><text>sapu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sapu_0" guid="7a0aa48d-5aa5-562c-973b-ed18d281af33"><grammatical-info value="Verb"/><gloss lang="en"><text>broom</text></gloss></sense><sense id="sapu_1" guid="370ea7f6-5189-52de-9ac9-d6268b15eab5"><grammatical-info value="Verb"/><gloss lang="en"><text>to sweep</text></gloss></sense></entry>
<entry id="sar" guid="09ecc20d-52d5-518b-b843-5d576933b820"><lexical-unit><form lang="id"><text>sar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sar_0" guid="f4b71545-2f7d-5e1c-a303-2b42794abb93"><grammatical-info value="Noun"/><gloss lang="en"><text>abbreviation of search and rescue</text></gloss></sense></entry>
<entry id="sara" guid="3e0b95a7-5922-5589-b460-66552d6262ec"><lexical-unit><form lang="id"><text>sara</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sara_0" guid="5d5d1b97-b245-557c-9abc-da65dc812c95"><grammatical-info value="Proper noun"/><gloss lang="en"><text>life support, sustenance, subsistence</text></gloss></sense><sense id="sara_1" guid="4a2a3dd6-d3f6-5426-acd1-ffce1c16572b"><grammatical-info value="Proper noun"/><gloss lang="en"><text>subsistence money</text></gloss></sense><sense id="sara_2" guid="03863187-6fda-5f04-95a9-d6247cac17c3"><grammatical-info value="Proper noun"/><gloss lang="en"><text>pension: an annuity paid regularly as benefit due to a retired employee, serviceman etc. in consideration of past services, originally and chiefly by a government but also by various private pension schemes</text></gloss></sense><sense id="sara_3" guid="0236c1b3-1bdd-5269-90a6-5e4d7be21d80"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to ask for suggestion</text></gloss></sense><sense id="sara_4" guid="81f0d888-bde2-5315-9a9a-7baf08b9a2a6"><grammatical-info value="Proper noun"/><gloss lang="en"><text>dry rice with no contents</text></gloss></sense><sense id="sara_5" guid="a67360c9-d766-5e3d-aaec-77961754c348"><grammatical-info value="Proper noun"/><gloss lang="en"><text>acronym of suku, agama, ras, dan antar-golongan (“ethnicity, religion, race and inter-group”), discrimination based on ethnic, religious, racial or other group affiliation</text></gloss></sense></entry>
<entry id="sarah" guid="75c0493d-1042-5695-b2d3-5c18eac1318f"><lexical-unit><form lang="id"><text>sarah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sarah_0" guid="e8984f78-73b6-5822-81b2-81796ecfa276"><grammatical-info value="Proper noun"/><gloss lang="en"><text>flotsam (debris floating in a river or sea, in particular fragments from a shipwreck)</text></gloss></sense><sense id="sarah_1" guid="400dad8d-78f8-5825-9520-c1e96a46bae7"><grammatical-info value="Proper noun"/><gloss lang="en"><text>synonym of peti (“chest”)</text></gloss></sense><sense id="sarah_2" guid="ff6945b2-e360-58f8-8a1d-7630d4843154"><grammatical-info value="Proper noun"/><gloss lang="en"><text>synonym of tong (“barrel”)</text></gloss></sense></entry>
<entry id="sarang" guid="0e81d6e2-5100-5cd6-9fbf-5ec13f6a7530"><lexical-unit><form lang="id"><text>sarang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sarang_0" guid="9c9c15f2-27dc-582b-a422-de423fd83cc2"><grammatical-info value="Noun"/><gloss lang="en"><text>nest</text></gloss></sense><sense id="sarang_1" guid="f5e084ea-f15c-5c2c-a628-c5a06e9ea69c"><grammatical-info value="Noun"/><gloss lang="en"><text>den</text></gloss></sense><sense id="sarang_2" guid="21254779-cdc0-5996-992b-a41a2143d2c0"><grammatical-info value="Noun"/><gloss lang="en"><text>sheath</text></gloss></sense><sense id="sarang_3" guid="a5efddd6-dbfe-5b23-ba83-df61b302f65e"><grammatical-info value="Noun"/><gloss lang="en"><text>the science of holding back or delaying rain</text></gloss></sense></entry>
<entry id="saring" guid="c60fc57d-9f87-5c8c-bd1a-c985ca4c7791"><lexical-unit><form lang="id"><text>saring</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="saring_0" guid="2f0c0599-97d4-567c-8741-f70412d7d646"><grammatical-info value="Verb"/><gloss lang="en"><text>to filter</text></gloss></sense></entry>
<entry id="sarung" guid="ee86cfee-5159-543b-9abb-906e0fba977f"><lexical-unit><form lang="id"><text>sarung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sarung_0" guid="da7db995-d786-5283-979a-026c75bf3666"><grammatical-info value="Noun"/><gloss lang="en"><text>sarong (garment made of printed cloth wrapped about the waist)</text></gloss></sense><sense id="sarung_1" guid="c30d011b-a2ed-5c0f-80b1-5ec30796203c"><grammatical-info value="Noun"/><gloss lang="en"><text>sheath (tight-fitting dress)</text></gloss></sense><sense id="sarung_2" guid="bf2ccfd3-3e4f-5ad2-aa44-23a053ef3630"><grammatical-info value="Noun"/><gloss lang="en"><text>condom</text></gloss></sense><sense id="sarung_3" guid="85a6dd66-b72a-5f8d-86bb-c1d0b5be8b30"><grammatical-info value="Noun"/><gloss lang="en"><text>ikat weaving where the base and ends are sewn together</text></gloss></sense><sense id="sarung_4" guid="fd2f6af7-e202-5e67-bc4b-a82a009b97fe"><grammatical-info value="Noun"/><gloss lang="en"><text>to sheathe</text></gloss></sense><sense id="sarung_5" guid="d421edd8-461f-53c7-a46c-b2292d3eeca9"><grammatical-info value="Noun"/><gloss lang="en"><text>to interrupt, to intrude.</text></gloss></sense></entry>
