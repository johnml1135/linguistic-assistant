<entry id="bohong" guid="cf730fff-fb65-5a7f-9030-099fa27dcfd3"><lexical-unit><form lang="id"><text>bohong</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bohong_0" guid="2708ded0-a5c4-5ef6-841a-5ee4f89009de"><grammatical-info value="Verb"/><gloss lang="en"><text>not in line with reality and truth; untrue, fraudulent, deceptive, lying</text></gloss></sense><sense id="bohong_1" guid="cb3ab466-410b-5213-af9f-c51c0cbb6c16"><grammatical-info value="Verb"/><gloss lang="en"><text>not the real thing; fake, counterfeit (often about games, toys, etc.)</text></gloss></sense></entry>
<entry id="boleh" guid="7a205c65-00cf-591f-b2ee-8e301da10d5f"><lexical-unit><form lang="id"><text>boleh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="boleh_0" guid="e39a83c8-3261-52e0-be19-8b3d20a5ad85"><grammatical-info value="Verb"/><gloss lang="en"><text>may (to have permission to, be allowed. used in granting permission and in a question to make a polite request)</text></gloss></sense><sense id="boleh_1" guid="eafb13b9-49cc-5ff4-a28c-50f60519f7b9"><grammatical-info value="Verb"/><gloss lang="en"><text>can</text></gloss></sense><sense id="boleh_2" guid="0ee92506-8777-5915-a9a3-edec6ca0296c"><grammatical-info value="Verb"/><gloss lang="en"><text>to be permitted or enabled to</text></gloss></sense><sense id="boleh_3" guid="38717745-78e2-5b6a-b8b9-db64330334f2"><grammatical-info value="Verb"/><gloss lang="en"><text>to know how to; to be able to</text></gloss></sense><sense id="boleh_4" guid="06a713ae-b3b4-510b-acd8-16a806c0f567"><grammatical-info value="Verb"/><gloss lang="en"><text>to have the potential to; be possible</text></gloss></sense></entry>
<entry id="bolong" guid="43107dd9-3e90-5948-9b41-2c84e2047cad"><lexical-unit><form lang="id"><text>bolong</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bolong_0" guid="b384167b-71a9-5dec-8fb9-6c87ebbd7133"><grammatical-info value="Verb"/><gloss lang="en"><text>perforated</text></gloss></sense></entry>
