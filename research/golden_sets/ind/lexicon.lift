<entry id="kidung" guid="2baf0fd3-5dd9-53ca-aa20-f3357c4f041e"><lexical-unit><form lang="id"><text>kidung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kidung_0" guid="93bbe786-e6c9-58f7-942f-19cb56426a86"><grammatical-info value="Noun"/><gloss lang="en"><text>poem, poetic work</text></gloss></sense><sense id="kidung_1" guid="4db3b706-f43d-55a4-ad64-6c4cc18f4bf6"><grammatical-info value="Noun"/><gloss lang="en"><text>song</text></gloss></sense><sense id="kidung_2" guid="1dacb99f-38e7-535b-ae9b-ee1eb1e98132"><grammatical-info value="Noun"/><gloss lang="en"><text>ballad, chant, lullaby, melody</text></gloss></sense></entry>
