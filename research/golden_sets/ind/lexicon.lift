<entry id="mengutuk" guid="6d1a69e1-1f0f-565a-95cc-53b055226f1c"><lexical-unit><form lang="id"><text>mengutuk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mengutuk_0" guid="2e2fa7da-f69f-5f4b-ac75-31fb9fba63b4"><grammatical-info value="Verb"/><gloss lang="en"><text>active of kutuk</text></gloss></sense></entry>
<entry id="menikah" guid="843c74eb-9bf9-5df1-b306-03b7091948bd"><lexical-unit><form lang="id"><text>menikah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="menikah_0" guid="3b685d42-51c7-5dd7-b5d5-9e0af6cb7a50"><grammatical-info value="Verb"/><gloss lang="en"><text>to be married, to marry</text></gloss></sense></entry>
