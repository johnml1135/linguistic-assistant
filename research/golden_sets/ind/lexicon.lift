<entry id="bongkar" guid="c4a8e330-5383-5ce7-bcf3-7564f021f627"><lexical-unit><form lang="id"><text>bongkar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bongkar_0" guid="be5931e4-5318-5245-9601-1ccc44ba1d22"><grammatical-info value="Noun"/><gloss lang="en"><text>only used in membongkar and other derivations.</text></gloss></sense><sense id="bongkar_1" guid="b4530e77-03db-5737-8e5c-3a263f2a2f33"><grammatical-info value="Noun"/><gloss lang="en"><text>synonym of membongkar</text></gloss></sense></entry>
