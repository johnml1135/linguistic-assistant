<entry id="salah" guid="186a95e3-4ed0-582c-af12-b83675a8f287"><lexical-unit><form lang="id"><text>salah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="salah_0" guid="004920c0-40ed-5d5a-8ba7-e14e2354c5c9"><grammatical-info value="Adjective"/><gloss lang="en"><text>false:</text></gloss></sense><sense id="salah_1" guid="33b92248-7b2b-5722-acb7-805c1a75d323"><grammatical-info value="Adjective"/><gloss lang="en"><text>untrue, not factual, factually incorrect</text></gloss></sense><sense id="salah_2" guid="6e407bb0-6efc-57fc-9192-f6188cc68061"><grammatical-info value="Adjective"/><gloss lang="en"><text>based on factually incorrect premises</text></gloss></sense><sense id="salah_3" guid="f392c741-a290-5dd9-b03b-0880b7591a09"><grammatical-info value="Adjective"/><gloss lang="en"><text>not well founded; not firm or trustworthy; erroneous</text></gloss></sense><sense id="salah_4" guid="fef7168c-f9ca-5452-bbf6-ee39b03faaf1"><grammatical-info value="Adjective"/><gloss lang="en"><text>mistaken, erroneous</text></gloss></sense><sense id="salah_5" guid="e2f831a5-3673-5d3d-bf71-2c8727b2eb0b"><grammatical-info value="Adjective"/><gloss lang="en"><text>improper</text></gloss></sense><sense id="salah_6" guid="e1cd7be6-04d5-5236-a660-4ad41aab64ac"><grammatical-info value="Adjective"/><gloss lang="en"><text>improper:</text></gloss></sense><sense id="salah_7" guid="69d2d56f-ea44-5ea5-af02-381ccf096dd8"><grammatical-info value="Adjective"/><gloss lang="en"><text>inappropriate; inapt</text></gloss></sense></entry>
<entry id="salam" guid="382fb6bf-ed79-55dd-ad63-f5bda097f6fd"><lexical-unit><form lang="id"><text>salam</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="salam_0" guid="db1e5b2d-3269-5d12-b8be-8d2e612555eb"><grammatical-info value="Proper noun"/><gloss lang="en"><text>peace</text></gloss></sense><sense id="salam_1" guid="e226e8a2-a8b2-5365-be3a-13b9a19d4d38"><grammatical-info value="Proper noun"/><gloss lang="en"><text>salaam alaikum (Muslim greeting)</text></gloss></sense><sense id="salam_2" guid="f5d39671-c8ae-58b3-bc77-ce184fe2e413"><grammatical-info value="Proper noun"/><gloss lang="en"><text>greeting</text></gloss></sense><sense id="salam_3" guid="c4196ce6-2731-5c34-a0b4-3c72ccf40e3e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>indian bay leaf (Syzygium polyanthum)</text></gloss></sense><sense id="salam_4" guid="9bb0a492-537f-55e0-bbe6-11db42cf63bd"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Malabar plum, Java plum (Syzygium cumini)</text></gloss></sense><sense id="salam_5" guid="c10deb53-6988-5886-b091-ca037ded8a23"><grammatical-info value="Proper noun"/><gloss lang="en"><text>futures contract</text></gloss></sense></entry>
