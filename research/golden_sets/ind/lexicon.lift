<entry id="mahkota" guid="50124618-e0e8-5ce7-8e3b-1e7f82ded07a"><lexical-unit><form lang="id"><text>mahkota</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mahkota_0" guid="dc39c918-3a9f-5fc0-a38f-71b72f049ba1"><grammatical-info value="Noun"/><gloss lang="en"><text>crown:</text></gloss></sense><sense id="mahkota_1" guid="40c05fdf-ef9a-5cd3-8285-6d79d0182789"><grammatical-info value="Noun"/><gloss lang="en"><text>diadem: a royal, imperial or princely headdress</text></gloss></sense><sense id="mahkota_2" guid="b5e0cabb-7d79-5b8e-82c4-971d1ac6bd28"><grammatical-info value="Noun"/><gloss lang="en"><text>king: the sovereign (in a monarchy), as head of state</text></gloss></sense><sense id="mahkota_3" guid="fc3db816-b79f-5868-9ed9-f9561bc025ec"><grammatical-info value="Noun"/><gloss lang="en"><text>imperial or regal power, or those who wield it</text></gloss></sense><sense id="mahkota_4" guid="3ee57d91-5b6b-5908-8802-56e3166c820b"><grammatical-info value="Noun"/><gloss lang="en"><text>treasure</text></gloss></sense><sense id="mahkota_5" guid="d835bc15-b0d0-5dee-b875-9c453712eadb"><grammatical-info value="Noun"/><gloss lang="en"><text>ellipsis of mahkota bunga (“petal, corolla”)</text></gloss></sense></entry>
<entry id="main" guid="10a80d1d-c304-531d-a013-0391a6db7c6c"><lexical-unit><form lang="id"><text>main</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="main_0" guid="d7841bd6-6022-5229-a881-0c1b2a1c0fde"><grammatical-info value="Verb"/><gloss lang="en"><text>to play</text></gloss></sense><sense id="main_1" guid="95d3cedb-493a-5203-9d8d-8622318199ce"><grammatical-info value="Verb"/><gloss lang="en"><text>unpromptedly (without prior notice; for no apparent reason)</text></gloss></sense></entry>
