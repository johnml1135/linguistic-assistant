<entry id="teras" guid="3491f6bb-de98-586f-bde0-f095575e537f"><lexical-unit><form lang="id"><text>teras</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="teras_0" guid="f924fa38-e280-5d76-bd94-b7c7371aca04"><grammatical-info value="Noun"/><gloss lang="en"><text>terrace (a platform that extends outwards from a building)</text></gloss></sense><sense id="teras_1" guid="8b055318-fa49-51d8-a8d2-ea4c35fd20b2"><grammatical-info value="Noun"/><gloss lang="en"><text>terrace (a raised, flat-topped bank of earth with sloping sides)</text></gloss></sense><sense id="teras_2" guid="e8e7881e-ff59-58bb-b8f2-0ee9be3e82ce"><grammatical-info value="Noun"/><gloss lang="en"><text>terrace (the roof of a building, especially if accessible to the residents)</text></gloss></sense><sense id="teras_3" guid="7c5daf15-b9a9-577d-a374-bb7d8f000b81"><grammatical-info value="Noun"/><gloss lang="en"><text>heart, pith (of wood)</text></gloss></sense><sense id="teras_4" guid="d4e35273-597f-5fa4-9baf-e315e0167a4d"><grammatical-info value="Noun"/><gloss lang="en"><text>essence</text></gloss></sense><sense id="teras_5" guid="05ddd80c-be00-56dd-8ea0-e3eb9e5b9c40"><grammatical-info value="Noun"/><gloss lang="en"><text>core (the inner part of a nuclear reactor)</text></gloss></sense><sense id="teras_6" guid="d5f0657f-9ff9-5eae-b224-037176340f6d"><grammatical-info value="Noun"/><gloss lang="en"><text>core (atomic nucleus plus inner/core electrons)</text></gloss></sense><sense id="teras_7" guid="1945c98d-32bb-539c-ac84-8169c3eae882"><grammatical-info value="Noun"/><gloss lang="en"><text>nonstandard form of tras (“trass”)</text></gloss></sense></entry>
