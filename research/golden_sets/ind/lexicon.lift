<entry id="menguntungkan" guid="fa0803a0-6b88-50a7-ae95-da486099c639"><lexical-unit><form lang="id"><text>menguntungkan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="menguntungkan_0" guid="7a439d0d-eb4f-548c-bc6f-ceeb6e20e346"><grammatical-info value="Verb"/><gloss lang="en"><text>sent</text></gloss></sense></entry>
<entry id="mengurapi" guid="df18e4bc-6370-5ef0-8d8e-1caea10860d1"><lexical-unit><form lang="id"><text>mengurapi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mengurapi_0" guid="2c7180e7-bb9e-5b2a-b532-eb69275c9ab2"><grammatical-info value="Verb"/><gloss lang="en"><text>to anoint</text></gloss></sense></entry>
