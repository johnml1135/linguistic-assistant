<entry id="atas" guid="4a40a941-cdb4-5649-8b1c-c141b3c89c77"><lexical-unit><form lang="id"><text>atas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="atas_0" guid="f7edea70-2fd4-5f40-a23e-c20f6e0ff040"><grammatical-info value="Adposition"/><gloss lang="en"><text>upstairs</text></gloss></sense><sense id="atas_1" guid="da7d258c-22b3-50cb-84fa-3058f0d8b86a"><grammatical-info value="Adposition"/><gloss lang="en"><text>on, upon, on top of</text></gloss></sense><sense id="atas_2" guid="fa718af6-68c0-51b9-9b9c-64452cbb452b"><grammatical-info value="Adposition"/><gloss lang="en"><text>upper, above</text></gloss></sense><sense id="atas_3" guid="77352b89-5661-5bff-b684-1321d8de9921"><grammatical-info value="Adposition"/><gloss lang="en"><text>in connection with, with reference to, regarding</text></gloss></sense><sense id="atas_4" guid="a2689035-3d28-5c27-9208-af39fbdc617a"><grammatical-info value="Adposition"/><gloss lang="en"><text>according to</text></gloss></sense><sense id="atas_5" guid="32bbff90-bb32-591f-a539-a55dc9f4b3bd"><grammatical-info value="Adposition"/><gloss lang="en"><text>of</text></gloss></sense><sense id="atas_6" guid="40024ae7-7412-5f70-a98c-c26396e6948b"><grammatical-info value="Adposition"/><gloss lang="en"><text>due to, because of</text></gloss></sense><sense id="atas_7" guid="32d26c50-0148-5d44-8c11-cabf8c0cf5f0"><grammatical-info value="Adposition"/><gloss lang="en"><text>about</text></gloss></sense></entry>
