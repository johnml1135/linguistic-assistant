<entry id="kelola" guid="33b58678-ba11-579a-a8ff-1e4456dc4fd9"><lexical-unit><form lang="id"><text>kelola</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kelola_0" guid="bdaaa2f5-5c76-5645-9871-7c7293cae414"><grammatical-info value="Verb"/><gloss lang="en"><text>to manage; to supervise; to organize</text></gloss></sense></entry>
<entry id="kelompok" guid="6e5e9e7b-a931-555a-8e87-2a09caffa0f3"><lexical-unit><form lang="id"><text>kelompok</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kelompok_0" guid="feb4f084-9f43-547a-9303-99ebc7c764ce"><grammatical-info value="Noun"/><gloss lang="en"><text>group, social group</text></gloss></sense><sense id="kelompok_1" guid="6fb86d45-5042-5e2d-b01e-f9f4731095c8"><grammatical-info value="Noun"/><gloss lang="en"><text>class, order, type</text></gloss></sense><sense id="kelompok_2" guid="e404f907-0622-52a9-8c7a-d0cfc26c8412"><grammatical-info value="Noun"/><gloss lang="en"><text>cluster</text></gloss></sense></entry>
<entry id="kelopak" guid="64313c3f-186e-5286-8223-19bfbb359431"><lexical-unit><form lang="id"><text>kelopak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kelopak_0" guid="5fdae3ce-d205-5512-9475-ab8a56b44c23"><grammatical-info value="Noun"/></sense></entry>
<entry id="keluar" guid="6aa513f2-615a-545e-b144-f1cdda35176b"><lexical-unit><form lang="id"><text>keluar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="keluar_0" guid="d08e1a91-6163-54b5-af05-5fbb22ea55a2"><grammatical-info value="Verb"/><gloss lang="en"><text>to go out, to get out, to exit</text></gloss></sense><sense id="keluar_1" guid="ab2c306e-519d-591f-8678-ec5be84d1a4c"><grammatical-info value="Verb"/><gloss lang="en"><text>to emerge, to show up</text></gloss></sense><sense id="keluar_2" guid="5fd98492-68de-5a39-aee8-2d0b9f7c5fb4"><grammatical-info value="Verb"/><gloss lang="en"><text>to be announced</text></gloss></sense><sense id="keluar_3" guid="207dc629-cb17-5f13-9a9a-c0fbcfbec4e4"><grammatical-info value="Verb"/><gloss lang="en"><text>to retire</text></gloss></sense><sense id="keluar_4" guid="45370048-b72c-5663-b2a4-d24739c8f98a"><grammatical-info value="Verb"/><gloss lang="en"><text>to take (s.th.) out</text></gloss></sense><sense id="keluar_5" guid="fac64b8a-0a6c-5a06-8c63-cf441098b504"><grammatical-info value="Verb"/><gloss lang="en"><text>to remove</text></gloss></sense><sense id="keluar_6" guid="8e852831-c427-5d0c-9920-baa79d23d377"><grammatical-info value="Verb"/><gloss lang="en"><text>to discharge (an employee)</text></gloss></sense><sense id="keluar_7" guid="e4824d50-3839-529b-a05a-82063b9247f9"><grammatical-info value="Verb"/><gloss lang="en"><text>to issue (a ticket etc.)</text></gloss></sense></entry>
<entry id="keluarga" guid="c90bf3c3-86fc-5a29-a6fb-e1f68eec7141"><lexical-unit><form lang="id"><text>keluarga</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="keluarga_0" guid="613a8a72-5516-52a9-af15-cc7bd45ada5a"><grammatical-info value="Noun"/><gloss lang="en"><text>family (immediate family as a group, or group of people related by blood, marriage, law, or custom)</text></gloss></sense><sense id="keluarga_1" guid="459a67e2-8aa5-52cd-ad5e-606a7a8c2607"><grammatical-info value="Noun"/><gloss lang="en"><text>family (any group or aggregation of things classed together with common characteristics)</text></gloss></sense><sense id="keluarga_2" guid="040842bf-50c4-5ee5-9cb8-c352085b782c"><grammatical-info value="Noun"/><gloss lang="en"><text>class (a collection of sets definable by a shared property)</text></gloss></sense></entry>
<entry id="keluarkan" guid="da74cdac-a005-5ce9-b0e7-d50f7f02e683"><lexical-unit><form lang="id"><text>keluarkan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="keluarkan_0" guid="88729e1d-22ca-5286-84bf-6a78776228ce"><grammatical-info value="Verb"/><gloss lang="en"><text>to remove, take out (to move from one place to another, especially to take away)</text></gloss></sense><sense id="keluarkan_1" guid="c82233ca-0b2c-5876-b0d3-e55eab31288b"><grammatical-info value="Verb"/><gloss lang="en"><text>to tell, express</text></gloss></sense><sense id="keluarkan_2" guid="23ae044a-fe6e-5cab-a6d1-dfd346bc93e0"><grammatical-info value="Verb"/><gloss lang="en"><text>to issue (to send out; to put into circulation)</text></gloss></sense><sense id="keluarkan_3" guid="90a67aeb-10bf-5e81-be28-af489813829c"><grammatical-info value="Verb"/><gloss lang="en"><text>to issue (to deliver by authority)</text></gloss></sense><sense id="keluarkan_4" guid="16ddd2e3-6465-563f-bb87-f64c5c714702"><grammatical-info value="Verb"/><gloss lang="en"><text>to spend (to pay out)</text></gloss></sense><sense id="keluarkan_5" guid="e9a800e7-3cb5-5f6a-9dd7-b59e81ca7faf"><grammatical-info value="Verb"/><gloss lang="en"><text>to provide (to give what is needed or desired)</text></gloss></sense><sense id="keluarkan_6" guid="24d86174-6590-5b91-b011-d82a083d2526"><grammatical-info value="Verb"/><gloss lang="en"><text>to release (to make available to the public)</text></gloss></sense><sense id="keluarkan_7" guid="ba7427e8-498e-5b95-b420-4db2ff678c69"><grammatical-info value="Verb"/><gloss lang="en"><text>to export (to sell goods to a foreign country)</text></gloss></sense></entry>
<entry id="keluh" guid="6793ac09-99ac-55a0-9523-ff9dbabf4958"><lexical-unit><form lang="id"><text>keluh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="keluh_0" guid="32205a27-8cfd-5f78-97aa-17f45610d34b"><grammatical-info value="Verb"/><gloss lang="en"><text>sigh</text></gloss></sense><sense id="keluh_1" guid="a2f452dc-c7b2-5175-a337-6e2f9f9773ba"><grammatical-info value="Verb"/><gloss lang="en"><text>lament, lamentation</text></gloss></sense><sense id="keluh_2" guid="df5f2d35-28f8-5354-a0f4-2494a17d5eb7"><grammatical-info value="Verb"/><gloss lang="en"><text>complaint</text></gloss></sense></entry>
<entry id="kemana" guid="2bd88614-0bf9-5d6f-b088-c4cd59ecd2b4"><lexical-unit><form lang="id"><text>kemana</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kemana_0" guid="317f5b41-0227-5e58-a58b-26694102794b"><grammatical-info value="Adverb"/><gloss lang="en"><text>wherever</text></gloss></sense></entry>
<entry id="kemarahan" guid="8bd35e24-124f-5df8-97db-b1323d46fbdd"><lexical-unit><form lang="id"><text>kemarahan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kemarahan_0" guid="69b78145-3ad0-52ed-81ec-01ee4b7e17bf"><grammatical-info value="Noun"/><gloss lang="en"><text>anger</text></gloss></sense></entry>
<entry id="kemarin" guid="7e895c80-573e-5dcb-aba4-fac24ece7663"><lexical-unit><form lang="id"><text>kemarin</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kemarin_0" guid="66dffaab-66bb-53c6-892e-e74e78839af8"><grammatical-info value="Noun"/><gloss lang="en"><text>yesterday (the day immediately before today; one day ago)</text></gloss></sense><sense id="kemarin_1" guid="a1515149-d3de-5d81-9aea-de4934d0eecb"><grammatical-info value="Noun"/><gloss lang="en"><text>yesterday (the recent past)</text></gloss></sense><sense id="kemarin_2" guid="c6a31d62-79bc-58c4-b634-875d2704a8b8"><grammatical-info value="Noun"/><gloss lang="en"><text>yesterday (on the day before today)</text></gloss></sense><sense id="kemarin_3" guid="81b39aa8-c718-5bd6-9cd6-ee12dc4f7ca1"><grammatical-info value="Noun"/><gloss lang="en"><text>last, previous</text></gloss></sense></entry>
<entry id="kematian" guid="77ec06d5-b836-5f07-8c15-0ea3d8a4b102"><lexical-unit><form lang="id"><text>kematian</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kematian_0" guid="156d4cfb-c4bb-5fbc-bda3-49930de4bbbc"><grammatical-info value="Noun"/><gloss lang="en"><text>death</text></gloss></sense><sense id="kematian_1" guid="1801a805-d58c-5597-87ad-00dcfcc2b9fa"><grammatical-info value="Noun"/><gloss lang="en"><text>the cessation of life and all associated processes; the end of an organism's existence as an entity independent from its environment and its return to an inert, nonliving state</text></gloss></sense><sense id="kematian_2" guid="ed29f8e6-6be2-586f-8531-43d8ffdb254d"><grammatical-info value="Noun"/><gloss lang="en"><text>the collapse or end of something</text></gloss></sense><sense id="kematian_3" guid="7b7c0a39-0a20-5ad1-820b-e0802366f763"><grammatical-info value="Noun"/><gloss lang="en"><text>to suffer because of someone's death</text></gloss></sense></entry>
<entry id="kemauan" guid="c2f4a295-e557-55d3-a183-ed4927843fa8"><lexical-unit><form lang="id"><text>kemauan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kemauan_0" guid="4ed3fd8d-b03f-5228-9052-77f7a6d415ad"><grammatical-info value="Noun"/><gloss lang="en"><text>synonym of keinginan (“wish; desire”)</text></gloss></sense></entry>
<entry id="kembali" guid="33bd67e0-b5bc-5d1b-84e4-5186887f0494"><lexical-unit><form lang="id"><text>kembali</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kembali_0" guid="fe68f850-f195-5a74-80c7-12a08366d1c6"><grammatical-info value="Verb"/><gloss lang="en"><text>to return (from a place to a place)</text></gloss></sense><sense id="kembali_1" guid="16d5f751-93e2-5935-b3bd-d5eb1d83fb1e"><grammatical-info value="Verb"/><gloss lang="en"><text>to repeat</text></gloss></sense><sense id="kembali_2" guid="2626148a-a372-5357-8dc4-763f18e4897e"><grammatical-info value="Verb"/><gloss lang="en"><text>again; once more</text></gloss></sense></entry>
<entry id="kembang" guid="17b93a2b-c225-5d91-b5d2-b9c5035849ab"><lexical-unit><form lang="id"><text>kembang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kembang_0" guid="b542f38a-e39f-5f9e-814b-e735aecf0c56"><grammatical-info value="Proper noun"/><gloss lang="en"><text>flower (reproductive structure in angiosperms)</text></gloss></sense><sense id="kembang_1" guid="d9743086-9737-5d38-85ef-bf208942d73f"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to bloom</text></gloss></sense></entry>
<entry id="kembar" guid="bb3c675c-a7db-57d2-950d-99199589c867"><lexical-unit><form lang="id"><text>kembar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kembar_0" guid="154df0e4-0e4e-5f23-b197-96ba1bb15dbe"><grammatical-info value="Noun"/><gloss lang="en"><text>twin (either of two people who shared the same uterus, or of two similar or closely related objects)</text></gloss></sense><sense id="kembar_1" guid="441c5691-e602-506d-9cb6-8df5aa570d45"><grammatical-info value="Noun"/><gloss lang="en"><text>similar, alike, comparable</text></gloss></sense><sense id="kembar_2" guid="4d2f20e9-4065-5085-9dd9-e51fb33ac7fd"><grammatical-info value="Noun"/><gloss lang="en"><text>copy: the result of copying; an identical duplicate of an original</text></gloss></sense></entry>
<entry id="kembara" guid="5bf2cef5-27e0-50e9-9e89-2a46d5d5951a"><lexical-unit><form lang="id"><text>kembara</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kembara_0" guid="256664b6-cded-5784-a293-8424db8a444b"><grammatical-info value="Verb"/><gloss lang="en"><text>to wander</text></gloss></sense></entry>
<entry id="kemenangan" guid="ed61cc92-e3c6-5ddb-8623-8b432c85c7ea"><lexical-unit><form lang="id"><text>kemenangan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kemenangan_0" guid="8c4c77f0-e9f5-5abb-b2c3-44bfbe680bbd"><grammatical-info value="Noun"/><gloss lang="en"><text>victory (the state of having won a competition or battle)</text></gloss></sense></entry>
<entry id="kemenyan" guid="31a6b54e-36a5-54d7-840c-d1ee6ca70e1d"><lexical-unit><form lang="id"><text>kemenyan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kemenyan_0" guid="dde79ea7-c347-5866-b5ce-e25f9f8d6013"><grammatical-info value="Noun"/><gloss lang="en"><text>incense</text></gloss></sense><sense id="kemenyan_1" guid="3d1b5141-19dd-542e-b191-88f65a7cb825"><grammatical-info value="Noun"/><gloss lang="en"><text>benzoin: a resinous substance, dry and brittle, obtained from Styrax benzoin, a tree of Sumatra, Java, etc., having a fragrant odor, and slightly aromatic taste. It is used in the preparation of benzoic acid, in medicine, and as a perfume</text></gloss></sense><sense id="kemenyan_2" guid="15bb5fea-bb91-56e5-a9f3-595ac8d4b545"><grammatical-info value="Noun"/><gloss lang="en"><text>gum benjamin (Styrax benzoin)</text></gloss></sense><sense id="kemenyan_3" guid="758e3732-a2cd-5607-aa49-ebfb17fa90d0"><grammatical-info value="Noun"/><gloss lang="en"><text>ellipsis of akar kemenyan (Dioscorea pyrifolia)</text></gloss></sense><sense id="kemenyan_4" guid="e170b660-5fc8-5b4d-9eff-2f39fe5b4592"><grammatical-info value="Noun"/><gloss lang="en"><text>synonym of hiu (“shark”)</text></gloss></sense></entry>
