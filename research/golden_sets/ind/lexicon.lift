<entry id="hubungan" guid="05411a34-c6ee-544a-9b14-fad03badc636"><lexical-unit><form lang="id"><text>hubungan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="hubungan_0" guid="2021890c-2872-5301-851f-dada049b51e1"><grammatical-info value="Noun"/><gloss lang="en"><text>relation, relationship, connection, link</text></gloss></sense><sense id="hubungan_1" guid="a9de813c-0810-52ee-9780-20bf9669e290"><grammatical-info value="Noun"/><gloss lang="en"><text>contact</text></gloss></sense><sense id="hubungan_2" guid="3a58bf08-4973-593f-867f-08deaa22fac2"><grammatical-info value="Noun"/><gloss lang="en"><text>bond</text></gloss></sense></entry>
