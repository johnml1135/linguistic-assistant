<entry id="sangka" guid="6538cd56-ee20-573e-a92d-82d167d71fac"><lexical-unit><form lang="id"><text>sangka</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sangka_0" guid="b0d2ab11-70c0-54bc-b8c4-0bf1262ee3b2"><grammatical-info value="Verb"/><gloss lang="en"><text>guess, suspect</text></gloss></sense><sense id="sangka_1" guid="cffe736c-c7b7-5678-b072-c8dc50031eea"><grammatical-info value="Verb"/><gloss lang="en"><text>doubt</text></gloss></sense><sense id="sangka_2" guid="3355d931-36ce-5767-bfec-0fde0135056e"><grammatical-info value="Verb"/><gloss lang="en"><text>shell, conch-shell</text></gloss></sense><sense id="sangka_3" guid="3b5641a5-0a65-5b96-9352-c46132c14b55"><grammatical-info value="Verb"/><gloss lang="en"><text>synonym of sangkakala</text></gloss></sense></entry>
<entry id="sangkal" guid="9a64b811-0cb1-531a-acb8-5b44386f1df6"><lexical-unit><form lang="id"><text>sangkal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sangkal_0" guid="c42ee76e-559c-5293-abde-93dda1537bfc"><grammatical-info value="Verb"/><gloss lang="en"><text>to say in protest; to protest</text></gloss></sense><sense id="sangkal_1" guid="095c4692-6190-58ef-ad1b-55134611a5ea"><grammatical-info value="Verb"/><gloss lang="en"><text>handle of a hammer or adze</text></gloss></sense><sense id="sangkal_2" guid="8a7c2353-57fc-58e9-8373-80e8ad3415cb"><grammatical-info value="Verb"/><gloss lang="en"><text>misfortune that befalls because of disobedience</text></gloss></sense></entry>
