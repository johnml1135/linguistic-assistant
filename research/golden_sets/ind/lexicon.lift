<entry id="lalu" guid="dc55674f-bddf-5b38-b0de-bb19a03dfcfc"><lexical-unit><form lang="id"><text>lalu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lalu_0" guid="c18ae767-d30c-5f8d-aa23-3a4a756e39b1"><grammatical-info value="Verb"/><gloss lang="en"><text>past</text></gloss></sense><sense id="lalu_1" guid="ced3a761-5a40-5157-970a-38bf8cf6295d"><grammatical-info value="Verb"/><gloss lang="en"><text>having already happened; in the past</text></gloss></sense><sense id="lalu_2" guid="1da0e154-f71f-52ea-9454-1aff81608f8f"><grammatical-info value="Verb"/><gloss lang="en"><text>of a period of time: having just gone by; previous</text></gloss></sense><sense id="lalu_3" guid="c09039ef-80fb-509a-ae18-0f930ef5c60f"><grammatical-info value="Verb"/><gloss lang="en"><text>last (most recent; latest; last so far)</text></gloss></sense><sense id="lalu_4" guid="de4c0e50-48ce-5fea-9082-663266c6f476"><grammatical-info value="Verb"/><gloss lang="en"><text>done; finished (having completed or finished an activity)</text></gloss></sense><sense id="lalu_5" guid="8ff1754a-6c0e-5eab-8bc2-a6f50ff4a42c"><grammatical-info value="Verb"/><gloss lang="en"><text>then</text></gloss></sense><sense id="lalu_6" guid="8b7ec823-88d5-5e45-8948-8f4491a75fa9"><grammatical-info value="Verb"/><gloss lang="en"><text>soon afterward</text></gloss></sense><sense id="lalu_7" guid="6cc10f4e-0d9a-52bf-8809-c620dc8b8a71"><grammatical-info value="Verb"/><gloss lang="en"><text>next in order of place</text></gloss></sense></entry>
