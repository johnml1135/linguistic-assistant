<entry id="sang" guid="c90a2281-2ee6-507a-b4dc-b7b83eb0eb23"><lexical-unit><form lang="id"><text>sang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sang_0" guid="864b5f81-044f-5cd7-8282-538143954926"><grammatical-info value="Determiner"/></sense></entry>
