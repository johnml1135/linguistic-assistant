<entry id="tanggung" guid="7652a9a8-9fca-5643-b129-c8726b92e2d4"><lexical-unit><form lang="id"><text>tanggung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tanggung_0" guid="1139e90b-bfde-5be8-bfab-8a8141e9da0e"><grammatical-info value="Verb"/><gloss lang="en"><text>to bear (a burden, loss, etc.)</text></gloss></sense><sense id="tanggung_1" guid="de40b494-fee7-5327-aff1-205b33582fa3"><grammatical-info value="Verb"/><gloss lang="en"><text>to assume a risk</text></gloss></sense><sense id="tanggung_2" guid="3b238dfc-b4cd-50ac-8ce1-404fb9f5215f"><grammatical-info value="Verb"/><gloss lang="en"><text>to guarantee; to warrantee; to be responsible for</text></gloss></sense><sense id="tanggung_3" guid="ddb7d8de-c206-5bc7-99c4-381c6f3cae85"><grammatical-info value="Verb"/><gloss lang="en"><text>to hold someone accountable or liable for</text></gloss></sense><sense id="tanggung_4" guid="984f159f-9679-5a67-b6b3-75139cf71b6b"><grammatical-info value="Verb"/><gloss lang="en"><text>to take up a question, address</text></gloss></sense><sense id="tanggung_5" guid="37392c91-cdf7-5bb2-ade2-e271300076d2"><grammatical-info value="Verb"/><gloss lang="en"><text>guaranteed</text></gloss></sense><sense id="tanggung_6" guid="ec784110-f67d-5c21-baea-d376259df09f"><grammatical-info value="Verb"/><gloss lang="en"><text>medium; not quite adequate or enough (in quantity, size, etc.)</text></gloss></sense><sense id="tanggung_7" guid="e6720fa5-9097-5873-93c1-f8753e742cfe"><grammatical-info value="Verb"/><gloss lang="en"><text>not quite on time; just too late</text></gloss></sense></entry>
