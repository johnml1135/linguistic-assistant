<entry id="membayang" guid="b61349ee-dad1-521e-aa36-fbb4d53cd862"><lexical-unit><form lang="id"><text>membayang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="membayang_0" guid="c01d81f7-4b69-50ae-80ff-b3acc5436663"><grammatical-info value="Verb"/><gloss lang="en"><text>to appear, to become vaguely visible</text></gloss></sense><sense id="membayang_1" guid="57cd8295-90be-50be-98fe-772a77c186a4"><grammatical-info value="Verb"/><gloss lang="en"><text>to flash (across).</text></gloss></sense><sense id="membayang_2" guid="5af6bcf0-fe15-5e25-be90-f98d56666d3d"><grammatical-info value="Verb"/><gloss lang="en"><text>to loom</text></gloss></sense><sense id="membayang_3" guid="19a035cb-61df-5a66-a3ec-1ba3cd54631e"><grammatical-info value="Verb"/><gloss lang="en"><text>to imagine</text></gloss></sense><sense id="membayang_4" guid="89ee15cb-7b05-5d7f-9aeb-090d8e706839"><grammatical-info value="Verb"/><gloss lang="en"><text>to can be seen</text></gloss></sense><sense id="membayang_5" guid="388479ed-1b8e-5785-b1ae-780869ba4062"><grammatical-info value="Verb"/><gloss lang="en"><text>to can be captured, to can be depicted</text></gloss></sense></entry>
<entry id="membayar" guid="07743bfa-d25d-5af7-b866-02136dd05883"><lexical-unit><form lang="id"><text>membayar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="membayar_0" guid="167d5a68-f8a2-5095-b24c-8dc3403f6876"><grammatical-info value="Verb"/><gloss lang="en"><text>to pay</text></gloss></sense><sense id="membayar_1" guid="3a3ce21a-82a7-5e6e-83a3-6057a980646f"><grammatical-info value="Verb"/><gloss lang="en"><text>to give money or other compensation to in exchange for goods or services</text></gloss></sense><sense id="membayar_2" guid="95437ffe-8a6c-56a8-a09a-06c5498800b9"><grammatical-info value="Verb"/><gloss lang="en"><text>to discharge, as a debt or other obligation, by giving or doing what is due or required</text></gloss></sense><sense id="membayar_3" guid="57a5dc3c-70d8-5978-8c22-5bcaa67ef75f"><grammatical-info value="Verb"/><gloss lang="en"><text>to satisfy, carry out, bring to completion (an obligation, a requirement, etc.); to fulfill</text></gloss></sense></entry>
<entry id="membebani" guid="bbf5a03f-00ed-513d-ad8b-81f7e382255d"><lexical-unit><form lang="id"><text>membebani</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="membebani_0" guid="dac8342f-26f6-5210-900f-dde809ad7fb7"><grammatical-info value="Verb"/><gloss lang="en"><text>to load on something</text></gloss></sense><sense id="membebani_1" guid="d1df7af8-b5f0-5712-96a2-3ae02213e5ed"><grammatical-info value="Verb"/><gloss lang="en"><text>to burden, to encumber</text></gloss></sense><sense id="membebani_2" guid="8f211a30-5363-55cb-8eed-15d4db4d7cbe"><grammatical-info value="Verb"/><gloss lang="en"><text>to charge (money)</text></gloss></sense></entry>
<entry id="membenci" guid="c28b51db-6f6d-5b1a-bbff-64abeccc3039"><lexical-unit><form lang="id"><text>membenci</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="membenci_0" guid="6b728257-da23-5451-a62a-073ab9d852a6"><grammatical-info value="Verb"/><gloss lang="en"><text>to hate (to dislike intensely)</text></gloss></sense></entry>
