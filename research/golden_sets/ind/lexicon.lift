<entry id="sabuk" guid="44515cdc-7613-5fcb-a20b-75d8d2645bad"><lexical-unit><form lang="id"><text>sabuk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sabuk_0" guid="c97f0962-a7ea-5a18-b17a-9d9de146dfff"><grammatical-info value="Noun"/><gloss lang="en"><text>belt (a band worn around the waist to hold clothing to one's body)</text></gloss></sense><sense id="sabuk_1" guid="d493ba90-2c4e-560d-af0d-1aa609f07ede"><grammatical-info value="Noun"/><gloss lang="en"><text>belt (a band used as a restraint for safety purposes)</text></gloss></sense><sense id="sabuk_2" guid="efe4e1a2-bfda-5099-8f27-544a035b0d77"><grammatical-info value="Noun"/><gloss lang="en"><text>belt (a collection of rocky-constituted bodies which orbit a star)</text></gloss></sense></entry>
<entry id="sadar" guid="ac26d2ac-516c-5ae0-aaa8-c2ce1510826a"><lexical-unit><form lang="id"><text>sadar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sadar_0" guid="686db11b-8ee1-5289-8724-4106cbb06d81"><grammatical-info value="Adjective"/><gloss lang="en"><text>aware</text></gloss></sense><sense id="sadar_1" guid="d858df2a-e670-51a6-82b0-5047f9b9ab8f"><grammatical-info value="Adjective"/><gloss lang="en"><text>to be conscious</text></gloss></sense><sense id="sadar_2" guid="d7b845be-8982-5ca0-b2ba-de3db63ddbbe"><grammatical-info value="Adjective"/><gloss lang="en"><text>to be aware</text></gloss></sense><sense id="sadar_3" guid="018ada40-fc0e-5f45-bc0a-6c2041aeac10"><grammatical-info value="Adjective"/><gloss lang="en"><text>to realize</text></gloss></sense><sense id="sadar_4" guid="785bf8ac-db4d-5634-9a2c-639aa4f0135b"><grammatical-info value="Adjective"/><gloss lang="en"><text>a chest, a breast</text></gloss></sense><sense id="sadar_5" guid="8aa3bce4-5c08-58a9-9de0-57bdc133c5b9"><grammatical-info value="Adjective"/><gloss lang="en"><text>a front</text></gloss></sense><sense id="sadar_6" guid="9df4d18f-2113-5126-b1b9-a1fe026f112a"><grammatical-info value="Adjective"/><gloss lang="en"><text>a beginning, a start, an outset, a commencement; an inception; a dawn, a rise</text></gloss></sense><sense id="sadar_7" guid="9fa46306-a526-5c92-bfa8-a0c56fb4b6c4"><grammatical-info value="Adjective"/><gloss lang="en"><text>a large mat that resembles a tarpaulin, made from woven thorny pandan leaves, used for drying rice and corn</text></gloss></sense></entry>
<entry id="sadari" guid="f9add556-c37a-51cb-8605-b4b436785f60"><lexical-unit><form lang="id"><text>sadari</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sadari_0" guid="540277f9-9eb7-5329-8221-9d554e66ac64"><grammatical-info value="Verb"/><gloss lang="en"><text>syllabic abbreviation of pemeriksaan payudara sendiri (“breast self-exam”)</text></gloss></sense></entry>
