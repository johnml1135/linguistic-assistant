<entry id="hidup" guid="1e572c4e-7f46-565e-9ff7-eb70dcb5f0f5"><lexical-unit><form lang="id"><text>hidup</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="hidup_0" guid="7ef21b69-6cca-5186-9ef1-cee5ab77460c"><grammatical-info value="Verb"/><gloss lang="en"><text>to live</text></gloss></sense><sense id="hidup_1" guid="acb8c4fd-24dc-5288-88fb-c79562228a60"><grammatical-info value="Verb"/><gloss lang="en"><text>to be alive; to have life</text></gloss></sense><sense id="hidup_2" guid="52656de3-dddd-5c17-84d4-c86b5119a866"><grammatical-info value="Verb"/><gloss lang="en"><text>to have permanent residence somewhere, to inhabit, to reside</text></gloss></sense><sense id="hidup_3" guid="23eb45e2-cac6-5438-91ae-0de65242717b"><grammatical-info value="Verb"/><gloss lang="en"><text>to pass life in a specified manner</text></gloss></sense><sense id="hidup_4" guid="23b106ff-e10e-5b21-8944-9d36eb492aef"><grammatical-info value="Verb"/><gloss lang="en"><text>to spend, as one's life; to pass; to maintain; to continue in, constantly or habitually</text></gloss></sense><sense id="hidup_5" guid="055db7bd-b12d-53e2-92fd-0e09253967ae"><grammatical-info value="Verb"/><gloss lang="en"><text>To maintain or support one's existence; to provide for oneself; to feed; to subsist</text></gloss></sense><sense id="hidup_6" guid="208fa2c8-d60c-5d1a-b1d3-78b5902fec5c"><grammatical-info value="Verb"/><gloss lang="en"><text>running: Of a machine, to be operating or working normally</text></gloss></sense><sense id="hidup_7" guid="cb5e1b9a-cc2f-516d-933d-e9fa7e748ef7"><grammatical-info value="Verb"/><gloss lang="en"><text>sustained</text></gloss></sense></entry>
