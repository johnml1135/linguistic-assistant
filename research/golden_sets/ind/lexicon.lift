<entry id="ratakan" guid="185aa302-1aa9-55ee-838b-92ccea78884f"><lexical-unit><form lang="id"><text>ratakan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ratakan_0" guid="712a5d97-126d-57d4-9829-349ddbe5dd6d"><grammatical-info value="Verb"/><gloss lang="en"><text>to flatten (to make flat or flatter)</text></gloss></sense><sense id="ratakan_1" guid="36102655-e6fe-5110-b185-2af1212b1caa"><grammatical-info value="Verb"/><gloss lang="en"><text>to apportion; to distribute (to divide and distribute portions of a whole)</text></gloss></sense></entry>
