<entry id="rut" guid="cd5f7664-b860-58df-aff0-07a5266f0bc0"><lexical-unit><form lang="id"><text>rut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="rut_0" guid="72c5011c-5b6a-5bfc-a97a-3b70a0f7e49e"><grammatical-info value="Verb"/><gloss lang="en"><text>to tighten</text></gloss></sense><sense id="rut_1" guid="d0fa4c52-7e9c-5470-88a8-df292121d308"><grammatical-info value="Verb"/><gloss lang="en"><text>Ruth:</text></gloss></sense><sense id="rut_2" guid="4c73098d-4654-5ad6-88c3-5c80f0d933a0"><grammatical-info value="Verb"/><gloss lang="en"><text>A book of the Old Testament and the Hebrew Tanakh</text></gloss></sense><sense id="rut_3" guid="84fc56f9-f67d-53a7-a44b-c78179754030"><grammatical-info value="Verb"/><gloss lang="en"><text>The resident of Moab around whom the text centers</text></gloss></sense></entry>
