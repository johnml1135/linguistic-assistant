<entry id="biaya" guid="a43f2100-a6f2-553b-96bf-4b1de4566e36"><lexical-unit><form lang="id"><text>biaya</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="biaya_0" guid="c7bab040-2cc6-57d4-a6d3-2123dce769fb"><grammatical-info value="Noun"/><gloss lang="en"><text>cost: amount of money that is required or used</text></gloss></sense><sense id="biaya_1" guid="6515eabc-b525-587b-94a5-f72bd1fb74e8"><grammatical-info value="Noun"/><gloss lang="en"><text>charge: the amount of money levied for a service</text></gloss></sense><sense id="biaya_2" guid="10d2f205-df0c-5fe6-a982-4123e5bc02d6"><grammatical-info value="Noun"/><gloss lang="en"><text>expense: a spending or consuming, often a disbursement of funds</text></gloss></sense></entry>
