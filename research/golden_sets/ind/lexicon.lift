<entry id="olahraga" guid="fa7b0a3d-56d6-5da7-bbf3-6a5fbbdc3fa2"><lexical-unit><form lang="id"><text>olahraga</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="olahraga_0" guid="f42b8f98-78fa-5f5e-89b9-16633e838aa9"><grammatical-info value="Noun"/><gloss lang="en"><text>exercise; any activity intended to improve physical strength and fitness</text></gloss></sense><sense id="olahraga_1" guid="09542697-9466-5591-97d7-5e0a9591f806"><grammatical-info value="Noun"/><gloss lang="en"><text>sport,</text></gloss></sense><sense id="olahraga_2" guid="5349420f-ef19-5d00-9990-f21f4294c15a"><grammatical-info value="Noun"/><gloss lang="en"><text>any activity that uses physical exertion or skills competitively under a set of rules that is not based on aesthetics</text></gloss></sense><sense id="olahraga_3" guid="c0e652f8-539d-5e2d-9cbc-a599d581d382"><grammatical-info value="Noun"/><gloss lang="en"><text>something done for fun, regardless of its design or intended purpose</text></gloss></sense></entry>
