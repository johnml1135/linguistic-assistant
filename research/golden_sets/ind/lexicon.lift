<entry id="koin" guid="e0ec69e1-fa87-53fe-aa7a-642bbf0d06c4"><lexical-unit><form lang="id"><text>koin</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="koin_0" guid="b4ca02bc-cc7d-5867-89c1-ceedbb9c7bef"><grammatical-info value="Noun"/><gloss lang="en"><text>coin</text></gloss></sense><sense id="koin_1" guid="ad6d6caa-9110-5072-b381-a1c02312a3f0"><grammatical-info value="Noun"/><gloss lang="en"><text>a piece of currency, usually metallic and in the shape of a disc, but sometimes polygonal, or with a hole in the middle</text></gloss></sense><sense id="koin_2" guid="1dff61bb-25d9-5e53-8a39-5b58e191672f"><grammatical-info value="Noun"/><gloss lang="en"><text>a cryptocurrency; a cryptocoin</text></gloss></sense></entry>
<entry id="kokoh" guid="0c0e6bff-40b7-589e-89ef-73d4782bf4c5"><lexical-unit><form lang="id"><text>kokoh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kokoh_0" guid="9f32ada3-a438-5bcf-a26e-7d38c31d30fc"><grammatical-info value="Adjective"/><gloss lang="en"><text>tenacious, solid (especially a building)</text></gloss></sense></entry>
<entry id="kolam" guid="fb68979a-776e-5120-847a-2ca715578ffc"><lexical-unit><form lang="id"><text>kolam</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kolam_0" guid="a65433da-11b5-57d3-851f-2d813f86426b"><grammatical-info value="Noun"/><gloss lang="en"><text>pond (small lake)</text></gloss></sense><sense id="kolam_1" guid="ae3eece6-8301-503d-9a79-c0bb55390b93"><grammatical-info value="Noun"/><gloss lang="en"><text>pool</text></gloss></sense></entry>
