<entry id="sekal" guid="704dfd43-c276-5520-bafb-6fb126977334"><lexical-unit><form lang="id"><text>sekal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sekal_0" guid="a373ee8e-bf8c-59d8-89cc-c531c1c534b4"><grammatical-info value="Noun"/><gloss lang="en"><text>scale</text></gloss></sense><sense id="sekal_1" guid="5d62360c-9a86-5792-8df1-1aaf1fdbb022"><grammatical-info value="Noun"/><gloss lang="en"><text>the ratio of depicted distance to actual distance; a line or bar associated with a drawing, used to indicate measurement when the image has been magnified or reduced</text></gloss></sense><sense id="sekal_2" guid="17bacf24-ce50-57d2-8a4c-a8b9ab33ce9f"><grammatical-info value="Noun"/><gloss lang="en"><text>a series of notes spanning an octave, tritave, or pseudo-octave, used to make melodies</text></gloss></sense><sense id="sekal_3" guid="1990c6d2-9656-57ac-82d8-9d0c41047c20"><grammatical-info value="Noun"/><gloss lang="en"><text>chubby, hefty</text></gloss></sense><sense id="sekal_4" guid="0efadb93-5d32-5eb4-b0c7-f3e6ade8b3bc"><grammatical-info value="Noun"/><gloss lang="en"><text>a path in the forest used for pulling wood</text></gloss></sense></entry>
<entry id="sekali" guid="995ca238-5a4e-53f6-8ec4-e03b813d2fe9"><lexical-unit><form lang="id"><text>sekali</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sekali_0" guid="7344b210-43e9-5bf5-a6cc-0ed933f2cb78"><grammatical-info value="Adverb"/><gloss lang="en"><text>once</text></gloss></sense><sense id="sekali_1" guid="f027e9d1-1f4b-5838-aad8-305e2052bca9"><grammatical-info value="Adverb"/><gloss lang="en"><text>very</text></gloss></sense><sense id="sekali_2" guid="88a2498e-5912-5d3b-8df1-549ad14b7ca2"><grammatical-info value="Adverb"/><gloss lang="en"><text>a surname from Karo Batak</text></gloss></sense></entry>
<entry id="sekaligus" guid="be3e2590-2637-5f12-8260-7de8cabb2649"><lexical-unit><form lang="id"><text>sekaligus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sekaligus_0" guid="40bcdc11-0ab8-56a5-990b-9af19d7f7fc2"><grammatical-info value="Adverb"/><gloss lang="en"><text>at once, all at once, all together</text></gloss></sense></entry>
<entry id="sekam" guid="26c1ce38-fb4d-5e51-8852-1272254f7cf7"><lexical-unit><form lang="id"><text>sekam</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sekam_0" guid="b3ba56ef-99cf-5183-beb6-b3a6c25fa119"><grammatical-info value="Noun"/><gloss lang="en"><text>rice husk; rice hull</text></gloss></sense><sense id="sekam_1" guid="a2afaa11-581b-58b9-a959-ae19f0b6b595"><grammatical-info value="Noun"/><gloss lang="en"><text>chaff: loose material, e.g. small strips of aluminum foil dropped from aircraft, intended to interfere with radar detection</text></gloss></sense></entry>
<entry id="sekedar" guid="4b296b7b-05db-5c0b-8610-a9da33cd9710"><lexical-unit><form lang="id"><text>sekedar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sekedar_0" guid="bfa8ad57-d7e9-5cd4-abc7-4fabe691308f"><grammatical-info value="Adverb"/><gloss lang="en"><text>nonstandard form of sekadar</text></gloss></sense></entry>
