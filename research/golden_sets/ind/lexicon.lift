<entry id="kisah" guid="728f9daf-bb43-5f3d-9511-bdc61c7f826a"><lexical-unit><form lang="id"><text>kisah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kisah_0" guid="ea6dd06f-ccde-509b-a92f-1ae701bae25e"><grammatical-info value="Noun"/><gloss lang="en"><text>story, tale</text></gloss></sense><sense id="kisah_1" guid="c312ae70-1454-59db-af9c-1a79309ff349"><grammatical-info value="Noun"/><gloss lang="en"><text>occurrence</text></gloss></sense></entry>
<entry id="kita" guid="7a3600b3-44d3-5962-be9e-270dde6ebf84"><lexical-unit><form lang="id"><text>kita</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kita_0" guid="62a0ffc5-1c50-5f14-8ba7-fabd5edda1e8"><grammatical-info value="Pronoun"/></sense></entry>
<entry id="kitab" guid="2e103082-6fb4-5423-8b3d-ed8aae64c29f"><lexical-unit><form lang="id"><text>kitab</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kitab_0" guid="3065b579-6cb3-5ed2-9880-85a77f11ac8d"><grammatical-info value="Noun"/><gloss lang="en"><text>book (collection of sheets of paper bound together containing printed or written material)</text></gloss></sense><sense id="kitab_1" guid="b594f02f-8b3c-5ede-92b5-e7fc3775d5a9"><grammatical-info value="Noun"/><gloss lang="en"><text>holy book, sacred writing, scripture</text></gloss></sense><sense id="kitab_2" guid="03e1b521-bfde-564a-9597-2f5ecd07c760"><grammatical-info value="Noun"/><gloss lang="en"><text>code, body of law</text></gloss></sense></entry>
<entry id="kitar" guid="9200f401-7f38-52eb-90e1-04d7955dfa2a"><lexical-unit><form lang="id"><text>kitar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kitar_0" guid="720e2b4e-1492-577c-91e6-9ae1c9cf2731"><grammatical-info value="Verb"/><gloss lang="en"><text>to rotate, to turn around</text></gloss></sense><sense id="kitar_1" guid="fdbc768c-ca97-5bc6-b414-5e9bca3e9119"><grammatical-info value="Verb"/><gloss lang="en"><text>cycle (the number of activities that can be carried out by a means of transportation from one starting point per unit time)</text></gloss></sense><sense id="kitar_2" guid="d35b32b2-8f8a-5ea7-9d89-3881fc56ac9f"><grammatical-info value="Verb"/><gloss lang="en"><text>to push (aside)</text></gloss></sense></entry>
<entry id="klaim" guid="87812582-fbb2-5c15-8c23-5566151c40f1"><lexical-unit><form lang="id"><text>klaim</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="klaim_0" guid="73124665-1998-5fc9-8130-1909dff24d67"><grammatical-info value="Noun"/><gloss lang="en"><text>claim</text></gloss></sense><sense id="klaim_1" guid="e2276bf9-29a8-5150-b3a3-c3ceea29c66f"><grammatical-info value="Noun"/><gloss lang="en"><text>a demand of ownership made for something</text></gloss></sense><sense id="klaim_2" guid="4366ce69-94f0-58ae-a3e2-9a97a469baf0"><grammatical-info value="Noun"/><gloss lang="en"><text>the thing claimed</text></gloss></sense><sense id="klaim_3" guid="00bd2e15-0159-5741-95d3-8225b349db05"><grammatical-info value="Noun"/><gloss lang="en"><text>the right or ground of demanding</text></gloss></sense><sense id="klaim_4" guid="cc2d5910-8636-5670-b3ef-8aa77f302d63"><grammatical-info value="Noun"/><gloss lang="en"><text>a new statement of something one believes to be the truth, usually when the statement has yet to be verified or without valid evidence provided</text></gloss></sense><sense id="klaim_5" guid="8e4e864b-bdf3-5b3c-a8e0-4a181456d667"><grammatical-info value="Noun"/><gloss lang="en"><text>a demand of ownership for previously unowned land</text></gloss></sense><sense id="klaim_6" guid="c3d5a941-0fd1-5621-9e5f-72e80f8cd596"><grammatical-info value="Noun"/><gloss lang="en"><text>a legal demand for compensation or damages</text></gloss></sense><sense id="klaim_7" guid="8682f5e8-c9e3-5d42-bc88-b9ba3c5fe9e9"><grammatical-info value="Noun"/><gloss lang="en"><text>to claim</text></gloss></sense></entry>
<entry id="kobar" guid="ad7e4e75-d1a6-590d-a347-eaac018fdbff"><lexical-unit><form lang="id"><text>kobar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kobar_0" guid="46280dd4-4ea7-5c09-96ca-4cffa771c48b"><grammatical-info value="Verb"/><gloss lang="en"><text>rooster</text></gloss></sense></entry>
