<entry id="memberitahukan" guid="ab8ef836-8aa5-5b13-a8a8-da4402a22a9a"><lexical-unit><form lang="id"><text>memberitahukan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="memberitahukan_0" guid="988027d2-295f-5095-85e7-54362088c39b"><grammatical-info value="Verb"/><gloss lang="en"><text>active of beritahukan</text></gloss></sense></entry>
<entry id="memberkati" guid="015c263b-6a19-5406-ac8d-f452d00c1f06"><lexical-unit><form lang="id"><text>memberkati</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="memberkati_0" guid="adcd6ca7-5cfe-5b21-a621-26c6d0ba7a08"><grammatical-info value="Verb"/><gloss lang="en"><text>to bless:</text></gloss></sense><sense id="memberkati_1" guid="85cff18d-a958-5ff1-9ed2-9a58e4272ccd"><grammatical-info value="Verb"/><gloss lang="en"><text>to make something holy by religious rite, to sanctify</text></gloss></sense><sense id="memberkati_2" guid="678400fc-1195-5fed-a532-7d84177c98a1"><grammatical-info value="Verb"/><gloss lang="en"><text>to invoke divine favor upon</text></gloss></sense><sense id="memberkati_3" guid="cb498504-606f-5bfd-b5ba-a3cbd471e028"><grammatical-info value="Verb"/><gloss lang="en"><text>to honor as holy, to glorify; to extol for excellence</text></gloss></sense><sense id="memberkati_4" guid="173bd76f-6f5c-5bb8-a624-5e7e8707f343"><grammatical-info value="Verb"/><gloss lang="en"><text>to esteem or account happy; to felicitate</text></gloss></sense><sense id="memberkati_5" guid="9f210a41-dab5-5601-9a0b-40067174393d"><grammatical-info value="Verb"/><gloss lang="en"><text>to ask for blessings for</text></gloss></sense><sense id="memberkati_6" guid="bbf581cc-408b-5699-8636-94e14a52e7e6"><grammatical-info value="Verb"/><gloss lang="en"><text>to bring good/blessings</text></gloss></sense></entry>
<entry id="membesar" guid="1f4c870c-1bca-597c-b7f0-c72ce87f39ab"><lexical-unit><form lang="id"><text>membesar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="membesar_0" guid="816388db-ca56-5927-8d4f-cb3e0381e9ff"><grammatical-info value="Verb"/><gloss lang="en"><text>to grow (larger); to enlarge</text></gloss></sense><sense id="membesar_1" guid="6234ea9e-e93c-5de6-a5f0-dfec44904381"><grammatical-info value="Verb"/><gloss lang="en"><text>to become or get louder</text></gloss></sense><sense id="membesar_2" guid="2115463b-4fd1-5e60-9acc-cde6b31cd675"><grammatical-info value="Verb"/><gloss lang="en"><text>to become arrogant</text></gloss></sense></entry>
<entry id="membongkar" guid="089298a6-ec13-5296-a287-e078f1e82660"><lexical-unit><form lang="id"><text>membongkar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="membongkar_0" guid="5daa7824-5ff5-5fff-8ee6-7963b8079c21"><grammatical-info value="Verb"/><gloss lang="en"><text>to unload (cargo)</text></gloss></sense><sense id="membongkar_1" guid="e445470d-3f6e-5b53-8062-03bb13a23c93"><grammatical-info value="Verb"/><gloss lang="en"><text>to unpack (e.g. a trunk)</text></gloss></sense><sense id="membongkar_2" guid="3ece6571-1903-5df0-96af-a2468fcfd123"><grammatical-info value="Verb"/><gloss lang="en"><text>to open up something using force; to break into and rummage around</text></gloss></sense><sense id="membongkar_3" guid="4d589d54-91cb-5c02-aa8b-59214aae6146"><grammatical-info value="Verb"/><gloss lang="en"><text>to take apart, to dismantle</text></gloss></sense><sense id="membongkar_4" guid="9fc9d645-afe2-55c6-84ca-a99e68553454"><grammatical-info value="Verb"/><gloss lang="en"><text>to tear down</text></gloss></sense><sense id="membongkar_5" guid="d6088553-8530-581e-8ae9-494bb7871fd1"><grammatical-info value="Verb"/><gloss lang="en"><text>to reveal, disclose (e.g. secrets, memories, shameful deeds)</text></gloss></sense><sense id="membongkar_6" guid="92064712-1d88-5b07-9405-5d359acb5f1d"><grammatical-info value="Verb"/><gloss lang="en"><text>to put in order, to clean, to prepare for guests (a room)</text></gloss></sense></entry>
