<entry id="terus" guid="d25bfb39-fa40-5f2d-a5b4-6344750e6b9b"><lexical-unit><form lang="id"><text>terus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="terus_0" guid="7b0678a6-c0bc-5f41-a8ce-b21d12157391"><grammatical-info value="Adverb"/><gloss lang="en"><text>straight:</text></gloss></sense><sense id="terus_1" guid="88ced4fa-2eec-5f20-80ad-60182c21a56a"><grammatical-info value="Adverb"/><gloss lang="en"><text>of a direction relative to the subject, precisely; as if following a direct line</text></gloss></sense><sense id="terus_2" guid="c8a8f643-0b8b-5730-8a50-54fbedd849ba"><grammatical-info value="Adverb"/><gloss lang="en"><text>directly; without pause, delay or detour</text></gloss></sense><sense id="terus_3" guid="97cadd7d-cea5-5261-8e62-b7c82f8da297"><grammatical-info value="Adverb"/><gloss lang="en"><text>continuously; without interruption or pause</text></gloss></sense><sense id="terus_4" guid="1fc1f48f-8cc7-59ee-b99b-8276512d5d9c"><grammatical-info value="Adverb"/><gloss lang="en"><text>continuously</text></gloss></sense><sense id="terus_5" guid="ef02eb05-441f-542d-87fa-9cbbfe523819"><grammatical-info value="Adverb"/><gloss lang="en"><text>keep</text></gloss></sense><sense id="terus_6" guid="b128dc60-f3aa-5520-8107-7d764c99d867"><grammatical-info value="Adverb"/><gloss lang="en"><text>to continue</text></gloss></sense><sense id="terus_7" guid="ce11c022-3ff4-5738-86b0-534747e1dfbd"><grammatical-info value="Adverb"/><gloss lang="en"><text>to keep going, straight ahead</text></gloss></sense></entry>
<entry id="tes" guid="6ba0798b-02be-5911-a548-f444263e21ba"><lexical-unit><form lang="id"><text>tes</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tes_0" guid="acb58e78-cee7-55f7-bc81-603920f0c2c0"><grammatical-info value="Verb"/><gloss lang="en"><text>test</text></gloss></sense><sense id="tes_1" guid="04e5ebf8-c7a7-583c-9968-cd81a25eec8f"><grammatical-info value="Verb"/><gloss lang="en"><text>drip</text></gloss></sense></entry>
<entry id="tetangga" guid="59062731-adb7-564e-abd6-222717424030"><lexical-unit><form lang="id"><text>tetangga</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tetangga_0" guid="a4770ce0-9d92-5a7a-bfea-927f53d81995"><grammatical-info value="Noun"/><gloss lang="en"><text>neighbors</text></gloss></sense></entry>
<entry id="tetap" guid="a01998f8-5063-5fba-82be-5342acaddae6"><lexical-unit><form lang="id"><text>tetap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tetap_0" guid="30de852f-526b-5604-91e4-8047735db410"><grammatical-info value="Adverb"/><gloss lang="en"><text>steady, fixed</text></gloss></sense><sense id="tetap_1" guid="3459a410-91db-5858-9791-34b51077cdae"><grammatical-info value="Adverb"/><gloss lang="en"><text>eternal</text></gloss></sense><sense id="tetap_2" guid="9aacb9b0-9aab-5593-a31a-73ca2621c3a4"><grammatical-info value="Adverb"/><gloss lang="en"><text>permanent</text></gloss></sense><sense id="tetap_3" guid="5e4bdc78-0c12-5c0d-8310-e21c1cc238a6"><grammatical-info value="Adverb"/><gloss lang="en"><text>continuously</text></gloss></sense><sense id="tetap_4" guid="b32b53e3-9d31-5bee-86ce-a1396655d334"><grammatical-info value="Adverb"/><gloss lang="en"><text>always</text></gloss></sense><sense id="tetap_5" guid="4c131686-8a4e-5b02-b121-d253bc17a3cd"><grammatical-info value="Adverb"/><gloss lang="en"><text>eternally</text></gloss></sense><sense id="tetap_6" guid="2c4cf6f3-04ad-50a9-9d42-cbe2f345ba90"><grammatical-info value="Adverb"/><gloss lang="en"><text>surely, certainly, undoubtedly</text></gloss></sense><sense id="tetap_7" guid="d2d03ed4-207d-5c8c-90b0-f9af10401bda"><grammatical-info value="Adverb"/><gloss lang="en"><text>still, nevertheless</text></gloss></sense></entry>
