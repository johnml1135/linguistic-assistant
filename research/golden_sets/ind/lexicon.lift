<entry id="menemukan" guid="e34ee31e-41c5-5332-bedb-386c99f4573a"><lexical-unit><form lang="id"><text>menemukan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="menemukan_0" guid="cbce25d3-5c5b-56c5-b500-b094c2049c59"><grammatical-info value="Verb"/><gloss lang="en"><text>to find, to locate, to detect</text></gloss></sense><sense id="menemukan_1" guid="fb12f4c4-e9d7-5b20-87e6-36a9de2fb8d0"><grammatical-info value="Verb"/><gloss lang="en"><text>to discover</text></gloss></sense><sense id="menemukan_2" guid="91026cae-69c2-5d43-8955-c0bbc808139c"><grammatical-info value="Verb"/><gloss lang="en"><text>to invent</text></gloss></sense><sense id="menemukan_3" guid="8d0c8b73-e4ba-5337-be70-30faa54a09cf"><grammatical-info value="Verb"/><gloss lang="en"><text>synonym of mendapatkan or mendapati</text></gloss></sense><sense id="menemukan_4" guid="ba4143ee-a2e0-58ed-b9d8-34b17cf851cf"><grammatical-info value="Verb"/><gloss lang="en"><text>synonym of mengalami or menderita</text></gloss></sense></entry>
