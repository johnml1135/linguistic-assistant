<entry id="atau" guid="cc85a6e1-e63f-5b0c-834e-a7050c3aa0d7"><lexical-unit><form lang="id"><text>atau</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="atau_0" guid="a0682695-4218-552d-bdfc-cc05ba193833"><grammatical-info value="Coordinating connective"/><gloss lang="en"><text>or</text></gloss></sense></entry>
<entry id="atena" guid="2ef658a9-a104-5ef0-81b7-50b798d5665e"><lexical-unit><form lang="id"><text>atena</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="atena_0" guid="287c50fa-6a38-5bc1-a2cf-24291f84c500"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Athena:</text></gloss></sense><sense id="atena_1" guid="122fba45-cde5-529e-ad3b-167689195b99"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the goddess of wisdom, especially strategic warfare, the arts, and especially crafts, in particular, weaving; daughter of Zeus and Metis. Her Roman counterpart is Minerva</text></gloss></sense><sense id="atena_2" guid="4f906f70-a0c5-5c6d-98a9-c1590dee287f"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a city in Umatilla County, Oregon, United States</text></gloss></sense><sense id="atena_3" guid="900146c0-787c-5afd-aec3-605fe94f2afa"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Athens</text></gloss></sense><sense id="atena_4" guid="906733ba-5cdf-5512-bd0c-527507be9390"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the capital city of Greece</text></gloss></sense><sense id="atena_5" guid="fbe51e06-8c12-5256-a51d-3590f21ba99e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the Greek government</text></gloss></sense><sense id="atena_6" guid="9c8548b2-62fe-5cd7-a7c4-7a965c74b413"><grammatical-info value="Proper noun"/><gloss lang="en"><text>several other places in United States of America and Canada</text></gloss></sense><sense id="atena_7" guid="f8a3af91-fa30-5189-b7de-bfc689e352f8"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a female given name from Ancient Greek</text></gloss></sense></entry>
<entry id="athena" guid="16fa2266-34a3-585b-8746-5927d438f861"><lexical-unit><form lang="id"><text>athena</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="athena_0" guid="6c76c38c-31aa-59e9-941c-273025a114de"><grammatical-info value="Proper noun"/><gloss lang="en"><text>alternative spelling of Atena (“Athena; Athens”)</text></gloss></sense></entry>
<entry id="atur" guid="719fe2bd-a8c6-5826-b09f-84d193bd691c"><lexical-unit><form lang="id"><text>atur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="atur_0" guid="927b84fa-9ee8-5906-bd66-f399002f0ace"><grammatical-info value="Noun"/><gloss lang="en"><text>to arrange, set, organize</text></gloss></sense><sense id="atur_1" guid="43894ee4-c9a1-5bd2-9456-f872f5424382"><grammatical-info value="Noun"/><gloss lang="en"><text>to regulate</text></gloss></sense><sense id="atur_2" guid="2795c841-c394-59b0-b075-cdac8bb17996"><grammatical-info value="Noun"/><gloss lang="en"><text>synonym of tusuk (“to pierce”)</text></gloss></sense></entry>
