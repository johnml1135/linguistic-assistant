<entry id="berbagi" guid="8b2cea4e-ad6e-52ee-a2a6-5fa7bdcb82d4"><lexical-unit><form lang="id"><text>berbagi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berbagi_0" guid="c71da75f-68bf-5733-92a3-3421f50fca85"><grammatical-info value="Verb"/><gloss lang="en"><text>to share (to have or use in common; to share together)</text></gloss></sense></entry>
<entry id="berbahagia" guid="39ab9e84-c46a-5542-a67f-c5211bd08396"><lexical-unit><form lang="id"><text>berbahagia</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berbahagia_0" guid="d14ad3b5-c4de-57e7-ac4b-5f3b0d7a69da"><grammatical-info value="Verb"/><gloss lang="en"><text>to be happy, to savor good fortune; to be rejoicing</text></gloss></sense><sense id="berbahagia_1" guid="9ce074a8-178b-571e-abb1-10658bc2b806"><grammatical-info value="Verb"/><gloss lang="en"><text>To be in a state of happiness; happy, joyous</text></gloss></sense><sense id="berbahagia_2" guid="c6d4aef3-48f1-5d26-a263-266b0c4028a5"><grammatical-info value="Verb"/><gloss lang="en"><text>To be fortuitous, auspicious</text></gloss></sense></entry>
<entry id="berbicara" guid="9a3e3225-815f-52c4-83d1-b7adeab4e7af"><lexical-unit><form lang="id"><text>berbicara</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berbicara_0" guid="67a53c1e-4bbc-554e-8bea-1750e7cc77ae"><grammatical-info value="Verb"/><gloss lang="en"><text>to talk; to speak</text></gloss></sense></entry>
<entry id="berbuat" guid="201ecfce-5e21-58ac-a5c7-d3970227188d"><lexical-unit><form lang="id"><text>berbuat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berbuat_0" guid="b2d927cd-2e3e-507d-b7b3-2905ff40c4ca"><grammatical-info value="Verb"/><gloss lang="en"><text>to do, act</text></gloss></sense></entry>
<entry id="berdasar" guid="e1ebcac3-dec6-5352-b0f2-28fc43dc3f04"><lexical-unit><form lang="id"><text>berdasar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berdasar_0" guid="c5ac6270-46f9-5cff-ac02-9656a0c6dcc0"><grammatical-info value="Verb"/><gloss lang="en"><text>to be founded</text></gloss></sense><sense id="berdasar_1" guid="039136b3-4965-5812-bfd9-4e93720f439b"><grammatical-info value="Verb"/><gloss lang="en"><text>to be based</text></gloss></sense><sense id="berdasar_2" guid="9775c419-a5eb-57cd-83fd-3557c5c74a9f"><grammatical-info value="Verb"/><gloss lang="en"><text>to have a base of</text></gloss></sense><sense id="berdasar_3" guid="4791f355-8491-52ec-9043-c264523472ab"><grammatical-info value="Verb"/><gloss lang="en"><text>based: Indicating emphatic approval of a statement or opinion, often a controversial or unpopular one.</text></gloss></sense></entry>
<entry id="berdiri" guid="efd2979a-b6d2-5885-981d-8ed5345e5d70"><lexical-unit><form lang="id"><text>berdiri</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berdiri_0" guid="8cc46f28-9d01-51fe-8ea2-0d3ba8ee5ea4"><grammatical-info value="Verb"/><gloss lang="en"><text>to stand</text></gloss></sense><sense id="berdiri_1" guid="9dfbd646-d74e-5131-ae82-a644c293ea1f"><grammatical-info value="Verb"/><gloss lang="en"><text>to support oneself on the feet in an erect position</text></gloss></sense><sense id="berdiri_2" guid="c93a6960-0177-5648-844e-dd751a0d22f5"><grammatical-info value="Verb"/><gloss lang="en"><text>to be placed in an upright or vertical orientation</text></gloss></sense><sense id="berdiri_3" guid="787da440-19b8-5c79-85cb-562718dc8b90"><grammatical-info value="Verb"/><gloss lang="en"><text>to back or favor a cause, party, etc., mentally or with concrete aid; to support</text></gloss></sense><sense id="berdiri_4" guid="c77bb7de-1e84-5e64-b849-05e0f5831ff6"><grammatical-info value="Verb"/><gloss lang="en"><text>to stand up (to rise from a lying or sitting position)</text></gloss></sense><sense id="berdiri_5" guid="06b5cf2f-6c04-5a5a-a24c-bf54b44c6c4e"><grammatical-info value="Verb"/><gloss lang="en"><text>to be found</text></gloss></sense><sense id="berdiri_6" guid="a513ebf1-7f20-58b3-a825-dc7e341d04d3"><grammatical-info value="Verb"/><gloss lang="en"><text>to start (an institution or organization)</text></gloss></sense><sense id="berdiri_7" guid="5bc3057c-0311-5814-b237-a1dba8718278"><grammatical-info value="Verb"/><gloss lang="en"><text>to be built</text></gloss></sense></entry>
<entry id="berdoa" guid="649c022b-7221-57cc-9278-2d261eabb0e1"><lexical-unit><form lang="id"><text>berdoa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berdoa_0" guid="963ab920-864f-51cc-a6f7-84715ed45aca"><grammatical-info value="Verb"/><gloss lang="en"><text>to pray</text></gloss></sense></entry>
