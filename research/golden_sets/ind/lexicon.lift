<entry id="ratu" guid="d5a869d6-97f1-5cbc-b15b-f6d9e4c89885"><lexical-unit><form lang="id"><text>ratu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ratu_0" guid="b655dbdb-e37f-51ee-8762-7adb01871253"><grammatical-info value="Noun"/><gloss lang="en"><text>monarch</text></gloss></sense><sense id="ratu_1" guid="2a5ba27e-de85-555a-8885-7ffbce0a36d9"><grammatical-info value="Noun"/><gloss lang="en"><text>queen:</text></gloss></sense><sense id="ratu_2" guid="0dfa542d-df18-5744-8842-7fe0bdce93c3"><grammatical-info value="Noun"/><gloss lang="en"><text>queen regnant: female monarch</text></gloss></sense><sense id="ratu_3" guid="f0383b03-e0be-598a-85de-a8382bbed425"><grammatical-info value="Noun"/><gloss lang="en"><text>queen consort: wife of a king</text></gloss></sense><sense id="ratu_4" guid="0d464878-bdf0-57ce-90c6-3f9d04242c72"><grammatical-info value="Noun"/><gloss lang="en"><text>the most powerful piece, able to move any number of spaces horizontally, vertically, or diagonally</text></gloss></sense><sense id="ratu_5" guid="72ea36b3-654c-598a-ac35-a99543349273"><grammatical-info value="Noun"/><gloss lang="en"><text>reproductive female insect in a hive.</text></gloss></sense><sense id="ratu_6" guid="0fe48e7e-3363-5080-8e2c-4dfb8a7633f5"><grammatical-info value="Noun"/><gloss lang="en"><text>a female given name from Malay</text></gloss></sense></entry>
