<entry id="gampang" guid="1859dfc0-d058-5e4a-b1bd-c633f5d26273"><lexical-unit><form lang="id"><text>gampang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gampang_0" guid="7bc19ec8-19ac-5bc8-953b-aaf67a2e851f"><grammatical-info value="Adjective"/><gloss lang="en"><text>easy (requiring little skill or effort)</text></gloss></sense><sense id="gampang_1" guid="35420823-391b-5598-9db6-b710cb0cb34d"><grammatical-info value="Adjective"/><gloss lang="en"><text>unimportant</text></gloss></sense></entry>
