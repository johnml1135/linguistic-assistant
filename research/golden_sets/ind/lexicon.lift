<entry id="marga" guid="c17bda7d-f218-59f6-b9ff-11f87073da0b"><lexical-unit><form lang="id"><text>marga</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="marga_0" guid="1f98c5ec-5577-5028-91ee-da9ff8671a93"><grammatical-info value="Noun"/><gloss lang="en"><text>wild animal</text></gloss></sense><sense id="marga_1" guid="b05bb2c4-1fa5-5299-8a8d-fc61ef69d165"><grammatical-info value="Noun"/><gloss lang="en"><text>clan</text></gloss></sense><sense id="marga_2" guid="af36e2f4-076f-5654-864d-6650731fc924"><grammatical-info value="Noun"/><gloss lang="en"><text>specifically, the marga, Batak clan</text></gloss></sense><sense id="marga_3" guid="fb0334f3-8dae-5269-80e6-aee9e838c203"><grammatical-info value="Noun"/><gloss lang="en"><text>the subdivision in South Sumatra, located above villages and below districts (kecamatan)</text></gloss></sense><sense id="marga_4" guid="ad4f2b18-4d61-5b94-bcdb-3b7b0f33f1d7"><grammatical-info value="Noun"/><gloss lang="en"><text>genus, a rank in the classification of organisms, below family and above species; a taxon at that rank</text></gloss></sense><sense id="marga_5" guid="adea4bc3-859f-5b5c-9a8b-7f5ad0038f0f"><grammatical-info value="Noun"/><gloss lang="en"><text>way, road, route, path</text></gloss></sense><sense id="marga_6" guid="12a11f3e-5e57-5f04-9a2a-9adebd67a1fe"><grammatical-info value="Noun"/><gloss lang="en"><text>surname; family name</text></gloss></sense><sense id="marga_7" guid="c98f6323-4958-5bf9-bb0f-773d78395da1"><grammatical-info value="Noun"/><gloss lang="en"><text>a surname</text></gloss></sense></entry>
<entry id="mari" guid="a3d40c15-282f-5428-935b-c1b8de059822"><lexical-unit><form lang="id"><text>mari</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mari_0" guid="9f218a33-1cfd-5bd3-93be-280edbdbc2d6"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to come here</text></gloss></sense><sense id="mari_1" guid="f4e492ae-0633-5b11-a3b4-62391e3cc6b9"><grammatical-info value="Proper noun"/><gloss lang="en"><text>let; let's</text></gloss></sense><sense id="mari_2" guid="376891b5-ee56-517c-81b4-1832ae9b86eb"><grammatical-info value="Proper noun"/><gloss lang="en"><text>come on!</text></gloss></sense></entry>
<entry id="maria" guid="5be71914-3259-5299-9b7c-30c9527529db"><lexical-unit><form lang="id"><text>maria</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="maria_0" guid="4c42e44d-8dfa-5a9d-a2e1-5853230928e8"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Mary (Biblical character, mother of Jesus)</text></gloss></sense><sense id="maria_1" guid="6efe798b-37db-57e9-ba40-5c81506ab3d8"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Mary (Biblical character, Mary Magdalene)</text></gloss></sense><sense id="maria_2" guid="2ea348b3-874b-5e21-8347-bfdc8f4c742f"><grammatical-info value="Proper noun"/><gloss lang="en"><text>maria, mare</text></gloss></sense><sense id="maria_3" guid="b6b403db-a265-52e2-bd10-9bc83da602a0"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a female given name from Hebrew</text></gloss></sense></entry>
<entry id="markas" guid="745adcbb-dd53-586c-97fe-4372fc37e7ae"><lexical-unit><form lang="id"><text>markas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="markas_0" guid="cde19a0b-b06e-5490-b958-7d6927c69864"><grammatical-info value="Noun"/><gloss lang="en"><text>base, headquarter</text></gloss></sense></entry>
<entry id="markus" guid="695aed6b-56a1-57d4-9798-e4a443696c64"><lexical-unit><form lang="id"><text>markus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="markus_0" guid="19dc15f6-00db-5884-8c1f-85f3af5c76d1"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Mark (disciple of Jesus, author of the Gospel of Matthew)</text></gloss></sense><sense id="markus_1" guid="8fb5fae8-5688-54c5-8c00-67ec887ecf52"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Mark (book of the Bible)</text></gloss></sense><sense id="markus_2" guid="eb31086e-2174-562d-9e5f-395788564b49"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a male given name from Latin</text></gloss></sense><sense id="markus_3" guid="39fa35f8-ab32-506d-ae19-f515e3fd6abe"><grammatical-info value="Proper noun"/><gloss lang="en"><text>syllabic abbreviation of makelar kasus</text></gloss></sense></entry>
<entry id="marta" guid="f2f8c481-e263-5456-984e-cbe86f0f4da6"><lexical-unit><form lang="id"><text>marta</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="marta_0" guid="f6fec01f-483e-5960-bdc0-1b0da8f82f00"><grammatical-info value="Proper noun"/><gloss lang="en"><text>martha</text></gloss></sense></entry>
<entry id="martir" guid="cf019bd2-0475-5860-b355-df6551a52788"><lexical-unit><form lang="id"><text>martir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="martir_0" guid="1d62c519-63b7-51f6-8262-0b9e212ff502"><grammatical-info value="Noun"/><gloss lang="en"><text>martyr, one who willingly accepts being put to death for adhering openly to one's religious beliefs</text></gloss></sense></entry>
<entry id="mas" guid="fd8ac29f-b5c5-5896-bcb3-e84bc40dbe0d"><lexical-unit><form lang="id"><text>mas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mas_0" guid="628232bf-609b-55ec-80f1-effa3e7193e8"><grammatical-info value="Proper noun"/><gloss lang="en"><text>alternative form of emas (“gold”)</text></gloss></sense></entry>
<entry id="masa" guid="c35ae79d-8c8d-59ed-9bf4-a88e5e2b1027"><lexical-unit><form lang="id"><text>masa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="masa_0" guid="6a524af6-691a-5919-9c75-667eab9264aa"><grammatical-info value="Noun"/><gloss lang="en"><text>period,</text></gloss></sense><sense id="masa_1" guid="5b631a2d-08d3-5dbe-9692-fe2088eca929"><grammatical-info value="Noun"/><gloss lang="en"><text>history: period of time seen as coherent entity</text></gloss></sense><sense id="masa_2" guid="e2dbce4f-624a-5dea-a490-501f4e0ac713"><grammatical-info value="Noun"/><gloss lang="en"><text>length of time</text></gloss></sense><sense id="masa_3" guid="9b79d045-8e4d-518d-8b2b-b66864394910"><grammatical-info value="Noun"/><gloss lang="en"><text>length of time during which something repeats</text></gloss></sense><sense id="masa_4" guid="4811d9e4-79ce-58a9-b3ed-12c84ee2ddff"><grammatical-info value="Noun"/><gloss lang="en"><text>time,</text></gloss></sense><sense id="masa_5" guid="e63970ec-08eb-5a12-9bb2-2f23db4cfa52"><grammatical-info value="Noun"/><gloss lang="en"><text>inevitable passing of events</text></gloss></sense><sense id="masa_6" guid="d5ba9498-ea46-52d3-a2f8-cb1f428c8368"><grammatical-info value="Noun"/><gloss lang="en"><text>quantity of availability in time</text></gloss></sense><sense id="masa_7" guid="c22b87d6-6c64-5f93-a8c6-54d8a5767f30"><grammatical-info value="Noun"/><gloss lang="en"><text>time of day, as indicated by a clock, etc.</text></gloss></sense></entry>
<entry id="masak" guid="711e335b-722b-5003-9ff0-08e8e0946cf9"><lexical-unit><form lang="id"><text>masak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="masak_0" guid="2314561f-b57c-514b-830d-9e9d341875bc"><grammatical-info value="Noun"/><gloss lang="en"><text>Cooked, done</text></gloss></sense><sense id="masak_1" guid="3edf8591-bb99-5cb5-bc4d-7f418987b9a0"><grammatical-info value="Noun"/><gloss lang="en"><text>Ripe</text></gloss></sense><sense id="masak_2" guid="b3a7532b-0afc-535d-ba6b-8e14042f624a"><grammatical-info value="Noun"/><gloss lang="en"><text>Final, finished; brought to a state of complete readiness.</text></gloss></sense><sense id="masak_3" guid="49b35778-c6dd-561a-b65e-6f3de58cbb8a"><grammatical-info value="Noun"/><gloss lang="en"><text>Mature; fully developed; grown up (typically in terms behavior or thinking).</text></gloss></sense><sense id="masak_4" guid="a4dd2c41-cfff-55c5-9377-17dae79ac752"><grammatical-info value="Noun"/><gloss lang="en"><text>to cook</text></gloss></sense><sense id="masak_5" guid="1c52d5a2-de50-581d-8f9c-be024dce3d3a"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative spelling of masa</text></gloss></sense></entry>
<entry id="masalah" guid="c3f89b22-d2d0-5bf7-9977-cba19d1dcb33"><lexical-unit><form lang="id"><text>masalah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="masalah_0" guid="b1ea3aa3-eabd-5501-87c4-4d9b857da1db"><grammatical-info value="Noun"/><gloss lang="en"><text>problem</text></gloss></sense><sense id="masalah_1" guid="db4917ae-4ae3-5add-b2d1-0b4af7701bf5"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative spelling of masyaallah (“mashallah, what God wills; God has willed”)</text></gloss></sense></entry>
<entry id="masih" guid="8e3388e5-bf91-5d1a-b4b1-3b7ac05b35f4"><lexical-unit><form lang="id"><text>masih</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="masih_0" guid="6648322a-dca4-5f56-a0b7-b4293c1f6a15"><grammatical-info value="Adverb"/><gloss lang="en"><text>still</text></gloss></sense></entry>
<entry id="masuk" guid="bc568939-8599-5550-90be-44d801e274e6"><lexical-unit><form lang="id"><text>masuk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="masuk_0" guid="fe95571d-09a3-5191-925c-b1b87df757b2"><grammatical-info value="Verb"/><gloss lang="en"><text>to come in</text></gloss></sense><sense id="masuk_1" guid="9bf0fbab-f647-573b-844c-16a249c06fe7"><grammatical-info value="Verb"/><gloss lang="en"><text>to enter</text></gloss></sense><sense id="masuk_2" guid="ed670f86-3d69-5487-98e9-ff4e20a34c10"><grammatical-info value="Verb"/><gloss lang="en"><text>to go or come into an enclosed or partially enclosed space</text></gloss></sense><sense id="masuk_3" guid="705fdc78-4bb8-5f77-803c-354d8291d1d5"><grammatical-info value="Verb"/><gloss lang="en"><text>to go or come into a state</text></gloss></sense><sense id="masuk_4" guid="2d646722-8c98-5de9-beed-1e4e12762c4c"><grammatical-info value="Verb"/><gloss lang="en"><text>to go or come into a profession</text></gloss></sense><sense id="masuk_5" guid="14a67d4e-ad17-5cb7-9e41-62a81e11fbae"><grammatical-info value="Verb"/><gloss lang="en"><text>to type (something) into a computer; to input</text></gloss></sense><sense id="masuk_6" guid="5c25f653-62d2-588d-998c-50dc81a24a65"><grammatical-info value="Verb"/><gloss lang="en"><text>to become a member of; to join</text></gloss></sense><sense id="masuk_7" guid="0cf23688-89b8-5c87-bc4a-556b19ab8930"><grammatical-info value="Verb"/><gloss lang="en"><text>to be included (dalam, in)</text></gloss></sense></entry>
<entry id="masukan" guid="b89729ff-fb4a-51c5-aebd-fa0a92f1f348"><lexical-unit><form lang="id"><text>masukan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="masukan_0" guid="93c512e0-2320-50a8-b936-cf60da45f01a"><grammatical-info value="Noun"/><gloss lang="en"><text>input</text></gloss></sense><sense id="masukan_1" guid="bb647214-e329-5cbb-9f9e-099abfe2a722"><grammatical-info value="Noun"/><gloss lang="en"><text>that which is put in, as in an amount.</text></gloss></sense><sense id="masukan_2" guid="ace05d29-132f-55bf-9eb0-ffe3b714677d"><grammatical-info value="Noun"/><gloss lang="en"><text>contribution of work or information, as an opinion or advice.</text></gloss></sense><sense id="masukan_3" guid="c5574ce7-67fc-5737-b565-8c70170416a3"><grammatical-info value="Noun"/><gloss lang="en"><text>data fed into a process with the intention of it shaping or affecting the output of that process.</text></gloss></sense><sense id="masukan_4" guid="510671d2-64e4-516f-8d19-cb0b308250f1"><grammatical-info value="Noun"/><gloss lang="en"><text>an input jack.</text></gloss></sense><sense id="masukan_5" guid="fe1e90ed-1de1-50f1-8202-ac6cb7f65c64"><grammatical-info value="Noun"/><gloss lang="en"><text>any resource or factor used in the production process to create goods and services.</text></gloss></sense><sense id="masukan_6" guid="0b9e2c06-e95f-5f23-a1f8-6cc54ae60412"><grammatical-info value="Noun"/><gloss lang="en"><text>advice</text></gloss></sense><sense id="masukan_7" guid="1edc7211-f97f-500d-953d-54b0fd6f37c6"><grammatical-info value="Noun"/><gloss lang="en"><text>inlet</text></gloss></sense></entry>
<entry id="masuki" guid="346840be-0aa4-566b-9797-682e860f71df"><lexical-unit><form lang="id"><text>masuki</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="masuki_0" guid="85f243bd-8b2f-543f-9c01-dbe088f9aadc"><gloss lang="en"><text>failed</text></gloss></sense></entry>
<entry id="masukkan" guid="c82eda7c-d48c-5ac4-9473-b1146f8e608b"><lexical-unit><form lang="id"><text>masukkan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="masukkan_0" guid="1655713d-8277-528b-8bce-039d2ed98111"><grammatical-info value="Verb"/></sense></entry>
<entry id="masyarakat" guid="7cadfc7d-d6d1-5a26-9aa7-8f7eafa7c944"><lexical-unit><form lang="id"><text>masyarakat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="masyarakat_0" guid="bf4997ff-9d64-56c2-8b58-529ef0d3f225"><grammatical-info value="Noun"/><gloss lang="en"><text>society</text></gloss></sense><sense id="masyarakat_1" guid="bf30128d-06dd-5ec6-8b87-416f922babab"><grammatical-info value="Noun"/><gloss lang="en"><text>community (a group sharing common characteristics, such as the same language, law, religion, or tradition)</text></gloss></sense><sense id="masyarakat_2" guid="3700a2a2-d373-541b-b77b-bfdba057ea60"><grammatical-info value="Noun"/><gloss lang="en"><text>community (a residential or religious collective; a commune)</text></gloss></sense><sense id="masyarakat_3" guid="07a6e76c-1401-58ca-b7a1-00e97ff5a4be"><grammatical-info value="Noun"/><gloss lang="en"><text>community (a group of people interacting by electronic means for educational, professional, social, or other purposes; a virtual community)</text></gloss></sense></entry>
<entry id="mata" guid="b14e1ca4-8789-5f03-9ff0-d6a94e2ad468"><lexical-unit><form lang="id"><text>mata</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mata_0" guid="42c6bd34-eff6-5fd3-b021-deea6b7aade7"><grammatical-info value="Noun"/><gloss lang="en"><text>eye:</text></gloss></sense><sense id="mata_1" guid="2a085152-7e1b-5616-a4b2-4c42c6103007"><grammatical-info value="Noun"/><gloss lang="en"><text>the organ through which animals perceive surroundings via light.</text></gloss></sense><sense id="mata_2" guid="4a536b4d-a4e1-58f4-9dca-b772e521f406"><grammatical-info value="Noun"/><gloss lang="en"><text>a loop forming part of anything, or a hole through anything, to receive a hook, etc.</text></gloss></sense><sense id="mata_3" guid="771e3e51-bed2-5bf6-b134-a54053c37f27"><grammatical-info value="Noun"/><gloss lang="en"><text>a part from which plant shoots grow; a reproductive bud.</text></gloss></sense><sense id="mata_4" guid="b657a70a-4742-528e-a531-7c7351c12f23"><grammatical-info value="Noun"/><gloss lang="en"><text>a gap between two lines.</text></gloss></sense><sense id="mata_5" guid="0321f7dd-a776-5389-a94a-f3bfb9397bb8"><grammatical-info value="Noun"/><gloss lang="en"><text>blade (the part of a knife, sword, razor, or other tool with which it cuts).</text></gloss></sense><sense id="mata_6" guid="8877f93d-c4a6-5455-b022-0d3807e905f9"><grammatical-info value="Noun"/><gloss lang="en"><text>an important part of something.</text></gloss></sense><sense id="mata_7" guid="33d86686-f777-5059-ab3a-a5bf7c8ae935"><grammatical-info value="Noun"/><gloss lang="en"><text>center.</text></gloss></sense></entry>
<entry id="matahari" guid="ebe4a50d-205f-509b-bcaf-aed45702dc55"><lexical-unit><form lang="id"><text>matahari</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="matahari_0" guid="5b32fb64-d475-56f2-9e8b-bbfcd83e16ec"><grammatical-info value="Noun"/><gloss lang="en"><text>sun</text></gloss></sense><sense id="matahari_1" guid="8fd236c6-0f06-5029-a3c5-75bde259b911"><grammatical-info value="Noun"/><gloss lang="en"><text>the Sun: the star around which the Earth revolves</text></gloss></sense></entry>
<entry id="matang" guid="8da195bd-c73d-575c-8204-4bf3a6f2b18f"><lexical-unit><form lang="id"><text>matang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="matang_0" guid="4cee5e55-479f-5686-9b27-5731624a429b"><grammatical-info value="Adjective"/><gloss lang="en"><text>ripe</text></gloss></sense><sense id="matang_1" guid="f276b8ac-9c30-5a4d-a6e4-6f92a2c2be88"><grammatical-info value="Adjective"/><gloss lang="en"><text>mature (ready for reaping or gathering; having attained perfection)</text></gloss></sense><sense id="matang_2" guid="89f09fd2-26ee-5fce-93e0-93e4faf19cf9"><grammatical-info value="Adjective"/><gloss lang="en"><text>mellow (advanced to the state of fitness for use)</text></gloss></sense><sense id="matang_3" guid="d58989cd-aa41-57db-b124-7bdee3034177"><grammatical-info value="Adjective"/><gloss lang="en"><text>mature; perfected (having attained its full development)</text></gloss></sense><sense id="matang_4" guid="b43f1abe-349d-5c15-b3da-1384ff0807db"><grammatical-info value="Adjective"/><gloss lang="en"><text>prepared (ready for action or effect).</text></gloss></sense><sense id="matang_5" guid="7bfd5a67-9d1c-5385-b5c1-786eea103a2c"><grammatical-info value="Adjective"/><gloss lang="en"><text>eager, ready, willing.</text></gloss></sense><sense id="matang_6" guid="ba00e5e8-d33b-5477-bc13-367e34bdded6"><grammatical-info value="Adjective"/><gloss lang="en"><text>boiled</text></gloss></sense><sense id="matang_7" guid="91c29769-4926-55f9-8ea3-0da72d5a0bc1"><grammatical-info value="Adjective"/><gloss lang="en"><text>certain, definite.</text></gloss></sense></entry>
<entry id="materai" guid="e5471b22-fab6-58cd-be88-9f34aebfd696"><lexical-unit><form lang="id"><text>materai</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="materai_0" guid="becf852e-3070-518e-bf70-2f799de38121"><grammatical-info value="Noun"/><gloss lang="en"><text>nonstandard form of meterai (“stamp”)</text></gloss></sense></entry>
<entry id="material" guid="fc8d6e6d-0c19-5c80-ba14-0b5af1ca227a"><lexical-unit><form lang="id"><text>material</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="material_0" guid="541db649-475e-5de9-a3ba-e5567e38eaf9"><grammatical-info value="Noun"/><gloss lang="en"><text>material (matter which may be shaped or manipulated, particularly in making something)</text></gloss></sense></entry>
<entry id="mati" guid="8987e2f2-06f1-5d4f-888f-e8196d43bb68"><lexical-unit><form lang="id"><text>mati</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mati_0" guid="efb72f9b-a74f-508a-8611-3c3d0067f25b"><grammatical-info value="Verb"/><gloss lang="en"><text>to die</text></gloss></sense><sense id="mati_1" guid="eadedfc5-0168-58e8-a9f3-fc9f81e55cba"><grammatical-info value="Verb"/><gloss lang="en"><text>to be dead</text></gloss></sense><sense id="mati_2" guid="73d99002-1853-5df6-9b05-d4dafd85c1f1"><grammatical-info value="Verb"/><gloss lang="en"><text>to stop (of an engine/watch, etc.), to be out of order, to be broken, to be stopped working</text></gloss></sense><sense id="mati_3" guid="6bdd30c0-df67-5847-a8ab-4f2754d2a614"><grammatical-info value="Verb"/><gloss lang="en"><text>to go out, to be extinguished (of a light/flame/fire/ lamp/radio, etc.)</text></gloss></sense><sense id="mati_4" guid="ccc96c10-5973-528e-a8a4-0bc665f2a32a"><grammatical-info value="Verb"/><gloss lang="en"><text>dead</text></gloss></sense><sense id="mati_5" guid="012b8c2c-d66b-5b89-8fb9-d02e88ab8999"><grammatical-info value="Verb"/><gloss lang="en"><text>no longer living; deceased</text></gloss></sense><sense id="mati_6" guid="d678f4b4-4e0a-5a8b-8ba4-fbd47f260806"><grammatical-info value="Verb"/><gloss lang="en"><text>devoid of living things; barren</text></gloss></sense><sense id="mati_7" guid="5ae808a4-3452-5ea5-8aed-76ef453db92d"><grammatical-info value="Verb"/><gloss lang="en"><text>completely inactive; currently without power; without a signal; not live</text></gloss></sense></entry>
<entry id="matikanlah" guid="de81d60c-c246-553e-97dc-a7732db9caa7"><lexical-unit><form lang="id"><text>matikanlah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="matikanlah_0" guid="14848565-bac7-5fae-84f3-2ae780858a05"><grammatical-info value="Verb"/><gloss lang="en"><text>jussive/emphatic of mematikan</text></gloss></sense></entry>
<entry id="matius" guid="d8ffdc15-9146-50ac-a8b3-d50d2d1f0fc9"><lexical-unit><form lang="id"><text>matius</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="matius_0" guid="ed4672b2-7209-511b-aec5-712e71422193"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Matthew (disciple of Jesus, author of the Gospel of Matthew)</text></gloss></sense><sense id="matius_1" guid="945aacfe-3719-5657-960d-4baad4e9d08e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Matthew (book of the Bible)</text></gloss></sense><sense id="matius_2" guid="fc7ee8d6-7ae1-5eee-92f0-a4485b1bf5be"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a male given name from Latin, equivalent to English Matthew</text></gloss></sense></entry>
<entry id="matras" guid="900408bb-0e2e-5521-8095-36b22098393e"><lexical-unit><form lang="id"><text>matras</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="matras_0" guid="9827bbab-bf2d-569b-a70f-8b9c8e93cbd2"><grammatical-info value="Noun"/><gloss lang="en"><text>mattress</text></gloss></sense><sense id="matras_1" guid="410cbaa9-01cb-5d70-a53d-fa347d242e86"><grammatical-info value="Noun"/><gloss lang="en"><text>bolthead flask</text></gloss></sense></entry>
<entry id="mau" guid="bda32a6b-5753-5ced-86b9-0952bd0f730c"><lexical-unit><form lang="id"><text>mau</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mau_0" guid="bc79209f-9752-535a-8463-c4c48eedbc9d"><grammatical-info value="Verb"/><gloss lang="en"><text>to want</text></gloss></sense><sense id="mau_1" guid="e1389a5c-cc3c-5631-82e6-d20472315078"><grammatical-info value="Verb"/><gloss lang="en"><text>to wish for or desire (something); to feel a need or desire for; to crave or demand</text></gloss></sense><sense id="mau_2" guid="4928e4e3-68d4-5310-b2df-3511c7df168f"><grammatical-info value="Verb"/><gloss lang="en"><text>to wish, desire, or demand to see, have the presence of or do business with</text></gloss></sense><sense id="mau_3" guid="f06035ec-9fb8-5c2a-b137-e000a381f284"><grammatical-info value="Verb"/><gloss lang="en"><text>to experience desire; to wish</text></gloss></sense><sense id="mau_4" guid="33742652-fe5c-5b48-b251-92745c2fe213"><grammatical-info value="Verb"/><gloss lang="en"><text>to will</text></gloss></sense><sense id="mau_5" guid="0a95de2d-141b-5c5e-96fe-81acc9e5470b"><grammatical-info value="Verb"/><gloss lang="en"><text>to be able to, to have the capacity</text></gloss></sense><sense id="mau_6" guid="17371b66-a8b3-5c41-8b48-cd810f974446"><grammatical-info value="Verb"/><gloss lang="en"><text>used to express intention but without any temporal connotations, often in questions and negation</text></gloss></sense></entry>
<entry id="maut" guid="8a0c16bd-8bf5-54ac-a9c1-f69e9e8a853c"><lexical-unit><form lang="id"><text>maut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="maut_0" guid="84894fe6-210f-522b-b6b9-829af54130e3"><grammatical-info value="Noun"/><gloss lang="en"><text>death</text></gloss></sense><sense id="maut_1" guid="2620404b-adb6-5713-bc38-e531f4df5090"><grammatical-info value="Noun"/><gloss lang="en"><text>deathly, deadly, fatal, causing death</text></gloss></sense><sense id="maut_2" guid="f7363a2e-8314-5d8e-9298-5c809ca7b2e8"><grammatical-info value="Noun"/><gloss lang="en"><text>extraordinary</text></gloss></sense></entry>
