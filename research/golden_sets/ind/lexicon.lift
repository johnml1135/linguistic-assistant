<entry id="alas" guid="f05afe4d-5ff4-5df1-b281-c3a5a270bf14"><lexical-unit><form lang="id"><text>alas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alas_0" guid="b33afe19-b0ba-5259-9def-c74924ea803c"><grammatical-info value="Proper noun"/><gloss lang="en"><text>base, foundation</text></gloss></sense><sense id="alas_1" guid="7d890a66-a4ad-5c7c-925c-866c3b3215d7"><grammatical-info value="Proper noun"/><gloss lang="en"><text>layer, lining, covering</text></gloss></sense><sense id="alas_2" guid="b3b78b03-b8f0-5f46-be9d-6dcab8857ccd"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a structure that becomes a support for other structures above it, such as a pedestal on a statue</text></gloss></sense><sense id="alas_3" guid="c60dfb96-d5b8-5063-aea1-184f2d5005d8"><grammatical-info value="Proper noun"/><gloss lang="en"><text>forest</text></gloss></sense><sense id="alas_4" guid="ff0c9a07-5f24-5f26-a0a2-4a64dc4cd983"><grammatical-info value="Proper noun"/><gloss lang="en"><text>rope on a small boat stabilizer</text></gloss></sense><sense id="alas_5" guid="fccb8c4b-718f-547c-a8a1-14f9f51358f0"><grammatical-info value="Proper noun"/><gloss lang="en"><text>coarse, sandy</text></gloss></sense><sense id="alas_6" guid="bc8d0e4f-dfb7-5d9c-a63c-1d254dd7fdbb"><grammatical-info value="Proper noun"/><gloss lang="en"><text>an indigenous Batak sub-ethnic group from Southeast Aceh Regency, Aceh, Sumatra, Indonesia.</text></gloss></sense></entry>
<entry id="alasan" guid="a8e391ff-395e-567c-b62a-3d7c3db59777"><lexical-unit><form lang="id"><text>alasan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alasan_0" guid="e5f40bb8-1705-5ca3-80e5-d1af43e67fda"><grammatical-info value="Noun"/><gloss lang="en"><text>proof</text></gloss></sense><sense id="alasan_1" guid="766f0f2e-4aee-5374-a8fb-d6634dd89acd"><grammatical-info value="Noun"/><gloss lang="en"><text>argument</text></gloss></sense><sense id="alasan_2" guid="df3a6dd4-5279-5c5c-a92b-0613f5e8a677"><grammatical-info value="Noun"/><gloss lang="en"><text>reason</text></gloss></sense><sense id="alasan_3" guid="7c86dd37-9182-5133-b579-0d96e6ee2318"><grammatical-info value="Noun"/><gloss lang="en"><text>excuse</text></gloss></sense></entry>
<entry id="alat" guid="ac3cc5e4-7364-5556-b6ac-2f6b36a5ed45"><lexical-unit><form lang="id"><text>alat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alat_0" guid="626d1de3-d413-50bf-b1f9-b80e8a69aca9"><grammatical-info value="Noun"/><gloss lang="en"><text>tool</text></gloss></sense><sense id="alat_1" guid="63347a9b-6dd7-525b-853d-aeb9069c150c"><grammatical-info value="Noun"/><gloss lang="en"><text>device intended to make a task easier; Any mechanical device meant to ease or do a task</text></gloss></sense><sense id="alat_2" guid="71719c78-7f8f-595d-8319-ac6425b98acf"><grammatical-info value="Noun"/><gloss lang="en"><text>any piece of equipment used in a profession, e.g. a craftman's tools</text></gloss></sense><sense id="alat_3" guid="b65a7e52-fc41-5139-9161-2d1e241c2394"><grammatical-info value="Noun"/><gloss lang="en"><text>something to perform an operation; an instrument; a means</text></gloss></sense><sense id="alat_4" guid="58f74a8b-e008-5563-abf4-f11e28e29908"><grammatical-info value="Noun"/><gloss lang="en"><text>equipment</text></gloss></sense><sense id="alat_5" guid="979bc2aa-1cb8-57fa-b6e0-3b727ec0eea0"><grammatical-info value="Noun"/><gloss lang="en"><text>guest</text></gloss></sense><sense id="alat_6" guid="f9c7582d-9c21-5c24-b43d-15292d6d1554"><grammatical-info value="Noun"/><gloss lang="en"><text>feast</text></gloss></sense></entry>
<entry id="aleksander" guid="c71059f0-f5f3-5f61-bb2c-0a2071bf44d9"><lexical-unit><form lang="id"><text>aleksander</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aleksander_0" guid="f2d38083-00fe-5fbd-bc0e-6a1d068c0b50"><grammatical-info value="Proper noun"/><gloss lang="en"><text>alexander</text></gloss></sense></entry>
<entry id="alexander" guid="c80f5d0e-2c1e-504a-848a-c39d8292e5b8"><lexical-unit><form lang="id"><text>alexander</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alexander_0" guid="47ff05ec-29a7-57a5-93eb-fc79052d3878"><grammatical-info value="Proper noun"/><gloss lang="en"><text>alexander</text></gloss></sense></entry>
<entry id="alfa" guid="29cb6a2e-acfd-5eae-ae6e-d81af028a9ad"><lexical-unit><form lang="id"><text>alfa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alfa_0" guid="4954cd69-00fb-5d09-9f80-883bf6065cbf"><grammatical-info value="Proper noun"/><gloss lang="en"><text>alpha:</text></gloss></sense><sense id="alfa_1" guid="b24530d3-17e3-5274-b3ee-97a92702e85e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>first, see alpha and omega</text></gloss></sense><sense id="alfa_2" guid="80ffe684-e7b9-520e-bf1c-2d0bab4b5d95"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Alpha, the brightest star in a constellation according to the Bayer designation</text></gloss></sense><sense id="alfa_3" guid="d057bd9a-d280-5eae-8e85-5546f1a394c7"><grammatical-info value="Proper noun"/><gloss lang="en"><text>common-base current gain of a transistor in electronics</text></gloss></sense><sense id="alfa_4" guid="18a5a713-bccd-5dc4-a9e2-0d20bec37cf1"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the significance level of a statistical test; the alpha level</text></gloss></sense><sense id="alfa_5" guid="a663d871-65a2-58d6-9e28-1ee520864af2"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the name of the first letter of the Greek alphabet (Α, α), followed by beta; in the Latin alphabet it is the predecessor to A</text></gloss></sense></entry>
<entry id="ali" guid="f0910550-b797-5dd1-a032-1c4dfa882e41"><lexical-unit><form lang="id"><text>ali</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ali_0" guid="a3b53092-72bd-552b-88db-a73fdda0d3cb"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to show oneself</text></gloss></sense><sense id="ali_1" guid="8eaf85e3-e7ae-5965-b3b7-b0de7bfcf5e6"><grammatical-info value="Proper noun"/><gloss lang="en"><text>greeting</text></gloss></sense><sense id="ali_2" guid="d9015098-2eff-529f-8c6b-69e99b52fcd3"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Ali ibn Abi Talib (son-in-law of Muhammad)</text></gloss></sense><sense id="ali_3" guid="41d074d5-94f7-50bc-a658-98e79ad59a03"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a male given name from Arabic, equivalent to English Ali</text></gloss></sense></entry>
<entry id="alih" guid="7e7735d0-b821-5a6c-ba43-ee88c664e8e0"><lexical-unit><form lang="id"><text>alih</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alih_0" guid="d94a2ec6-98af-5f7d-869f-b4042be761a5"><grammatical-info value="Verb"/><gloss lang="en"><text>synonym of pindah (“to move, change place”); to wend</text></gloss></sense><sense id="alih_1" guid="34899ede-214b-5d65-9aa1-a52236ae7903"><grammatical-info value="Verb"/><gloss lang="en"><text>trans-, re- shift</text></gloss></sense></entry>
<entry id="alir" guid="13b9e24b-ce01-5ab0-b36a-2d56ffed1442"><lexical-unit><form lang="id"><text>alir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alir_0" guid="859b680c-1440-5f62-a16e-2c67d3a0b510"><grammatical-info value="Noun"/><gloss lang="en"><text>basic form of mengalir (“to flow”)</text></gloss></sense><sense id="alir_1" guid="d7ec6b45-9131-5e3d-88bd-f0ded59dea6a"><grammatical-info value="Noun"/><gloss lang="en"><text>a rod, usually with live bait to catch a crocodile</text></gloss></sense><sense id="alir_2" guid="f44262ed-48d1-52fd-937f-5bd24d541967"><grammatical-info value="Noun"/><gloss lang="en"><text>to catch, a crocodile with that fishing rod</text></gloss></sense></entry>
<entry id="alis" guid="c70725ac-0761-581c-a5c5-91eeba64176c"><lexical-unit><form lang="id"><text>alis</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="alis_0" guid="d54acc02-5349-5ffd-a522-794200b12229"><grammatical-info value="Noun"/><gloss lang="en"><text>eyebrow</text></gloss></sense></entry>
