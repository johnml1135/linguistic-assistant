<entry id="pengertian" guid="5ef42a5c-526c-5e47-bcfe-fda00de5f694"><lexical-unit><form lang="id"><text>pengertian</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pengertian_0" guid="3a28f2e4-322d-5b38-ac92-3e25395b9ab8"><grammatical-info value="Noun"/><gloss lang="en"><text>understanding (the act of one that understands)</text></gloss></sense><sense id="pengertian_1" guid="d5aa5e37-106b-596b-a57e-ec379077da1d"><grammatical-info value="Noun"/><gloss lang="en"><text>definition</text></gloss></sense><sense id="pengertian_2" guid="57ea8b7e-6748-59ae-be82-faa8d1ae5544"><grammatical-info value="Noun"/><gloss lang="en"><text>a statement of the meaning of a word or word group or a sign or symbol (dictionary definitons)</text></gloss></sense><sense id="pengertian_3" guid="5aca44f3-a539-5b85-a6d1-a4e935d463f9"><grammatical-info value="Noun"/><gloss lang="en"><text>a clear instance conforming to the dictionary or textbook definition</text></gloss></sense></entry>
<entry id="pengetahuan" guid="b52ab6dd-50b2-5ccb-8c83-cedafcd8a91b"><lexical-unit><form lang="id"><text>pengetahuan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pengetahuan_0" guid="e804cc23-2c21-5ba8-bd02-0614befded54"><grammatical-info value="Noun"/><gloss lang="en"><text>knowledge</text></gloss></sense><sense id="pengetahuan_1" guid="2d432354-7be2-538c-a992-6efd6350d39e"><grammatical-info value="Noun"/><gloss lang="en"><text>the fact of knowing about something; general understanding or familiarity with a subject, place, situation etc.</text></gloss></sense><sense id="pengetahuan_2" guid="f21e2dc4-20a4-59eb-8ab2-1781856fe65f"><grammatical-info value="Noun"/><gloss lang="en"><text>awareness of a particular fact or situation; a state of having been informed or made aware of something</text></gloss></sense><sense id="pengetahuan_3" guid="e180b352-c3b7-5025-b8dd-c2f1562df199"><grammatical-info value="Noun"/><gloss lang="en"><text>intellectual understanding; the state of appreciating truth or information</text></gloss></sense><sense id="pengetahuan_4" guid="f365fdae-1982-5d33-b7b7-e4a79db27204"><grammatical-info value="Noun"/><gloss lang="en"><text>familiarity or understanding of a particular skill, branch of learning etc.</text></gloss></sense><sense id="pengetahuan_5" guid="d04474b8-f36a-5834-accd-0c462a3c40b2"><grammatical-info value="Noun"/><gloss lang="en"><text>justified true belief</text></gloss></sense><sense id="pengetahuan_6" guid="f4cb8232-92f6-59fb-9a3b-873bd2ca6210"><grammatical-info value="Noun"/><gloss lang="en"><text>the total of what is known; all information and products of learning</text></gloss></sense></entry>
