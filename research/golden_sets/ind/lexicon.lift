<entry id="mengalahkan" guid="f91ce78d-c055-547d-a078-031f28cde629"><lexical-unit><form lang="id"><text>mengalahkan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mengalahkan_0" guid="76d0b785-b628-5960-b99b-7eac9a9711b0"><grammatical-info value="Verb"/><gloss lang="en"><text>active of kalahkan</text></gloss></sense><sense id="mengalahkan_1" guid="90e92f0f-207d-5510-a7ad-a6bdd2ac46f6"><grammatical-info value="Verb"/><gloss lang="en"><text>active of alahkan</text></gloss></sense></entry>
