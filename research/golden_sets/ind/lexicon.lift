<entry id="am" guid="dd3291d3-12de-5001-a0ba-50b048c14f11"><lexical-unit><form lang="id"><text>am</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="am_0" guid="f456635a-afb4-5953-b083-de615f3b6d79"><grammatical-info value="Noun"/><gloss lang="en"><text>common, general</text></gloss></sense><sense id="am_1" guid="7c2407de-e6c4-581e-b8d4-2c31d4d98b42"><grammatical-info value="Noun"/><gloss lang="en"><text>common (not expert)</text></gloss></sense></entry>
<entry id="aman" guid="48077ab7-1cc2-5f4f-a705-99cbae2cdb58"><lexical-unit><form lang="id"><text>aman</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="aman_0" guid="c7ea3f02-78d4-512c-b371-766a16fd2261"><grammatical-info value="Adjective"/><gloss lang="en"><text>safe; secure</text></gloss></sense><sense id="aman_1" guid="1852f4b8-fd4e-5b8a-9645-6cdd5abc1e7a"><grammatical-info value="Adjective"/><gloss lang="en"><text>all good; no worries</text></gloss></sense><sense id="aman_2" guid="73acfc8a-1554-56c0-966f-fc2a43e7ca81"><grammatical-info value="Adjective"/><gloss lang="en"><text>a male given name from Javanese</text></gloss></sense></entry>
<entry id="amankan" guid="d5611ff6-6fda-5c46-afd8-4d2cc08b74a8"><lexical-unit><form lang="id"><text>amankan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="amankan_0" guid="81c4bc1f-da86-5374-b5c8-43efbba1d667"><grammatical-info value="Verb"/><gloss lang="en"><text>to safe (to make safe)</text></gloss></sense><sense id="amankan_1" guid="408ccae0-0fde-5054-ac3f-8e92d8dede4a"><grammatical-info value="Verb"/><gloss lang="en"><text>to secure</text></gloss></sense><sense id="amankan_2" guid="a6afefd1-21f0-5eb7-8ccb-52b3ae3b5d6e"><grammatical-info value="Verb"/><gloss lang="en"><text>to make safe; to relieve from apprehensions of, or exposure to, danger; to guard; to protect</text></gloss></sense><sense id="amankan_3" guid="426e5944-1d40-5ce1-acd5-41959fe5afaf"><grammatical-info value="Verb"/><gloss lang="en"><text>to put beyond hazard of losing or of not receiving; to make certain; to assure; frequently with "dari" or "terhadap"</text></gloss></sense><sense id="amankan_4" guid="286a68e7-f2fc-5bf1-8223-5cdd5ad784f3"><grammatical-info value="Verb"/><gloss lang="en"><text>to get possession of; to make oneself secure of; to acquire certainly</text></gloss></sense></entry>
