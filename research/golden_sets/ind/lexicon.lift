<entry id="menengah" guid="d3106b21-ea4f-5582-96cb-20e41d3647dd"><lexical-unit><form lang="id"><text>menengah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="menengah_0" guid="8d55a61b-1457-5d51-af48-2ebea9123a58"><grammatical-info value="Adjective"/><gloss lang="en"><text>to center (American spelling), to centre (British spelling): to cause (an object) to occupy the center of an area</text></gloss></sense><sense id="menengah_1" guid="368ab3fb-5753-56f6-9d13-037116dd6d2b"><grammatical-info value="Adjective"/><gloss lang="en"><text>middle: located in the middle; in between</text></gloss></sense></entry>
<entry id="menenggelamkan" guid="1e2ca829-cc27-5349-b5f7-38d2e03de14f"><lexical-unit><form lang="id"><text>menenggelamkan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="menenggelamkan_0" guid="b9aeb8e6-60fe-53b0-8db3-415c6146bb58"><grammatical-info value="Verb"/><gloss lang="en"><text>to immerse, to submerge, to plunge</text></gloss></sense></entry>
