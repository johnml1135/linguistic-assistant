<entry id="godaan" guid="55944729-dd5c-566b-838c-fb75cba5c4d9"><lexical-unit><form lang="id"><text>godaan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="godaan_0" guid="bd823571-37a5-516b-becd-30997c468abc"><grammatical-info value="Noun"/><gloss lang="en"><text>temptation</text></gloss></sense><sense id="godaan_1" guid="54074462-238c-5939-9196-855cb72fa41c"><grammatical-info value="Noun"/><gloss lang="en"><text>seduction</text></gloss></sense><sense id="godaan_2" guid="6e993415-6c05-596a-830e-3c0e4a438d28"><grammatical-info value="Noun"/><gloss lang="en"><text>torment, plague</text></gloss></sense></entry>
