<entry id="suatu" guid="49b24fe2-1453-5b44-b10f-2becad8c1073"><lexical-unit><form lang="id"><text>suatu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="suatu_0" guid="8f965165-76c3-5671-9387-5e93db0e8a8b"><grammatical-info value="Determiner"/><gloss lang="en"><text>a; an</text></gloss></sense></entry>
<entry id="subuh" guid="06812574-f3a6-5ea3-82ab-5ad2d12f3827"><lexical-unit><form lang="id"><text>subuh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="subuh_0" guid="f938c055-3c83-54af-8e12-0cfaf0555dbc"><grammatical-info value="Noun"/><gloss lang="en"><text>fajr</text></gloss></sense><sense id="subuh_1" guid="571601f5-591d-5127-8622-4ac555d41400"><grammatical-info value="Noun"/><gloss lang="en"><text>dawn (the time of the day when daylight first appears)</text></gloss></sense></entry>
