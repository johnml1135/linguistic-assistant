<entry id="menegur" guid="996bd0bc-73b5-5e79-b20c-287326fcb3a2"><lexical-unit><form lang="id"><text>menegur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="menegur_0" guid="be7115cb-f994-5260-98b5-29377e349280"><grammatical-info value="Verb"/><gloss lang="en"><text>to initiate a conversation, to approach, to greet</text></gloss></sense><sense id="menegur_1" guid="d5a0b775-dec6-5238-bd4e-6267d598d4d8"><grammatical-info value="Verb"/><gloss lang="en"><text>to warn, to caution, to admonish</text></gloss></sense><sense id="menegur_2" guid="e708783a-1cdb-51e4-b182-0a8d295d0646"><grammatical-info value="Verb"/><gloss lang="en"><text>to criticize</text></gloss></sense><sense id="menegur_3" guid="ce6659e2-7250-5e1e-8444-b0134b63fa96"><grammatical-info value="Verb"/><gloss lang="en"><text>to bother, trouble (said of ghosts and alike)</text></gloss></sense></entry>
