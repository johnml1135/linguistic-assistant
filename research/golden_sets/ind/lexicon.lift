<entry id="hosea" guid="ac4dd2fd-3d4e-5435-8057-f581b46e4e35"><lexical-unit><form lang="id"><text>hosea</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="hosea_0" guid="d9af1d58-4086-5c16-9b5b-b29a35da33e4"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Hosea:</text></gloss></sense><sense id="hosea_1" guid="87dbb8c8-9367-596c-9ab0-a055bd4b8d00"><grammatical-info value="Proper noun"/><gloss lang="en"><text>A book of the Old Testament of the Bible</text></gloss></sense><sense id="hosea_2" guid="d146af37-aef8-5b45-a7d0-dcd2b725913e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>A prophet</text></gloss></sense></entry>
