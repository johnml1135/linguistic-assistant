<entry id="unta" guid="64e4f3af-5530-5e46-b11d-52e8f06d9d25"><lexical-unit><form lang="id"><text>unta</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="unta_0" guid="463d8810-3736-5992-8bbe-e845ba801d2d"><grammatical-info value="Verb"/><gloss lang="en"><text>camel</text></gloss></sense></entry>
<entry id="untuk" guid="0697823d-1bf1-59eb-8194-dbae1657b599"><lexical-unit><form lang="id"><text>untuk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="untuk_0" guid="e4280d4e-7c54-5ec1-83a9-ff02ee001af4"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>for</text></gloss></sense><sense id="untuk_1" guid="19696c55-02bc-5f94-a3b5-37d87b11c524"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>to (a particle used for marking the following verb as an infinitive; indicating the aim or goal of an action)</text></gloss></sense><sense id="untuk_2" guid="94764c9e-42aa-5d4b-b113-bbb6e712a758"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>to (a guide or key to something)</text></gloss></sense></entry>
<entry id="untung" guid="53122817-51ff-5893-b509-d0abe15e78c8"><lexical-unit><form lang="id"><text>untung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="untung_0" guid="0127bbbe-d280-5ffa-b44b-ae087fb28067"><grammatical-info value="Adposition"/><gloss lang="en"><text>gain (what one gains (profit))</text></gloss></sense><sense id="untung_1" guid="060229eb-72df-5f5c-9ac8-0ef7c8ebda04"><grammatical-info value="Adposition"/><gloss lang="en"><text>profit</text></gloss></sense><sense id="untung_2" guid="324c26cb-7907-5441-9e42-18d605525a90"><grammatical-info value="Adposition"/><gloss lang="en"><text>synonym of mujur, bahagia (“luck”)</text></gloss></sense><sense id="untung_3" guid="f56ec865-a6f7-503a-ae59-368c98de5c84"><grammatical-info value="Adposition"/><gloss lang="en"><text>synonym of faedah, guna, manfaat (“use”)</text></gloss></sense></entry>
<entry id="unutk" guid="2b2c3a54-579f-5232-9e37-580a75ef38df"><lexical-unit><form lang="id"><text>unutk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="unutk_0" guid="ec11a9f4-af6a-53cf-ae94-3ab020b079e7"><grammatical-info value="Adposition"/></sense></entry>
<entry id="upacara" guid="d02fef27-d21c-57cc-98e7-524f78f325f3"><lexical-unit><form lang="id"><text>upacara</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="upacara_0" guid="5d1c7d65-f022-511a-ba64-5f88f1013f10"><grammatical-info value="Noun"/><gloss lang="en"><text>ceremony</text></gloss></sense><sense id="upacara_1" guid="a12b492b-3ff7-5a02-8069-638291cec90e"><grammatical-info value="Noun"/><gloss lang="en"><text>procedure, practice, method</text></gloss></sense></entry>
<entry id="upah" guid="47080d87-efd5-56e3-b7a6-4d760e6209b8"><lexical-unit><form lang="id"><text>upah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="upah_0" guid="4368dcaf-a297-54bd-8298-4506c998b626"><grammatical-info value="Noun"/><gloss lang="en"><text>wage: an amount of money paid to a worker for a specified quantity of work, usually calculated on an hourly basis and expressed in an amount of money per hour</text></gloss></sense><sense id="upah_1" guid="fd408053-072b-5cfc-bbde-789c56b08ded"><grammatical-info value="Noun"/><gloss lang="en"><text>reward:</text></gloss></sense><sense id="upah_2" guid="f9a04c0e-9f88-599f-b23a-a6151a412aef"><grammatical-info value="Noun"/><gloss lang="en"><text>a prize promised for a certain deed or catch</text></gloss></sense><sense id="upah_3" guid="d1235cd7-f430-59f4-bc60-5f3f2bb49ba3"><grammatical-info value="Noun"/><gloss lang="en"><text>the result of an action, whether good or bad</text></gloss></sense></entry>
<entry id="upaya" guid="04024b89-6656-5a70-8d45-a19e20c8fc0e"><lexical-unit><form lang="id"><text>upaya</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="upaya_0" guid="3a03c063-f72a-54e7-86ee-c3d8ecd4e2e6"><grammatical-info value="Noun"/><gloss lang="en"><text>attempt</text></gloss></sense><sense id="upaya_1" guid="0ce3f674-463d-5850-ae2c-d15307816ecf"><grammatical-info value="Noun"/><gloss lang="en"><text>endeavor; effort</text></gloss></sense></entry>
<entry id="urap" guid="8cce80d0-8872-57b7-acb3-f5cd72bc3523"><lexical-unit><form lang="id"><text>urap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="urap_0" guid="770ebdce-289c-5d3a-ab66-a3e71084c273"><grammatical-info value="Noun"/><gloss lang="en"><text>ointment, unguent, liniment, salve, cream; a perfumed cosmetic</text></gloss></sense><sense id="urap_1" guid="2e35aa96-8c57-55c1-b7fb-8963e029cbaa"><grammatical-info value="Noun"/><gloss lang="en"><text>sanctity</text></gloss></sense><sense id="urap_2" guid="aa07f5e4-ae98-5def-ba69-622340801050"><grammatical-info value="Noun"/><gloss lang="en"><text>seasoned grated coconut for mixture</text></gloss></sense></entry>
<entry id="urat" guid="8bf8302b-39b9-5330-ad01-506e350351b0"><lexical-unit><form lang="id"><text>urat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="urat_0" guid="d1988eea-5d64-575a-80e6-9efdab7f7028"><grammatical-info value="Verb"/><gloss lang="en"><text>string or chord-like body structures (muscle, tendon, vein or nerve)</text></gloss></sense><sense id="urat_1" guid="34b4fd66-37fa-5de3-a31b-11b29291991b"><grammatical-info value="Verb"/><gloss lang="en"><text>tendon: a tough band of flexible but inelastic fibrous collagen tissue that connects a muscle with its bony attachment and transmits the force which the muscle exerts</text></gloss></sense><sense id="urat_2" guid="bc593809-c051-5a12-a445-67feacf11096"><grammatical-info value="Verb"/><gloss lang="en"><text>vein: a sheetlike body of crystallized minerals within a rock</text></gloss></sense><sense id="urat_3" guid="293a852b-ab20-56d0-988f-7906923ee38d"><grammatical-info value="Verb"/><gloss lang="en"><text>muscle</text></gloss></sense><sense id="urat_4" guid="cbf04162-0010-51b9-8829-bf864a78515f"><grammatical-info value="Verb"/><gloss lang="en"><text>urate: any salt of uric acid</text></gloss></sense></entry>
<entry id="urun" guid="ed2cb501-0c83-56bc-a17b-b5ab8d72420a"><lexical-unit><form lang="id"><text>urun</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="urun_0" guid="63c3d4c7-c52e-5707-97da-a8490062ec1c"><grammatical-info value="Verb"/><gloss lang="en"><text>to contribute; to support</text></gloss></sense></entry>
<entry id="urus" guid="ebb9ff24-c99c-5162-871c-498182901948"><lexical-unit><form lang="id"><text>urus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="urus_0" guid="521f2a03-d1bd-5d90-999c-0559f75ee325"><grammatical-info value="Verb"/><gloss lang="en"><text>to manage (to direct or be in charge)</text></gloss></sense><sense id="urus_1" guid="42a33755-d10c-5a5a-ab32-8042842fe8a3"><grammatical-info value="Verb"/><gloss lang="en"><text>to manage (to handle or control a situation or job)</text></gloss></sense></entry>
