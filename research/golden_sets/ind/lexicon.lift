<entry id="jatuh" guid="bd8cf5b0-abb6-57e0-8869-2101794b3e0b"><lexical-unit><form lang="id"><text>jatuh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="jatuh_0" guid="50ac100b-c675-5429-ac70-a71ba2360ad3"><grammatical-info value="Verb"/><gloss lang="en"><text>to fall:</text></gloss></sense><sense id="jatuh_1" guid="171fa775-403d-5bf0-97a3-c8d395750937"><grammatical-info value="Verb"/><gloss lang="en"><text>to move to a lower position under the effect of gravity</text></gloss></sense><sense id="jatuh_2" guid="13f81e48-fc9e-58f0-a5f0-562401c5c2d3"><grammatical-info value="Verb"/><gloss lang="en"><text>to come down, to drop or descend</text></gloss></sense><sense id="jatuh_3" guid="093b9b8b-e1be-5f78-95e2-ccfbd5fc7c76"><grammatical-info value="Verb"/><gloss lang="en"><text>to become</text></gloss></sense><sense id="jatuh_4" guid="81a89e48-3867-5256-8f98-9ee4e367100e"><grammatical-info value="Verb"/><gloss lang="en"><text>to occur (on a certain day of the week, date, or similar); said of an instance of a recurring event such as a holiday or date</text></gloss></sense><sense id="jatuh_5" guid="4c34d000-1082-598b-91e0-a43343c1f8d8"><grammatical-info value="Verb"/><gloss lang="en"><text>to collapse; to be overthrown or defeated</text></gloss></sense><sense id="jatuh_6" guid="b1845635-74d8-56e0-863e-2dbd4d0ca004"><grammatical-info value="Verb"/><gloss lang="en"><text>to be bankrupt</text></gloss></sense><sense id="jatuh_7" guid="7936cb50-b8f7-5a9d-a36c-08d377ca3d75"><grammatical-info value="Verb"/><gloss lang="en"><text>to descend in character or reputation; to become degraded; to sink into vice, error, or sin</text></gloss></sense></entry>
