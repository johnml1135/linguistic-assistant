<entry id="bay" guid="6d6396a7-bfbd-5103-90a4-e1d8b64a2a9d"><lexical-unit><form lang="id"><text>bay</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bay_0" guid="385143df-a328-590d-b803-b78d7af1df4a"><grammatical-info value="Proper noun"/><gloss lang="en"><text>baby</text></gloss></sense></entry>
