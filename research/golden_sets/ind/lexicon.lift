<entry id="sayang" guid="94cf843c-58a7-5193-b331-d0c9b432b8c6"><lexical-unit><form lang="id"><text>sayang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sayang_0" guid="74210d90-c81c-5992-bf29-4314958d0b58"><grammatical-info value="Noun"/><gloss lang="en"><text>love (a profound and caring affection towards someone)</text></gloss></sense><sense id="sayang_1" guid="855c193c-04f0-5173-ab05-08377ea66449"><grammatical-info value="Noun"/><gloss lang="en"><text>an affectionate term of address: darling</text></gloss></sense><sense id="sayang_2" guid="a272bb51-08eb-54a2-afc0-3cd12e73414a"><grammatical-info value="Noun"/><gloss lang="en"><text>a term of endearment used to refer to or address one's girlfriend, boyfriend or spouse: baby</text></gloss></sense><sense id="sayang_3" guid="ead13a34-806b-52f4-9321-fa8116bb9401"><grammatical-info value="Noun"/><gloss lang="en"><text>alas, what a pity, what a shame, what a waste</text></gloss></sense><sense id="sayang_4" guid="11012e1e-e6eb-5d1f-960a-ba97ecfcfd15"><grammatical-info value="Noun"/><gloss lang="en"><text>waste, wasteful</text></gloss></sense><sense id="sayang_5" guid="0fa06d5f-461b-5066-955a-f904d610e17b"><grammatical-info value="Noun"/><gloss lang="en"><text>to love</text></gloss></sense></entry>
