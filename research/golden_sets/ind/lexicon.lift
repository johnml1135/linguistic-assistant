<entry id="betul" guid="2d285549-7b4d-5bb8-897a-f2fbce9f2ee9"><lexical-unit><form lang="id"><text>betul</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="betul_0" guid="de3a7213-c9c8-56fb-9f0d-f430a1c5fd6b"><grammatical-info value="Adjective"/><gloss lang="en"><text>true:</text></gloss></sense><sense id="betul_1" guid="73b6420b-9a35-5638-a0ad-09e7c6f626e5"><grammatical-info value="Adjective"/><gloss lang="en"><text>conforming to the actual state of reality or fact; factually correct</text></gloss></sense><sense id="betul_2" guid="0db87c37-530b-5447-a8a4-27419e4ad14f"><grammatical-info value="Adjective"/><gloss lang="en"><text>genuine; legitimate</text></gloss></sense><sense id="betul_3" guid="3141496a-e5ea-5e55-8489-a74cd03aff4a"><grammatical-info value="Adjective"/><gloss lang="en"><text>correct: free from error; true; accurate</text></gloss></sense><sense id="betul_4" guid="600db819-ed88-559e-bb81-35dccb9b70ff"><grammatical-info value="Adjective"/><gloss lang="en"><text>right, straight</text></gloss></sense><sense id="betul_5" guid="83dce751-f0c2-5ac6-ac32-c0f931e42fe5"><grammatical-info value="Adjective"/><gloss lang="en"><text>aright: rightly, correctly; in the right way or form</text></gloss></sense><sense id="betul_6" guid="08906e9c-5361-58c1-a66a-63398e762888"><grammatical-info value="Adjective"/><gloss lang="en"><text>directly</text></gloss></sense><sense id="betul_7" guid="5f4cd06b-e475-53e4-b4d4-99fc922459bd"><grammatical-info value="Adjective"/><gloss lang="en"><text>very, really</text></gloss></sense></entry>
<entry id="biar" guid="243008e3-844d-5a26-9a21-0df1ff6f1730"><lexical-unit><form lang="id"><text>biar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="biar_0" guid="8d454452-0461-5191-a2df-fb6ad001c69c"><grammatical-info value="Verb"/><gloss lang="en"><text>to let; to allow</text></gloss></sense><sense id="biar_1" guid="7e155dd8-bad3-5dd9-8605-2f0c64d289c5"><grammatical-info value="Verb"/><gloss lang="en"><text>so that; in order to</text></gloss></sense></entry>
