<entry id="peraturan" guid="54876164-dd8c-5599-8ac2-ade8c462049d"><lexical-unit><form lang="id"><text>peraturan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="peraturan_0" guid="c2f7af80-8a00-5664-894c-6e79e176ba08"><grammatical-info value="Noun"/><gloss lang="en"><text>rule</text></gloss></sense><sense id="peraturan_1" guid="7f3715fd-c337-52cd-b990-cda94402c0ba"><grammatical-info value="Noun"/><gloss lang="en"><text>a regulation, law, guideline</text></gloss></sense><sense id="peraturan_2" guid="5f66ecd7-9b6f-5479-8bde-2a04a4c6a7db"><grammatical-info value="Noun"/><gloss lang="en"><text>a regulating principle</text></gloss></sense><sense id="peraturan_3" guid="d68c8cfe-2929-50e9-877d-3f92d2f26885"><grammatical-info value="Noun"/><gloss lang="en"><text>regulation: a type of law made by the executive branch of a government, usually as authorized by a statute made by the legislative branch giving the executive the authority to do so</text></gloss></sense></entry>
