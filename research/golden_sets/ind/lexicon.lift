<entry id="tular" guid="f2f38a77-1016-5920-8496-7d8f1e2e11b6"><lexical-unit><form lang="id"><text>tular</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tular_0" guid="74fb65a2-dea1-535f-b6b2-71700dd3935e"><grammatical-info value="Verb"/><gloss lang="en"><text>to infect</text></gloss></sense><sense id="tular_1" guid="26ebaf06-e65c-534c-b36a-d61175c4dd23"><grammatical-info value="Verb"/><gloss lang="en"><text>contagious</text></gloss></sense></entry>
<entry id="tuli" guid="d89939d1-b776-5824-b85e-3acd30ae87ce"><lexical-unit><form lang="id"><text>tuli</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="tuli_0" guid="cc80b0a1-fa93-5ce8-93e7-3db34b29f32c"><grammatical-info value="Noun"/><gloss lang="en"><text>deaf</text></gloss></sense></entry>
