<entry id="dapur" guid="4b73c482-9037-5870-9915-44a6f506b540"><lexical-unit><form lang="id"><text>dapur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="dapur_0" guid="bc98f05d-d8cc-5bf1-9f4a-194b0f6cc34e"><grammatical-info value="Noun"/><gloss lang="en"><text>kitchen (room)</text></gloss></sense><sense id="dapur_1" guid="d936d294-d992-5ea2-aaa3-ffba1efaa51d"><grammatical-info value="Noun"/><gloss lang="en"><text>hearth, the lowest part of a metallurgical furnace</text></gloss></sense><sense id="dapur_2" guid="5f704c6f-20f5-5fbe-9869-a8520b36a45b"><grammatical-info value="Noun"/><gloss lang="en"><text>stove</text></gloss></sense><sense id="dapur_3" guid="312d6274-6111-5616-82af-e2734beda1eb"><grammatical-info value="Noun"/><gloss lang="en"><text>furnace: an industrial heating device, e.g. for smelting metal or baking ceramics</text></gloss></sense><sense id="dapur_4" guid="55dbde91-a3ef-5597-9b00-2d9cf5962cde"><grammatical-info value="Noun"/><gloss lang="en"><text>kiln</text></gloss></sense><sense id="dapur_5" guid="c1834d26-2167-5d6b-a895-dfb5d5faba41"><grammatical-info value="Noun"/><gloss lang="en"><text>soil-filled can for the place of the stove</text></gloss></sense><sense id="dapur_6" guid="bcda3946-263a-50c5-b406-92802c1ef729"><grammatical-info value="Noun"/><gloss lang="en"><text>ancient village society in Ancient Java</text></gloss></sense><sense id="dapur_7" guid="e90b98a0-96ee-52c6-8ad8-013d48d1d886"><grammatical-info value="Noun"/><gloss lang="en"><text>the shape of a keris blade is marked by chips on the keris blade</text></gloss></sense></entry>
