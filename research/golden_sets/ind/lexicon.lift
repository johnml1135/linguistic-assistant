<entry id="rak" guid="8c5b6c8e-6be0-5537-b5b2-d0d3803a990a"><lexical-unit><form lang="id"><text>rak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="rak_0" guid="03a9b3b8-f68c-57e3-9bb2-7388713e585e"><grammatical-info value="Noun"/><gloss lang="en"><text>sound of cracking (specifically about wooden branch breaking)</text></gloss></sense><sense id="rak_1" guid="a1fb4d63-b403-50fc-8586-522099e3482a"><grammatical-info value="Noun"/><gloss lang="en"><text>sound of a pen being scratched</text></gloss></sense><sense id="rak_2" guid="aa0197d3-5592-5e72-b84a-69b9715efedf"><grammatical-info value="Noun"/><gloss lang="en"><text>rack:</text></gloss></sense><sense id="rak_3" guid="ea5eca9d-0988-544d-be89-b3e923e04f22"><grammatical-info value="Noun"/><gloss lang="en"><text>a series of one or more shelves, stacked one above the other</text></gloss></sense><sense id="rak_4" guid="451d83f8-c217-59d7-a53f-a55d0797099b"><grammatical-info value="Noun"/><gloss lang="en"><text>any of various kinds of frame for holding luggage or other objects on a vehicle or vessel.</text></gloss></sense><sense id="rak_5" guid="23e371e2-1868-5bc2-917b-0839f687cedb"><grammatical-info value="Noun"/><gloss lang="en"><text>shelf: a flat, rigid structure, fixed at right angles to a wall or forming a part of a cabinet, desk, etc., and used to display, store, or support objects</text></gloss></sense></entry>
