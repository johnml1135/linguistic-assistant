<entry id="langkah" guid="62716ea0-8600-5e28-9cce-481b76eb4123"><lexical-unit><form lang="id"><text>langkah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="langkah_0" guid="2928e240-75e7-5a4b-96eb-79789f535b5e"><grammatical-info value="Noun"/><gloss lang="en"><text>step:</text></gloss></sense><sense id="langkah_1" guid="3b4a0df0-ab41-55e5-b217-d1de4f15df56"><grammatical-info value="Noun"/><gloss lang="en"><text>pace: an advance or movement made from one foot to the other</text></gloss></sense><sense id="langkah_2" guid="cc2b2e96-3347-5b1b-a6be-5e1766f4180a"><grammatical-info value="Noun"/><gloss lang="en"><text>the space passed over by one movement of the foot in walking or running</text></gloss></sense><sense id="langkah_3" guid="bb5d01e1-481d-58b6-9f0c-7c5b8671b2d7"><grammatical-info value="Noun"/><gloss lang="en"><text>a distinct part of a process; stage; phase</text></gloss></sense><sense id="langkah_4" guid="bd410946-f40f-5a87-8c77-ec8e3f1fdc8b"><grammatical-info value="Noun"/><gloss lang="en"><text>measure, action</text></gloss></sense><sense id="langkah_5" guid="842e05d4-ad69-537f-aecc-f3b6cd4e1fe7"><grammatical-info value="Noun"/><gloss lang="en"><text>stroke, cycle, phase</text></gloss></sense></entry>
