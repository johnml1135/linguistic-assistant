<entry id="panggil" guid="178e2de4-7a4f-5b5c-8c08-46d4c8a8fac8"><lexical-unit><form lang="id"><text>panggil</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="panggil_0" guid="309a305c-70bb-5d2d-9df2-275d29ca20fd"><grammatical-info value="Verb"/><gloss lang="en"><text>to call (to request, summon, or beckon)</text></gloss></sense><sense id="panggil_1" guid="ffcf94ce-8048-5503-bb51-60f92e8a65fd"><grammatical-info value="Verb"/><gloss lang="en"><text>to call (to utter in a loud or distinct voice)</text></gloss></sense><sense id="panggil_2" guid="88206ae2-bb15-5897-b8d8-f16cbf8b3cb7"><grammatical-info value="Verb"/><gloss lang="en"><text>to call (to name or refer to)</text></gloss></sense></entry>
<entry id="panggilan" guid="5b7122d6-7a4b-5f93-bfcd-5f2fa21c9112"><lexical-unit><form lang="id"><text>panggilan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="panggilan_0" guid="5da1bf03-fd18-555b-a756-16c5c66614c7"><grammatical-info value="Noun"/><gloss lang="en"><text>call (beckoning or summoning)</text></gloss></sense><sense id="panggilan_1" guid="45dd9499-dbe5-543f-85fb-2173b9439ce8"><grammatical-info value="Noun"/><gloss lang="en"><text>call (telephone conversation)</text></gloss></sense><sense id="panggilan_2" guid="33dbd3ff-64f5-53a5-8c82-7e0d570abe9f"><grammatical-info value="Noun"/><gloss lang="en"><text>call (instance of calling someone on the telephone)</text></gloss></sense><sense id="panggilan_3" guid="f7e9c3d3-a367-58b9-8cf7-d51302593bad"><grammatical-info value="Noun"/><gloss lang="en"><text>call (social visit)</text></gloss></sense><sense id="panggilan_4" guid="bef4e7f0-f17b-58c0-aa60-44b65712df4e"><grammatical-info value="Noun"/><gloss lang="en"><text>calling (act of making a call)</text></gloss></sense><sense id="panggilan_5" guid="6ebe08ec-bb27-5a6d-81a4-d509c9d8325d"><grammatical-info value="Noun"/><gloss lang="en"><text>invited (having been asked to attend, especially by a call)</text></gloss></sense><sense id="panggilan_6" guid="76dbc8a3-d14c-555e-a978-2c4f33af8b6a"><grammatical-info value="Noun"/><gloss lang="en"><text>nickname (familiar, invented given name)</text></gloss></sense></entry>
<entry id="pangkal" guid="df3a1901-a237-5306-9e7f-4ea277182d30"><lexical-unit><form lang="id"><text>pangkal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pangkal_0" guid="d7cbfd0d-785e-5d28-a04b-e48f5b8b3b0b"><grammatical-info value="Proper noun"/><gloss lang="en"><text>base</text></gloss></sense><sense id="pangkal_1" guid="8c9700b8-880d-5866-90bb-e9ed76749731"><grammatical-info value="Proper noun"/><gloss lang="en"><text>stem (The main part of an uninflected word to which affixes may be added to form inflections of the word)</text></gloss></sense><sense id="pangkal_2" guid="1e67dc92-cebb-55e9-89f6-b9c5fe890393"><grammatical-info value="Proper noun"/><gloss lang="en"><text>origin, source</text></gloss></sense><sense id="pangkal_3" guid="60b40f94-db74-5ea9-abce-e84fae274cbf"><grammatical-info value="Proper noun"/><gloss lang="en"><text>beginning</text></gloss></sense><sense id="pangkal_4" guid="6bdd8f39-1601-5992-83f2-3e40076d5612"><grammatical-info value="Proper noun"/><gloss lang="en"><text>main cause</text></gloss></sense><sense id="pangkal_5" guid="aafd4cb8-e841-5a46-ac99-75c6f70df49d"><grammatical-info value="Proper noun"/><gloss lang="en"><text>capital: money and wealth; the means to acquire goods and services, especially in a non-barter system</text></gloss></sense></entry>
<entry id="pangkas" guid="eafb8b18-8dd2-5611-aeb8-a9b7faea64a7"><lexical-unit><form lang="id"><text>pangkas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pangkas_0" guid="7bc2a2d4-c5b0-5f1c-b9b6-af4ce524ddac"><grammatical-info value="Verb"/><gloss lang="en"><text>cut (hair)</text></gloss></sense></entry>
<entry id="pangku" guid="ed61a987-7dab-5ccf-9319-40edbaef8c45"><lexical-unit><form lang="id"><text>pangku</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pangku_0" guid="a59039a4-33b9-5445-937b-1f6f2c896f1c"><grammatical-info value="Verb"/><gloss lang="en"><text>to lap:</text></gloss></sense><sense id="pangku_1" guid="2e6dedaa-ef5d-5c4b-bb9b-673e2d502701"><grammatical-info value="Verb"/><gloss lang="en"><text>to hold (someone) in one's lap</text></gloss></sense><sense id="pangku_2" guid="f13fc8b2-8d2c-5a4a-a133-4db15f254773"><grammatical-info value="Verb"/><gloss lang="en"><text>to hold (someone) in a similar way as above</text></gloss></sense></entry>
<entry id="panjang" guid="5de470b8-17ff-5eee-94c8-0d9c9347f085"><lexical-unit><form lang="id"><text>panjang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="panjang_0" guid="29aac7c0-4264-50c6-9de9-8a1a057d06d5"><grammatical-info value="Adjective"/><gloss lang="en"><text>long:</text></gloss></sense><sense id="panjang_1" guid="4c76fbe2-ab63-5665-8f6c-b08264489eb1"><grammatical-info value="Adjective"/><gloss lang="en"><text>having much distance from one terminating point on an object or an area to another terminating point</text></gloss></sense><sense id="panjang_2" guid="68fac0ac-f6ad-5fbd-b223-ad868e19fa6c"><grammatical-info value="Adjective"/><gloss lang="en"><text>having great duration; seemingly lasting a lot of time, because it is boring or tedious or tiring</text></gloss></sense><sense id="panjang_3" guid="a276bf93-4d31-5086-9ed9-a91944177b70"><grammatical-info value="Adjective"/><gloss lang="en"><text>length: the distance measured along the longest dimension of an object</text></gloss></sense></entry>
<entry id="panjat" guid="770ebe29-f9ca-5bdd-9e7b-2b6aeebcadd3"><lexical-unit><form lang="id"><text>panjat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="panjat_0" guid="2259063b-621b-5e63-b260-950cfcc04cef"><grammatical-info value="Verb"/><gloss lang="en"><text>to climb, to mount, to move upwards</text></gloss></sense></entry>
<entry id="pantai" guid="58ce9820-ba60-50d4-a87a-6dd683e6a4db"><lexical-unit><form lang="id"><text>pantai</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pantai_0" guid="a2709ff2-8249-5ffa-93fb-be4b85dd70df"><grammatical-info value="Noun"/><gloss lang="en"><text>beach</text></gloss></sense><sense id="pantai_1" guid="3ad952d0-04ec-526e-ac84-8a3c2a0b4555"><grammatical-info value="Noun"/><gloss lang="en"><text>coast, seashore, shore</text></gloss></sense><sense id="pantai_2" guid="ffe4969f-c348-5c68-b7a2-07ce922da1da"><grammatical-info value="Noun"/><gloss lang="en"><text>sloping, slanting (down to the coast)</text></gloss></sense></entry>
<entry id="pantas" guid="5fe9931d-4021-509d-a856-8ff36881b8d5"><lexical-unit><form lang="id"><text>pantas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pantas_0" guid="7ea96173-b23e-569f-8da8-cba9ed3fb918"><grammatical-info value="Adjective"/><gloss lang="en"><text>worthy</text></gloss></sense><sense id="pantas_1" guid="a4f12d54-4ba8-57d8-872f-d8317def1ab4"><grammatical-info value="Adjective"/><gloss lang="en"><text>appropriate</text></gloss></sense><sense id="pantas_2" guid="b0dd8383-d51f-5680-b794-9b6345025f56"><grammatical-info value="Adjective"/><gloss lang="en"><text>fit</text></gloss></sense><sense id="pantas_3" guid="a23cc3c7-ed38-50d7-92eb-fb79e163b854"><grammatical-info value="Adjective"/><gloss lang="en"><text>deft</text></gloss></sense><sense id="pantas_4" guid="7fe0781b-019c-584b-b203-723573d0fde9"><grammatical-info value="Adjective"/><gloss lang="en"><text>fast</text></gloss></sense></entry>
<entry id="pantul" guid="54f750a9-b1d8-559e-b3fa-b477a3fad299"><lexical-unit><form lang="id"><text>pantul</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pantul_0" guid="d83ed00d-9e72-57d1-bc92-980092522ccb"><grammatical-info value="Verb"/></sense></entry>
<entry id="pap" guid="048d69c4-02ac-52e6-b1b3-be58c04133c1"><lexical-unit><form lang="id"><text>pap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pap_0" guid="63c50e2c-d828-5555-9e2f-cb1d2591dc4e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a picture obtained as a result of pap</text></gloss></sense><sense id="pap_1" guid="01087548-3322-5454-9ce8-cad35281b502"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to take/send/post a picture (especially a photograph), usually as proof of something</text></gloss></sense><sense id="pap_2" guid="973a4db5-f723-5151-b7fc-7cec0fa383c9"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to take/send/post a picture of oneself with their background location visible and/or to take/send/post a picture of a location (in which one is currently in), especially (as proof) to show where one currently is</text></gloss></sense><sense id="pap_3" guid="e8c31903-9004-53b1-9f5c-bac2def03e16"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to take a picture of something</text></gloss></sense><sense id="pap_4" guid="6ae53f89-d4b6-55e8-ac3f-ac44683cbb01"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to take/send a picture of oneself, especially of their sexual body parts; to send a nude</text></gloss></sense><sense id="pap_5" guid="507b0fce-8944-5f24-a02a-99d52636a3e2"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to take a picture of someone, usually surreptitiously and without their consent</text></gloss></sense><sense id="pap_6" guid="df44ef72-4857-5081-9fa1-9792b6b89ead"><grammatical-info value="Proper noun"/><gloss lang="en"><text>alternative letter-case form of pap</text></gloss></sense></entry>
<entry id="para" guid="3bb14f44-b365-5dce-a714-6a5a5e3a7f99"><lexical-unit><form lang="id"><text>para</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="para_0" guid="14dbc7e3-28ff-5631-8ba1-34d0520b3eb6"><grammatical-info value="Determiner"/><gloss lang="en"><text>rubber</text></gloss></sense><sense id="para_1" guid="87b8c517-c88e-5176-8a18-c61e0979c5a4"><grammatical-info value="Determiner"/><gloss lang="en"><text>apocopic form of parasut</text></gloss></sense><sense id="para_2" guid="0c379d7b-2346-572c-949b-4ec812551ab3"><grammatical-info value="Determiner"/><gloss lang="en"><text>paratrooper, military parachutist</text></gloss></sense><sense id="para_3" guid="540b578f-309a-561f-ab5b-7100cae0b3a7"><grammatical-info value="Determiner"/><gloss lang="en"><text>the space between the ceiling and the roof of a house</text></gloss></sense><sense id="para_4" guid="676a3ee4-71d4-506d-93ed-d957bdfc8709"><grammatical-info value="Determiner"/><gloss lang="en"><text>upper arm</text></gloss></sense><sense id="para_5" guid="f13c5332-966b-5bf2-9549-41d08d338eeb"><grammatical-info value="Determiner"/><gloss lang="en"><text>edible half rotten (melted) egg.</text></gloss></sense><sense id="para_6" guid="0f215435-027b-5e2d-9856-7742352e6d26"><grammatical-info value="Determiner"/><gloss lang="en"><text>alternative spelling of para-para (“shelf”)</text></gloss></sense></entry>
<entry id="parah" guid="3787413d-ae16-5bac-b2ea-398ae5277ba7"><lexical-unit><form lang="id"><text>parah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="parah_0" guid="52aee3be-f8c1-58f6-b81f-104856dfa6d3"><grammatical-info value="Adjective"/><gloss lang="en"><text>severe</text></gloss></sense><sense id="parah_1" guid="71bb92f8-9d57-5fda-99f6-1cbecb79ed9e"><grammatical-info value="Adjective"/><gloss lang="en"><text>enormous</text></gloss></sense><sense id="parah_2" guid="ff39bc76-9e02-54bd-8cab-2acbcb325c82"><grammatical-info value="Adjective"/><gloss lang="en"><text>critical</text></gloss></sense><sense id="parah_3" guid="71cf6a32-2094-5149-abbf-a8fcfa2ee930"><grammatical-info value="Adjective"/><gloss lang="en"><text>advanced</text></gloss></sense><sense id="parah_4" guid="4c657582-cae8-5d5c-97a0-0d3f0fea3c40"><grammatical-info value="Adjective"/><gloss lang="en"><text>grave</text></gloss></sense></entry>
<entry id="parang" guid="4733f101-cdba-53af-bf54-659ae71b2403"><lexical-unit><form lang="id"><text>parang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="parang_0" guid="d36d2c30-f5b7-5cf9-851b-ef4445d1855b"><grammatical-info value="Noun"/><gloss lang="en"><text>a short, heavy, straight-edged knife or machete</text></gloss></sense><sense id="parang_1" guid="107f8f41-89e3-594d-b0b6-2a6c405f030b"><grammatical-info value="Noun"/><gloss lang="en"><text>a classic batik motif</text></gloss></sense><sense id="parang_2" guid="8cd1b2ab-183b-5845-9360-ad91d8983586"><grammatical-info value="Noun"/><gloss lang="en"><text>dorab wolf-herring (Chirocentrus dorab)</text></gloss></sense><sense id="parang_3" guid="e20a04f5-aa54-5aa1-862e-76a4c7afac96"><grammatical-info value="Noun"/><gloss lang="en"><text>see parangan entry</text></gloss></sense></entry>
<entry id="parfum" guid="9ca7bdde-bfb8-520f-961e-8b7049ba6c77"><lexical-unit><form lang="id"><text>parfum</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="parfum_0" guid="2af1aad0-2fc7-55bf-ac48-7def09608396"><grammatical-info value="Noun"/><gloss lang="en"><text>perfume,</text></gloss></sense><sense id="parfum_1" guid="5601c8e5-d7cf-5312-9d9e-f61044f9dcd6"><grammatical-info value="Noun"/><gloss lang="en"><text>a pleasant smell; the scent, odor, or odoriferous particles emitted from a sweet-smelling substance; a pleasant odor</text></gloss></sense><sense id="parfum_2" guid="6d4c6a15-1c39-588e-b043-2e345d19f6f1"><grammatical-info value="Noun"/><gloss lang="en"><text>a substance created to provide a pleasant smell or one which emits an agreeable odor</text></gloss></sense></entry>
<entry id="paruh" guid="d1392161-9d65-58e1-8c37-1d00be5c9db7"><lexical-unit><form lang="id"><text>paruh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="paruh_0" guid="b4eb4962-ca8e-56d5-aec3-b2924cdac9cb"><grammatical-info value="Noun"/><gloss lang="en"><text>beak</text></gloss></sense><sense id="paruh_1" guid="1e917541-1d26-5caf-b900-67538202d027"><grammatical-info value="Noun"/><gloss lang="en"><text>half</text></gloss></sense></entry>
<entry id="pas" guid="59f37192-652f-59bf-a09a-95a03f987fc0"><lexical-unit><form lang="id"><text>pas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pas_0" guid="bcb9a2d1-00d7-5bc0-a58c-4486badfc9e3"><grammatical-info value="Adjective"/><gloss lang="en"><text>pass, permission or license to pass, or to go and come</text></gloss></sense><sense id="pas_1" guid="1d4eaa38-4942-5fef-b6c0-5e40da1cbe26"><grammatical-info value="Adjective"/><gloss lang="en"><text>mountain pass</text></gloss></sense><sense id="pas_2" guid="d8395699-80a6-5db3-bf4d-597c2f46fb29"><grammatical-info value="Adjective"/><gloss lang="en"><text>fit, suitable, proper</text></gloss></sense><sense id="pas_3" guid="d0b1b3aa-ff19-5a12-b504-f684f07de3ed"><grammatical-info value="Adjective"/><gloss lang="en"><text>to pass, to achieve a successful outcome from</text></gloss></sense><sense id="pas_4" guid="f89e301e-95e4-5104-b1d6-5685e9ffa696"><grammatical-info value="Adjective"/><gloss lang="en"><text>only, not until, not any sooner</text></gloss></sense><sense id="pas_5" guid="cf0b3fb4-8cc5-5e33-b251-f250a7cf0a89"><grammatical-info value="Adjective"/><gloss lang="en"><text>when, at the time of</text></gloss></sense><sense id="pas_6" guid="7f7e1a9a-101d-54be-83c7-0b8f66f9b235"><grammatical-info value="Adjective"/><gloss lang="en"><text>when</text></gloss></sense><sense id="pas_7" guid="7f0be49c-b19a-5063-b360-c1ae5c3c9b34"><grammatical-info value="Adjective"/><gloss lang="en"><text>during, at the time of</text></gloss></sense></entry>
<entry id="pasang" guid="ded30465-d488-55f0-b86a-cec5b221d5af"><lexical-unit><form lang="id"><text>pasang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pasang_0" guid="08ec80d4-3139-5035-af96-d398dbc91975"><grammatical-info value="Noun"/><gloss lang="en"><text>couple, pair</text></gloss></sense><sense id="pasang_1" guid="216efe85-7636-5fba-ab08-bd3f21b9cdaa"><grammatical-info value="Noun"/><gloss lang="en"><text>set</text></gloss></sense><sense id="pasang_2" guid="ce5fd16e-47d6-5e8e-9137-dc9327724c48"><grammatical-info value="Noun"/><gloss lang="en"><text>to rise</text></gloss></sense><sense id="pasang_3" guid="2ba8a96b-0714-5eb8-b718-31e4c5c3198a"><grammatical-info value="Noun"/><gloss lang="en"><text>to shoot</text></gloss></sense><sense id="pasang_4" guid="34a0d68c-1964-55d8-beaa-c1c27cb4e971"><grammatical-info value="Noun"/><gloss lang="en"><text>to put, to insert, to place</text></gloss></sense><sense id="pasang_5" guid="4bc98210-b83b-505f-9a01-06895069917d"><grammatical-info value="Noun"/><gloss lang="en"><text>to install</text></gloss></sense><sense id="pasang_6" guid="83ce3e33-9c40-5523-83c6-1155a79d257f"><grammatical-info value="Noun"/><gloss lang="en"><text>to stake</text></gloss></sense><sense id="pasang_7" guid="c5d3acb2-f344-5e83-bf8f-b7840b331318"><grammatical-info value="Noun"/><gloss lang="en"><text>Lithocarpus javensis</text></gloss></sense></entry>
