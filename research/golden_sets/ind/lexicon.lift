<entry id="ibadat" guid="9bbc830f-6f31-5717-84ca-1695bae896e3"><lexical-unit><form lang="id"><text>ibadat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ibadat_0" guid="235b7e61-c7b6-5b7b-89c6-7c024277579c"><grammatical-info value="Proper noun"/><gloss lang="en"><text>worship</text></gloss></sense><sense id="ibadat_1" guid="d189a966-7c92-5cbb-b843-018ebaf3248b"><grammatical-info value="Proper noun"/><gloss lang="en"><text>religious ceremony</text></gloss></sense></entry>
<entry id="iblis" guid="6a0aee2f-0d4f-517b-a40b-a454c2215921"><lexical-unit><form lang="id"><text>iblis</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="iblis_0" guid="8156eb4f-777d-565c-9909-3004428eb94a"><grammatical-info value="Noun"/><gloss lang="en"><text>devil</text></gloss></sense><sense id="iblis_1" guid="99a929dd-13a3-5135-9ff9-d2443bee1d9b"><grammatical-info value="Noun"/><gloss lang="en"><text>an evil creature, the objectification of a hostile and destructive force</text></gloss></sense><sense id="iblis_2" guid="adfb3516-acde-583c-9a0c-178172ab539b"><grammatical-info value="Noun"/><gloss lang="en"><text>a fictional image of a man, usually red or orange in skin color; with a set of horns on his head, a pointed goatee and a long tail and carrying a pitchfork; that represents evil and portrayed to children in an effort to discourage bad behavior</text></gloss></sense><sense id="iblis_3" guid="503eb68c-0eb1-52cd-8bda-f03d4908dc8f"><grammatical-info value="Noun"/><gloss lang="en"><text>the bad part of the conscience</text></gloss></sense></entry>
<entry id="ibrani" guid="629a9431-efc5-5fea-937e-3c70ffc8a3a3"><lexical-unit><form lang="id"><text>ibrani</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ibrani_0" guid="e6480a2c-f45b-59a4-a947-7634829e7794"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Hebrew, of or pertaining to the Hebrew people or language</text></gloss></sense><sense id="ibrani_1" guid="61dda020-cbb6-537b-a912-811879dd69d9"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Hebrew</text></gloss></sense><sense id="ibrani_2" guid="84a67646-8969-5660-92d2-92caf45d1534"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a member or descendant of a Semitic people claiming descent from Abraham, Isaac, and Jacob</text></gloss></sense><sense id="ibrani_3" guid="df4c2280-764e-551a-8088-b219f90f1cdd"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the Semitic language spoken by the Hebrew people</text></gloss></sense><sense id="ibrani_4" guid="ac7cb77a-1cc9-516f-b93a-ed343afb1c1c"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Jude: The second last book of the New Testament of the Bible</text></gloss></sense></entry>
<entry id="ibu" guid="e1be348c-e679-5b0e-97da-be4b9d313f06"><lexical-unit><form lang="id"><text>ibu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ibu_0" guid="9041ecc0-78ae-5f75-822f-84a38983d7cc"><grammatical-info value="Noun"/><gloss lang="en"><text>mother</text></gloss></sense><sense id="ibu_1" guid="ffc66892-3b69-5d88-a123-92949b79a09d"><grammatical-info value="Noun"/><gloss lang="en"><text>madam: A polite form of address for an adult woman or lady.</text></gloss></sense><sense id="ibu_2" guid="e9a6295c-2e24-55f7-b3d3-cc1ef20d3ebb"><grammatical-info value="Noun"/><gloss lang="en"><text>you (polite, to a woman)</text></gloss></sense></entry>
<entry id="icu" guid="2770d903-9b63-5a26-bc2c-e693dff4d8d6"><lexical-unit><form lang="id"><text>icu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="icu_0" guid="f9f50eea-7045-5bd1-a9ab-5added791137"><grammatical-info value="Noun"/><gloss lang="en"><text>intensive care unit, a hospital ward into which critically ill patients, in danger of dying, are admitted and closely monitored</text></gloss></sense></entry>
<entry id="ide" guid="18dc71d1-aa92-5be7-a93d-3da96e30bc49"><lexical-unit><form lang="id"><text>ide</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ide_0" guid="d1ea5d23-8b9c-522c-9ea6-92fc0936bd59"><grammatical-info value="Noun"/><gloss lang="en"><text>idea</text></gloss></sense></entry>
<entry id="ideal" guid="d75fbdb0-3f28-5116-b4fa-49bb0d9a5d2b"><lexical-unit><form lang="id"><text>ideal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ideal_0" guid="aadaf6b8-0bf7-53e5-8843-e8563ba39bbc"><grammatical-info value="Adjective"/><gloss lang="en"><text>ideal; optimal, being the best possibility</text></gloss></sense><sense id="ideal_1" guid="044144b5-2754-5d4f-8fda-2e047926c35e"><grammatical-info value="Adjective"/><gloss lang="en"><text>ideal; pertaining to ideas, or to a given idea</text></gloss></sense><sense id="ideal_2" guid="41d6e7ee-c4b0-5271-a0f9-951ad7e3d2f2"><grammatical-info value="Adjective"/><gloss lang="en"><text>ideal; a subring closed under multiplication by its containing ring</text></gloss></sense></entry>
<entry id="ijin" guid="df74a3a5-7149-5254-b61e-43b7a5a038ea"><lexical-unit><form lang="id"><text>ijin</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ijin_0" guid="0f00b3ee-952f-5123-b1e0-88e144546625"><grammatical-info value="Noun"/><gloss lang="en"><text>nonstandard form of izin</text></gloss></sense></entry>
<entry id="ikan" guid="2d2eb8da-2cbf-515b-99ee-5e84b66d69dd"><lexical-unit><form lang="id"><text>ikan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ikan_0" guid="f428b32c-1358-5252-acd4-a358fba9939f"><grammatical-info value="Noun"/><gloss lang="en"><text>fish (vertebrate animal)</text></gloss></sense></entry>
<entry id="ikat" guid="d259ee6a-167d-5867-ba22-490f75462d0b"><lexical-unit><form lang="id"><text>ikat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ikat_0" guid="ec7edaea-190f-5639-b15d-e50f781c5eb6"><grammatical-info value="Noun"/><gloss lang="en"><text>ikat (a style of weaving)</text></gloss></sense><sense id="ikat_1" guid="e6b31f73-74fd-5f92-adc6-9966044a2e9d"><grammatical-info value="Noun"/><gloss lang="en"><text>frame</text></gloss></sense><sense id="ikat_2" guid="ff22f14a-7d49-5d66-917a-6af81ecdf50d"><grammatical-info value="Noun"/><gloss lang="en"><text>bundle</text></gloss></sense><sense id="ikat_3" guid="d053e7cb-5c08-5cc9-b004-3cbfac2d325f"><grammatical-info value="Noun"/><gloss lang="en"><text>troop arrangement</text></gloss></sense><sense id="ikat_4" guid="a27d8187-67fb-549f-9cc0-feeecb4dfe26"><grammatical-info value="Noun"/><gloss lang="en"><text>synonym of kebat</text></gloss></sense><sense id="ikat_5" guid="df143c30-71f8-5fed-bc33-ae484a789fee"><grammatical-info value="Noun"/><gloss lang="en"><text>to tie; to bind</text></gloss></sense></entry>
<entry id="ikatan" guid="20133ec4-bb13-5b1b-a2dd-0124ef859730"><lexical-unit><form lang="id"><text>ikatan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ikatan_0" guid="5e0e12fb-b5f4-5bcb-940c-5e18632117bc"><grammatical-info value="Noun"/><gloss lang="en"><text>knot</text></gloss></sense><sense id="ikatan_1" guid="6c5a9f31-72f9-5c3e-bdab-e3793d268287"><grammatical-info value="Noun"/><gloss lang="en"><text>bond</text></gloss></sense><sense id="ikatan_2" guid="e7a65382-c2ee-500c-afff-3152e220ea4c"><grammatical-info value="Noun"/><gloss lang="en"><text>a link or force between neighbouring atoms in a molecule</text></gloss></sense><sense id="ikatan_3" guid="60c5361d-e2be-5e8c-8bdc-e43489c66add"><grammatical-info value="Noun"/><gloss lang="en"><text>bundle, bunch</text></gloss></sense><sense id="ikatan_4" guid="18280999-d583-52ef-8b5f-0d09aade22bb"><grammatical-info value="Noun"/><gloss lang="en"><text>composition</text></gloss></sense><sense id="ikatan_5" guid="21caa2b0-070f-5e79-821a-0740763f92aa"><grammatical-info value="Noun"/><gloss lang="en"><text>association, club, organization, society, union</text></gloss></sense><sense id="ikatan_6" guid="d39c7c3c-3b83-5729-a64c-687776a6bc86"><grammatical-info value="Noun"/><gloss lang="en"><text>commitment</text></gloss></sense><sense id="ikatan_7" guid="b8956e1e-4ae4-51a3-8fdf-c89b7ba3957c"><grammatical-info value="Noun"/><gloss lang="en"><text>constraint: a condition that a solution to an optimization problem must satisfy</text></gloss></sense></entry>
<entry id="ikut" guid="8175b64c-50f0-51f0-ae4b-edad3883fb2a"><lexical-unit><form lang="id"><text>ikut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ikut_0" guid="c9f0291f-2468-5320-9169-1294f5d050cb"><grammatical-info value="Verb"/><gloss lang="en"><text>to follow</text></gloss></sense><sense id="ikut_1" guid="d6c0f172-4194-54d7-93b9-d7e8caebc6d0"><grammatical-info value="Verb"/><gloss lang="en"><text>phimosis</text></gloss></sense></entry>
<entry id="il" guid="287471b6-147d-5dda-93b1-cace7969cbc6"><lexical-unit><form lang="id"><text>il</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="il_0" guid="b83ea017-0c06-52b0-a001-5fa275555dc8"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="ilah" guid="335b4528-fc8a-5d8d-9c5b-6036e8365eba"><lexical-unit><form lang="id"><text>ilah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ilah_0" guid="64aca3d7-0494-57b3-8a95-5d26714e37bf"><grammatical-info value="Noun"/><gloss lang="en"><text>god (deity)</text></gloss></sense><sense id="ilah_1" guid="39f8a822-e411-5262-ab9c-1c222e82bafd"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative form of ilat</text></gloss></sense></entry>
<entry id="ilai" guid="cc07ec7d-9ce8-5e3b-9816-a410fe82ac7c"><lexical-unit><form lang="id"><text>ilai</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ilai_0" guid="410212fe-6e09-5759-b2bf-be654b43a63f"><grammatical-info value="Verb"/><gloss lang="en"><text>to neigh</text></gloss></sense></entry>
<entry id="ilham" guid="c22e03a2-a4f3-5f37-ab4d-490700c4d7e5"><lexical-unit><form lang="id"><text>ilham</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ilham_0" guid="fe5ca48a-3a99-5ad9-8d83-72dec1931131"><grammatical-info value="Noun"/><gloss lang="en"><text>inspiration:</text></gloss></sense><sense id="ilham_1" guid="a48c508e-58d2-590e-96aa-ffdc2342f419"><grammatical-info value="Noun"/><gloss lang="en"><text>a supernatural divine influence on the prophets, apostles, or sacred writers, by which they were qualified to communicate moral or religious truth with authority; a supernatural influence which qualifies people to receive and communicate divine truth; also, the truth communicated</text></gloss></sense><sense id="ilham_2" guid="69240e6a-5d47-5ff7-b2bf-4b3abd69b68c"><grammatical-info value="Noun"/><gloss lang="en"><text>a male given name from Arabic</text></gloss></sense></entry>
<entry id="ilmu" guid="a314f25f-e4b0-5f94-bb8a-1c7adbc2159e"><lexical-unit><form lang="id"><text>ilmu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ilmu_0" guid="d788d1fa-7015-53bd-9c64-8021f7294ec9"><grammatical-info value="Noun"/><gloss lang="en"><text>knowledge</text></gloss></sense><sense id="ilmu_1" guid="c54dd377-50f0-52f6-9d37-dd561e79d7f2"><grammatical-info value="Noun"/><gloss lang="en"><text>science</text></gloss></sense><sense id="ilmu_2" guid="a09dbec6-fa6b-5e4e-ad81-81c3d69c7489"><grammatical-info value="Noun"/><gloss lang="en"><text>the collective discipline of study or learning acquired through the scientific method; the sum of knowledge gained from such methods and discipline</text></gloss></sense><sense id="ilmu_3" guid="878bd2fb-fb24-5704-8f15-b195a2b28028"><grammatical-info value="Noun"/><gloss lang="en"><text>a particular discipline or branch of knowledge that is natural, measurable or consisting of systematic principles rather than intuition or technical skill</text></gloss></sense><sense id="ilmu_4" guid="b94eb352-0c81-5ff4-a109-7d8f13a90443"><grammatical-info value="Noun"/><gloss lang="en"><text>supernatural knowledge, esoteric wisdom</text></gloss></sense></entry>
<entry id="ilustrasi" guid="9f86e7e9-d6e0-5cf3-a896-8e5cfe08000e"><lexical-unit><form lang="id"><text>ilustrasi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ilustrasi_0" guid="f122a5b7-81e6-5e10-8bae-02b496a4b64d"><grammatical-info value="Noun"/><gloss lang="en"><text>illustration: something which illustrates; a comparison or example intended to make clear or apprehensible, or to remove obscurity</text></gloss></sense></entry>
<entry id="im" guid="37586f6a-29b1-56ff-a84b-068f45f86826"><lexical-unit><form lang="id"><text>im</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="im_0" guid="6b36c87f-6e9c-5ba1-8ff3-a030536c78f7"><grammatical-info value="Noun"/></sense></entry>
<entry id="imam" guid="05a0d510-fb0e-58bb-9e39-4e053dbb74ae"><lexical-unit><form lang="id"><text>imam</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="imam_0" guid="ccae3abb-60e7-5ab4-b196-d1f06515a833"><grammatical-info value="Noun"/><gloss lang="en"><text>imam</text></gloss></sense><sense id="imam_1" guid="6abab941-98d8-55f0-a324-3dd48a4d3ca1"><grammatical-info value="Noun"/><gloss lang="en"><text>priest</text></gloss></sense><sense id="imam_2" guid="5599f68c-db75-5cf7-8eb7-5b0c4512d074"><grammatical-info value="Noun"/><gloss lang="en"><text>leader</text></gloss></sense><sense id="imam_3" guid="3987b74f-5cca-5085-a355-2f900bed9012"><grammatical-info value="Noun"/><gloss lang="en"><text>anyone who leads a group of Muslims in prayer</text></gloss></sense><sense id="imam_4" guid="eb5fd8b5-7eb9-52dd-880e-5161976f7860"><grammatical-info value="Noun"/><gloss lang="en"><text>imam; a trained cleric who leads a congregation</text></gloss></sense><sense id="imam_5" guid="cb580b2c-03fb-56f7-971b-9fdc70e7c1f3"><grammatical-info value="Noun"/><gloss lang="en"><text>a male given name from Arabic</text></gloss></sense></entry>
<entry id="imamat" guid="40838bc0-9e9c-5e2c-ac99-3fbe50829499"><lexical-unit><form lang="id"><text>imamat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="imamat_0" guid="9530ccec-c44d-52ab-8693-02e345a2bcd0"><grammatical-info value="Proper noun"/><gloss lang="en"><text>leadership</text></gloss></sense><sense id="imamat_1" guid="d47a97c1-82ac-5265-8362-3ef208cd37e7"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Leviticus (book of the Bible)</text></gloss></sense><sense id="imamat_2" guid="036dc5a6-ba51-52b7-896b-12169a966cac"><grammatical-info value="Proper noun"/><gloss lang="en"><text>priesthood: authority to act in the name of God or the divine in general</text></gloss></sense></entry>
<entry id="iman" guid="069f255d-73ce-5b03-882b-1c1280f0e074"><lexical-unit><form lang="id"><text>iman</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="iman_0" guid="a73212cd-40b5-5f0c-8d0a-b0f2ee7141c9"><grammatical-info value="Noun"/><gloss lang="en"><text>faith</text></gloss></sense><sense id="iman_1" guid="bbe871b6-55a1-51a8-bea2-86df618c1374"><grammatical-info value="Noun"/><gloss lang="en"><text>a conviction about abstractions, ideas, or beliefs, without empirical evidence, experience, or observation</text></gloss></sense></entry>
<entry id="imanuel" guid="620f5d90-3ee7-5af1-8cf5-dd281f5a1bb1"><lexical-unit><form lang="id"><text>imanuel</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="imanuel_0" guid="db939977-4e2b-57d9-bd86-8b224b96cc20"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Immanuel:</text></gloss></sense><sense id="imanuel_1" guid="9d593415-bb99-5e88-9321-922e40f69f40"><grammatical-info value="Proper noun"/><gloss lang="en"><text>A figure whose birth is prophesied in the Book of Isaiah in the Bible</text></gloss></sense><sense id="imanuel_2" guid="d5b8a144-2ad8-503f-8182-85ec410604e0"><grammatical-info value="Proper noun"/><gloss lang="en"><text>this figure, regarded by Christians as the Messiah or Christ</text></gloss></sense></entry>
<entry id="imbal" guid="24c346ab-6df0-5c7d-8e52-2a86e3d4e68c"><lexical-unit><form lang="id"><text>imbal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="imbal_0" guid="3573168e-00fc-5bd3-9653-70cb55876517"><grammatical-info value="Adjective"/><gloss lang="en"><text>bent</text></gloss></sense><sense id="imbal_1" guid="11524c42-864a-53f4-98fb-1120e3515e6e"><grammatical-info value="Adjective"/><gloss lang="en"><text>unbalanced</text></gloss></sense><sense id="imbal_2" guid="b5db1be1-eda0-522b-8d48-877c61e7d4e9"><grammatical-info value="Adjective"/><gloss lang="en"><text>lopsided</text></gloss></sense><sense id="imbal_3" guid="c48c0852-d9ba-5d44-a01e-7e883afb4a51"><grammatical-info value="Adjective"/><gloss lang="en"><text>lame</text></gloss></sense><sense id="imbal_4" guid="f6ba1bd2-85e9-51e3-b99d-04695ad4d3a4"><grammatical-info value="Adjective"/><gloss lang="en"><text>reply</text></gloss></sense><sense id="imbal_5" guid="055d6d60-ae5c-5142-b30f-dce848a692ac"><grammatical-info value="Adjective"/><gloss lang="en"><text>wages</text></gloss></sense></entry>
<entry id="imbang" guid="4f8d8906-9608-537a-8e56-307f9fc341a1"><lexical-unit><form lang="id"><text>imbang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="imbang_0" guid="3f7e2092-0276-5333-bd5f-647613e42723"><grammatical-info value="Verb"/><gloss lang="en"><text>balanced</text></gloss></sense><sense id="imbang_1" guid="f86e9860-3d9a-55ab-b99a-0afe58b5dba5"><grammatical-info value="Verb"/><gloss lang="en"><text>draw</text></gloss></sense><sense id="imbang_2" guid="852e71e7-b011-5cc9-8c80-e5bf05ec4df0"><grammatical-info value="Verb"/><gloss lang="en"><text>synonym of bimbang (“uncertain, doubtful, hesitant”)</text></gloss></sense></entry>
<entry id="impi" guid="8e64d738-8bb6-5edb-b05b-cbcf3af8c514"><lexical-unit><form lang="id"><text>impi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="impi_0" guid="8cd49a35-e562-5375-af0d-98a845ef8bbc"><grammatical-info value="Verb"/><gloss lang="en"><text>to dream (to hope; to wish)</text></gloss></sense></entry>
<entry id="impuls" guid="23326ea5-f05c-5445-960b-cb9c072e13b8"><lexical-unit><form lang="id"><text>impuls</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="impuls_0" guid="02844d65-e8b1-5ec5-9696-939c61412c6d"><grammatical-info value="Noun"/><gloss lang="en"><text>momentum (product of mass and velocity)</text></gloss></sense><sense id="impuls_1" guid="a881a0ff-1ce3-5fcf-97cb-6035e2998c07"><grammatical-info value="Noun"/><gloss lang="en"><text>impulse:</text></gloss></sense><sense id="impuls_2" guid="c0764111-391d-537b-8a50-9817c2233143"><grammatical-info value="Noun"/><gloss lang="en"><text>a thrust; a push; a sudden force that impels</text></gloss></sense><sense id="impuls_3" guid="431e21ba-2493-5378-b4bd-1a818544300f"><grammatical-info value="Noun"/><gloss lang="en"><text>a wish or urge, particularly a sudden one prompting action</text></gloss></sense></entry>
<entry id="in" guid="5530d6c5-be31-5fbd-b6af-168b555dc98a"><lexical-unit><form lang="id"><text>in</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="in_0" guid="31de77c9-0f9a-5c03-be0f-65aaa1ef968e"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="inap" guid="4cd53a82-876d-504f-b1ae-6e4079bbb5ad"><lexical-unit><form lang="id"><text>inap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="inap_0" guid="244a9fc4-41a8-50b9-b896-e02085b4951a"><grammatical-info value="Verb"/><gloss lang="en"><text>to stay overnight, to spend the night</text></gloss></sense></entry>
<entry id="indah" guid="697dd083-d54d-5ced-888b-eca2d197beba"><lexical-unit><form lang="id"><text>indah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="indah_0" guid="4e2fa0db-88bc-560a-8772-b594b6a803b0"><grammatical-info value="Adjective"/><gloss lang="en"><text>beautiful</text></gloss></sense><sense id="indah_1" guid="fb16388f-8ecd-526a-b48c-271c84f83dce"><grammatical-info value="Adjective"/><gloss lang="en"><text>to care, to pay attention</text></gloss></sense></entry>
<entry id="induk" guid="3d1b363a-bd35-537a-a489-e63055fffe4c"><lexical-unit><form lang="id"><text>induk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="induk_0" guid="d1554eb7-b2f4-5823-bc4a-5cc8a02e033d"><grammatical-info value="Noun"/><gloss lang="en"><text>mother (especially of animals)</text></gloss></sense><sense id="induk_1" guid="a59753e2-2cb9-5308-989d-2cf42f130155"><grammatical-info value="Noun"/><gloss lang="en"><text>parent</text></gloss></sense><sense id="induk_2" guid="481a4f58-2ee7-5f7e-adfb-ba7445076abe"><grammatical-info value="Noun"/><gloss lang="en"><text>main, master, principal, center</text></gloss></sense><sense id="induk_3" guid="48f0d780-6264-5729-a3ec-90727f762fb3"><grammatical-info value="Noun"/><gloss lang="en"><text>essence, quintessence, nucleus, origin, core, source</text></gloss></sense></entry>
<entry id="informasi" guid="ae560923-cc5b-57b9-a94f-5844f24494b1"><lexical-unit><form lang="id"><text>informasi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="informasi_0" guid="c5363188-db4f-500d-baa0-74d365ff1ac8"><grammatical-info value="Noun"/><gloss lang="en"><text>explanation</text></gloss></sense><sense id="informasi_1" guid="45dece56-0fe0-5cfb-a305-1a551a7308ec"><grammatical-info value="Noun"/><gloss lang="en"><text>announcement</text></gloss></sense><sense id="informasi_2" guid="a5970f6c-25b7-5578-a3d0-55d9b63d72fd"><grammatical-info value="Noun"/><gloss lang="en"><text>information, knowledge</text></gloss></sense></entry>
<entry id="ingat" guid="dc380665-fe5b-59a1-a4b4-03050df912c8"><lexical-unit><form lang="id"><text>ingat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ingat_0" guid="99294ca4-898a-5861-99d1-d2eb864afbd1"><grammatical-info value="Verb"/><gloss lang="en"><text>to remember</text></gloss></sense><sense id="ingat_1" guid="b452450b-0208-54e9-b01a-8b7163d05224"><grammatical-info value="Verb"/><gloss lang="en"><text>to be conscious, to be aware</text></gloss></sense><sense id="ingat_2" guid="f0f96622-273e-5e10-819e-9e3e522c8d45"><grammatical-info value="Verb"/><gloss lang="en"><text>to think about, to think of</text></gloss></sense><sense id="ingat_3" guid="e30ee54f-6508-511a-94db-a2ff304252ee"><grammatical-info value="Verb"/><gloss lang="en"><text>to be careful</text></gloss></sense><sense id="ingat_4" guid="95904c79-c2fb-5456-ae99-8015e574c072"><grammatical-info value="Verb"/><gloss lang="en"><text>to consider</text></gloss></sense><sense id="ingat_5" guid="016d5b00-0a66-536c-b9a0-31487f334be2"><grammatical-info value="Verb"/><gloss lang="en"><text>to intend</text></gloss></sense></entry>
<entry id="ingin" guid="bac823ab-a916-5a09-b26a-57d3c3fcb0ab"><lexical-unit><form lang="id"><text>ingin</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ingin_0" guid="7978ef8d-66ec-5699-9777-52643bbb96a5"><grammatical-info value="Verb"/><gloss lang="en"><text>to want</text></gloss></sense><sense id="ingin_1" guid="0aa7bea5-45c4-5597-b40e-5476b05de233"><grammatical-info value="Verb"/><gloss lang="en"><text>to wish for or desire (something); to feel a need or desire for; to crave or demand</text></gloss></sense><sense id="ingin_2" guid="2131ebe8-6f34-550d-aeb0-cf508c62b352"><grammatical-info value="Verb"/><gloss lang="en"><text>to wish, desire, or demand to see, have the presence of or do business with</text></gloss></sense><sense id="ingin_3" guid="7dc2e0de-c900-53ce-b579-6d637d81bd30"><grammatical-info value="Verb"/><gloss lang="en"><text>to experience desire; to wish</text></gloss></sense></entry>
<entry id="ingini" guid="00dab051-d029-53d3-9217-594f9aede971"><lexical-unit><form lang="id"><text>ingini</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ingini_0" guid="c7900e30-ffae-596c-bc0c-27fbc3dc3241"><grammatical-info value="Verb"/><gloss lang="en"><text>synonym of inginkan (“to want”)</text></gloss></sense></entry>
<entry id="inginkan" guid="83270e72-0eeb-5aeb-907f-d64223e299d0"><lexical-unit><form lang="id"><text>inginkan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="inginkan_0" guid="d2056162-27b1-583c-be41-3d953d8340b1"><grammatical-info value="Verb"/><gloss lang="en"><text>to want (to wish, desire, or demand to see, have the presence of or do business with)</text></gloss></sense></entry>
<entry id="ini" guid="2d2931a4-3e95-540e-b516-7c1b4923cb2e"><lexical-unit><form lang="id"><text>ini</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ini_0" guid="2c4f404e-4a91-537d-92a6-f50c4cfaf086"><grammatical-info value="Determiner"/><gloss lang="en"><text>only, just</text></gloss></sense><sense id="ini_1" guid="dd5af7d5-87e8-5583-97a6-b53a83be4653"><grammatical-info value="Determiner"/><gloss lang="en"><text>this (the (thing) here)</text></gloss></sense><sense id="ini_2" guid="6fc1da28-e607-55bc-8be7-c5f8e8fe8ee3"><grammatical-info value="Determiner"/><gloss lang="en"><text>this (known (thing) just mentioned)</text></gloss></sense><sense id="ini_3" guid="29eeef9f-bd07-54b6-b049-1ace461dc202"><grammatical-info value="Determiner"/><gloss lang="en"><text>this (known (thing) about to be mentioned)</text></gloss></sense><sense id="ini_4" guid="c56b5be0-f7ab-58d3-9a16-10140cde1c82"><grammatical-info value="Determiner"/><gloss lang="en"><text>this (known (thing) that the speaker does not think is known to the audience)</text></gloss></sense><sense id="ini_5" guid="6a25d321-b877-58d1-932d-5bfe3c744bbf"><grammatical-info value="Determiner"/><gloss lang="en"><text>this (The thing, item, etc. being indicated)</text></gloss></sense><sense id="ini_6" guid="2ff579d2-e63c-56c7-b500-596e3b28b045"><grammatical-info value="Determiner"/><gloss lang="en"><text>rice seeds in the form of grains or seeds that will be planted in gardens or fields</text></gloss></sense></entry>
<entry id="injak" guid="fde80358-ffd9-54ad-a434-60ae4b528730"><lexical-unit><form lang="id"><text>injak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="injak_0" guid="a3980196-08e4-5e7a-857c-56c6b3fc820f"><grammatical-info value="Verb"/><gloss lang="en"><text>to step on, to tread on</text></gloss></sense></entry>
<entry id="injil" guid="320cb405-31a9-559f-8510-1ea54d524336"><lexical-unit><form lang="id"><text>injil</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="injil_0" guid="ac52bfa6-dca2-5584-bc3e-4610901692c8"><grammatical-info value="Noun"/><gloss lang="en"><text>gospel</text></gloss></sense></entry>
<entry id="inspirasi" guid="7a4cb38f-7c88-583f-a586-02345e5b5b19"><lexical-unit><form lang="id"><text>inspirasi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="inspirasi_0" guid="339c6a29-3bc8-5395-b667-006f9258d619"><grammatical-info value="Noun"/><gloss lang="en"><text>inspiration</text></gloss></sense><sense id="inspirasi_1" guid="1aa92de2-5e8c-50c5-a3b8-0b1c7640c0b2"><grammatical-info value="Noun"/><gloss lang="en"><text>the drawing of air into the lungs, accomplished in mammals by elevation of the chest walls and flattening of the diaphragm, as part of the act of respiration</text></gloss></sense></entry>
<entry id="instruksi" guid="d204d743-5d38-5a0e-9967-8037926844cc"><lexical-unit><form lang="id"><text>instruksi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="instruksi_0" guid="b972b43f-dc09-5be2-9756-47d84997e85a"><grammatical-info value="Noun"/><gloss lang="en"><text>instruction (act of instructing, teaching, or furnishing with knowledge; information)</text></gloss></sense><sense id="instruksi_1" guid="17670767-f442-5705-98a3-03c2f2295a38"><grammatical-info value="Noun"/><gloss lang="en"><text>instruction (that which instructs, or with which one is instructed)</text></gloss></sense><sense id="instruksi_2" guid="af4dd00a-0afd-5c94-9dfb-fc3cbaa6b60b"><grammatical-info value="Noun"/><gloss lang="en"><text>to instruct (to inform instruction or command)</text></gloss></sense></entry>
<entry id="instruktur" guid="68bebf24-1755-542c-b467-04060197972b"><lexical-unit><form lang="id"><text>instruktur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="instruktur_0" guid="8cdf4bf6-eb0c-59ab-9b24-58e8eadae487"><grammatical-info value="Noun"/><gloss lang="en"><text>instructor (one who instructs; a teacher)</text></gloss></sense></entry>
<entry id="integritas" guid="b5a6ffda-b0bd-5012-9643-da95113edc73"><lexical-unit><form lang="id"><text>integritas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="integritas_0" guid="297460ad-62b6-56c0-9e3e-d176a9261991"><grammatical-info value="Noun"/><gloss lang="en"><text>integrity:</text></gloss></sense><sense id="integritas_1" guid="0a763010-c54d-5e9e-a7d2-dae60b1d62e4"><grammatical-info value="Noun"/><gloss lang="en"><text>steadfast adherence to a strict moral or ethical code</text></gloss></sense><sense id="integritas_2" guid="24b9a479-18ba-5fd1-9634-b83cf4083036"><grammatical-info value="Noun"/><gloss lang="en"><text>unimpaired; the state of being wholesome</text></gloss></sense></entry>
<entry id="interogasi" guid="3c29dbe5-ca96-589e-a7e9-7a805685b5ba"><lexical-unit><form lang="id"><text>interogasi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="interogasi_0" guid="ffd82396-bb58-5565-b33f-dc21639cdda5"><grammatical-info value="Verb"/><gloss lang="en"><text>sent</text></gloss></sense></entry>
<entry id="inti" guid="8138c148-8d43-5ded-b36c-508abcdeac22"><lexical-unit><form lang="id"><text>inti</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="inti_0" guid="335f89e4-8268-590c-8ab4-33520c7f3e30"><grammatical-info value="Noun"/><gloss lang="en"><text>essence</text></gloss></sense><sense id="inti_1" guid="9916cd16-e757-540b-b86c-fff03bddf7dc"><grammatical-info value="Noun"/><gloss lang="en"><text>core</text></gloss></sense><sense id="inti_2" guid="9045dc3a-e352-5869-afcc-206f4e868923"><grammatical-info value="Noun"/><gloss lang="en"><text>ellipsis of inti atom (“atomic nucleus”)</text></gloss></sense><sense id="inti_3" guid="91af11b3-2c03-5ea8-905c-2486f24122f0"><grammatical-info value="Noun"/><gloss lang="en"><text>kernel, nucleus, centre (UK)/center (US)</text></gloss></sense></entry>
<entry id="intimidasi" guid="43959d73-0066-5f8d-9867-06a3037b3c59"><lexical-unit><form lang="id"><text>intimidasi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="intimidasi_0" guid="9363f44d-8c98-5527-9df5-4a568a8c80f8"><grammatical-info value="Verb"/><gloss lang="en"><text>intimidation, the act of making timid or fearful or of deterring by threats; the state of being intimidated</text></gloss></sense></entry>
<entry id="ir" guid="ccd7ceae-269b-5626-9e9c-24ebe80f46bc"><lexical-unit><form lang="id"><text>ir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ir_0" guid="123c5c17-faa6-5ddd-8cff-39cc0c41a10c"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="ira" guid="cbe846cf-1ab6-598a-8728-68e145f24a33"><lexical-unit><form lang="id"><text>ira</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ira_0" guid="1257a352-9e07-550c-b2aa-02df28fb4ad5"><grammatical-info value="Noun"/></sense></entry>
<entry id="iri" guid="b9cfa468-9512-5d02-9ee3-a648e7fa1a5f"><lexical-unit><form lang="id"><text>iri</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="iri_0" guid="81ab1136-a898-5986-9f9b-ece3638f541a"><grammatical-info value="Adjective"/><gloss lang="en"><text>envy</text></gloss></sense></entry>
<entry id="iring" guid="f4e16d2d-b328-58d7-979d-dcdf5b96a4ec"><lexical-unit><form lang="id"><text>iring</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="iring_0" guid="d56de217-7460-5cdd-9be1-2ff17023cb2e"><grammatical-info value="Verb"/><gloss lang="en"><text>To accompany:</text></gloss></sense><sense id="iring_1" guid="cf421d43-891c-577f-9517-c2f1a8eb80ba"><grammatical-info value="Verb"/><gloss lang="en"><text>To go with or attend as a companion or associate; to keep company with; to go along with.</text></gloss></sense><sense id="iring_2" guid="a05ab6ad-5dc9-59f4-afae-5083f2b19c4a"><grammatical-info value="Verb"/><gloss lang="en"><text>To perform an accompanying part or parts in a composition.</text></gloss></sense><sense id="iring_3" guid="1ab64233-1355-51cf-a755-b1347497966b"><grammatical-info value="Verb"/><gloss lang="en"><text>To parade or trail; to walk or move past successively, one following another.</text></gloss></sense></entry>
<entry id="iru" guid="77f6dddd-e80a-5d47-a2cc-04373a5bc976"><lexical-unit><form lang="id"><text>iru</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="iru_0" guid="aadb55ca-6e07-5fc8-9b25-ba3f9c10f5bc"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="is" guid="75797095-c811-5b90-8c04-8f9d4636d1e5"><lexical-unit><form lang="id"><text>is</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="is_0" guid="3a162533-2fee-5dc7-beec-b2a9916cf355"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="isa" guid="d41b8d0e-f0f0-5968-a45c-1c6ae01199f4"><lexical-unit><form lang="id"><text>isa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="isa_0" guid="6d86b298-9693-5798-8a04-dac173f618cb"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Jesus (Isa), son of Mary, revered as a major prophet in Islam</text></gloss></sense></entry>
<entry id="isak" guid="d1accc2e-5e23-5c5a-8315-07d49f9ba101"><lexical-unit><form lang="id"><text>isak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="isak_0" guid="cb19deea-124d-5519-ab58-ab6fb7d72e48"><grammatical-info value="Noun"/><gloss lang="en"><text>jacob</text></gloss></sense></entry>
<entry id="isap" guid="9b7c9219-a884-5eb2-a880-ed752bcbb2e9"><lexical-unit><form lang="id"><text>isap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="isap_0" guid="90866a0b-ebad-59c6-a357-2aa82fc4e9a5"><grammatical-info value="Verb"/><gloss lang="en"><text>to suck (to use the mouth to pull in liquid etc)</text></gloss></sense><sense id="isap_1" guid="25efbbe8-bdb3-5dc0-96e0-7b16df21c206"><grammatical-info value="Verb"/><gloss lang="en"><text>to smoke</text></gloss></sense></entry>
<entry id="ishak" guid="a318cda2-05fe-5a6f-88d6-3b33021a37c4"><lexical-unit><form lang="id"><text>ishak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ishak_0" guid="5f540a24-cd82-5a03-b191-27023f798bee"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Isaac (prophet)</text></gloss></sense><sense id="ishak_1" guid="bec1721a-d401-5837-b951-037da4c94786"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Isaac (Biblical character)</text></gloss></sense><sense id="ishak_2" guid="091f5d0c-db7a-5ca2-8f69-761251392e4d"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a male given name from Arabic</text></gloss></sense></entry>
<entry id="isi" guid="87409cbd-618a-58cd-a258-664aa9a0d1c5"><lexical-unit><form lang="id"><text>isi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="isi_0" guid="ec37eb61-2779-54bd-a269-4ee3b83fe2f9"><grammatical-info value="Noun"/><gloss lang="en"><text>content:</text></gloss></sense><sense id="isi_1" guid="a0508110-861c-5486-a249-b6d2edb2aef1"><grammatical-info value="Noun"/><gloss lang="en"><text>that which is contained.</text></gloss></sense><sense id="isi_2" guid="f929db3c-bb88-5f7c-accb-a96e67ab7905"><grammatical-info value="Noun"/><gloss lang="en"><text>subject matter; semantic information (or a portion or body thereof); that which is contained in writing, speech, video, etc.</text></gloss></sense><sense id="isi_3" guid="73ae0bf0-1b86-5a4e-895c-9e110d0fbab7"><grammatical-info value="Noun"/><gloss lang="en"><text>list of contents.</text></gloss></sense><sense id="isi_4" guid="515fd703-0b1b-5685-99e8-cdf96b4010bd"><grammatical-info value="Noun"/><gloss lang="en"><text>table of contents</text></gloss></sense><sense id="isi_5" guid="c3b437bf-d933-530d-a57c-8986d2824498"><grammatical-info value="Noun"/><gloss lang="en"><text>capacity, volume.</text></gloss></sense><sense id="isi_6" guid="9303e812-ee0e-5613-9e74-37865bcc56e6"><grammatical-info value="Noun"/><gloss lang="en"><text>crux, essence, gist, heart, pith, quintessence, thrust</text></gloss></sense><sense id="isi_7" guid="92560f5d-22e6-5e28-ab65-2adc44e04de0"><grammatical-info value="Noun"/><gloss lang="en"><text>terms (of an agreement).</text></gloss></sense></entry>
<entry id="israel" guid="d1642bdf-ee6f-512a-b6eb-ca1d5df5561a"><lexical-unit><form lang="id"><text>israel</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="israel_0" guid="c4734eb0-bf63-522a-8562-ee956ed0d263"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Israel:</text></gloss></sense><sense id="israel_1" guid="fff01dcb-5d7f-5fcc-b685-52244516acf6"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a country in Western Asia in the Middle East, at the eastern shore of the Mediterranean</text></gloss></sense><sense id="israel_2" guid="c8e24be4-ec3b-50de-af77-b79bba684051"><grammatical-info value="Proper noun"/><gloss lang="en"><text>A Biblical region of Western Asia roughly coextensive with the modern State of Israel, known in the Bible as the Land of Israel and considered the ancestral homeland of the Jewish people</text></gloss></sense><sense id="israel_3" guid="903e51f0-bbae-5843-9014-054838ce4d51"><grammatical-info value="Proper noun"/><gloss lang="en"><text>an ancient kingdom in Western Asia, roughly coextensive with the modern State of Israel and the Land of Israel</text></gloss></sense><sense id="israel_4" guid="bb619789-9850-5da3-8eb4-158b47d43008"><grammatical-info value="Proper noun"/><gloss lang="en"><text>an ancient kingdom that occupied the northern part of the Land of Israel and modern State of Israel, as distinct from Judah</text></gloss></sense><sense id="israel_5" guid="16297c56-d07f-53a5-bc62-753ad17c5cb3"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the Jews, taken collectively</text></gloss></sense></entry>
