<entry id="timba" guid="39056d8c-edfe-5cc2-b319-716352d36fbf"><lexical-unit><form lang="id"><text>timba</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="timba_0" guid="1258e52b-50bb-51c5-b5d1-b112c05d0610"><grammatical-info value="Verb"/><gloss lang="en"><text>bailer; dipper</text></gloss></sense><sense id="timba_1" guid="6bc775eb-34bd-5854-ad0f-11bafbada4a4"><grammatical-info value="Verb"/><gloss lang="en"><text>bucket; pail</text></gloss></sense></entry>
<entry id="timbang" guid="60d5dc80-4836-554f-913f-aad1bd03226e"><lexical-unit><form lang="id"><text>timbang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="timbang_0" guid="dd8197b5-9aaa-51af-a643-c8ba1ba1d42e"><grammatical-info value="Verb"/><gloss lang="en"><text>fair, unbiased</text></gloss></sense><sense id="timbang_1" guid="0de8c423-5cc3-5e98-87da-a361a55149be"><grammatical-info value="Verb"/><gloss lang="en"><text>weigh, weight</text></gloss></sense><sense id="timbang_2" guid="c2d444f5-64cc-5663-a11d-81b32638817d"><grammatical-info value="Verb"/><gloss lang="en"><text>apheretic form of ketimbang (“rather than”)</text></gloss></sense></entry>
<entry id="timbul" guid="5af41d95-9267-5922-a3c7-7a33d3a75099"><lexical-unit><form lang="id"><text>timbul</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="timbul_0" guid="46935a66-a591-5a0a-893c-e066cc31596a"><grammatical-info value="Verb"/><gloss lang="en"><text>to emerge</text></gloss></sense><sense id="timbul_1" guid="8006a061-b0a1-5dae-86ef-9a14849b8c41"><grammatical-info value="Verb"/><gloss lang="en"><text>to (float to the) surface</text></gloss></sense><sense id="timbul_2" guid="8da49510-e551-5f1d-8362-5cb61f91e971"><grammatical-info value="Verb"/><gloss lang="en"><text>to come, to spring up</text></gloss></sense><sense id="timbul_3" guid="7a7056ca-ebe4-567c-8b9e-a4c9ca8a36ae"><grammatical-info value="Verb"/><gloss lang="en"><text>to appear,</text></gloss></sense><sense id="timbul_4" guid="71ef5ebb-91d8-5aac-9b26-c3aabf558c00"><grammatical-info value="Verb"/><gloss lang="en"><text>to rise,</text></gloss></sense><sense id="timbul_5" guid="e20e8f8f-0846-5dbc-904d-77ba1415099e"><grammatical-info value="Verb"/><gloss lang="en"><text>to arise,</text></gloss></sense><sense id="timbul_6" guid="579e687b-5fa4-582d-ab46-629cd93f833e"><grammatical-info value="Verb"/><gloss lang="en"><text>to occur,</text></gloss></sense><sense id="timbul_7" guid="867b210f-3c02-5ed1-876a-7c9ce0f95424"><grammatical-info value="Verb"/><gloss lang="en"><text>to break out,</text></gloss></sense></entry>
<entry id="timbun" guid="7084bc23-1866-5c04-8ba0-150780ebe861"><lexical-unit><form lang="id"><text>timbun</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="timbun_0" guid="02915305-b1f6-57fe-b101-e8f4df16f7fa"><grammatical-info value="Verb"/><gloss lang="en"><text>pile, heap</text></gloss></sense></entry>
