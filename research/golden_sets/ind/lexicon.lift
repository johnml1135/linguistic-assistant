<entry id="akibat" guid="21090952-76dd-591e-872f-978fa7d7da68"><lexical-unit><form lang="id"><text>akibat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="akibat_0" guid="a06a979a-f02e-55e7-8f9c-8b6c5b0d6423"><grammatical-info value="Noun"/><gloss lang="en"><text>consequence, result</text></gloss></sense><sense id="akibat_1" guid="c2440c4b-8b21-59bc-85ed-052d55bc0a77"><grammatical-info value="Noun"/><gloss lang="en"><text>ellipsis of teorema akibat (“corollary”)</text></gloss></sense></entry>
