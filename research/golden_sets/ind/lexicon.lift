<entry id="melepaskan" guid="f9537ae3-4daa-5254-8913-3f3e6e2b853c"><lexical-unit><form lang="id"><text>melepaskan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="melepaskan_0" guid="6e563dd1-9b74-5226-8b28-d5afe72714ce"><grammatical-info value="Verb"/><gloss lang="en"><text>to no longer hold; to release; let go</text></gloss></sense><sense id="melepaskan_1" guid="c44b277b-0d47-5794-b43f-2dca2171cad0"><grammatical-info value="Verb"/><gloss lang="en"><text>to release from one's grasp</text></gloss></sense><sense id="melepaskan_2" guid="888d5e9f-b341-5657-bd28-7fec6915158a"><grammatical-info value="Verb"/><gloss lang="en"><text>to discharge (e.g. from prison)</text></gloss></sense><sense id="melepaskan_3" guid="d42e4acd-6d63-5dac-b32c-dda579308a46"><grammatical-info value="Verb"/><gloss lang="en"><text>to waive, forgive (a debt)</text></gloss></sense><sense id="melepaskan_4" guid="1d2194b3-30e1-5858-a902-6672125c3f78"><grammatical-info value="Verb"/><gloss lang="en"><text>to fire, to sack</text></gloss></sense><sense id="melepaskan_5" guid="739efd0d-4fe2-5ae1-bd93-dc2db9466eb3"><grammatical-info value="Verb"/><gloss lang="en"><text>to drop (a plan, an issue etc.); to lo longer be concerned with</text></gloss></sense><sense id="melepaskan_6" guid="845d4441-b84a-5b88-853c-96088c0371ee"><grammatical-info value="Verb"/><gloss lang="en"><text>to relinquish, to renounce, to no longer claim</text></gloss></sense><sense id="melepaskan_7" guid="9bdfbf08-747c-5f3a-8394-3bd65ca096f7"><grammatical-info value="Verb"/><gloss lang="en"><text>to take off (clothes)</text></gloss></sense></entry>
