<entry id="sisi" guid="7b6650b9-3612-5ab1-97e5-19657345a2e7"><lexical-unit><form lang="id"><text>sisi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sisi_0" guid="23a0787d-d087-5856-bd06-c5c4acc2127c"><grammatical-info value="Noun"/><gloss lang="en"><text>side:</text></gloss></sense><sense id="sisi_1" guid="6d2da1f1-23c5-53fa-b70b-5c3b11758eee"><grammatical-info value="Noun"/><gloss lang="en"><text>a bounding straight edge of a two-dimensional shape</text></gloss></sense><sense id="sisi_2" guid="ba541e77-2958-5759-9a3e-4582069bc8e8"><grammatical-info value="Noun"/><gloss lang="en"><text>face: any of the flat bounding surfaces of a polyhedron. More generally, any of the bounding pieces of a polytope of any dimension</text></gloss></sense><sense id="sisi_3" guid="8e6abdbe-2167-5ee7-b435-2527817fcbdb"><grammatical-info value="Noun"/><gloss lang="en"><text>perspective; side</text></gloss></sense><sense id="sisi_4" guid="7695037b-b898-534e-b9be-37888908607f"><grammatical-info value="Noun"/><gloss lang="en"><text>one half (left or right, top or bottom, front or back, etc.) of something or someone</text></gloss></sense><sense id="sisi_5" guid="49377237-8d90-5aa1-b333-604b11acebf3"><grammatical-info value="Noun"/><gloss lang="en"><text>a region in a specified position with respect to something</text></gloss></sense><sense id="sisi_6" guid="d8aa0f9e-f2b5-5ede-8dcf-0b86a910297d"><grammatical-info value="Noun"/><gloss lang="en"><text>faction; side</text></gloss></sense><sense id="sisi_7" guid="5cdd3159-8ce7-59ce-80c1-e0bd27dd36cd"><grammatical-info value="Noun"/><gloss lang="en"><text>one set of competitors in a game</text></gloss></sense></entry>
