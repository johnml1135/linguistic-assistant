<entry id="undangan" guid="0309aea8-702f-5bfc-a605-d9f300d952ab"><lexical-unit><form lang="id"><text>undangan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="undangan_0" guid="5832cc77-1c9b-52a5-8d93-082c78d95593"><grammatical-info value="Noun"/><gloss lang="en"><text>invitation (the act of inviting, asking for someone's company or presence)</text></gloss></sense><sense id="undangan_1" guid="4d12b8b0-8a62-582e-b5d1-8034c66da74b"><grammatical-info value="Noun"/><gloss lang="en"><text>invitation (a document or verbal message conveying an invitation)</text></gloss></sense><sense id="undangan_2" guid="e3f61c3f-18b0-583e-b30a-4528fbb335ef"><grammatical-info value="Noun"/><gloss lang="en"><text>early admission</text></gloss></sense><sense id="undangan_3" guid="11b2eb4d-3e78-5f5c-bf52-3187463972ff"><grammatical-info value="Noun"/><gloss lang="en"><text>legislative body (a political institution which holds the legislative power in a state)</text></gloss></sense></entry>
<entry id="undi" guid="e560ff24-78fb-5005-ab76-1ac37d8d68bd"><lexical-unit><form lang="id"><text>undi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="undi_0" guid="bf70c531-2132-58ea-a1a1-84e324d5c8f4"><grammatical-info value="Verb"/><gloss lang="en"><text>lot: anything (as a die, pebble, ball, or slip of paper) used in determining a question by chance, or without human choice or will</text></gloss></sense><sense id="undi_1" guid="3385bd69-bc0d-5c80-a31e-ba3fe000db6c"><grammatical-info value="Verb"/><gloss lang="en"><text>to draw</text></gloss></sense><sense id="undi_2" guid="e9aca6d4-8028-56ac-8c44-0866d5d764c0"><grammatical-info value="Verb"/><gloss lang="en"><text>to conduct (a lottery); to select (the numbers) for a lottery</text></gloss></sense></entry>
