<entry id="raja" guid="95475317-9991-5a6d-9682-4447024ff955"><lexical-unit><form lang="id"><text>raja</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="raja_0" guid="773362c4-3bb8-5e4c-a61b-4fd4c9b7f8cf"><grammatical-info value="Proper noun"/><gloss lang="en"><text>king, male monarch</text></gloss></sense><sense id="raja_1" guid="8641ecca-4b4f-59af-bfd3-23dbdcc9eb77"><grammatical-info value="Proper noun"/><gloss lang="en"><text>king; the principal chess piece</text></gloss></sense><sense id="raja_2" guid="4a7e0ccd-5fe8-5cae-a5f9-4a7892093622"><grammatical-info value="Proper noun"/><gloss lang="en"><text>king; a playing card with the letter "K" and the image of a king on it, the thirteenth card in a given suit</text></gloss></sense><sense id="raja_3" guid="29a7b8ec-1c4d-55dc-950b-b5522881be8f"><grammatical-info value="Proper noun"/><gloss lang="en"><text>general; a xiangqi piece that is moved one point orthogonally and confined within the palace</text></gloss></sense><sense id="raja_4" guid="bfce3f73-c646-5d9f-addc-ebd4fa3346e2"><grammatical-info value="Proper noun"/><gloss lang="en"><text>superseded spelling of raya</text></gloss></sense></entry>
