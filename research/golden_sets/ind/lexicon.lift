<entry id="botol" guid="d58bd86d-1e0d-538e-8cb1-a80b8c839dbe"><lexical-unit><form lang="id"><text>botol</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="botol_0" guid="f29fc3b3-9347-5218-8fad-acfca85eae1d"><grammatical-info value="Noun"/><gloss lang="en"><text>bottle (container used for holding liquids)</text></gloss></sense><sense id="botol_1" guid="b746137e-6890-51eb-9fca-e2194f0151bc"><grammatical-info value="Noun"/><gloss lang="en"><text>stupid, foolish, moronic</text></gloss></sense></entry>
<entry id="bu" guid="2c0024f2-57a2-5d11-952b-0b43a873396e"><lexical-unit><form lang="id"><text>bu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bu_0" guid="f7bd02ae-92e6-5cfa-99dd-9987fa29e204"><grammatical-info value="Noun"/><gloss lang="en"><text>mam</text></gloss></sense><sense id="bu_1" guid="030dabb0-2bda-5b18-943e-9386c0bbe707"><grammatical-info value="Noun"/><gloss lang="en"><text>Mrs, Ms, madam</text></gloss></sense><sense id="bu_2" guid="57af8de1-5982-5540-ae4b-be55b19ea9c5"><grammatical-info value="Noun"/><gloss lang="en"><text>Mum</text></gloss></sense><sense id="bu_3" guid="7ad30e34-126b-52a7-9ef7-aade2b7be924"><grammatical-info value="Noun"/><gloss lang="en"><text>initialism of bising usus</text></gloss></sense></entry>
<entry id="buah" guid="5e42c9b9-7435-5fac-92b5-1f358cda0b2c"><lexical-unit><form lang="id"><text>buah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="buah_0" guid="0c29f997-8b8d-5647-9eb1-f1cd9ffd1d1f"><grammatical-info value="Noun"/><gloss lang="en"><text>fruit</text></gloss></sense><sense id="buah_1" guid="aea315d2-9675-56b9-a5d3-aa0ddcd79555"><grammatical-info value="Noun"/><gloss lang="en"><text>result, outcome</text></gloss></sense><sense id="buah_2" guid="57af0f27-fd56-5cff-b97b-11701a5904ab"><grammatical-info value="Noun"/><gloss lang="en"><text>origin, subject, topic, theme</text></gloss></sense><sense id="buah_3" guid="1e6cc17d-6a2f-5d7a-b396-5ec1d2473234"><grammatical-info value="Noun"/><gloss lang="en"><text>Classifier for anything generally concretely big and having volume, as well as abstract things.</text></gloss></sense></entry>
<entry id="buang" guid="aff0f4e1-001e-5367-8783-102dcfb9ba36"><lexical-unit><form lang="id"><text>buang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="buang_0" guid="05d8723b-3b47-51d6-836e-614238025f22"><grammatical-info value="Verb"/><gloss lang="en"><text>to throw away (to discard trash, garbage, or the like; to toss out; to put in the trash)</text></gloss></sense><sense id="buang_1" guid="99b478f7-ff24-52f7-9c1a-62cdcbc3e03b"><grammatical-info value="Verb"/><gloss lang="en"><text>beetle</text></gloss></sense></entry>
<entry id="buangan" guid="8b495c74-24fe-5c7d-82fc-7e987ab6a8be"><lexical-unit><form lang="id"><text>buangan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="buangan_0" guid="28394c7e-6ee5-5f86-93c8-34c1b5c2d810"><grammatical-info value="Noun"/><gloss lang="en"><text>outcast</text></gloss></sense><sense id="buangan_1" guid="3744bd01-ee28-5907-b4cf-258d67ae13f5"><grammatical-info value="Noun"/><gloss lang="en"><text>waste</text></gloss></sense></entry>
<entry id="buas" guid="43c68b14-8609-5626-aa69-3cb0bb63477b"><lexical-unit><form lang="id"><text>buas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="buas_0" guid="5ee3bf00-4dfd-5a96-ae3c-786ac3c2edbe"><grammatical-info value="Noun"/><gloss lang="en"><text>wild, savage</text></gloss></sense><sense id="buas_1" guid="49829dda-4d49-5c28-8f7b-202b52ff07b4"><grammatical-info value="Noun"/><gloss lang="en"><text>cruel, fierce</text></gloss></sense></entry>
<entry id="buat" guid="a6ceea1a-ebd2-5af9-abcb-a89f047b9086"><lexical-unit><form lang="id"><text>buat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="buat_0" guid="9b5cd20f-b6aa-5684-8f2b-f8a118f232c2"><grammatical-info value="Verb"/><gloss lang="en"><text>to make, create</text></gloss></sense><sense id="buat_1" guid="354a4e55-2a23-547d-8d4b-eade0495b601"><grammatical-info value="Verb"/><gloss lang="en"><text>to make, cause</text></gloss></sense><sense id="buat_2" guid="6e186c3a-64d6-5150-b012-3ddd56be0910"><grammatical-info value="Verb"/><gloss lang="en"><text>for</text></gloss></sense><sense id="buat_3" guid="60b75929-b34d-526b-952e-6244f984ca96"><grammatical-info value="Verb"/><gloss lang="en"><text>so that, in order to, in order that</text></gloss></sense></entry>
<entry id="buatkan" guid="d7ec6568-e640-5906-9781-182e25fb82cf"><lexical-unit><form lang="id"><text>buatkan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="buatkan_0" guid="1ebbd84f-e182-55f1-9fa6-5edeb257761d"><grammatical-info value="Verb"/><gloss lang="en"><text>to make</text></gloss></sense></entry>
<entry id="budak" guid="513b39f4-f039-51db-9ed6-a141c92cc190"><lexical-unit><form lang="id"><text>budak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="budak_0" guid="c34e5c89-43d0-52ba-834b-017e7b3eada9"><grammatical-info value="Noun"/><gloss lang="en"><text>slave</text></gloss></sense><sense id="budak_1" guid="63511695-c5f4-5ec1-8e2c-f75ac644ef1d"><grammatical-info value="Noun"/><gloss lang="en"><text>child</text></gloss></sense></entry>
<entry id="budaya" guid="b1c497c6-5a25-5cf1-90a6-ed82cd8915ed"><lexical-unit><form lang="id"><text>budaya</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="budaya_0" guid="232aab38-0454-50a6-a424-bd4993b2e56b"><grammatical-info value="Noun"/><gloss lang="en"><text>intellectual capacity (the faculty of reasoning and understanding)</text></gloss></sense><sense id="budaya_1" guid="539b5cee-83a9-58eb-9ae7-5187924684b4"><grammatical-info value="Noun"/><gloss lang="en"><text>culture (the arts, customs, lifestyles, background, and habits that characterize a particular society or nation)</text></gloss></sense><sense id="budaya_2" guid="81fc3c84-f331-5574-b374-a60450c4f310"><grammatical-info value="Noun"/><gloss lang="en"><text>tendency, habit, norm (a pervasively engrained practice, especially one that is hard to give up)</text></gloss></sense></entry>
<entry id="bujuk" guid="4e332149-76ac-5f6f-8695-4d4655fef385"><lexical-unit><form lang="id"><text>bujuk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bujuk_0" guid="ed2f1298-4ced-5b25-b128-f139d160ee78"><grammatical-info value="Noun"/><gloss lang="en"><text>persuasion (an argument or other statement intended to influence one's opinions or beliefs)</text></gloss></sense><sense id="bujuk_1" guid="c49c2879-e1cd-579a-beab-c91c712d3d1c"><grammatical-info value="Noun"/><gloss lang="en"><text>persuasion (one's ability or power to influence someone's opinions or feelings)</text></gloss></sense><sense id="bujuk_2" guid="87795ffd-eeec-5f26-a847-d627aaef8396"><grammatical-info value="Noun"/><gloss lang="en"><text>to persuade</text></gloss></sense><sense id="bujuk_3" guid="5475af90-3d9b-5ba8-8137-195d0480b8fc"><grammatical-info value="Noun"/><gloss lang="en"><text>forest snakehead (a species of snakehead)</text></gloss></sense></entry>
<entry id="buk" guid="b1b21eda-ed83-5a8c-8d4f-a727391915b9"><lexical-unit><form lang="id"><text>buk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="buk_0" guid="f27a14b3-a581-544d-993c-1ebaf53541da"><grammatical-info value="Noun"/><gloss lang="en"><text>thud, bam; a sound of a large ripe fruit or heavy object falling to the ground</text></gloss></sense><sense id="buk_1" guid="7f620d8f-c578-5d4e-a895-bb8f3e59d596"><grammatical-info value="Noun"/><gloss lang="en"><text>to book, to reserve</text></gloss></sense><sense id="buk_2" guid="100233cd-9295-5c39-9d71-dcac8aef86aa"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative form of ibu (“mother; madam”)</text></gloss></sense></entry>
<entry id="buka" guid="05806fd5-65f6-52f3-a9ab-74e59bac9551"><lexical-unit><form lang="id"><text>buka</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="buka_0" guid="ee7145b6-e2fd-583a-845a-78dc0f0615f2"><grammatical-info value="Verb"/><gloss lang="en"><text>open (actively conducting or prepared to conduct business)</text></gloss></sense><sense id="buka_1" guid="dfc0c63a-6ec4-56c4-a1fd-785ee7f0124b"><grammatical-info value="Verb"/><gloss lang="en"><text>to open</text></gloss></sense><sense id="buka_2" guid="3e954e3c-0ad3-5c24-ad20-aa8d9b33148b"><grammatical-info value="Verb"/><gloss lang="en"><text>to break the fast; to have iftar</text></gloss></sense></entry>
<entry id="bukak" guid="82586b36-cd5d-5539-b89e-532a9ed89df6"><lexical-unit><form lang="id"><text>bukak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bukak_0" guid="1c39d465-f496-5e98-a1f2-53f07c1b5502"><grammatical-info value="Adjective"/><gloss lang="en"><text>alternative form of buka</text></gloss></sense></entry>
<entry id="bukakan" guid="bae6028f-54c0-58aa-9b2f-88ea0cfdaa15"><lexical-unit><form lang="id"><text>bukakan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bukakan_0" guid="717372d9-b5d1-5ea5-9d4a-aad19a785e27"><grammatical-info value="Verb"/><gloss lang="en"><text>to open (for)</text></gloss></sense><sense id="bukakan_1" guid="4ad79b55-9b07-5f41-9641-bd5b751b1675"><grammatical-info value="Verb"/><gloss lang="en"><text>to reveal</text></gloss></sense></entry>
<entry id="bukan" guid="339904bc-ebd2-5c5c-a4ee-e96bc5b53e7f"><lexical-unit><form lang="id"><text>bukan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bukan_0" guid="9b5be43c-eb8a-5d40-b2c6-234d656ac031"><grammatical-info value="Particle"/><gloss lang="en"><text>not</text></gloss></sense></entry>
<entry id="bukit" guid="daa58e7f-7f5d-5d5a-a7c2-60ee3fdc6ae5"><lexical-unit><form lang="id"><text>bukit</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bukit_0" guid="d5ee3f74-bc16-5ab7-9b64-cda5d749f2b2"><grammatical-info value="Proper noun"/><gloss lang="en"><text>hill (elevated location)</text></gloss></sense><sense id="bukit_1" guid="baa53eb9-96bd-57c9-906b-35eb64c83bdc"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a surname from Karo Batak</text></gloss></sense></entry>
<entry id="bukti" guid="391bd091-954b-5634-a07d-c6e655d4862d"><lexical-unit><form lang="id"><text>bukti</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bukti_0" guid="5d1274b3-afc7-5de2-a01b-7fa60622683c"><grammatical-info value="Noun"/><gloss lang="en"><text>proof, evidence</text></gloss></sense></entry>
<entry id="buku" guid="3b3f00d2-4dca-539a-9543-077d7746431b"><lexical-unit><form lang="id"><text>buku</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="buku_0" guid="e311d009-dfb0-5542-a207-c6b3dbf8d644"><grammatical-info value="Noun"/><gloss lang="en"><text>book (collection of sheets of paper bound together containing printed or written material)</text></gloss></sense><sense id="buku_1" guid="7c4741cf-30b7-54b6-8577-b22ee3ceb149"><grammatical-info value="Noun"/><gloss lang="en"><text>ellipsis of buku besar (“ledger”)</text></gloss></sense><sense id="buku_2" guid="8694f086-8645-5129-a753-051fc8e22988"><grammatical-info value="Noun"/><gloss lang="en"><text>account (a registry of pecuniary transactions)</text></gloss></sense><sense id="buku_3" guid="c883bfa6-a369-5534-bab4-680706a4aa4a"><grammatical-info value="Noun"/><gloss lang="en"><text>a lumpy joint (of fingers or similar structures)</text></gloss></sense><sense id="buku_4" guid="03a80d77-9085-56ee-b695-6e1b7f2a59c5"><grammatical-info value="Noun"/><gloss lang="en"><text>a small block or segment of something (of bamboos or similar structures)</text></gloss></sense><sense id="buku_5" guid="ec644ea0-39b6-5be4-bf07-5b2207e94db9"><grammatical-info value="Noun"/><gloss lang="en"><text>articulation: a joint between two separable parts, as a leaf and a stem</text></gloss></sense><sense id="buku_6" guid="a5d92f72-055e-5fed-9d2f-a2581d38a936"><grammatical-info value="Noun"/><gloss lang="en"><text>node:</text></gloss></sense><sense id="buku_7" guid="2f1c4aef-960e-561b-abce-9ff67e2446a3"><grammatical-info value="Noun"/><gloss lang="en"><text>knot, knob, protuberance or swelling</text></gloss></sense></entry>
<entry id="bulan" guid="8417a17d-157b-5725-90e4-0f4cebd463d0"><lexical-unit><form lang="id"><text>bulan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bulan_0" guid="753177db-5d0c-57db-b69c-f8df69204842"><grammatical-info value="Noun"/><gloss lang="en"><text>moon (largest natural satellite of planet Earth)</text></gloss></sense><sense id="bulan_1" guid="e2c0d7f8-c61b-592a-83a2-969fda12e77f"><grammatical-info value="Noun"/><gloss lang="en"><text>moon (any substantially sized natural satellite of a planet)</text></gloss></sense><sense id="bulan_2" guid="443b5818-2b6c-592d-aeb4-c261f8333dfe"><grammatical-info value="Noun"/><gloss lang="en"><text>month (period into which a year is divided)</text></gloss></sense><sense id="bulan_3" guid="a5f239c5-9100-5a94-84be-a81e5c9a807c"><grammatical-info value="Noun"/><gloss lang="en"><text>the Moon: the only permanent natural satellite of the Earth</text></gloss></sense></entry>
<entry id="bulat" guid="a2fe35dc-1874-5a18-886e-7a41d903c316"><lexical-unit><form lang="id"><text>bulat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bulat_0" guid="c944cbcc-00d4-5924-9d8b-0c0b11381144"><grammatical-info value="Noun"/><gloss lang="en"><text>round</text></gloss></sense><sense id="bulat_1" guid="d13b398f-e1a8-5d40-9b1b-30f985ca1427"><grammatical-info value="Noun"/><gloss lang="en"><text>spherical</text></gloss></sense></entry>
<entry id="bulir" guid="6d4c11d3-c96a-520d-8441-c87154c8258b"><lexical-unit><form lang="id"><text>bulir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bulir_0" guid="52f18785-4c0f-5c6e-a69b-b3a5de8ff268"><grammatical-info value="Noun"/><gloss lang="en"><text>ear (the fruiting body of a grain plant.)</text></gloss></sense><sense id="bulir_1" guid="981a7e49-2d86-5e2c-aac4-c8cc1be9ce18"><grammatical-info value="Noun"/><gloss lang="en"><text>spike (A kind of inflorescence in which sessile flowers are arranged on an unbranched elongated axis)</text></gloss></sense></entry>
<entry id="bulu" guid="c0f0c7db-c458-54c5-9209-75713f49564e"><lexical-unit><form lang="id"><text>bulu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bulu_0" guid="0dcf3adf-d3e0-591b-b986-a9c13ded7ac2"><grammatical-info value="Noun"/><gloss lang="en"><text>body hair</text></gloss></sense><sense id="bulu_1" guid="c876013b-82d8-59ca-82c7-35b1100ea3c5"><grammatical-info value="Noun"/><gloss lang="en"><text>fur</text></gloss></sense><sense id="bulu_2" guid="19876ab4-3217-5dfa-b851-62913a36fd94"><grammatical-info value="Noun"/><gloss lang="en"><text>feather</text></gloss></sense><sense id="bulu_3" guid="4edd3d2e-11a2-5df9-a0ce-9f5802dac56a"><grammatical-info value="Noun"/><gloss lang="en"><text>a kind of small plate, made of turtle shell on gold scales</text></gloss></sense></entry>
<entry id="buluh" guid="e6eeaa0f-ee88-5564-8874-798143c2864e"><lexical-unit><form lang="id"><text>buluh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="buluh_0" guid="6d4793a3-700a-590c-873e-312962953c9f"><grammatical-info value="Numeral"/><gloss lang="en"><text>bamboo (plant)</text></gloss></sense><sense id="buluh_1" guid="66f7179a-556c-503b-8399-67aa472cc8f9"><grammatical-info value="Numeral"/><gloss lang="en"><text>bamboo (wood)</text></gloss></sense><sense id="buluh_2" guid="181266fb-e412-54c5-be7d-5336399d48e0"><grammatical-info value="Numeral"/><gloss lang="en"><text>culm (the stem of a plant, especially of grass or sedge)</text></gloss></sense></entry>
<entry id="bum" guid="675ce9bf-bddf-57aa-9014-25642206f0a4"><lexical-unit><form lang="id"><text>bum</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bum_0" guid="9390665c-af60-518a-b7d1-e1110d431bda"><grammatical-info value="Noun"/><gloss lang="en"><text>boom barrier, boom gate (a bar or pole that can be lowered or raised to controll the traffic)</text></gloss></sense><sense id="bum_1" guid="69ce3b51-ce52-5e50-bba3-1b55206898f7"><grammatical-info value="Noun"/><gloss lang="en"><text>customs (government agency that handles taxes of imported goods)</text></gloss></sense><sense id="bum_2" guid="b71eebc8-a5a7-50c8-866f-f0826f3759c3"><grammatical-info value="Noun"/><gloss lang="en"><text>boom (a period of prosperity, growth, progress, or high market activity)</text></gloss></sense></entry>
<entry id="bumi" guid="7b6fc61c-6a34-5e94-942d-7525b2004959"><lexical-unit><form lang="id"><text>bumi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bumi_0" guid="92213454-2547-501f-88ee-59bac8116f53"><grammatical-info value="Noun"/><gloss lang="en"><text>Earth</text></gloss></sense><sense id="bumi_1" guid="76b5fa99-b48b-5b26-84b4-75d42de1649e"><grammatical-info value="Noun"/><gloss lang="en"><text>earth, soil</text></gloss></sense><sense id="bumi_2" guid="ca5504a4-6a72-55c5-ad18-1c97f5f9cead"><grammatical-info value="Noun"/><gloss lang="en"><text>the Earth: the third planet of the Solar System; the world upon which humans live</text></gloss></sense></entry>
<entry id="bun" guid="09ccdd99-b635-58f9-b507-1b2c76f06ec2"><lexical-unit><form lang="id"><text>bun</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bun_0" guid="4e258170-aa34-5acb-b727-f6a82a7bbb2d"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a surname from Hakka</text></gloss></sense></entry>
<entry id="bunga" guid="3b91573c-c0d8-5dcf-ab87-eb84d3400fc2"><lexical-unit><form lang="id"><text>bunga</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bunga_0" guid="a4f206a6-3e9a-5d29-8ecb-5bea458982b7"><grammatical-info value="Noun"/><gloss lang="en"><text>flower:</text></gloss></sense><sense id="bunga_1" guid="d876ea7b-fa5b-515f-b020-90c11edce0dd"><grammatical-info value="Noun"/><gloss lang="en"><text>a reproductive structure in angiosperms (flowering plants), often conspicuously colourful and typically including sepals, petals, and either or both stamens and/or a pistil</text></gloss></sense><sense id="bunga_2" guid="8929ff18-472e-5612-921f-a9f7ea3c6de2"><grammatical-info value="Noun"/><gloss lang="en"><text>a plant that bears flowers, especially a plant that is small and lacks wood</text></gloss></sense><sense id="bunga_3" guid="6ff0aeac-57e5-5502-acf2-d87cd4d1b4de"><grammatical-info value="Noun"/><gloss lang="en"><text>beauty:</text></gloss></sense><sense id="bunga_4" guid="8bf50197-cdb2-5734-8083-7b6c1c8ed2f7"><grammatical-info value="Noun"/><gloss lang="en"><text>something that is particularly good or pleasing</text></gloss></sense><sense id="bunga_5" guid="7d0a94dd-b3aa-5a9c-a8e9-5c8c206e059b"><grammatical-info value="Noun"/><gloss lang="en"><text>someone who is beautiful</text></gloss></sense><sense id="bunga_6" guid="8f3cd401-2d8e-5562-a5c9-6f781bca200d"><grammatical-info value="Noun"/><gloss lang="en"><text>flowery pattern or design</text></gloss></sense><sense id="bunga_7" guid="da381ccc-2d27-56b0-8524-18f8079ea940"><grammatical-info value="Noun"/><gloss lang="en"><text>interest: the price paid for obtaining, or price received for providing, money or goods in a credit transaction, calculated as a fraction of the amount or value of what was borrowed</text></gloss></sense></entry>
<entry id="bungkam" guid="8101c8e2-3eec-543b-a617-e2e5b9aaade9"><lexical-unit><form lang="id"><text>bungkam</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bungkam_0" guid="fc2dd6a7-cf36-50e3-b42e-bf1b1eff5df4"><grammatical-info value="Verb"/></sense></entry>
