<entry id="mengikuti" guid="2c54c89b-0f7a-5b0c-8571-573eb62b9f7e"><lexical-unit><form lang="id"><text>mengikuti</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mengikuti_0" guid="ae99c385-a5ab-5189-9cbd-29b0eb57c7a2"><grammatical-info value="Verb"/><gloss lang="en"><text>to follow</text></gloss></sense><sense id="mengikuti_1" guid="3b51e2ea-7c39-5441-a7ce-548358d0ed9f"><grammatical-info value="Verb"/><gloss lang="en"><text>to obey, observe</text></gloss></sense><sense id="mengikuti_2" guid="c88a6e62-c2cc-5334-b723-18a1d775a115"><grammatical-info value="Verb"/><gloss lang="en"><text>to take after (to resemble)</text></gloss></sense><sense id="mengikuti_3" guid="730b6a1e-c4a8-59da-a3ca-bf2a1c58fcae"><grammatical-info value="Verb"/><gloss lang="en"><text>to keep up with</text></gloss></sense><sense id="mengikuti_4" guid="783fa3d6-9634-563f-815d-d90573c01cc6"><grammatical-info value="Verb"/><gloss lang="en"><text>to take (a university course etc.)</text></gloss></sense></entry>
<entry id="mengingat" guid="7b4465dc-9e5c-5d3c-9926-0d6c105678ac"><lexical-unit><form lang="id"><text>mengingat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mengingat_0" guid="0e41bede-517e-5225-ac52-06bd75a00ad9"><grammatical-info value="Verb"/><gloss lang="en"><text>to remember, to recollect, to recall</text></gloss></sense><sense id="mengingat_1" guid="66b962d1-cdca-50d1-a9b5-1a655d40debe"><grammatical-info value="Verb"/><gloss lang="en"><text>to think of, to keep in mind</text></gloss></sense><sense id="mengingat_2" guid="03d053a8-23e1-5d74-a71d-1760cbb54d20"><grammatical-info value="Verb"/><gloss lang="en"><text>observing</text></gloss></sense></entry>
<entry id="mengirim" guid="a4e2c553-8087-55f3-b4e3-2564d21d2d3a"><lexical-unit><form lang="id"><text>mengirim</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mengirim_0" guid="fc9a7e62-ac43-54be-a0fe-4708047c3bf2"><grammatical-info value="Verb"/><gloss lang="en"><text>to send:</text></gloss></sense><sense id="mengirim_1" guid="9c937fb9-6c80-5ba6-b51c-2c7b1ae045a4"><grammatical-info value="Verb"/><gloss lang="en"><text>to make something (such as an object or message) go from one place to another</text></gloss></sense><sense id="mengirim_2" guid="bcdbec25-94df-59da-a6ce-aa7aa8beeebe"><grammatical-info value="Verb"/><gloss lang="en"><text>to dispatch an agent or messenger to convey a message, or to do an errand</text></gloss></sense><sense id="mengirim_3" guid="90c401e7-7e8b-5233-91a7-e435b42f126b"><grammatical-info value="Verb"/><gloss lang="en"><text>to consign: to transfer to the custody of, usually for sale, transport, or safekeeping</text></gloss></sense></entry>
<entry id="mengisi" guid="11dcf463-4480-5f16-9f0a-65a500ee2037"><lexical-unit><form lang="id"><text>mengisi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mengisi_0" guid="bd4d2542-ea60-50a5-8a62-04db567c3ee1"><grammatical-info value="Verb"/><gloss lang="en"><text>to fill in, to fill</text></gloss></sense><sense id="mengisi_1" guid="7d21d4bf-ab78-5370-aa05-8e61a886379c"><grammatical-info value="Verb"/><gloss lang="en"><text>to occupy (time)</text></gloss></sense></entry>
<entry id="mengoreksi" guid="42725886-ce95-56d0-a723-8329a0156a4d"><lexical-unit><form lang="id"><text>mengoreksi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mengoreksi_0" guid="cf135b9a-e6c7-551c-ae1b-5b7d0fc648b1"><grammatical-info value="Verb"/><gloss lang="en"><text>to correct:</text></gloss></sense><sense id="mengoreksi_1" guid="2841efbb-3190-53b4-a183-d3a6aa3939c8"><grammatical-info value="Verb"/><gloss lang="en"><text>to make something that was wrong become right; to remove error from</text></gloss></sense><sense id="mengoreksi_2" guid="969e86c0-8130-5c90-84be-c9cd74247701"><grammatical-info value="Verb"/><gloss lang="en"><text>to inform (someone) of their error</text></gloss></sense><sense id="mengoreksi_3" guid="b45f04bc-abf0-527f-85b7-48646fbe7385"><grammatical-info value="Verb"/><gloss lang="en"><text>to grade (examination papers)</text></gloss></sense><sense id="mengoreksi_4" guid="1cc20dcf-7b79-5153-8653-61e894cbe6f4"><grammatical-info value="Verb"/><gloss lang="en"><text>to discipline; to punish</text></gloss></sense></entry>
<entry id="menguasai" guid="f9f59cbb-d14c-523d-86c0-d1a9e1919371"><lexical-unit><form lang="id"><text>menguasai</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="menguasai_0" guid="68e1e9a5-588b-5588-a3ed-8a33d87e1b22"><grammatical-info value="Verb"/><gloss lang="en"><text>to be in power of</text></gloss></sense><sense id="menguasai_1" guid="814eb808-74c3-5f19-a5c8-b0a5ed386928"><grammatical-info value="Verb"/><gloss lang="en"><text>to conquer</text></gloss></sense><sense id="menguasai_2" guid="c8a8c24e-2bd4-54dc-a714-33dd5b752579"><grammatical-info value="Verb"/><gloss lang="en"><text>to master (a skill, field of study, discipline)</text></gloss></sense></entry>
<entry id="menguat" guid="edb2a141-3c36-5ca7-b62d-8cff392f49ef"><lexical-unit><form lang="id"><text>menguat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="menguat_0" guid="d84b14e4-c76c-59d4-bfd5-24f38b5205f4"><grammatical-info value="Verb"/><gloss lang="en"><text>to become stronger, to appreciate, to strengthen</text></gloss></sense></entry>
