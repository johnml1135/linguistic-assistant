<entry id="pada" guid="148a2da2-a9c0-58a9-917a-a1f0c67e9219"><lexical-unit><form lang="id"><text>pada</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pada_0" guid="59d4c40a-a7b8-5c47-86b3-353ad7105e9a"><grammatical-info value="Adposition"/><gloss lang="en"><text>at, on</text></gloss></sense><sense id="pada_1" guid="0c636283-4e26-5fd1-a808-9f598309115f"><grammatical-info value="Adposition"/><gloss lang="en"><text>in (as time preposition, regardless of the unit)</text></gloss></sense><sense id="pada_2" guid="32848a1c-58da-5a9e-9359-a4679ee3a60e"><grammatical-info value="Adposition"/><gloss lang="en"><text>adequate, enough, sufficient, satisfactory</text></gloss></sense><sense id="pada_3" guid="3680bc9f-1dd6-595c-a94d-5ddeb1555636"><grammatical-info value="Adposition"/><gloss lang="en"><text>satisfied</text></gloss></sense><sense id="pada_4" guid="8b366b43-8373-51ad-92fe-44973acd7872"><grammatical-info value="Adposition"/><gloss lang="en"><text>all</text></gloss></sense><sense id="pada_5" guid="dfc69cd7-2dd8-56b3-a159-122a71ca1e6c"><grammatical-info value="Adposition"/><gloss lang="en"><text>pada: The basic metric unit of Vedic poetry, consisting of one line of verse in Sanskrit, typically as part of a four-line stanza</text></gloss></sense></entry>
