<entry id="terbayang" guid="f398f345-9a38-50c5-8250-ce47f9a0c3a2"><lexical-unit><form lang="id"><text>terbayang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="terbayang_0" guid="e0f0dafa-d689-502c-be3a-a36ecf39f9bc"><grammatical-info value="Verb"/><gloss lang="en"><text>to brought to light, to be revealed</text></gloss></sense><sense id="terbayang_1" guid="ca2d37f2-9087-5357-a056-45fb095f6794"><grammatical-info value="Verb"/><gloss lang="en"><text>to be imagined.</text></gloss></sense><sense id="terbayang_2" guid="fa5efeb0-d77e-5e93-b106-ef63bf91b7a1"><grammatical-info value="Verb"/><gloss lang="en"><text>to be sketched out, to appear vaguely.</text></gloss></sense><sense id="terbayang_3" guid="8ef1fc58-938a-5bfe-a3b7-e5cf5f7e4bb2"><grammatical-info value="Verb"/><gloss lang="en"><text>to be visible</text></gloss></sense></entry>
