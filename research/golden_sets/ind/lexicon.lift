<entry id="najis" guid="5f16ddac-791b-5087-8e1b-0d64bf90b0d7"><lexical-unit><form lang="id"><text>najis</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="najis_0" guid="ea9db38c-17f5-5160-8196-124bc22c4322"><grammatical-info value="Noun"/><gloss lang="en"><text>filth, dirt</text></gloss></sense><sense id="najis_1" guid="8acbadd6-1423-5738-9c2f-039a956a0035"><grammatical-info value="Noun"/><gloss lang="en"><text>ritually unclean, such that contact with it puts a Muslim in a state of impurity</text></gloss></sense><sense id="najis_2" guid="cb6ecddd-e95c-5f62-ba94-186e9347d414"><grammatical-info value="Noun"/><gloss lang="en"><text>disgusting</text></gloss></sense></entry>
