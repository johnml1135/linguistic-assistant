<entry id="kait" guid="8627e4c5-e414-5724-b7b8-e5e0a1938134"><lexical-unit><form lang="id"><text>kait</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kait_0" guid="d451b8f8-d89f-5e63-8b3d-2cc68e030867"><grammatical-info value="Verb"/><gloss lang="en"><text>hook (a rod bent into a curved shape)</text></gloss></sense><sense id="kait_1" guid="bcc7c1e1-ed7f-56df-a06a-93d1c56f7c5d"><grammatical-info value="Verb"/><gloss lang="en"><text>hook (a snare; a trap)</text></gloss></sense><sense id="kait_2" guid="b6ec243e-9dd0-5b50-92c3-56b56046ba21"><grammatical-info value="Verb"/><gloss lang="en"><text>hook (the part of a system's operation that can be intercepted to change or augment its behaviour)</text></gloss></sense><sense id="kait_3" guid="88264397-cbe6-5568-b153-a8f88837342e"><grammatical-info value="Verb"/><gloss lang="en"><text>space between lines, see ⏎</text></gloss></sense><sense id="kait_4" guid="6d26adef-19c2-570d-bd65-be15d6139c3a"><grammatical-info value="Verb"/><gloss lang="en"><text>serif (a short line added to the end of a stroke in traditional typefaces)</text></gloss></sense><sense id="kait_5" guid="9fde7f86-0e9e-5b84-b42c-1a1219ee8d5a"><grammatical-info value="Verb"/><gloss lang="en"><text>complication</text></gloss></sense><sense id="kait_6" guid="b1e5c0c9-6c60-53ea-95e5-4cf407c3afc1"><grammatical-info value="Verb"/><gloss lang="en"><text>crosier, crozier</text></gloss></sense><sense id="kait_7" guid="3d3bed19-132f-5a6d-950b-195fd1b47de3"><grammatical-info value="Verb"/><gloss lang="en"><text>to pull with a hook</text></gloss></sense></entry>
