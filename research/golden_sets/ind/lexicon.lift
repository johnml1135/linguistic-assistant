<entry id="membunuh" guid="9c80f435-5372-55e3-9c56-2537042c6458"><lexical-unit><form lang="id"><text>membunuh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="membunuh_0" guid="7f350968-bb61-53e0-a010-0f8e2a436aa4"><grammatical-info value="Verb"/><gloss lang="en"><text>to kill</text></gloss></sense><sense id="membunuh_1" guid="8dffd1c3-aba9-5a45-aaf0-0cff1134f08e"><grammatical-info value="Verb"/><gloss lang="en"><text>to extinguish another's life; to make someone die</text></gloss></sense><sense id="membunuh_2" guid="fa0ae418-368d-5770-994c-bc853aa6aa02"><grammatical-info value="Verb"/><gloss lang="en"><text>to overpower, overwhelm, or defeat</text></gloss></sense><sense id="membunuh_3" guid="a70113fa-714a-5b70-b2cc-e64f087c23fd"><grammatical-info value="Verb"/><gloss lang="en"><text>to vanquish; to close or finish off, to make something disappear</text></gloss></sense></entry>
