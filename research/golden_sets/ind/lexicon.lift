<entry id="sungkur" guid="60bf1f01-0192-5406-9f1b-95e51a1b1bea"><lexical-unit><form lang="id"><text>sungkur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sungkur_0" guid="39070ed7-4a07-5554-8049-60befbac0608"><grammatical-info value="Verb"/><gloss lang="en"><text>samaritan</text></gloss></sense></entry>
<entry id="sunyi" guid="31d28066-b823-5286-bdac-c4750e1e6dca"><lexical-unit><form lang="id"><text>sunyi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="sunyi_0" guid="c960a834-750b-553c-ae2a-0dbc5dbccfe4"><grammatical-info value="Noun"/><gloss lang="en"><text>quiet, silent</text></gloss></sense><sense id="sunyi_1" guid="0fb3e04c-01a8-578f-ad9b-8ddee0cd8ee9"><grammatical-info value="Noun"/><gloss lang="en"><text>deserted, empty</text></gloss></sense><sense id="sunyi_2" guid="c9ce35ee-492b-5ad3-9169-65995ed3c7ac"><grammatical-info value="Noun"/><gloss lang="en"><text>free</text></gloss></sense></entry>
<entry id="supaya" guid="84666c25-27b6-5feb-9447-c1148dee8acc"><lexical-unit><form lang="id"><text>supaya</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="supaya_0" guid="e7540f0b-f6f4-5469-a81d-77966661613b"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>so that (in order to)</text></gloss></sense></entry>
<entry id="super" guid="5a16cdc6-55f6-518c-9a51-f1fb74d449d1"><lexical-unit><form lang="id"><text>super</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="super_0" guid="b6f4bf38-1280-5656-a00a-22700ec5b612"><grammatical-info value="Proper noun"/><gloss lang="en"><text>reckon</text></gloss></sense></entry>
