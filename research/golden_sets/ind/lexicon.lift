<entry id="larang" guid="51492311-0dff-5014-a69f-42d84d7be515"><lexical-unit><form lang="id"><text>larang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="larang_0" guid="4e2be906-0a6f-5118-9e7a-f45ba663e8ef"><grammatical-info value="Verb"/><gloss lang="en"><text>to forbid, prohibit</text></gloss></sense><sense id="larang_1" guid="9c0b0cd4-c239-5cdf-ba2e-6bcb5192b3d1"><grammatical-info value="Verb"/><gloss lang="en"><text>to ban</text></gloss></sense></entry>
<entry id="lari" guid="41500bff-a072-5932-b54d-8c0df3edb5bc"><lexical-unit><form lang="id"><text>lari</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lari_0" guid="83fb347e-25b6-5a72-ad17-6aef7187742e"><grammatical-info value="Verb"/><gloss lang="en"><text>to run (to move swiftly)</text></gloss></sense><sense id="lari_1" guid="2a63db44-5e7f-536c-8ae0-9735812c6e6c"><grammatical-info value="Verb"/><gloss lang="en"><text>to move forward quickly upon two feet by alternately making a short jump off either foot</text></gloss></sense><sense id="lari_2" guid="aa5ca750-62a1-5c7f-952f-9f230ced024d"><grammatical-info value="Verb"/><gloss lang="en"><text>to go at a fast pace; to move quickly</text></gloss></sense><sense id="lari_3" guid="3fe36fb1-20eb-5f4a-8899-8f9ed5eaafcf"><grammatical-info value="Verb"/><gloss lang="en"><text>to compete in a race</text></gloss></sense><sense id="lari_4" guid="380d47bb-1f50-5810-ac92-96496c8faf3b"><grammatical-info value="Verb"/><gloss lang="en"><text>to flee from a danger or towards help</text></gloss></sense><sense id="lari_5" guid="d5aa22b0-5811-5671-80cc-ccd73c9013f3"><grammatical-info value="Verb"/><gloss lang="en"><text>to run away</text></gloss></sense><sense id="lari_6" guid="9c5ccfe7-3028-5255-82fb-ce7267039808"><grammatical-info value="Verb"/><gloss lang="en"><text>to flee by running</text></gloss></sense><sense id="lari_7" guid="90079ee8-25c5-5d7f-9c57-fac7bb043a2a"><grammatical-info value="Verb"/><gloss lang="en"><text>to leave home, or other place of residence, usually unannounced, or to make good on a threat, with such action usually performed by a child or juvenile</text></gloss></sense></entry>
<entry id="larian" guid="23b50c66-a9b8-5297-830b-d017bc0ecd7c"><lexical-unit><form lang="id"><text>larian</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="larian_0" guid="22502db7-c670-57a8-82e5-2dad74b509c8"><grammatical-info value="Noun"/><gloss lang="en"><text>escape (the act of leaving a dangerous or unpleasant situation)</text></gloss></sense><sense id="larian_1" guid="6aad8703-71a6-5ec9-ac79-61ca0bc64b7d"><grammatical-info value="Noun"/><gloss lang="en"><text>runaway (the act of running away)</text></gloss></sense></entry>
<entry id="larikan" guid="c085c71a-40eb-5285-aa09-61e0a0bdcc4a"><lexical-unit><form lang="id"><text>larikan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="larikan_0" guid="9cc2b61d-4f2d-56cb-9b6b-63914fb58c66"><grammatical-info value="Verb"/><gloss lang="en"><text>row (a line of objects; a horizantal line of entries)</text></gloss></sense><sense id="larikan_1" guid="4b70119d-90d4-501f-8a27-1844c7a249b3"><grammatical-info value="Verb"/><gloss lang="en"><text>to run, transport</text></gloss></sense><sense id="larikan_2" guid="35bfbd47-4e80-56b7-816d-bb1eda0c965c"><grammatical-info value="Verb"/><gloss lang="en"><text>to carry away, steal, take away</text></gloss></sense></entry>
<entry id="larut" guid="35670529-80b6-51dd-a3f3-69970fef40b4"><lexical-unit><form lang="id"><text>larut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="larut_0" guid="dae39d1f-6fab-50c5-abb7-96c36932cce7"><grammatical-info value="Verb"/><gloss lang="en"><text>soluble, dissolved</text></gloss></sense><sense id="larut_1" guid="81be73d2-4716-5cf4-b15d-7b0c5eff208b"><grammatical-info value="Verb"/><gloss lang="en"><text>late</text></gloss></sense><sense id="larut_2" guid="b3ae7816-d165-5ea8-85ba-93c00b74ab2b"><grammatical-info value="Verb"/><gloss lang="en"><text>protracted</text></gloss></sense><sense id="larut_3" guid="65a75bd0-f42d-5b97-bd90-291b13167d11"><grammatical-info value="Verb"/><gloss lang="en"><text>solvable</text></gloss></sense><sense id="larut_4" guid="4499445d-57e0-52d2-8899-b6f64f89d072"><grammatical-info value="Verb"/><gloss lang="en"><text>dissoluble</text></gloss></sense><sense id="larut_5" guid="08751a0e-3bed-5c4f-a910-37c837b95af9"><grammatical-info value="Verb"/><gloss lang="en"><text>arrowroot, maranta, West Indian arrowroot, obedience plant, or Bermuda arrowroot (Maranta arundinacea).</text></gloss></sense><sense id="larut_6" guid="836f91d0-016b-56ab-94e3-2d766b3b5503"><grammatical-info value="Verb"/><gloss lang="en"><text>a typical snack from grated coconut mixed with sago flour, cooked until thick and resembling porridge</text></gloss></sense></entry>
<entry id="las" guid="b244e939-5bb9-5e6c-bac6-8742bb842f30"><lexical-unit><form lang="id"><text>las</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="las_0" guid="c523426a-690c-5480-81a7-54525d4e7ebd"><grammatical-info value="Proper noun"/><gloss lang="en"><text>weld</text></gloss></sense></entry>
<entry id="lata" guid="5e17191c-9ec6-5ba4-9649-f43be0fbad7c"><lexical-unit><form lang="id"><text>lata</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lata_0" guid="3b94ec35-8e71-5a84-99ad-90639d0eb318"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to creep,</text></gloss></sense><sense id="lata_1" guid="a3dd2f5b-f789-57e2-878e-dc2db1316e12"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to move slowly with the abdomen close to the ground</text></gloss></sense><sense id="lata_2" guid="42350eab-87e2-54fb-9bb1-c493862d12cb"><grammatical-info value="Proper noun"/><gloss lang="en"><text>of plants, to grow across a surface rather than upwards</text></gloss></sense><sense id="lata_3" guid="a9e5e11b-7d52-515f-88ea-ae3fbbe06f3e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>bad, dirty, despicable</text></gloss></sense><sense id="lata_4" guid="fe491cc7-d61e-5590-9c27-c79e4445cdad"><grammatical-info value="Proper noun"/><gloss lang="en"><text>range of tide</text></gloss></sense></entry>
<entry id="latar" guid="3877f4ba-dd91-546e-be57-3137ceb33c70"><lexical-unit><form lang="id"><text>latar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="latar_0" guid="e45122e3-e8da-5347-bc62-5ede02c17f82"><grammatical-info value="Noun"/><gloss lang="en"><text>level, flat</text></gloss></sense><sense id="latar_1" guid="49ea43d7-1c9d-537c-b7df-9dcb805110c3"><grammatical-info value="Noun"/><gloss lang="en"><text>surface</text></gloss></sense><sense id="latar_2" guid="fef303c0-68a0-58d1-b88b-c378ca40a0c6"><grammatical-info value="Noun"/><gloss lang="en"><text>synonym of halaman (“backyard, courtyard; page”)</text></gloss></sense><sense id="latar_3" guid="bfe1818f-7565-53a7-b09b-80f53f1e848b"><grammatical-info value="Noun"/><gloss lang="en"><text>setting:</text></gloss></sense><sense id="latar_4" guid="b14cc2be-8fe8-5232-b8d6-f639d0a80b6a"><grammatical-info value="Noun"/><gloss lang="en"><text>the time, place and circumstance in which something (such as a story or picture) is set</text></gloss></sense><sense id="latar_5" guid="868a7d1d-6a35-5803-a296-e60641ece73b"><grammatical-info value="Noun"/><gloss lang="en"><text>the mounting of a play, etc., for the stage</text></gloss></sense><sense id="latar_6" guid="bd801a95-ef75-5d94-a4a0-019331198421"><grammatical-info value="Noun"/><gloss lang="en"><text>background: a part of the picture that depicts scenery to the rear or behind the main subject</text></gloss></sense></entry>
