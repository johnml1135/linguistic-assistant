<entry id="susur" guid="941c9356-bbf5-5294-a79b-77092305cd7b"><lexical-unit><form lang="id"><text>susur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="susur_0" guid="c86922ab-7a67-5a5e-ac0d-915d3f465402"><grammatical-info value="Verb"/><gloss lang="en"><text>edge, fringe, rim</text></gloss></sense><sense id="susur_1" guid="7c797408-dd99-5b8b-9c1f-a92e3c04048d"><grammatical-info value="Verb"/><gloss lang="en"><text>quid: a piece of material for chewing, especially chewing tobacco</text></gloss></sense><sense id="susur_2" guid="6a07e2db-7a45-594d-8dd3-ebe84484a99f"><grammatical-info value="Verb"/><gloss lang="en"><text>sharp fibers on the trunk of a coconut tree</text></gloss></sense></entry>
<entry id="susut" guid="24b3c05d-9b6e-57ef-bfe8-ff1375585fc6"><lexical-unit><form lang="id"><text>susut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="susut_0" guid="f113c7a4-11b0-5e3e-9805-83efb240719b"><grammatical-info value="Verb"/><gloss lang="en"><text>to shrink (to become smaller)</text></gloss></sense><sense id="susut_1" guid="7d6f6e05-c6a6-535a-bdba-d3e38cd6ce9e"><grammatical-info value="Verb"/><gloss lang="en"><text>to decrease</text></gloss></sense><sense id="susut_2" guid="08e72ae6-71d8-55ad-b1b1-7b5fc8fe1518"><grammatical-info value="Verb"/><gloss lang="en"><text>of a quantity, to become smaller</text></gloss></sense><sense id="susut_3" guid="d4fe95a6-0c77-55c5-8cfc-5cb16154fed1"><grammatical-info value="Verb"/><gloss lang="en"><text>of a liquid, to become smaller</text></gloss></sense><sense id="susut_4" guid="7b7acfde-dac1-5177-917d-29fc2878d15a"><grammatical-info value="Verb"/><gloss lang="en"><text>loss</text></gloss></sense></entry>
