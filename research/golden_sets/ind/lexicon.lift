<entry id="toleransi" guid="9d9c8d99-926c-5bc2-b897-5078e7f03941"><lexical-unit><form lang="id"><text>toleransi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="toleransi_0" guid="bd1037fd-963c-5804-a531-e32fe0a05fae"><grammatical-info value="Noun"/><gloss lang="en"><text>tolerance:</text></gloss></sense><sense id="toleransi_1" guid="92afc623-7c97-5c91-b7c0-00c1153885aa"><grammatical-info value="Noun"/><gloss lang="en"><text>the ability or practice of tolerating; an acceptance of or patience with the beliefs, opinions or practices of others; a lack of bigotry</text></gloss></sense><sense id="toleransi_2" guid="f3c8fee8-6ed8-5b7d-8ae4-4afdb303d3ca"><grammatical-info value="Noun"/><gloss lang="en"><text>the variation or deviation from a standard, especially the maximum permitted variation in an engineering measurement</text></gloss></sense></entry>
