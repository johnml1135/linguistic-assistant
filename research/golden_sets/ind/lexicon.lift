<entry id="ganti" guid="d22677ea-8e9c-56d6-8aa8-4cdee9b0189a"><lexical-unit><form lang="id"><text>ganti</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ganti_0" guid="8f06d21d-bf70-58ea-bbc1-29935d161169"><grammatical-info value="Verb"/><gloss lang="en"><text>deputy, vice</text></gloss></sense><sense id="ganti_1" guid="fdfc28c9-7c57-54ca-a04e-cd4009435537"><grammatical-info value="Verb"/><gloss lang="en"><text>replacement, substitute</text></gloss></sense><sense id="ganti_2" guid="26037b70-7b79-5730-bc8b-26a6bdf02bcb"><grammatical-info value="Verb"/><gloss lang="en"><text>compensation, indemnification</text></gloss></sense><sense id="ganti_3" guid="9637fc72-274b-5141-bd76-32795cfc0746"><grammatical-info value="Verb"/><gloss lang="en"><text>to replace, to substitute</text></gloss></sense><sense id="ganti_4" guid="03087157-85f3-5bf2-bc60-5be1877c8bda"><grammatical-info value="Verb"/><gloss lang="en"><text>to change:</text></gloss></sense><sense id="ganti_5" guid="b64b8c42-199e-52dc-873e-8bd05fe4f718"><grammatical-info value="Verb"/><gloss lang="en"><text>to become something different</text></gloss></sense><sense id="ganti_6" guid="5dcff24a-3893-5b44-8ce4-f3627b41fdb1"><grammatical-info value="Verb"/><gloss lang="en"><text>to make something into something else</text></gloss></sense><sense id="ganti_7" guid="4c211dad-52f0-5721-87fb-f2efa944e4c7"><grammatical-info value="Verb"/><gloss lang="en"><text>to replace</text></gloss></sense></entry>
<entry id="gantung" guid="daf46c5d-ce78-5fca-b243-757f2a7e60a9"><lexical-unit><form lang="id"><text>gantung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gantung_0" guid="281d92a3-5896-5a23-9220-ae15c79f9aad"><grammatical-info value="Verb"/><gloss lang="en"><text>to hang</text></gloss></sense><sense id="gantung_1" guid="8f190dc4-48a8-52f7-9ef3-08cd70b1fd86"><grammatical-info value="Verb"/><gloss lang="en"><text>to depend on</text></gloss></sense><sense id="gantung_2" guid="29c26725-03eb-5d0e-8fc4-45dfaac3b03e"><grammatical-info value="Verb"/><gloss lang="en"><text>hanging, aerial</text></gloss></sense><sense id="gantung_3" guid="da299790-2c7d-5800-9a70-a5b3fa90f960"><grammatical-info value="Verb"/><gloss lang="en"><text>a district of East Belitung, Bangka Belitung Islands</text></gloss></sense><sense id="gantung_4" guid="3e4cd00b-fc5d-55ad-8e7a-7c117204ae7b"><grammatical-info value="Verb"/><gloss lang="en"><text>a subdistrict of Gantung district, East Belitung, Bangka Belitung Islands</text></gloss></sense></entry>
<entry id="gap" guid="6e9f5cd4-2d39-5e7c-a2fd-53f7781f236d"><lexical-unit><form lang="id"><text>gap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gap_0" guid="90c1ded6-e727-52bb-8166-fff86969b8d5"><grammatical-info value="Noun"/><gloss lang="en"><text>beating, the sound of action by which someone or something is beaten</text></gloss></sense><sense id="gap_1" guid="b012d623-06ec-5cb9-a23e-1635069fbbd6"><grammatical-info value="Noun"/><gloss lang="en"><text>gap,</text></gloss></sense><sense id="gap_2" guid="73d683b0-d91a-5029-9798-981bf0e676a0"><grammatical-info value="Noun"/><gloss lang="en"><text>an opening in anything</text></gloss></sense><sense id="gap_3" guid="b179ef98-f3d9-56b0-96b6-e1761a212387"><grammatical-info value="Noun"/><gloss lang="en"><text>the disparity between communities with regard to life expectancy, education, health, etc.</text></gloss></sense></entry>
<entry id="gapai" guid="b9f1beb1-2687-571a-9499-d095a2409435"><lexical-unit><form lang="id"><text>gapai</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gapai_0" guid="650059d7-5438-5060-b23f-f9faf69ce6cb"><grammatical-info value="Proper noun"/><gloss lang="en"><text>wagging</text></gloss></sense></entry>
<entry id="garam" guid="c59ae540-2c36-5f7e-8ca9-c6d4afdf1586"><lexical-unit><form lang="id"><text>garam</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="garam_0" guid="26c13c12-388c-57f2-8a3b-8c1b1854740b"><grammatical-info value="Noun"/><gloss lang="en"><text>salt:</text></gloss></sense><sense id="garam_1" guid="222d2f31-c888-5132-adfa-55e370c9644f"><grammatical-info value="Noun"/><gloss lang="en"><text>a common substance, chemically consisting mainly of sodium chloride (NaCl), used extensively as a condiment and preservative</text></gloss></sense><sense id="garam_2" guid="a620a3ab-c15f-5568-bb0d-21881e27ffe3"><grammatical-info value="Noun"/><gloss lang="en"><text>one of the compounds formed from the reaction of an acid with a base, where a positive ion replaces a hydrogen of the acid</text></gloss></sense><sense id="garam_3" guid="6ca5e867-b149-5422-8db8-ac63e7c3788c"><grammatical-info value="Noun"/><gloss lang="en"><text>ellipsis of garam dapur (“table salt”)</text></gloss></sense><sense id="garam_4" guid="28d57227-86fa-5474-bf52-c162dec219cc"><grammatical-info value="Noun"/><gloss lang="en"><text>(salt-like) fertilizer</text></gloss></sense></entry>
<entry id="garis" guid="0a8516ae-82b5-5e17-a362-8d27c1dd5ddb"><lexical-unit><form lang="id"><text>garis</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="garis_0" guid="36bd4e8b-1645-5c57-aeb6-6e44a1ae80f8"><grammatical-info value="Noun"/><gloss lang="en"><text>line, dash, stripe</text></gloss></sense><sense id="garis_1" guid="5ab45c10-46ab-5940-aebd-e8441a996ba1"><grammatical-info value="Noun"/><gloss lang="en"><text>limit</text></gloss></sense><sense id="garis_2" guid="a7c6be7e-6c29-5d11-a344-8ab493d98655"><grammatical-info value="Noun"/><gloss lang="en"><text>rule, regulation</text></gloss></sense></entry>
<entry id="gas" guid="41ff4de4-3f7a-5490-a07f-607cb61a386d"><lexical-unit><form lang="id"><text>gas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gas_0" guid="5fb4494d-9fcc-5997-affc-51373084d8aa"><grammatical-info value="Noun"/><gloss lang="en"><text>gas, matter in an intermediate state between liquid and plasma</text></gloss></sense><sense id="gas_1" guid="93196b88-1505-57ac-a58a-9d12ec04bab1"><grammatical-info value="Noun"/><gloss lang="en"><text>accelerator (UK), gas pedal (US)</text></gloss></sense><sense id="gas_2" guid="1a4f1436-c72e-551d-8db8-01f108cb7eea"><grammatical-info value="Noun"/><gloss lang="en"><text>to hit the gas, to accelerate</text></gloss></sense></entry>
<entry id="gaul" guid="a68012a1-1992-5fa6-9cc6-458a3f28a263"><lexical-unit><form lang="id"><text>gaul</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gaul_0" guid="77beff4b-ba58-58b2-9a05-abead64cbcef"><grammatical-info value="Verb"/><gloss lang="en"><text>to mix</text></gloss></sense><sense id="gaul_1" guid="1aa73938-5d61-5d87-9a79-631de9c17455"><grammatical-info value="Verb"/><gloss lang="en"><text>to socialize</text></gloss></sense><sense id="gaul_2" guid="d61b4cf7-1078-5c56-8e01-5cc605189676"><grammatical-info value="Verb"/><gloss lang="en"><text>slang</text></gloss></sense><sense id="gaul_3" guid="1396f9e4-f07f-52ab-a6d2-4b30b8023e44"><grammatical-info value="Verb"/><gloss lang="en"><text>cool, trendy</text></gloss></sense></entry>
<entry id="gaya" guid="052d844e-af16-594a-b187-277fb47ddffd"><lexical-unit><form lang="id"><text>gaya</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gaya_0" guid="e4ca1565-ea59-5f65-9aaf-f32aea384ee3"><grammatical-info value="Noun"/><gloss lang="en"><text>power, strength</text></gloss></sense><sense id="gaya_1" guid="0872316e-3f35-5ba2-b3bd-f51cec22bd35"><grammatical-info value="Noun"/><gloss lang="en"><text>force: a physical quantity that denotes ability to push, pull, twist or accelerate a body and which has a direction and is measured in a unit dimensioned in mass × distance/time² (ML/T²): SI: newton (N); CGS: dyne (dyn)</text></gloss></sense><sense id="gaya_2" guid="5283ef7d-5f18-5001-b26b-d47c31d63d40"><grammatical-info value="Noun"/><gloss lang="en"><text>attitude, gesture, manner</text></gloss></sense><sense id="gaya_3" guid="861b2290-877c-5b53-a451-a4101095ade1"><grammatical-info value="Noun"/><gloss lang="en"><text>style</text></gloss></sense><sense id="gaya_4" guid="da0ab993-7e3c-530a-86d1-b2bbec495943"><grammatical-info value="Noun"/><gloss lang="en"><text>genre</text></gloss></sense><sense id="gaya_5" guid="c850b589-2b93-5e1d-b92a-7b8c13c043cd"><grammatical-info value="Noun"/><gloss lang="en"><text>order</text></gloss></sense><sense id="gaya_6" guid="6a8516c8-13c6-5b45-80b5-ff65a0c141b0"><grammatical-info value="Noun"/><gloss lang="en"><text>elegant, beautiful</text></gloss></sense></entry>
<entry id="gaza" guid="a58da479-95e2-51f8-b2cf-bbf997220135"><lexical-unit><form lang="id"><text>gaza</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gaza_0" guid="a1468461-a7c3-58a7-be8b-4bb4a7376959"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="gedung" guid="2cf365ae-94bb-5601-8b58-77715aabeda4"><lexical-unit><form lang="id"><text>gedung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gedung_0" guid="5924ab9f-be32-53ee-a45e-1b7179135c13"><grammatical-info value="Noun"/><gloss lang="en"><text>building</text></gloss></sense></entry>
<entry id="gegas" guid="aebcdd19-2558-5986-af0c-d0eac8469d16"><lexical-unit><form lang="id"><text>gegas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gegas_0" guid="c703d01c-a2a5-5c96-b350-0f93b4ac3f5e"><grammatical-info value="Verb"/><gloss lang="en"><text>rushed</text></gloss></sense></entry>
<entry id="gelak" guid="686be4a2-383d-55ed-be3e-d22bb3191b7e"><lexical-unit><form lang="id"><text>gelak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gelak_0" guid="c59e081e-df87-53ec-8658-b7a6d4e9f1d2"><grammatical-info value="Noun"/><gloss lang="en"><text>laughter (sound (as) of laughing)</text></gloss></sense></entry>
<entry id="gelang" guid="c1c6efbc-5870-5c79-a1c8-aa52a00eb4bc"><lexical-unit><form lang="id"><text>gelang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gelang_0" guid="6eace0f9-9655-5086-b153-2dee48b7b6f4"><grammatical-info value="Verb"/><gloss lang="en"><text>bracelet</text></gloss></sense><sense id="gelang_1" guid="92a59b71-bc20-5361-aec4-9cef90c62c3f"><grammatical-info value="Verb"/><gloss lang="en"><text>a ring; a band or stripe that encircles something</text></gloss></sense></entry>
<entry id="gelap" guid="fdab9070-d7ba-5a82-8091-5c81e4b14a40"><lexical-unit><form lang="id"><text>gelap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gelap_0" guid="b67a2a2a-abcc-5a44-a1e0-ef6438b564a2"><grammatical-info value="Adjective"/><gloss lang="en"><text>dark (having an absolute or relative lack of light)</text></gloss></sense><sense id="gelap_1" guid="2fb31ccf-62f2-5a34-b139-2308e84ca7bf"><grammatical-info value="Adjective"/><gloss lang="en"><text>dark (dull or deeper in hue)</text></gloss></sense><sense id="gelap_2" guid="2784dfe6-675e-541c-adf5-9cf2df3185fe"><grammatical-info value="Adjective"/><gloss lang="en"><text>dark, hidden, secret, obscure</text></gloss></sense></entry>
<entry id="gelar" guid="2842c7bc-d24e-5b2c-9b41-98446f51312e"><lexical-unit><form lang="id"><text>gelar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gelar_0" guid="ac0c6a5e-2869-5c51-b645-f441817c4527"><grammatical-info value="Noun"/><gloss lang="en"><text>title (of a name)</text></gloss></sense><sense id="gelar_1" guid="43e00e2d-85f8-53d4-9a40-797ec099386e"><grammatical-info value="Noun"/><gloss lang="en"><text>nickname that relates to one's characteristics or condition</text></gloss></sense><sense id="gelar_2" guid="3d05b57b-3d62-554d-8070-88e13b0cf3f6"><grammatical-info value="Noun"/><gloss lang="en"><text>degree: a stage of proficiency or qualification in a course of study, now especially an award bestowed by a university/college, as a certification of academic achievement</text></gloss></sense><sense id="gelar_3" guid="58a270ed-81a0-5e3b-b45c-5721ed5b8238"><grammatical-info value="Noun"/><gloss lang="en"><text>deployment</text></gloss></sense><sense id="gelar_4" guid="588ab887-09b5-599c-a585-4471e3b020e1"><grammatical-info value="Noun"/><gloss lang="en"><text>to spread</text></gloss></sense><sense id="gelar_5" guid="3e70c861-05b8-577e-a131-66df3851f6c0"><grammatical-info value="Noun"/><gloss lang="en"><text>to hold (to organise an event or meeting)</text></gloss></sense></entry>
<entry id="gelas" guid="7fee4ce2-e64c-572c-b9d7-99ee3ecdcf60"><lexical-unit><form lang="id"><text>gelas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gelas_0" guid="91692252-2ad4-5d04-9f49-50f1e7fd501f"><grammatical-info value="Noun"/><gloss lang="en"><text>glass (drinking vessel; material)</text></gloss></sense></entry>
<entry id="gelegar" guid="6a2a76d7-84c7-5340-bc10-c953b9ff74b8"><lexical-unit><form lang="id"><text>gelegar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gelegar_0" guid="4cdce4d9-8a01-5eea-87ac-9bfef4c22108"><grammatical-info value="Verb"/><gloss lang="en"><text>sound of cannon, thunder, or rumble</text></gloss></sense><sense id="gelegar_1" guid="7a7d0178-037f-50ee-918c-bca13ef49f06"><grammatical-info value="Verb"/><gloss lang="en"><text>beam, girder, joint (of floor)</text></gloss></sense></entry>
<entry id="gelisah" guid="1f9004a1-3b7c-5a95-88cd-f97d4aacec55"><lexical-unit><form lang="id"><text>gelisah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gelisah_0" guid="4ed231e6-f420-5b8f-b0ae-cbbe672c52f7"><grammatical-info value="Noun"/><gloss lang="en"><text>nervous, anxious</text></gloss></sense></entry>
<entry id="gelombang" guid="46a76df4-fbdc-5c11-94c1-9670b1355869"><lexical-unit><form lang="id"><text>gelombang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gelombang_0" guid="a568c53c-35d3-51f7-a863-080509c69fac"><grammatical-info value="Noun"/><gloss lang="en"><text>wave</text></gloss></sense></entry>
<entry id="gelora" guid="ea07e7c8-09e6-504b-9adf-8c1aeb09d03e"><lexical-unit><form lang="id"><text>gelora</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gelora_0" guid="b71a398a-147e-53ac-8969-685bf6c549fa"><grammatical-info value="Verb"/><gloss lang="en"><text>surge; wave</text></gloss></sense><sense id="gelora_1" guid="61e03884-3a9a-5370-9751-18011f3471fa"><grammatical-info value="Verb"/><gloss lang="en"><text>rainstorm</text></gloss></sense><sense id="gelora_2" guid="739bfd51-486a-5d91-91ee-9658f4d77e83"><grammatical-info value="Verb"/><gloss lang="en"><text>wavicle</text></gloss></sense><sense id="gelora_3" guid="64b2467b-a5f2-56b5-b8c2-47231f91a386"><grammatical-info value="Verb"/><gloss lang="en"><text>syllabic abbreviation of gelanggang olahraga (“sports arena”)</text></gloss></sense></entry>
<entry id="geluh" guid="9e6a2d3f-f5f8-5b50-ab94-b1f7ea6ff205"><lexical-unit><form lang="id"><text>geluh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="geluh_0" guid="bd12e614-89c1-5dd2-9577-42e0c915275f"><grammatical-info value="Noun"/><gloss lang="en"><text>loam (a type of soil; an earthy mixture of sand, silt and clay, with organic matter to which its fertility is chiefly due)</text></gloss></sense></entry>
<entry id="gema" guid="6475e9f8-0535-5956-ab32-644f74930bbf"><lexical-unit><form lang="id"><text>gema</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gema_0" guid="b6aad91c-cc35-5543-8854-6bbad5df4e03"><grammatical-info value="Proper noun"/><gloss lang="en"><text>echo:</text></gloss></sense><sense id="gema_1" guid="5fe93bf8-887f-5dc5-a8e7-8bf7aa0a360e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a reflected sound that is heard again by its initial observer</text></gloss></sense><sense id="gema_2" guid="2992cbde-352e-5fa9-9a5d-5fa68fcdc866"><grammatical-info value="Proper noun"/><gloss lang="en"><text>an utterance repeating what has just been said</text></gloss></sense></entry>
<entry id="gemas" guid="01d24bb5-1d18-5304-9ea8-238867525b0e"><lexical-unit><form lang="id"><text>gemas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gemas_0" guid="73113fc4-d31f-5778-875c-c67bb1825476"><grammatical-info value="Adjective"/><gloss lang="en"><text>annoyed, irritated, frustrated</text></gloss></sense><sense id="gemas_1" guid="4ef6c131-63af-56ba-9a2d-471378613845"><grammatical-info value="Adjective"/><gloss lang="en"><text>carried away from intense emotion (usually cute aggression), moved emotionally to do something physical; gigil</text></gloss></sense></entry>
<entry id="gembala" guid="4042b564-0e31-5ccb-baf7-2c34f7f02bd9"><lexical-unit><form lang="id"><text>gembala</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gembala_0" guid="b55b8d68-b758-586c-a326-51b1557d0a8c"><grammatical-info value="Noun"/><gloss lang="en"><text>herder, one who herds</text></gloss></sense><sense id="gembala_1" guid="db6cc410-3a8e-59e9-973a-78d5c0905fdf"><grammatical-info value="Noun"/><gloss lang="en"><text>saviour, shepherd</text></gloss></sense></entry>
<entry id="gembira" guid="326461b7-ed89-55be-8e1a-6385ced9dc62"><lexical-unit><form lang="id"><text>gembira</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gembira_0" guid="328fd6fc-a25d-5af3-941e-24f29b1cd061"><grammatical-info value="Adjective"/><gloss lang="en"><text>happy, proud</text></gloss></sense></entry>
<entry id="gempa" guid="8e6c143b-1609-5e8e-8251-f274a6852046"><lexical-unit><form lang="id"><text>gempa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gempa_0" guid="8c88a6be-3217-55e5-942b-1b027b2de834"><grammatical-info value="Noun"/><gloss lang="en"><text>quake</text></gloss></sense><sense id="gempa_1" guid="d679471a-e322-53df-95ae-0723417e7dbf"><grammatical-info value="Noun"/><gloss lang="en"><text>a trembling or shaking</text></gloss></sense><sense id="gempa_2" guid="a8e175fd-92dc-5490-893f-49bc962287eb"><grammatical-info value="Noun"/><gloss lang="en"><text>an earthquake, a trembling of the ground with force</text></gloss></sense></entry>
<entry id="gempar" guid="3d864299-dfd0-5ba4-a58d-ac48a6f6d18a"><lexical-unit><form lang="id"><text>gempar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gempar_0" guid="4e6e810d-3d3a-5aaa-b34f-d078cb78b20b"><grammatical-info value="Noun"/><gloss lang="en"><text>in an uproar</text></gloss></sense><sense id="gempar_1" guid="fb6586c5-a1ef-554d-9641-630ce6cf9536"><grammatical-info value="Noun"/><gloss lang="en"><text>exciting (creating or producing excitement)</text></gloss></sense><sense id="gempar_2" guid="c7db3b89-bde0-51d8-90e8-f2896501a11b"><grammatical-info value="Noun"/><gloss lang="en"><text>chaotic, noisy</text></gloss></sense><sense id="gempar_3" guid="a56ca3fc-18cd-5883-a0ed-c66ccac40e7f"><grammatical-info value="Noun"/><gloss lang="en"><text>karalla daura (a species of marine fish that lives in tropical waters)</text></gloss></sense></entry>
<entry id="gemuk" guid="45e82984-c057-5df3-842b-e74d84699d3a"><lexical-unit><form lang="id"><text>gemuk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gemuk_0" guid="e44bc186-d2fb-5de4-9486-716272a33b75"><grammatical-info value="Adjective"/><gloss lang="en"><text>fat (carrying a larger than normal amount of fat on one's body)</text></gloss></sense><sense id="gemuk_1" guid="b6658113-7399-5f36-84c7-ec2e0b57ccfe"><grammatical-info value="Adjective"/><gloss lang="en"><text>fertile</text></gloss></sense><sense id="gemuk_2" guid="3f432501-4ad7-575a-ae1c-50a5285398e9"><grammatical-info value="Adjective"/><gloss lang="en"><text>fat</text></gloss></sense><sense id="gemuk_3" guid="482d0054-cef4-5c44-b7cd-fa38335dd1cc"><grammatical-info value="Adjective"/><gloss lang="en"><text>fertilizer</text></gloss></sense><sense id="gemuk_4" guid="7308c756-7cc5-5713-af75-b588285e4372"><grammatical-info value="Adjective"/><gloss lang="en"><text>grease</text></gloss></sense></entry>
<entry id="gemuruh" guid="36e4dfd1-2b6f-5cea-a775-a28221710e28"><lexical-unit><form lang="id"><text>gemuruh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gemuruh_0" guid="90d443de-3d49-5617-a8ca-69c4bf22ac31"><grammatical-info value="Verb"/><gloss lang="en"><text>refined</text></gloss></sense></entry>
<entry id="genang" guid="f79e97ea-bd6b-5556-8c8c-c226291a8de6"><lexical-unit><form lang="id"><text>genang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="genang_0" guid="a2e3246d-7c48-5f44-95d2-bd105c28faf6"><grammatical-info value="Noun"/><gloss lang="en"><text>stagnate (water)</text></gloss></sense><sense id="genang_1" guid="4f635d8e-350d-5e91-97d2-ebdb362546d3"><grammatical-info value="Noun"/><gloss lang="en"><text>good memory</text></gloss></sense></entry>
<entry id="genap" guid="4d846557-d100-53c6-834e-d5991bae7656"><lexical-unit><form lang="id"><text>genap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="genap_0" guid="7f4cfadb-b4bb-50f5-bf80-ff4473957d77"><grammatical-info value="Noun"/><gloss lang="en"><text>complete, full</text></gloss></sense><sense id="genap_1" guid="e82a0fab-74a1-5d9f-b939-061656f77f9a"><grammatical-info value="Noun"/><gloss lang="en"><text>even, divisible by two</text></gloss></sense><sense id="genap_2" guid="382bffb5-0f58-5d43-b10e-0b145714f900"><grammatical-info value="Noun"/><gloss lang="en"><text>appropriate, fit, suitable</text></gloss></sense></entry>
<entry id="gendari" guid="1127b9a8-7c7a-5b9a-9203-9f0c33e2b455"><lexical-unit><form lang="id"><text>gendari</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gendari_0" guid="f2aa501b-3e66-58c0-a611-12527f57e84d"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="gendong" guid="c5b0ac42-8b56-58e9-8a2e-e6542f7fdc44"><lexical-unit><form lang="id"><text>gendong</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gendong_0" guid="10374015-8d3f-5e3f-b41d-c2c9e319cf7c"><grammatical-info value="Verb"/><gloss lang="en"><text>wagging</text></gloss></sense></entry>
<entry id="generasi" guid="647a72a4-e9a2-53e2-97c1-0fe030aefc9f"><lexical-unit><form lang="id"><text>generasi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="generasi_0" guid="048e2a8f-2e56-52bb-b747-d82e810b7c91"><grammatical-info value="Noun"/><gloss lang="en"><text>generation:</text></gloss></sense><sense id="generasi_1" guid="808e199f-1e08-520c-a800-fee190f52685"><grammatical-info value="Noun"/><gloss lang="en"><text>the average amount of time needed for children to grow up and have children of their own, generally considered to be a period of around thirty years, used as a measure of time</text></gloss></sense><sense id="generasi_2" guid="0406eb6a-90f8-5f50-85aa-c50745963cfc"><grammatical-info value="Noun"/><gloss lang="en"><text>a group of people born in a specific range of years and whose members can relate culturally to one another</text></gloss></sense></entry>
<entry id="gerak" guid="cb5144b9-515a-5d8c-95a5-c1e1150d8a87"><lexical-unit><form lang="id"><text>gerak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gerak_0" guid="c7926349-0d1e-58e1-bb1c-50682be2e960"><grammatical-info value="Noun"/><gloss lang="en"><text>motion (a change from one place to another)</text></gloss></sense><sense id="gerak_1" guid="c55f47bd-0646-5377-a2d7-5c09b9e7aa6a"><grammatical-info value="Noun"/><gloss lang="en"><text>movement</text></gloss></sense></entry>
<entry id="gerakan" guid="8f5044ee-163c-5590-9609-a740c781577c"><lexical-unit><form lang="id"><text>gerakan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gerakan_0" guid="af16fcf2-7099-528a-a4ed-3f2b6a6becc8"><grammatical-info value="Noun"/><gloss lang="en"><text>movement:</text></gloss></sense><sense id="gerakan_1" guid="76cf3abb-c2ef-5232-94fd-91ef899be648"><grammatical-info value="Noun"/><gloss lang="en"><text>physical motion between points in space</text></gloss></sense><sense id="gerakan_2" guid="996323d5-65a6-57ba-bd9d-c4fd0dfe9d30"><grammatical-info value="Noun"/><gloss lang="en"><text>a trend in various fields or social categories, a group of people with a common ideology who try together to achieve certain general goals</text></gloss></sense></entry>
<entry id="gerbang" guid="3e566625-7ee9-5f43-a804-fddd796b075f"><lexical-unit><form lang="id"><text>gerbang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gerbang_0" guid="56c969fe-cb77-5bcf-bcf8-2d190ce137c4"><grammatical-info value="Noun"/><gloss lang="en"><text>gate:</text></gloss></sense><sense id="gerbang_1" guid="f4c9d3e4-ecea-5094-82f7-902a0601c20c"><grammatical-info value="Noun"/><gloss lang="en"><text>a doorlike structure outside a house; doorway, opening, or passage in a fence or wall</text></gloss></sense><sense id="gerbang_2" guid="88926b4f-1726-5e52-a79f-99630056eb8d"><grammatical-info value="Noun"/><gloss lang="en"><text>passageway (as in an air terminal) where passengers can embark or disembark</text></gloss></sense><sense id="gerbang_3" guid="cb6c8e01-6a42-5290-a639-3d8d25b79fc3"><grammatical-info value="Noun"/><gloss lang="en"><text>a logical pathway made up of switches which turn on or off. Examples are AND, OR, NAND, etc.</text></gloss></sense><sense id="gerbang_4" guid="98ce0017-2c41-5b58-8295-562b34d51bef"><grammatical-info value="Noun"/><gloss lang="en"><text>the controlling terminal of a field effect transistor (FET)</text></gloss></sense><sense id="gerbang_5" guid="92e05616-62e6-5c1e-b892-54d2a1957502"><grammatical-info value="Noun"/><gloss lang="en"><text>gateway: In wireless internet, an access point with additional software capabilities such as providing NAT and DHCP, which may also provide VPN support, roaming, firewalls, various levels of security, etc</text></gloss></sense><sense id="gerbang_6" guid="b2392884-823f-543f-92a2-07d6ecba5105"><grammatical-info value="Noun"/><gloss lang="en"><text>threshold</text></gloss></sense><sense id="gerbang_7" guid="71134dcb-ebda-5a23-8bdd-c3e5f12c9487"><grammatical-info value="Noun"/><gloss lang="en"><text>loose</text></gloss></sense></entry>
<entry id="gereja" guid="580402a3-cfdb-5abd-b0cc-873798e40849"><lexical-unit><form lang="id"><text>gereja</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gereja_0" guid="91255ea5-5911-5a87-b2a6-e2b537534b2f"><grammatical-info value="Noun"/><gloss lang="en"><text>church:</text></gloss></sense><sense id="gereja_1" guid="e4094323-a0b2-51b7-8069-0a4fb1bc1a43"><grammatical-info value="Noun"/><gloss lang="en"><text>a Christian house of worship; a building where Christian religious services take place.</text></gloss></sense><sense id="gereja_2" guid="1064ef06-4ff1-519c-8c02-4b449bd5eecd"><grammatical-info value="Noun"/><gloss lang="en"><text>Christians collectively seen as a single spiritual community; Christianity; Christendom.</text></gloss></sense><sense id="gereja_3" guid="7edd7a19-fa6d-515b-9b4c-b74aa685287e"><grammatical-info value="Noun"/><gloss lang="en"><text>a particular denomination of Christianity.</text></gloss></sense><sense id="gereja_4" guid="a033ab48-e4c4-53ad-96ae-22c5cd52c6ba"><grammatical-info value="Noun"/><gloss lang="en"><text>a local group of people who follow the same Christian religious beliefs, local or general.</text></gloss></sense><sense id="gereja_5" guid="996474c9-b489-5439-b46a-427cbd9f0b3c"><grammatical-info value="Noun"/><gloss lang="en"><text>congregation:</text></gloss></sense><sense id="gereja_6" guid="b5947db9-e5b1-5502-809b-99028b503a8c"><grammatical-info value="Noun"/><gloss lang="en"><text>a gathering of faithful in a temple, church, synagogue, mosque or other place of worship. It can also refer to the people who are present at a devotional service in the building, particularly in contrast to the pastor, minister, imam, rabbi etc. and/or choir, who may be seated apart from the general congregation or lead the service (notably in responsory form).</text></gloss></sense><sense id="gereja_7" guid="552c2710-d4b1-5201-8d65-bd06f6e6db8f"><grammatical-info value="Noun"/><gloss lang="en"><text>a corporate body whose members gather for worship, or the members of such a body.</text></gloss></sense></entry>
<entry id="gergaji" guid="fdfbc06c-8971-5318-a979-953527aad49a"><lexical-unit><form lang="id"><text>gergaji</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gergaji_0" guid="a7bfca70-0050-5d1f-a0a3-d2d09b7c6488"><grammatical-info value="Noun"/><gloss lang="en"><text>saw: a tool with a toothed blade used for cutting hard substances, in particular wood or metal</text></gloss></sense></entry>
<entry id="gering" guid="22113972-223f-5e0d-88dc-e8a1698c6b0b"><lexical-unit><form lang="id"><text>gering</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gering_0" guid="7379fe38-a32c-53d2-97c3-94169fe4230f"><grammatical-info value="Adjective"/><gloss lang="en"><text>sick</text></gloss></sense></entry>
<entry id="gerutu" guid="f2ae7741-eb99-5ec8-bc2b-ec143b8c6fbb"><lexical-unit><form lang="id"><text>gerutu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gerutu_0" guid="25047f91-dc22-554e-ad61-f0ea82e3fb35"><grammatical-info value="Verb"/><gloss lang="en"><text>murmurers</text></gloss></sense></entry>
<entry id="geser" guid="8cba4e24-929a-5d88-ab20-9e280966a966"><lexical-unit><form lang="id"><text>geser</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="geser_0" guid="8652c9cb-209f-522a-9a2c-3adb6521ea01"><grammatical-info value="Verb"/><gloss lang="en"><text>sliding</text></gloss></sense><sense id="geser_1" guid="595a64e5-b837-5819-a90c-e31dcf834989"><grammatical-info value="Verb"/><gloss lang="en"><text>to move</text></gloss></sense></entry>
<entry id="giat" guid="bdec384d-fa19-5193-a4d0-48b2f6d6a0e8"><lexical-unit><form lang="id"><text>giat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="giat_0" guid="fc18a290-c514-5c58-b6e2-86572b9499b3"><grammatical-info value="Verb"/><gloss lang="en"><text>active, busy</text></gloss></sense><sense id="giat_1" guid="1a9b9f3c-9539-5bd0-9d05-07c25cb8d686"><grammatical-info value="Verb"/><gloss lang="en"><text>energetic, strong, powerful, forceful, zealous, aggressive</text></gloss></sense><sense id="giat_2" guid="2513dff8-e798-501b-bf6e-b232a8fa01f7"><grammatical-info value="Verb"/><gloss lang="en"><text>clipping of kegiatan</text></gloss></sense></entry>
<entry id="gigi" guid="eedab153-f326-531c-8d50-8107eb7f83bc"><lexical-unit><form lang="id"><text>gigi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gigi_0" guid="dcf9f554-17c0-5942-8aec-b1b18f47b0f6"><grammatical-info value="Noun"/><gloss lang="en"><text>tooth:</text></gloss></sense><sense id="gigi_1" guid="3151e384-95c5-530b-8ad0-17e42f658b82"><grammatical-info value="Noun"/><gloss lang="en"><text>a hard, calcareous structure present in the mouth of many vertebrate animals, generally used for eating</text></gloss></sense><sense id="gigi_2" guid="5f428539-37b4-5896-8e05-a8daaa5b36ee"><grammatical-info value="Noun"/><gloss lang="en"><text>a sharp projection</text></gloss></sense><sense id="gigi_3" guid="f4cede42-5f8c-5931-92f6-1433d237727f"><grammatical-info value="Noun"/><gloss lang="en"><text>power, authority</text></gloss></sense><sense id="gigi_4" guid="daa90b73-2d7c-577c-a8ba-541ab5f672f9"><grammatical-info value="Noun"/><gloss lang="en"><text>gear; cog</text></gloss></sense></entry>
<entry id="gigit" guid="d3a8f8f7-7127-577f-9ec2-ea1a683e8c0e"><lexical-unit><form lang="id"><text>gigit</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gigit_0" guid="4e0afaf9-ecb6-55b7-9b9e-913dcc1ea41e"><grammatical-info value="Verb"/><gloss lang="en"><text>to bite (to cut or hold by clamping the teeth)</text></gloss></sense></entry>
<entry id="gigitan" guid="37a3cc44-f173-5f6f-87c8-cae7d980e06b"><lexical-unit><form lang="id"><text>gigitan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gigitan_0" guid="d4e6001c-478d-5ce8-a914-eff5a0156d1b"><grammatical-info value="Noun"/><gloss lang="en"><text>bite</text></gloss></sense><sense id="gigitan_1" guid="c046f141-8d87-54b1-97ad-ae3f97340f88"><grammatical-info value="Noun"/><gloss lang="en"><text>the act of biting.</text></gloss></sense><sense id="gigitan_2" guid="ca7c1b5c-d99d-5a51-8fa6-db884a34526f"><grammatical-info value="Noun"/><gloss lang="en"><text>the wound left behind after having been bitten.</text></gloss></sense><sense id="gigitan_3" guid="43df7390-ba82-5852-96e9-363a968f5571"><grammatical-info value="Noun"/><gloss lang="en"><text>a piece of something (such as food) of a size that would be produced by biting</text></gloss></sense></entry>
<entry id="gila" guid="fde6db17-450e-50be-8e48-5aa6c14601de"><lexical-unit><form lang="id"><text>gila</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gila_0" guid="a4ad9cf9-8b1e-5028-b5fd-3c63f609d6c4"><grammatical-info value="Noun"/><gloss lang="en"><text>crazy, insane</text></gloss></sense><sense id="gila_1" guid="59600055-95a4-5f82-9769-f3d3abe3f10f"><grammatical-info value="Noun"/><gloss lang="en"><text>extraordinary</text></gloss></sense><sense id="gila_2" guid="49d9a0f8-b95d-5f4d-abdf-732398efb696"><grammatical-info value="Noun"/><gloss lang="en"><text>illogical</text></gloss></sense><sense id="gila_3" guid="e75006ec-4916-5f21-93e9-cd999459e3a1"><grammatical-info value="Noun"/><gloss lang="en"><text>wonderful</text></gloss></sense><sense id="gila_4" guid="ddf69fa2-e30f-52dc-90b1-8558cbfc9b08"><grammatical-info value="Noun"/><gloss lang="en"><text>to obsess</text></gloss></sense></entry>
<entry id="giling" guid="5968de9c-a4f9-5b55-b568-bfcb137ada55"><lexical-unit><form lang="id"><text>giling</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="giling_0" guid="83266238-5c1b-53c4-bbb1-e01729fa825a"><grammatical-info value="Verb"/><gloss lang="en"><text>to roll</text></gloss></sense><sense id="giling_1" guid="d8d5624b-fce5-5b69-b8b8-7601ba3de30f"><grammatical-info value="Verb"/><gloss lang="en"><text>to grind</text></gloss></sense></entry>
