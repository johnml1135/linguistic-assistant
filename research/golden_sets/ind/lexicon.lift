<entry id="reaksi" guid="692d7a76-96d8-5af6-b766-15f97804f742"><lexical-unit><form lang="id"><text>reaksi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="reaksi_0" guid="e56781f2-1fa1-51d3-b39c-c29bba1a807d"><grammatical-info value="Noun"/><gloss lang="en"><text>reaction:</text></gloss></sense><sense id="reaksi_1" guid="b8061d99-03f3-5eb1-8e1a-f6e27da1034b"><grammatical-info value="Noun"/><gloss lang="en"><text>an action or statement in response to a stimulus or other event</text></gloss></sense><sense id="reaksi_2" guid="fc829a68-1fc0-5773-8b11-2493cdadf7ac"><grammatical-info value="Noun"/><gloss lang="en"><text>a transformation in which one or more substances is converted into another by combination or decomposition</text></gloss></sense></entry>
