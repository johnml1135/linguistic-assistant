<entry id="takluk" guid="f6909744-d778-5a68-8c13-93cfe36e4fc5"><lexical-unit><form lang="id"><text>takluk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="takluk_0" guid="c9987968-ffcd-5d39-ac26-6cfba21ee9ee"><grammatical-info value="Verb"/><gloss lang="en"><text>to surrender; to yield; to give up</text></gloss></sense><sense id="takluk_1" guid="5a9836b9-f0e6-5065-af60-c29edb46cb9f"><grammatical-info value="Verb"/><gloss lang="en"><text>to conquer</text></gloss></sense></entry>
<entry id="taklukkan" guid="e28c7f67-547d-5fbe-acd7-8a32d8bc4054"><lexical-unit><form lang="id"><text>taklukkan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="taklukkan_0" guid="b687d7f1-424c-587a-86bf-73bba2397eb0"><grammatical-info value="Verb"/><gloss lang="en"><text>to conquer</text></gloss></sense></entry>
