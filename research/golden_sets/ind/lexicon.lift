<entry id="kata" guid="6862637c-d58b-5825-8262-aa07cb933260"><lexical-unit><form lang="id"><text>kata</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kata_0" guid="fe6965e8-f92f-5001-ad98-3d73e4c1a60c"><grammatical-info value="Verb"/><gloss lang="en"><text>word (the smallest discrete, meaningful unit of language)</text></gloss></sense><sense id="kata_1" guid="744ad73c-da6a-5cbd-95fe-0c97975ba2f3"><grammatical-info value="Verb"/><gloss lang="en"><text>speech (something which has been said)</text></gloss></sense><sense id="kata_2" guid="d4775a44-c3a5-5194-a4c2-f20c1f0b4072"><grammatical-info value="Verb"/><gloss lang="en"><text>to say</text></gloss></sense></entry>
