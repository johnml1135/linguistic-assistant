<entry id="rasul" guid="0484f37a-bf53-5dd0-b8df-83da8812c41f"><lexical-unit><form lang="id"><text>rasul</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="rasul_0" guid="32cb70f3-9f93-5119-a776-3ccbe829eac9"><grammatical-info value="Noun"/><gloss lang="en"><text>rasul: a prophet or messenger in Islam; Muhammad, as a special messenger of God</text></gloss></sense><sense id="rasul_1" guid="09ca442f-2ed6-5fbc-9ee2-787c29f150d6"><grammatical-info value="Noun"/><gloss lang="en"><text>apostle</text></gloss></sense><sense id="rasul_2" guid="49ce69da-4d6f-51ea-bcb7-69979b11958f"><grammatical-info value="Noun"/><gloss lang="en"><text>any of the group of twelve disciples chosen by Jesus to preach and spread the Gospel</text></gloss></sense></entry>
