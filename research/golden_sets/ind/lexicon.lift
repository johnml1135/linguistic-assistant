<entry id="kap" guid="c9b77b65-21f7-50b2-8a53-9efe9eade820"><lexical-unit><form lang="id"><text>kap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kap_0" guid="cc050adf-6663-540e-9a2a-8e1de1800e42"><grammatical-info value="Noun"/><gloss lang="en"><text>rope</text></gloss></sense><sense id="kap_1" guid="2eaa3be0-f03f-5630-8dde-d73ee3a3a798"><grammatical-info value="Noun"/><gloss lang="en"><text>cap</text></gloss></sense><sense id="kap_2" guid="85117866-b0c9-56e6-a3ac-310d92da18c9"><grammatical-info value="Noun"/><gloss lang="en"><text>cover</text></gloss></sense><sense id="kap_3" guid="5f09986e-6303-5033-9513-0775a88c6b36"><grammatical-info value="Noun"/><gloss lang="en"><text>bonnet, cowl, hood (soft top of a convertible car or carriage, the hinged cover over the engine of a motor vehicle)</text></gloss></sense><sense id="kap_4" guid="cad97521-f3b2-50a4-ad1b-ed4f7492a680"><grammatical-info value="Noun"/><gloss lang="en"><text>clipping of kapital</text></gloss></sense></entry>
<entry id="kapak" guid="77070e3a-9540-564a-8413-849f0285c6fb"><lexical-unit><form lang="id"><text>kapak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kapak_0" guid="25a5cce6-ac4f-5a35-84ec-adaf45b6185f"><grammatical-info value="Noun"/><gloss lang="en"><text>axe</text></gloss></sense></entry>
<entry id="kapal" guid="8bf78178-0cbf-5046-aed3-282a0ccec022"><lexical-unit><form lang="id"><text>kapal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kapal_0" guid="3fa10450-4dd7-53c8-976b-f915800f896a"><grammatical-info value="Noun"/><gloss lang="en"><text>ship (a water-borne vessel generally larger than a boat)</text></gloss></sense><sense id="kapal_1" guid="65e18e72-8ee8-50ac-9450-742477f0ebfe"><grammatical-info value="Noun"/><gloss lang="en"><text>ship (a vessel which travels through any medium other than across land)</text></gloss></sense><sense id="kapal_2" guid="803cb674-75fe-59dd-a647-790b9256cb43"><grammatical-info value="Noun"/><gloss lang="en"><text>ship (a fictional romantic relationship between two characters)</text></gloss></sense><sense id="kapal_3" guid="b186210d-0632-5080-913d-e20cd60bfeda"><grammatical-info value="Noun"/><gloss lang="en"><text>thickening skin; lichenification</text></gloss></sense></entry>
<entry id="kapan" guid="83806e8a-b609-573d-8b88-0cb490be18c4"><lexical-unit><form lang="id"><text>kapan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kapan_0" guid="3980b8cb-de32-5168-b4ff-2baff5fb2660"><grammatical-info value="Adverb"/><gloss lang="en"><text>when</text></gloss></sense><sense id="kapan_1" guid="7f519acf-ddbb-53b4-84d0-6cc7cb268222"><grammatical-info value="Adverb"/><gloss lang="en"><text>nonstandard form of kafan</text></gloss></sense></entry>
<entry id="kapten" guid="d3da38cc-5006-5978-be2e-2221f7d9e7b8"><lexical-unit><form lang="id"><text>kapten</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kapten_0" guid="40bfbbc3-4189-5d14-87ca-598edcddb7a1"><grammatical-info value="Noun"/><gloss lang="en"><text>captain:</text></gloss></sense><sense id="kapten_1" guid="80abff45-3288-513a-957d-20e40d236124"><grammatical-info value="Noun"/><gloss lang="en"><text>an army or air force officer whose rank is higher than that of a lieutenant but lower than that of a major</text></gloss></sense><sense id="kapten_2" guid="1305b193-7613-5544-a7ed-e171923590fb"><grammatical-info value="Noun"/><gloss lang="en"><text>a naval officer whose rank is higher than that of a commander but lower than that of a commodore</text></gloss></sense><sense id="kapten_3" guid="d7b4a8fc-f366-527f-9612-96ff5435b789"><grammatical-info value="Noun"/><gloss lang="en"><text>the first officer or co-pilot of an aircraft</text></gloss></sense><sense id="kapten_4" guid="5f5abd2a-bb93-5e9b-ab26-8f5f25118495"><grammatical-info value="Noun"/><gloss lang="en"><text>the leader of a squad or a team in a game (of football, hockey, and others)</text></gloss></sense><sense id="kapten_5" guid="c1609f4e-9e83-5345-ab3d-450e294083ab"><grammatical-info value="Noun"/><gloss lang="en"><text>someone who has been given the power to lead an organization, group, and so on</text></gloss></sense></entry>
<entry id="karakter" guid="ca775984-e94d-5921-842c-1445ac56976e"><lexical-unit><form lang="id"><text>karakter</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="karakter_0" guid="944f2a1f-47a0-52b2-a3ab-2831dd9ac3dc"><grammatical-info value="Noun"/><gloss lang="en"><text>character:</text></gloss></sense><sense id="karakter_1" guid="e65212cd-e3c3-52c3-9850-6e9ca8bf4299"><grammatical-info value="Noun"/><gloss lang="en"><text>a written or printed symbol, or letter</text></gloss></sense><sense id="karakter_2" guid="3af527f5-a36c-56c5-bcb0-c14560e7a95c"><grammatical-info value="Noun"/><gloss lang="en"><text>one of the basic elements making up a text file or string: a code representing a printing character or a control character</text></gloss></sense></entry>
<entry id="karam" guid="43a96289-0266-5750-b6e9-a3d2db8f7416"><lexical-unit><form lang="id"><text>karam</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="karam_0" guid="7bab7238-bed9-5aa7-8745-406831177b44"><grammatical-info value="Verb"/><gloss lang="en"><text>to be wrecked at sea</text></gloss></sense></entry>
<entry id="karang" guid="b9f19feb-f8d4-529b-ba34-31a8bfe50a5f"><lexical-unit><form lang="id"><text>karang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="karang_0" guid="a90302bf-1fb4-56c4-8be7-169565f7e2b9"><grammatical-info value="Noun"/><gloss lang="en"><text>coral, a hard substance made of the limestone skeletons of marine polyps</text></gloss></sense><sense id="karang_1" guid="81197eb4-97b1-5127-a769-f27656717d0b"><grammatical-info value="Noun"/><gloss lang="en"><text>coral reef, a reef formed by compacted coral skeletons</text></gloss></sense><sense id="karang_2" guid="2c7839c3-bf84-5a60-b4f1-2d233856dbbf"><grammatical-info value="Noun"/><gloss lang="en"><text>assembly point</text></gloss></sense><sense id="karang_3" guid="c0e8b4a7-0752-5fa3-80f0-740127661c87"><grammatical-info value="Noun"/><gloss lang="en"><text>to compose, to create</text></gloss></sense><sense id="karang_4" guid="192fcd1f-fa95-5cbc-b8d2-b9242078248c"><grammatical-info value="Noun"/><gloss lang="en"><text>building ornaments in the form of carvings</text></gloss></sense><sense id="karang_5" guid="093cba16-7eb7-527f-9ddd-f40dfe17dfc0"><grammatical-info value="Noun"/><gloss lang="en"><text>later, soon.</text></gloss></sense></entry>
<entry id="karangan" guid="ef995656-350e-5470-9a58-1aeacb8d898b"><lexical-unit><form lang="id"><text>karangan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="karangan_0" guid="b83a3c6a-ddad-59b3-ab61-42651a573dbd"><grammatical-info value="Noun"/><gloss lang="en"><text>galilean</text></gloss></sense></entry>
<entry id="karat" guid="043f8258-112b-5ddf-974c-a9869c1391ee"><lexical-unit><form lang="id"><text>karat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="karat_0" guid="c8102a69-dde1-5878-b302-04056abf1109"><grammatical-info value="Verb"/><gloss lang="en"><text>rust (the deteriorated state of iron or steel as a result of moisture and oxidation)</text></gloss></sense><sense id="karat_1" guid="9fcd9398-b41a-5ae2-bb52-3c8042748b1f"><grammatical-info value="Verb"/><gloss lang="en"><text>rust (a similar substance based on another metal)</text></gloss></sense><sense id="karat_2" guid="5382be4c-3788-5088-ab30-642d3a6cff33"><grammatical-info value="Verb"/><gloss lang="en"><text>rust (a reddish-brown color)</text></gloss></sense><sense id="karat_3" guid="f90901aa-2c43-516f-87ac-49644a5e3957"><grammatical-info value="Verb"/><gloss lang="en"><text>rusty red</text></gloss></sense><sense id="karat_4" guid="b9eb2d9f-a2b3-54b0-a88a-40b237af2ee5"><grammatical-info value="Verb"/><gloss lang="en"><text>rust brown</text></gloss></sense><sense id="karat_5" guid="702a1659-42af-5dd5-9c8c-1e14f5f65b0d"><grammatical-info value="Verb"/><gloss lang="en"><text>carat (a unit of weight for precious stones and pearls, equivalent to 200 milligrams)</text></gloss></sense><sense id="karat_6" guid="d07439a4-518a-5b25-bfeb-741713c4cb95"><grammatical-info value="Verb"/><gloss lang="en"><text>carat (a measure of the purity of gold, pure gold being 24 carats)</text></gloss></sense><sense id="karat_7" guid="5ba7d296-142c-5cc5-8c8c-4656e0a0fcc9"><grammatical-info value="Verb"/><gloss lang="en"><text>quality</text></gloss></sense></entry>
<entry id="karena" guid="34217ed7-8010-54b0-86a8-8a545eed8a8e"><lexical-unit><form lang="id"><text>karena</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="karena_0" guid="31381336-3119-5640-ae17-184f11d11550"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>because</text></gloss></sense><sense id="karena_1" guid="4a83a1f1-acb3-58cd-ac07-cda2bb33e04b"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>since</text></gloss></sense></entry>
<entry id="karung" guid="980e2931-f73a-5f6b-a019-d346de83003f"><lexical-unit><form lang="id"><text>karung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="karung_0" guid="2f16cbda-a253-51e4-876e-4292421b6c1f"><grammatical-info value="Verb"/><gloss lang="en"><text>sack, a bag; especially a large bag of strong, coarse material for storage and handling of various commodities, such as potatoes, coal, coffee; or, a bag with handles used at a supermarket, a grocery sack; or, a small bag for small items, a satchel</text></gloss></sense></entry>
<entry id="karunia" guid="54faef3d-5ba7-5294-aa88-975aa8330404"><lexical-unit><form lang="id"><text>karunia</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="karunia_0" guid="71a270f3-f73d-597a-87ec-8e0e4bcffc81"><grammatical-info value="Noun"/><gloss lang="en"><text>blessing</text></gloss></sense></entry>
<entry id="karya" guid="65f4e1ec-5609-501f-bc2c-0046e43ebf95"><lexical-unit><form lang="id"><text>karya</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="karya_0" guid="3e76b3ee-8c35-5ffb-b495-d4f804364d87"><grammatical-info value="Noun"/><gloss lang="en"><text>work, product; the result of effort</text></gloss></sense><sense id="karya_1" guid="64f3eefd-79f5-5e4e-8707-0eff9aa98a75"><grammatical-info value="Noun"/><gloss lang="en"><text>a literary, artistic, or intellectual production</text></gloss></sense><sense id="karya_2" guid="9e292109-f1cd-5a0d-b208-4e27435997cf"><grammatical-info value="Noun"/><gloss lang="en"><text>the result of a particular manner of production</text></gloss></sense><sense id="karya_3" guid="47c70c97-ac85-5e8b-b506-a16951505dd3"><grammatical-info value="Noun"/><gloss lang="en"><text>synonym of pekerjaan</text></gloss></sense></entry>
<entry id="kas" guid="d698e117-f99e-5d27-8d69-ed18cd84057a"><lexical-unit><form lang="id"><text>kas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kas_0" guid="ca836076-1d92-5159-9797-a34c75d0eda9"><grammatical-info value="Noun"/><gloss lang="en"><text>cash:</text></gloss></sense><sense id="kas_1" guid="1c237e0d-a9ec-51e9-9d7f-4af6a8aacbc5"><grammatical-info value="Noun"/><gloss lang="en"><text>money in the form of notes/bills and coins, as opposed to cheques/checks or electronic transactions</text></gloss></sense><sense id="kas_2" guid="3d0b1b8d-8b2e-5155-8281-c3c143dc6fec"><grammatical-info value="Noun"/><gloss lang="en"><text>liquid assets, money that can be traded quickly, as distinct from assets that are invested and cannot be easily exchanged</text></gloss></sense><sense id="kas_3" guid="8bb08b75-36f6-5f96-8882-8f124d45227a"><grammatical-info value="Noun"/><gloss lang="en"><text>a box</text></gloss></sense><sense id="kas_4" guid="c9ce5d54-f733-558d-b344-32eace6e4a84"><grammatical-info value="Noun"/><gloss lang="en"><text>a cashbox</text></gloss></sense><sense id="kas_5" guid="14cc6518-969b-529d-b461-466b8171664c"><grammatical-info value="Noun"/><gloss lang="en"><text>a watch-box</text></gloss></sense><sense id="kas_6" guid="cc2f7360-babb-5373-a8c4-91dfe84226fb"><grammatical-info value="Noun"/><gloss lang="en"><text>leaves used as a natural red dye</text></gloss></sense></entry>
<entry id="kasar" guid="7ac42155-6fdf-59c7-98d7-1a9f8d77a0e2"><lexical-unit><form lang="id"><text>kasar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kasar_0" guid="21a1eec9-ff7f-5225-8a7a-b023aa070ab6"><grammatical-info value="Adjective"/><gloss lang="en"><text>rough, harsh, coarse</text></gloss></sense><sense id="kasar_1" guid="4b8693b1-29cb-5e54-abab-5b1157e26b93"><grammatical-info value="Adjective"/><gloss lang="en"><text>uncorrected, without analysis</text></gloss></sense><sense id="kasar_2" guid="34d6a351-5684-5136-9b17-f24c720dce78"><grammatical-info value="Adjective"/><gloss lang="en"><text>crude (in a natural, untreated state)</text></gloss></sense><sense id="kasar_3" guid="5bdbd2d8-1247-50ef-be31-7157fc1757cc"><grammatical-info value="Adjective"/><gloss lang="en"><text>synonym of mentah (“raw”)</text></gloss></sense><sense id="kasar_4" guid="7fa346ce-c53e-53ed-b4f7-c5cf18ba10a7"><grammatical-info value="Adjective"/><gloss lang="en"><text>alternative form of qasar</text></gloss></sense></entry>
<entry id="kasih" guid="294d88c9-bd5f-5839-9844-62a24f06df37"><lexical-unit><form lang="id"><text>kasih</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kasih_0" guid="a58469f0-8ba9-5039-8b3f-6638983eaaca"><grammatical-info value="Noun"/><gloss lang="en"><text>a deep caring for the existence of another</text></gloss></sense><sense id="kasih_1" guid="3ca1c059-5b12-5089-bf2b-558979c61f02"><grammatical-info value="Noun"/><gloss lang="en"><text>a profound and caring affection towards someone</text></gloss></sense><sense id="kasih_2" guid="0b8c1840-080d-5da5-b133-328b76a47793"><grammatical-info value="Noun"/><gloss lang="en"><text>synonym of beri (“to give”)</text></gloss></sense></entry>
<entry id="kasihan" guid="1d1549a5-63a5-503f-ae9f-9304cff2d54a"><lexical-unit><form lang="id"><text>kasihan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kasihan_0" guid="a8c1ae54-f596-5fb2-a399-74bd8d7afc22"><grammatical-info value="Noun"/><gloss lang="en"><text>pitiful</text></gloss></sense><sense id="kasihan_1" guid="519866a0-edb0-5ef8-a22d-f0084be70b6d"><grammatical-info value="Noun"/><gloss lang="en"><text>used to express sadness or pity for someone</text></gloss></sense><sense id="kasihan_2" guid="8a2d2145-60fa-5b5b-8fb9-ff07655d81d9"><grammatical-info value="Noun"/><gloss lang="en"><text>to feel pity, to feel bad</text></gloss></sense></entry>
