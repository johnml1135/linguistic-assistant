<entry id="revolusi" guid="b1b03269-ac7f-5afc-bcca-5c3dbff311f8"><lexical-unit><form lang="id"><text>revolusi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="revolusi_0" guid="ccf2f28c-5683-51e2-bb27-a2fc21b7a2ee"><grammatical-info value="Proper noun"/><gloss lang="en"><text>revolution:</text></gloss></sense><sense id="revolusi_1" guid="249a75cd-9ab9-5683-ab3a-36113eed4b30"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a political upheaval in a government or nation state characterized by great change</text></gloss></sense><sense id="revolusi_2" guid="5a56181c-dcb6-519f-a0cc-32bc9b5da35d"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the removal and replacement of a government, especially by sudden violent action</text></gloss></sense><sense id="revolusi_3" guid="7cb70632-9683-5e20-8899-afa84816dfa2"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a sudden, vast change in a situation, a discipline, or the way of thinking and behaving</text></gloss></sense><sense id="revolusi_4" guid="35c43d1f-c145-5864-a3e1-5c910a0c135a"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the movement of an object in a circular or elliptical course around another or about an axis or center</text></gloss></sense></entry>
