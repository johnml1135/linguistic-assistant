<entry id="pulau" guid="134c2066-daf0-5b42-a55f-eeab2e5d2c6a"><lexical-unit><form lang="id"><text>pulau</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pulau_0" guid="d2e97f91-8884-5610-9311-63564d17a00a"><grammatical-info value="Noun"/><gloss lang="en"><text>island (a contiguous area of land, smaller than a continent, totally surrounded by water)</text></gloss></sense><sense id="pulau_1" guid="45daac54-c5a7-5e66-b3bf-1fd317e7f33e"><grammatical-info value="Noun"/><gloss lang="en"><text>clumps of wood of the same type in the forest</text></gloss></sense></entry>
<entry id="pulih" guid="18bdf352-fcf0-5165-a986-23642c3baad2"><lexical-unit><form lang="id"><text>pulih</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pulih_0" guid="48284346-be2e-5a11-9978-be5ace6a82a1"><grammatical-info value="Verb"/><gloss lang="en"><text>to recover, to restore</text></gloss></sense></entry>
