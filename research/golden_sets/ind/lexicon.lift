<entry id="makna" guid="492a2465-3f64-575b-989d-c8840338fa60"><lexical-unit><form lang="id"><text>makna</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="makna_0" guid="ed09818f-19e5-5976-87a6-d337250d7171"><grammatical-info value="Noun"/><gloss lang="en"><text>meaning (of a word or similar)</text></gloss></sense><sense id="makna_1" guid="c382b429-962f-5f16-9708-879f595175f5"><grammatical-info value="Noun"/><gloss lang="en"><text>meaning, significance</text></gloss></sense></entry>
