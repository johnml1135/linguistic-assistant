<entry id="es" guid="82a1b3dc-3546-5daa-813b-fddbecc03dfe"><lexical-unit><form lang="id"><text>es</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="es_0" guid="79a49884-5591-57ca-8bee-5345afdf97e2"><grammatical-info value="Noun"/><gloss lang="en"><text>ice</text></gloss></sense><sense id="es_1" guid="04f61439-1bf5-5c52-99c3-96ea5e6159d8"><grammatical-info value="Noun"/><gloss lang="en"><text>cold beverage</text></gloss></sense><sense id="es_2" guid="92addb64-1fa3-5ae7-9ac1-17bc32e469f9"><grammatical-info value="Noun"/><gloss lang="en"><text>The name of the Latin script letter S/s.</text></gloss></sense></entry>
<entry id="esok" guid="55a2dc96-f1df-5b50-b79a-4c29525807bb"><lexical-unit><form lang="id"><text>esok</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="esok_0" guid="f04e38e4-1802-5b1a-9d1c-7140dd46562a"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative form of besok</text></gloss></sense></entry>
<entry id="etik" guid="04ee9cdd-57c3-559d-8def-33a4e9db3111"><lexical-unit><form lang="id"><text>etik</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="etik_0" guid="e6a0ae45-5a19-5075-aef6-fe09e61d3632"><grammatical-info value="Noun"/><gloss lang="en"><text>ethic, a set of principles of right and wrong behaviour guiding, or representative of, a specific culture, society, group, or individual</text></gloss></sense></entry>
<entry id="ewa" guid="ae1a1111-4548-5ed7-8592-980c60e06db5"><lexical-unit><form lang="id"><text>ewa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ewa_0" guid="e36a3a3b-106a-5310-a007-63940572b3e5"><grammatical-info value="Proper noun"/></sense></entry>
<entry id="fajar" guid="021fccd2-c6f8-5f73-b6e9-4fad3f3376b2"><lexical-unit><form lang="id"><text>fajar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="fajar_0" guid="845d3c40-23a4-57dd-bbc0-13e6b7168a6d"><grammatical-info value="Noun"/><gloss lang="en"><text>dawn: the morning twilight period immediately before sunrise</text></gloss></sense><sense id="fajar_1" guid="812669a6-c3ff-504f-a1bf-fb4cf7fab2fd"><grammatical-info value="Noun"/><gloss lang="en"><text>daybreak: The morning twilight immediately before sunrise</text></gloss></sense></entry>
<entry id="fakta" guid="164ddb44-4b33-5340-ae26-b3f3b7ee2dd7"><lexical-unit><form lang="id"><text>fakta</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="fakta_0" guid="30386bcf-e023-51bd-ab78-06d782496abc"><grammatical-info value="Noun"/><gloss lang="en"><text>fact: something which is real; something actual as opposed to invented</text></gloss></sense></entry>
<entry id="fana" guid="0f710fcd-f053-5a29-9888-6efa764f6844"><lexical-unit><form lang="id"><text>fana</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="fana_0" guid="1a9af81d-ffdd-598f-9979-548e7355dc7d"><grammatical-info value="Adjective"/><gloss lang="en"><text>Impermanent, ephemeral; existing only for a period or periods of time</text></gloss></sense></entry>
<entry id="fanatik" guid="7118e448-d6e4-53e0-aeee-4c49fb7e59d1"><lexical-unit><form lang="id"><text>fanatik</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="fanatik_0" guid="f7892e03-78d0-54f0-93e9-d2c1b4057bbc"><grammatical-info value="Adjective"/><gloss lang="en"><text>fanatic</text></gloss></sense></entry>
<entry id="farisi" guid="9dea181c-8b3d-57bb-b28e-9392fa9159a9"><lexical-unit><form lang="id"><text>farisi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="farisi_0" guid="de8d31a6-07fb-5a90-8a5d-39f34047c1ec"><grammatical-info value="Noun"/><gloss lang="en"><text>Pharisee</text></gloss></sense><sense id="farisi_1" guid="9257e827-3d9d-54b7-9cb6-c1b281300b6c"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative letter-case form of farisi</text></gloss></sense></entry>
<entry id="fas" guid="3a2fe6a4-eeca-5da2-b14b-864f57780bf4"><lexical-unit><form lang="id"><text>fas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="fas_0" guid="204f4448-95b9-5b61-83a5-437363561b1b"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative spelling of vas (“vase”)</text></gloss></sense></entry>
<entry id="fasih" guid="8fd2f916-8d52-5963-bdf1-6bab3a559228"><lexical-unit><form lang="id"><text>fasih</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="fasih_0" guid="8a9755b5-eae3-5ab7-a96e-948af2487e43"><grammatical-info value="Noun"/><gloss lang="en"><text>Fluent; being able to use a language accurately, rapidly, and confidently.</text></gloss></sense><sense id="fasih_1" guid="c360c55e-c3a8-52e7-938f-60a6426c3fd6"><grammatical-info value="Noun"/><gloss lang="en"><text>Eloquent, well-spoken; effective in expressing meaning by speech.</text></gloss></sense></entry>
<entry id="fasik" guid="5fcdea4a-2826-5e04-acd1-d4190c172043"><lexical-unit><form lang="id"><text>fasik</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="fasik_0" guid="f67d00e1-e1f7-5493-ba46-27a7141d6370"><grammatical-info value="Noun"/><gloss lang="en"><text>not caring about God's commands; wicked</text></gloss></sense><sense id="fasik_1" guid="538cfcc6-702d-577a-b92a-d57d2dc3d9f6"><grammatical-info value="Noun"/><gloss lang="en"><text>people who believe in God Almighty, but do not carry out His commands, even commit sinful acts</text></gloss></sense></entry>
<entry id="favorit" guid="f969fd60-2b8d-5c82-bc46-ae2d46424761"><lexical-unit><form lang="id"><text>favorit</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="favorit_0" guid="debabddb-c90a-5d6d-8f36-d5ddda87e886"><grammatical-info value="Adjective"/><gloss lang="en"><text>favourite:</text></gloss></sense><sense id="favorit_1" guid="a9845d03-5619-5863-8e8e-714127707fcc"><grammatical-info value="Adjective"/><gloss lang="en"><text>a contestant or competitor thought most likely to win</text></gloss></sense><sense id="favorit_2" guid="66442785-511b-5bc8-b0ba-aeb818e9b8c4"><grammatical-info value="Adjective"/><gloss lang="en"><text>bookmark</text></gloss></sense><sense id="favorit_3" guid="62c25958-9cf7-55ff-8fca-07a37dcbe4c2"><grammatical-info value="Adjective"/><gloss lang="en"><text>favourite</text></gloss></sense></entry>
<entry id="feniks" guid="b3792a3f-74da-5efe-9314-7c4e196c3488"><lexical-unit><form lang="id"><text>feniks</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="feniks_0" guid="780728eb-fd4e-5fbe-bc2d-b7cb3ad13cc1"><grammatical-info value="Noun"/><gloss lang="en"><text>phoenix:</text></gloss></sense><sense id="feniks_1" guid="1d8d3a00-d9d2-531d-8e41-22aae25ebe03"><grammatical-info value="Noun"/><gloss lang="en"><text>a mythological bird, said to be the only one of its kind, which lives for 500 years and then dies by burning to ashes on a pyre of its own making, ignited by the sun. It then arises anew from the ashes</text></gloss></sense><sense id="feniks_2" guid="f82c531a-1eed-55a5-9f55-2459f62f4871"><grammatical-info value="Noun"/><gloss lang="en"><text>a mythological Chinese chimerical bird whose physical body symbolizes the six celestial bodies; a fenghuang</text></gloss></sense><sense id="feniks_3" guid="4d888ae8-6f77-5755-9e2a-8e06b52e3d47"><grammatical-info value="Noun"/><gloss lang="en"><text>Phoenix: A spring constellation of the southern sky, said to resemble the mythical bird. It lies north of Tucana</text></gloss></sense></entry>
<entry id="fenisia" guid="90765e42-b8a1-5862-bb4c-ec2f295cacb2"><lexical-unit><form lang="id"><text>fenisia</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="fenisia_0" guid="4373bd4b-506f-519a-9b45-c7e065fdb4b6"><grammatical-info value="Proper noun"/><gloss lang="en"><text>phoenicia</text></gloss></sense></entry>
<entry id="festival" guid="8493f55a-0824-5bd7-9cbd-2ce855780e78"><lexical-unit><form lang="id"><text>festival</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="festival_0" guid="e6ba2b09-c62d-58c9-93a8-7610801b1a3d"><grammatical-info value="Proper noun"/><gloss lang="en"><text>festival</text></gloss></sense></entry>
<entry id="filemon" guid="6ea70275-e399-517c-800a-1c6f90680e10"><lexical-unit><form lang="id"><text>filemon</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="filemon_0" guid="aa84bda2-be15-5f6e-b025-42862f3e3416"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Philemon: The eighteenth book of the New Testament of the Bible, the epistle of Saint Paul to a fellow Christian called Philemon</text></gloss></sense></entry>
<entry id="filip" guid="949fba78-929f-572c-8a1a-cd400a399b61"><lexical-unit><form lang="id"><text>filip</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="filip_0" guid="10f9af87-8737-57fe-a465-aa5911b968ae"><grammatical-info value="Proper noun"/><gloss lang="en"><text>philippi</text></gloss></sense></entry>
<entry id="filipus" guid="a3d4824b-1204-5dae-a4b1-6c4a9d0fe5c5"><lexical-unit><form lang="id"><text>filipus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="filipus_0" guid="6a1895b3-5a23-5095-82b7-1429714f2c5f"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Philip: one of the twelve disciples of Jesus in the Bible; one of the seven deacons</text></gloss></sense></entry>
<entry id="filosof" guid="902adb8f-52dd-5961-8594-83014ff96416"><lexical-unit><form lang="id"><text>filosof</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="filosof_0" guid="3fb61a19-3409-5bdf-ba90-b031003d12e7"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative form of filsuf</text></gloss></sense></entry>
<entry id="filsafat" guid="5043c90f-5255-5bf6-9e6a-5fcf28c0f3ea"><lexical-unit><form lang="id"><text>filsafat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="filsafat_0" guid="d4937e1c-d3ba-511c-bf1a-1dc339b81c79"><grammatical-info value="Noun"/><gloss lang="en"><text>philosophy (academic discipline)</text></gloss></sense><sense id="filsafat_1" guid="627d281e-50bb-5fa2-8f6e-ece8ec0562f5"><grammatical-info value="Noun"/><gloss lang="en"><text>philosophy (view regarding fundamental principles)</text></gloss></sense></entry>
<entry id="finansial" guid="7bb6f6d9-727d-542c-a7a6-d68b2ea42d44"><lexical-unit><form lang="id"><text>finansial</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="finansial_0" guid="f4a72cda-1217-5035-b1ee-8041c5a596f6"><grammatical-info value="Adjective"/><gloss lang="en"><text>financial: related to finances</text></gloss></sense></entry>
<entry id="firaun" guid="d4b3385f-3e9f-5944-9e7a-d58067b849f0"><lexical-unit><form lang="id"><text>firaun</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="firaun_0" guid="07be9e66-e5f7-52d8-a159-d4397f49cba8"><grammatical-info value="Noun"/><gloss lang="en"><text>a pharaoh (ancient Egyptian ruler)</text></gloss></sense></entry>
<entry id="firdaus" guid="8bfcc8f8-a1ca-5410-8aa2-336eacf11ea6"><lexical-unit><form lang="id"><text>firdaus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="firdaus_0" guid="26fb43dd-306a-53b0-bd44-d159662d3d1e"><grammatical-info value="Verb"/><gloss lang="en"><text>garden, Elysium, Eden, heaven, Heaven, paradise</text></gloss></sense></entry>
<entry id="firman" guid="7a79e91b-eb45-55bd-aee4-7302d54aeac0"><lexical-unit><form lang="id"><text>firman</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="firman_0" guid="c6cbc834-2693-5148-9b46-92b3bb38bc28"><grammatical-info value="Proper noun"/><gloss lang="en"><text>word of God</text></gloss></sense><sense id="firman_1" guid="a994a792-d263-598b-9817-ffd166d1857a"><grammatical-info value="Proper noun"/><gloss lang="en"><text>commandment (a divinely ordained command, especially one of the Ten Commandments)</text></gloss></sense></entry>
<entry id="fisik" guid="c0b0a96f-f5b9-57f0-bb17-07ff36edd613"><lexical-unit><form lang="id"><text>fisik</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="fisik_0" guid="8a879a31-b22c-5c38-a00e-8d3426fb37c8"><grammatical-info value="Noun"/><gloss lang="en"><text>physical</text></gloss></sense><sense id="fisik_1" guid="54d987e8-aeea-5081-817d-6807dad495d3"><grammatical-info value="Noun"/><gloss lang="en"><text>physique</text></gloss></sense></entry>
<entry id="fitnah" guid="3205428d-cb52-5643-8b65-d00000c3274e"><lexical-unit><form lang="id"><text>fitnah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="fitnah_0" guid="3eb68d59-4966-56a0-9ee5-ce2c85f2b9bd"><grammatical-info value="Noun"/><gloss lang="en"><text>fitna</text></gloss></sense><sense id="fitnah_1" guid="43bc94ff-7fa1-57a5-8738-7587db477b41"><grammatical-info value="Noun"/><gloss lang="en"><text>slander (false or unsupported spoken malicious statement)</text></gloss></sense><sense id="fitnah_2" guid="1046ba57-98f2-5818-a3ab-23a699420c74"><grammatical-info value="Noun"/><gloss lang="en"><text>to slander, defame</text></gloss></sense></entry>
<entry id="fokus" guid="da36128c-daf9-5206-8a1c-1308f845249c"><lexical-unit><form lang="id"><text>fokus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="fokus_0" guid="2d691821-3ec6-5043-b75f-6d892da1259e"><grammatical-info value="Noun"/><gloss lang="en"><text>focus</text></gloss></sense><sense id="fokus_1" guid="ce18c246-a999-5230-8b10-c600861136be"><grammatical-info value="Noun"/><gloss lang="en"><text>a point at which reflected or refracted rays of light converge.</text></gloss></sense><sense id="fokus_2" guid="b604f8e8-3fb4-56e1-aaad-50ba60f1e3a8"><grammatical-info value="Noun"/><gloss lang="en"><text>the most important word or phrase in a sentence or passage, or the one that imparts information.</text></gloss></sense><sense id="fokus_3" guid="94534a46-e47b-5a85-b129-78d2a011628d"><grammatical-info value="Noun"/><gloss lang="en"><text>to focus</text></gloss></sense></entry>
<entry id="fondasi" guid="bdc2e608-3a9b-5e3e-94ba-10fb65334487"><lexical-unit><form lang="id"><text>fondasi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="fondasi_0" guid="6b4d5489-9cd0-5634-9a30-ab30339b3d0e"><grammatical-info value="Noun"/><gloss lang="en"><text>foundation: the lowest and supporting part or member of a wall, including the base course and footing courses; in a frame house, the whole substructure of masonry</text></gloss></sense></entry>
<entry id="forum" guid="4102bcec-0082-5b72-a0e0-a46b8f3b1f15"><lexical-unit><form lang="id"><text>forum</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="forum_0" guid="cf8ccdf8-a793-5dda-aa39-1ed5875b319c"><grammatical-info value="Noun"/><gloss lang="en"><text>forum (a place for discussion)</text></gloss></sense><sense id="forum_1" guid="60ab2537-f655-52a3-af78-be092124596e"><grammatical-info value="Noun"/><gloss lang="en"><text>institution, body</text></gloss></sense><sense id="forum_2" guid="6d938623-8506-591b-bc89-2eb04ba6fd70"><grammatical-info value="Noun"/><gloss lang="en"><text>meeting, session, assembly</text></gloss></sense></entry>
<entry id="fungsi" guid="31097f4c-c493-518d-9d00-91cff2532145"><lexical-unit><form lang="id"><text>fungsi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="fungsi_0" guid="5b9a89d0-70cd-53cd-abdc-2b261a26dbec"><grammatical-info value="Noun"/><gloss lang="en"><text>function:</text></gloss></sense><sense id="fungsi_1" guid="9b24b091-3958-5d93-b08b-b2ad5060c321"><grammatical-info value="Noun"/><gloss lang="en"><text>what something does or is used for</text></gloss></sense><sense id="fungsi_2" guid="1cce5832-d5b5-5085-82cc-5b9fdafc84db"><grammatical-info value="Noun"/><gloss lang="en"><text>a professional or official position</text></gloss></sense><sense id="fungsi_3" guid="c354f9d0-38d4-51de-b732-e3e6a1a915c2"><grammatical-info value="Noun"/><gloss lang="en"><text>the physiological activity of an organ or body part</text></gloss></sense><sense id="fungsi_4" guid="c8a34719-3a2c-5f90-acca-849e7b8977a3"><grammatical-info value="Noun"/><gloss lang="en"><text>a relation in which each element of the domain is associated with exactly one element of the codomain</text></gloss></sense><sense id="fungsi_5" guid="17eb149d-3c98-5b68-acdb-6c62669d02fb"><grammatical-info value="Noun"/><gloss lang="en"><text>a way of achieving an aim using language</text></gloss></sense></entry>
<entry id="gabriel" guid="a72f44be-9114-5749-8ed7-5261b854de49"><lexical-unit><form lang="id"><text>gabriel</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gabriel_0" guid="f72b926b-fc16-560d-a431-73627c4d1896"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Gabriel (an archangel associated in Judaism, Christianity and Islam, with carrying messages from God)</text></gloss></sense><sense id="gabriel_1" guid="49057aab-807f-5f47-9ebf-11f61d690909"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a male given name from Latin [in turn from Ancient Greek, in turn from Hebrew].</text></gloss></sense></entry>
<entry id="gabung" guid="9e4fae71-2915-52c0-b9b9-2b2e68ea8bed"><lexical-unit><form lang="id"><text>gabung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gabung_0" guid="27c8af4d-d4e8-5e02-ba30-06cc04d3ea09"><grammatical-info value="Verb"/><gloss lang="en"><text>bundle, cluster, sheaf, string.</text></gloss></sense><sense id="gabung_1" guid="6a419e79-1d25-50a2-b2cc-3575317030e6"><grammatical-info value="Verb"/><gloss lang="en"><text>join</text></gloss></sense><sense id="gabung_2" guid="dcbf8c22-33f1-5c26-95e7-c5e674625db8"><grammatical-info value="Verb"/><gloss lang="en"><text>unit of measurement for several bundles of young coconut leaves, one bundle contains 10--25 strands</text></gloss></sense></entry>
<entry id="gading" guid="e5f21c41-f0c3-586a-ba22-22ca944b9319"><lexical-unit><form lang="id"><text>gading</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gading_0" guid="d392ec66-79e7-5f14-9656-cc27e30c5a83"><grammatical-info value="Noun"/><gloss lang="en"><text>ivory (material)</text></gloss></sense><sense id="gading_1" guid="b2a1e84a-9ebf-58ea-8595-0c1bf9934b6c"><grammatical-info value="Noun"/><gloss lang="en"><text>ivory (colour)</text></gloss></sense><sense id="gading_2" guid="d523d1b6-1b6f-5fc5-bf23-bac846b32ae1"><grammatical-info value="Noun"/><gloss lang="en"><text>ivory (made of ivory)</text></gloss></sense><sense id="gading_3" guid="8febcb70-9c54-5be8-9f5a-32fef82a0acf"><grammatical-info value="Noun"/><gloss lang="en"><text>ivory (having colour of ivory)m</text></gloss></sense><sense id="gading_4" guid="69f35638-04af-53f2-808f-8d262eed274c"><grammatical-info value="Noun"/><gloss lang="en"><text>two girls fanning the bride at the wedding dais</text></gloss></sense><sense id="gading_5" guid="73ff5084-af1e-573b-928c-ec53221671fa"><grammatical-info value="Noun"/><gloss lang="en"><text>the groom's companions when being paraded to the bride's house, usually two men who are relatives or friends of the groom</text></gloss></sense><sense id="gading_6" guid="e6c0c368-d536-54f1-8c51-3691af0a4575"><grammatical-info value="Noun"/><gloss lang="en"><text>candlenut seeds that have been planted or buried for a long time and the shell has turned white</text></gloss></sense><sense id="gading_7" guid="ce0f1c53-3b04-5f66-936d-82d58364e446"><grammatical-info value="Noun"/><gloss lang="en"><text>the inside of the boat in the form of partitions to attach planks to make the boat strong</text></gloss></sense></entry>
<entry id="gadis" guid="462b5059-5a9c-5cdc-932a-48f1a4f5b59e"><lexical-unit><form lang="id"><text>gadis</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="gadis_0" guid="e116f3db-0d71-5ae8-b819-489d98fab21a"><grammatical-info value="Noun"/><gloss lang="en"><text>girl</text></gloss></sense><sense id="gadis_1" guid="775e9dee-dbf2-58b1-9587-e4d7b4b4fb5e"><grammatical-info value="Noun"/><gloss lang="en"><text>maid, maiden</text></gloss></sense><sense id="gadis_2" guid="5ec62fd0-454d-5c63-a351-4b26aeca41a1"><grammatical-info value="Noun"/><gloss lang="en"><text>virgin</text></gloss></sense><sense id="gadis_3" guid="c67db34c-a295-5b46-ad1c-dcd2b468b4a5"><grammatical-info value="Noun"/><gloss lang="en"><text>an animal which has never laid eggs or reproduced young</text></gloss></sense></entry>
