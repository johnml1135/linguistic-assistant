<entry id="kelahi" guid="213eff98-1b0f-54be-a1c2-10ae641a44fb"><lexical-unit><form lang="id"><text>kelahi</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kelahi_0" guid="f0807b6a-fe64-5f74-9015-a9e6530dc287"><grammatical-info value="Verb"/><gloss lang="en"><text>fight,</text></gloss></sense><sense id="kelahi_1" guid="5d73010e-598c-53ac-b613-f9b2fe128067"><grammatical-info value="Verb"/><gloss lang="en"><text>a physical confrontation or combat between two or more people or groups</text></gloss></sense><sense id="kelahi_2" guid="b19d42ff-b619-5de5-85b1-05f75bffa7e2"><grammatical-info value="Verb"/><gloss lang="en"><text>a conflict, possibly nonphysical, with opposing ideas or forces; strife</text></gloss></sense></entry>
<entry id="kelahiran" guid="ed00cbf0-8d08-5c0f-8762-11fc408a461c"><lexical-unit><form lang="id"><text>kelahiran</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kelahiran_0" guid="4f21ae09-f21f-5491-9cf6-359d7b541946"><grammatical-info value="Noun"/><gloss lang="en"><text>birth:</text></gloss></sense><sense id="kelahiran_1" guid="17e27c59-8459-5193-809c-8baef0256f6a"><grammatical-info value="Noun"/><gloss lang="en"><text>the process of childbearing; the beginning of life</text></gloss></sense><sense id="kelahiran_2" guid="edee826d-cfc9-563c-ba6c-3cd7047eeb54"><grammatical-info value="Noun"/><gloss lang="en"><text>the beginning or start; a point of origin</text></gloss></sense><sense id="kelahiran_3" guid="98110777-b41c-5360-af8e-684bbf49f068"><grammatical-info value="Noun"/><gloss lang="en"><text>childbirth, parturition: The fact or action of giving birth to a child, as the culmination of pregnancy</text></gloss></sense></entry>
<entry id="kelebihan" guid="98725437-bbf6-5de3-a3ee-0aa2d12faabf"><lexical-unit><form lang="id"><text>kelebihan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kelebihan_0" guid="1b431b5d-fb53-5957-83da-f1c31399b6c1"><grammatical-info value="Noun"/><gloss lang="en"><text>excess</text></gloss></sense><sense id="kelebihan_1" guid="520659d8-ac7b-52d8-b78c-e0bee9b6eb4c"><grammatical-info value="Noun"/><gloss lang="en"><text>surplus</text></gloss></sense><sense id="kelebihan_2" guid="19b85284-9ae1-5f64-bf38-decc38ce852e"><grammatical-info value="Noun"/><gloss lang="en"><text>lead, superiority</text></gloss></sense></entry>
<entry id="keledai" guid="b1eaab70-b1e5-5d93-bcb2-55c92a42f1a1"><lexical-unit><form lang="id"><text>keledai</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="keledai_0" guid="9ed3d0bb-affa-5d20-abf7-e185e0432953"><grammatical-info value="Noun"/><gloss lang="en"><text>donkey:</text></gloss></sense><sense id="keledai_1" guid="50cbf453-e572-57c7-918d-3f0ff946d345"><grammatical-info value="Noun"/><gloss lang="en"><text>a domestic animal, Equus asinus asinus, similar to a horse.</text></gloss></sense><sense id="keledai_2" guid="3b3824d4-a0c5-59d4-a87f-976e649bc237"><grammatical-info value="Noun"/><gloss lang="en"><text>a fool.</text></gloss></sense></entry>
