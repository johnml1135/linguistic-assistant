<entry id="murni" guid="c08bc340-d58d-56fd-87b8-7bc850445ba4"><lexical-unit><form lang="id"><text>murni</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="murni_0" guid="50b3a8b8-06b1-53da-94d8-cfa18e6e8c5b"><grammatical-info value="Proper noun"/><gloss lang="en"><text>pure:</text></gloss></sense><sense id="murni_1" guid="cd5347cb-abbc-5d11-86c4-55308fbc1d22"><grammatical-info value="Proper noun"/><gloss lang="en"><text>free of foreign material or pollutants</text></gloss></sense><sense id="murni_2" guid="b1fe2390-c436-5f47-88be-e18c4ffe757e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>free of immoral behavior or qualities; clean</text></gloss></sense><sense id="murni_3" guid="f5afebea-8fbc-5a7c-8200-fc02d6d02631"><grammatical-info value="Proper noun"/><gloss lang="en"><text>original</text></gloss></sense><sense id="murni_4" guid="9e2c2592-683a-5ff8-ad18-9f5b506efae3"><grammatical-info value="Proper noun"/><gloss lang="en"><text>virgin: in a state of virginity; chaste, not having had sexual intercourse</text></gloss></sense></entry>
