<entry id="roma" guid="3ac4c0e9-5207-5ec7-8cfb-f1bb53ea49a1"><lexical-unit><form lang="id"><text>roma</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="roma_0" guid="395ea582-a4e9-59a9-8c19-14dcbbecc6cb"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Rome:</text></gloss></sense><sense id="roma_1" guid="933392e0-6c28-5174-b129-2b82e0fe0d54"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Rome (a major city, the capital of Italy and the Italian region of Lazio, located on the Tiber River; the ancient capital of the Roman Empire)</text></gloss></sense><sense id="roma_2" guid="4d60d358-a912-58b0-a583-6a47a053ee65"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Rome (a metropolitan city of Lazio, Italy)</text></gloss></sense><sense id="roma_3" guid="e95fa31e-5632-595b-8e14-33c7bf35e446"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Rome, Ancient Rome (an ancient empire based out of the city of Rome, covering vast territories in Europe, Asia and Africa; in full, Roman Empire)</text></gloss></sense><sense id="roma_4" guid="3a9af2e0-8a12-5299-975d-da19c75cbf9d"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the Italian government</text></gloss></sense><sense id="roma_5" guid="4e4c41f8-77ed-5a63-935c-943f5ca1cd95"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the Holy See, the leadership of the Roman Catholic Church, particularly prior to the establishment of the Vatican City in the 19th century</text></gloss></sense><sense id="roma_6" guid="8511f13f-66ba-5c99-9393-8af41c661b90"><grammatical-info value="Proper noun"/><gloss lang="en"><text>the Church of Rome, the Roman Catholic Church generally</text></gloss></sense><sense id="roma_7" guid="a93b28e7-625a-5bf1-8c84-0b9bb17d02e4"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Epistle to the Romans</text></gloss></sense></entry>
