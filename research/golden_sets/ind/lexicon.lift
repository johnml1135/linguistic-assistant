<entry id="lama" guid="32b7f4b8-7f66-51a2-bb17-081ec84d2a5b"><lexical-unit><form lang="id"><text>lama</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lama_0" guid="255bd448-1960-565d-b95c-a80a433745e8"><grammatical-info value="Adjective"/><gloss lang="en"><text>long: having great duration; seemingly lasting a lot of time, because it is boring or tedious or tiring</text></gloss></sense><sense id="lama_1" guid="d87ba55a-6479-5b82-a160-9f9be6df357a"><grammatical-info value="Adjective"/><gloss lang="en"><text>duration</text></gloss></sense><sense id="lama_2" guid="b52696ba-b6ad-59a9-927d-b262c8c0a13e"><grammatical-info value="Adjective"/><gloss lang="en"><text>ancient</text></gloss></sense><sense id="lama_3" guid="4089f302-7e28-5930-adcb-eb1deaef6dbe"><grammatical-info value="Adjective"/><gloss lang="en"><text>old</text></gloss></sense></entry>
<entry id="lambai" guid="f04c8760-b9ee-5312-803d-7d2321ca85d7"><lexical-unit><form lang="id"><text>lambai</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="lambai_0" guid="d7798b11-513e-5cae-a501-3058aaecd19b"><grammatical-info value="Noun"/><gloss lang="en"><text>wave (To move back and forth repeatedly and somewhat loosely.)</text></gloss></sense><sense id="lambai_1" guid="ad4d04dc-4435-54d9-976f-d2d6bdcb22ff"><grammatical-info value="Noun"/><gloss lang="en"><text>wave (To move one's hand back and forth (generally above the shoulders) in greeting or departure.)</text></gloss></sense></entry>
