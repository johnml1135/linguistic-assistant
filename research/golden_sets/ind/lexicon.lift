<entry id="bungkus" guid="eefd791c-35a8-5b43-9565-0f1d521e571e"><lexical-unit><form lang="id"><text>bungkus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bungkus_0" guid="e4635026-ceb6-511c-989a-806baad7aa1d"><grammatical-info value="Noun"/><gloss lang="en"><text>wrap, wrapper: paper or sheeting that is wrapped around something to protect, contain, or conceal it</text></gloss></sense><sense id="bungkus_1" guid="c6421951-9bba-5f2d-a186-f2212aee77e0"><grammatical-info value="Noun"/><gloss lang="en"><text>counter for wrapped objects, pack, package, parcel</text></gloss></sense><sense id="bungkus_2" guid="a9a794e1-e315-5b7a-a2a9-368695204fbf"><grammatical-info value="Noun"/><gloss lang="en"><text>to wrap</text></gloss></sense><sense id="bungkus_3" guid="894f6a51-a25d-50a7-8652-20600e88b7f1"><grammatical-info value="Noun"/><gloss lang="en"><text>to pack (food) so it can be consumed elsewhere</text></gloss></sense><sense id="bungkus_4" guid="bc34a87a-401e-54a0-8d8b-4d61a1308e8a"><grammatical-info value="Noun"/><gloss lang="en"><text>to cancel (of a television programme)</text></gloss></sense></entry>
