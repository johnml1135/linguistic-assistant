<entry id="mutlak" guid="cd6ed139-4509-54c2-8c7d-bf939bc89a31"><lexical-unit><form lang="id"><text>mutlak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="mutlak_0" guid="ade80ae9-dd15-5d36-8272-373589df2918"><grammatical-info value="Adjective"/><gloss lang="en"><text>complete</text></gloss></sense></entry>
