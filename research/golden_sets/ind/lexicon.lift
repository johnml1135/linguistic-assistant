<entry id="berseru" guid="9b719155-3ced-5a80-91df-2cb9747c14c7"><lexical-unit><form lang="id"><text>berseru</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berseru_0" guid="112afa88-fbcc-52b8-b859-76a227769632"><grammatical-info value="Verb"/><gloss lang="en"><text>to shout, to exclaim</text></gloss></sense></entry>
<entry id="bersih" guid="f3531698-f846-59eb-8aaf-fbb2448c1a3d"><lexical-unit><form lang="id"><text>bersih</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bersih_0" guid="43ff5e26-a83f-5f89-bb69-518d786c6cc4"><grammatical-info value="Adjective"/><gloss lang="en"><text>clean</text></gloss></sense><sense id="bersih_1" guid="aae49ddf-de56-5353-88c3-a8cc41892a9c"><grammatical-info value="Adjective"/><gloss lang="en"><text>Free of dirt or impurities or protruberances.</text></gloss></sense><sense id="bersih_2" guid="969efda2-6bdc-5eb8-8485-d9ea971d6764"><grammatical-info value="Adjective"/><gloss lang="en"><text>not dirty</text></gloss></sense><sense id="bersih_3" guid="dd8de544-90e3-55da-8a86-093c56aa3c9e"><grammatical-info value="Adjective"/><gloss lang="en"><text>in an unmarked condition</text></gloss></sense><sense id="bersih_4" guid="12299fa8-1ea9-5a38-9ed8-9a9ca48e9209"><grammatical-info value="Adjective"/><gloss lang="en"><text>empty</text></gloss></sense><sense id="bersih_5" guid="59e0aa7c-ed48-582d-9993-65db98d86173"><grammatical-info value="Adjective"/><gloss lang="en"><text>Free of immorality or criminality.</text></gloss></sense><sense id="bersih_6" guid="9ef7e0e4-b13b-52d8-aea6-4db17ed016c6"><grammatical-info value="Adjective"/><gloss lang="en"><text>pure, especially morally or religiously</text></gloss></sense><sense id="bersih_7" guid="562ae064-90b3-5483-81c2-ec5e4021fa65"><grammatical-info value="Adjective"/><gloss lang="en"><text>without restrictions or penalties, or someone having such a record</text></gloss></sense></entry>
<entry id="bersihan" guid="ca399b89-f2ce-54be-be57-5a863cebbd12"><lexical-unit><form lang="id"><text>bersihan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bersihan_0" guid="b0e210b8-b971-5e9d-b91f-1ed30fdfe04a"><grammatical-info value="Noun"/><gloss lang="en"><text>clearance: the removal of harmful substances from the blood</text></gloss></sense></entry>
<entry id="bersikeras" guid="f48338a5-1003-5d03-91b3-8f4219851480"><lexical-unit><form lang="id"><text>bersikeras</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bersikeras_0" guid="2884d8d0-6d92-5964-b35f-96a6e3bebfc7"><grammatical-info value="Verb"/><gloss lang="en"><text>conscience</text></gloss></sense></entry>
<entry id="bersorak" guid="616063ee-8efb-54f7-a2dc-a47ca2ca96cb"><lexical-unit><form lang="id"><text>bersorak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bersorak_0" guid="2a64d5d4-12f9-5b9b-b62c-518efb7955eb"><grammatical-info value="Verb"/><gloss lang="en"><text>cheer</text></gloss></sense></entry>
<entry id="bersyukur" guid="b1bc70c2-88a0-5513-8327-0bfbafbc9dd6"><lexical-unit><form lang="id"><text>bersyukur</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bersyukur_0" guid="50edf72f-1a4f-5858-925e-26d7b0567513"><grammatical-info value="Verb"/><gloss lang="en"><text>grateful</text></gloss></sense></entry>
<entry id="bertanya" guid="24654f53-1df0-5605-be30-51c0262070b3"><lexical-unit><form lang="id"><text>bertanya</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bertanya_0" guid="f3b965e5-003a-5518-aaa3-e5cdb2350a26"><grammatical-info value="Verb"/><gloss lang="en"><text>to ask</text></gloss></sense></entry>
<entry id="berteriak" guid="fb9d9a14-c55a-5870-a1af-f92cf7bb8267"><lexical-unit><form lang="id"><text>berteriak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berteriak_0" guid="3bedbadc-091f-5e8c-a506-131012ee48b4"><grammatical-info value="Verb"/><gloss lang="en"><text>to scream (to cry out with a shrill voice; to utter a sudden, shout outcry, or shrill, loud cry, as in fright or extreme pain)</text></gloss></sense><sense id="berteriak_1" guid="c38295df-9aad-56b5-9f25-3a7d138a33cf"><grammatical-info value="Verb"/><gloss lang="en"><text>to shout (to utter a sudden and loud cry, as in joy, triumph, exultation or anger, or to attract attention, to animate others, etc)</text></gloss></sense></entry>
<entry id="bertindak" guid="e5de2279-4ef9-5152-a734-f925c028d475"><lexical-unit><form lang="id"><text>bertindak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bertindak_0" guid="ae2a6a68-801a-5f3b-b8c5-c98e3564d4ba"><grammatical-info value="Verb"/><gloss lang="en"><text>active of tindak</text></gloss></sense></entry>
<entry id="beruntung" guid="12c904e9-8b29-5785-901d-b47a9116e9b5"><lexical-unit><form lang="id"><text>beruntung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="beruntung_0" guid="5a72a222-943b-551c-b7d5-156912ca6231"><grammatical-info value="Adjective"/><gloss lang="en"><text>having profit; profited</text></gloss></sense><sense id="beruntung_1" guid="56d002cf-cd61-5d31-a1a0-79316cb90a56"><grammatical-info value="Adjective"/><gloss lang="en"><text>lucky</text></gloss></sense></entry>
<entry id="berusaha" guid="6c83cd23-16ad-5c3d-b461-9f5d9a73f6fe"><lexical-unit><form lang="id"><text>berusaha</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berusaha_0" guid="dd710126-476b-5267-a104-5ed43ebd8b90"><grammatical-info value="Verb"/><gloss lang="en"><text>to try</text></gloss></sense></entry>
