<entry id="pupuk" guid="1ce631c4-b144-5bcb-9df1-efb572d564a3"><lexical-unit><form lang="id"><text>pupuk</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pupuk_0" guid="7fe20a17-aa2a-506e-860c-e2303fcc8a4f"><grammatical-info value="Noun"/><gloss lang="en"><text>fertilizer, fertiliser:</text></gloss></sense><sense id="pupuk_1" guid="326ae152-49bd-538a-b298-cad6ab6b86f3"><grammatical-info value="Noun"/><gloss lang="en"><text>a natural substance that is used to make the ground more suitable for growing plants</text></gloss></sense><sense id="pupuk_2" guid="05b65f03-135e-570c-b673-75404dc69a00"><grammatical-info value="Noun"/><gloss lang="en"><text>a chemical compound created to have the same effect</text></gloss></sense><sense id="pupuk_3" guid="8f637323-79d4-5188-836e-1f328d4c0fc9"><grammatical-info value="Noun"/><gloss lang="en"><text>medicine from plants (leaves and so on) that are ground into a paste, attached to the upper forehead, close to the crown</text></gloss></sense></entry>
