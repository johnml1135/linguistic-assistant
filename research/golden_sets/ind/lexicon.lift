<entry id="bidang" guid="5c775a19-ca4f-50ef-bd2b-9bdd7a31e32c"><lexical-unit><form lang="id"><text>bidang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bidang_0" guid="d67b57b9-3316-5302-b1d9-367d9b829485"><grammatical-info value="Noun"/><gloss lang="en"><text>field, as in a field of work, an academic field</text></gloss></sense><sense id="bidang_1" guid="fb582d07-2032-560d-8178-7007d4acaff9"><grammatical-info value="Noun"/><gloss lang="en"><text>plane (a level or flat surface)</text></gloss></sense><sense id="bidang_2" guid="478bea19-01ce-5562-9078-2b97c2cd62ed"><grammatical-info value="Noun"/><gloss lang="en"><text>plane (a flat surface extending infinitely in all directions)</text></gloss></sense><sense id="bidang_3" guid="d7874292-0672-5f91-8022-b90d0ce32179"><grammatical-info value="Noun"/><gloss lang="en"><text>plane (an imaginary plane which divides the body into two portions)</text></gloss></sense><sense id="bidang_4" guid="67ed3ec6-e2fd-5673-a5cc-6ef25c35f99a"><grammatical-info value="Noun"/><gloss lang="en"><text>broad, wide</text></gloss></sense><sense id="bidang_5" guid="1c8e7070-c189-58d4-b56e-bc1d929a8b8a"><grammatical-info value="Noun"/><gloss lang="en"><text>Classifier for broad objects like field or paddy field.</text></gloss></sense></entry>
