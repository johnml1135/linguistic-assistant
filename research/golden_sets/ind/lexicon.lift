<entry id="kumandang" guid="704c36f7-edb6-5de7-9e05-27ab9ada753f"><lexical-unit><form lang="id"><text>kumandang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kumandang_0" guid="e5e092de-0563-5b88-a4c5-5189abedcc8b"><grammatical-info value="Verb"/><gloss lang="en"><text>echo (a reflected sound that is heard again by its initial observer)</text></gloss></sense><sense id="kumandang_1" guid="ee512216-b83b-5a1c-a27b-c94eeb619920"><grammatical-info value="Verb"/><gloss lang="en"><text>echo (an utterance repeating what has just been said)</text></gloss></sense></entry>
