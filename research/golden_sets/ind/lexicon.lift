<entry id="usul" guid="7f36a109-6458-59ad-912a-fa73764b5918"><lexical-unit><form lang="id"><text>usul</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="usul_0" guid="89f7e3ce-2b83-5059-8b6d-bce7bc8ea77a"><grammatical-info value="Noun"/><gloss lang="en"><text>origin, source, beginning</text></gloss></sense><sense id="usul_1" guid="98800b15-ab46-5ee4-95dc-e62c2e09203b"><grammatical-info value="Noun"/><gloss lang="en"><text>original</text></gloss></sense><sense id="usul_2" guid="b4ac56e5-6682-58ac-b08a-56d75c769bf3"><grammatical-info value="Noun"/><gloss lang="en"><text>character, nature</text></gloss></sense><sense id="usul_3" guid="e3dc99c2-c79d-556a-99ab-d88776cb774d"><grammatical-info value="Noun"/><gloss lang="en"><text>proposal, suggestion</text></gloss></sense><sense id="usul_4" guid="184790bd-d843-522c-9618-367fae308727"><grammatical-info value="Noun"/><gloss lang="en"><text>to investigate, to examine, to check</text></gloss></sense></entry>
<entry id="usung" guid="3ca7689f-a87f-5cbe-9d54-e4f28d3f2b7b"><lexical-unit><form lang="id"><text>usung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="usung_0" guid="c596e5eb-fc8a-5ea6-af07-75b0c531afd0"><grammatical-info value="Verb"/><gloss lang="en"><text>to carry (to lift something and take it to another place or to transport something by lifting)</text></gloss></sense><sense id="usung_1" guid="06761a00-3bfe-5784-9daa-92cda761c1d4"><grammatical-info value="Verb"/><gloss lang="en"><text>to support a candidate or candidate pair in a political contestation (by political parties or important figures)</text></gloss></sense><sense id="usung_2" guid="6897fe0c-0525-5525-9eae-daa21c3433cc"><grammatical-info value="Verb"/><gloss lang="en"><text>to have, to use or to address a theme or a title in a activity (debate, carnaval, etc)</text></gloss></sense><sense id="usung_3" guid="162bb414-30dd-5b7e-b495-03ef611b4c82"><grammatical-info value="Verb"/><gloss lang="en"><text>to show artworks (in a art show, etc)</text></gloss></sense><sense id="usung_4" guid="2a28f6c2-00b5-5c1c-8219-15304c17941c"><grammatical-info value="Verb"/><gloss lang="en"><text>to sport (to display; to have as a notable feature)</text></gloss></sense></entry>
<entry id="utama" guid="99c8f19e-4dff-5b07-8804-aa3651ff2061"><lexical-unit><form lang="id"><text>utama</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="utama_0" guid="a55f5468-5593-56b3-a489-e50c6f349082"><grammatical-info value="Adjective"/><gloss lang="en"><text>best</text></gloss></sense><sense id="utama_1" guid="e4e29df4-f650-5b9b-a15e-aaa0062e0ae5"><grammatical-info value="Adjective"/><gloss lang="en"><text>main, principal</text></gloss></sense><sense id="utama_2" guid="af595caf-b69a-5a4f-b19f-e862acf74ca4"><grammatical-info value="Adjective"/><gloss lang="en"><text>chief</text></gloss></sense></entry>
