<entry id="satu" guid="575f6830-4a54-535a-a8f4-35bdbe3f76c3"><lexical-unit><form lang="id"><text>satu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="satu_0" guid="e7623441-922a-5397-919e-9b9521f29146"><grammatical-info value="Numeral"/><gloss lang="en"><text>one</text></gloss></sense></entry>
<entry id="satukan" guid="a4c9413b-b061-58b8-9234-ff87b5c80149"><lexical-unit><form lang="id"><text>satukan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="satukan_0" guid="4e158606-a0aa-5e7d-9705-1a84c32e7a6e"><grammatical-info value="Verb"/><gloss lang="en"><text>to unite; to unify (to bring together as one)</text></gloss></sense><sense id="satukan_1" guid="d8308e07-1c12-5f43-b0f0-ce28e1c243c1"><grammatical-info value="Verb"/><gloss lang="en"><text>to join; to joint (to connect or combine into one; to put together)</text></gloss></sense><sense id="satukan_2" guid="e8100220-2ac0-5dd3-8a7c-b7265f2935d9"><grammatical-info value="Verb"/><gloss lang="en"><text>to hold together (to cause to stay together)</text></gloss></sense></entry>
<entry id="saudara" guid="19e30cd8-027a-5a2f-b947-a71c95dbe62c"><lexical-unit><form lang="id"><text>saudara</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="saudara_0" guid="2c783aba-671f-5033-b715-e8ada83e1f75"><grammatical-info value="Noun"/><gloss lang="en"><text>relative, someone in the same family; someone connected by blood, marriage, or adoption</text></gloss></sense><sense id="saudara_1" guid="9d5191d3-a155-5ea0-8087-a90c19bb8f80"><grammatical-info value="Noun"/><gloss lang="en"><text>companion, friend, comrade</text></gloss></sense><sense id="saudara_2" guid="f9b5ffb7-996b-5cb0-aff5-abd4d72c9ee9"><grammatical-info value="Noun"/><gloss lang="en"><text>correlative</text></gloss></sense><sense id="saudara_3" guid="64470071-2750-5b30-853f-6119b6fa63f0"><grammatical-info value="Noun"/><gloss lang="en"><text>placenta</text></gloss></sense></entry>
