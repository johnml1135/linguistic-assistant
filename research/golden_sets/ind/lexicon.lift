<entry id="berhenti" guid="5b845e91-bbb9-51a7-9a59-ea5bd8e291f9"><lexical-unit><form lang="id"><text>berhenti</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berhenti_0" guid="a06182b7-3848-545c-9a3a-59b22a1f3015"><grammatical-info value="Verb"/><gloss lang="en"><text>to stop, to halt</text></gloss></sense><sense id="berhenti_1" guid="d8cc5e55-f1b4-55f8-8464-c4c5d78ab36f"><grammatical-info value="Verb"/><gloss lang="en"><text>to cease moving</text></gloss></sense><sense id="berhenti_2" guid="457fef5a-a2ec-528b-83b5-c70c2c9606e0"><grammatical-info value="Verb"/><gloss lang="en"><text>to not continue</text></gloss></sense><sense id="berhenti_3" guid="6c33c301-469d-5e91-9267-8a2c3a3ae17c"><grammatical-info value="Verb"/><gloss lang="en"><text>to cease; to no longer continue (doing something)</text></gloss></sense><sense id="berhenti_4" guid="dc08767a-9f6e-54eb-9e72-b8df8b2549e2"><grammatical-info value="Verb"/><gloss lang="en"><text>to (take a) rest, to pause</text></gloss></sense><sense id="berhenti_5" guid="fd2e5328-fe73-5e83-8cab-a8a029463a59"><grammatical-info value="Verb"/><gloss lang="en"><text>to quit, to give up, to desist, to resign</text></gloss></sense></entry>
<entry id="beri" guid="bc72d8fb-fe0a-5f86-a96e-6402a47fc0cc"><lexical-unit><form lang="id"><text>beri</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="beri_0" guid="2964ca03-b1f9-5acb-a3da-9f9ff97da545"><grammatical-info value="Verb"/><gloss lang="en"><text>to give</text></gloss></sense><sense id="beri_1" guid="57bbc572-59cd-5487-9880-e5dc4105f1f1"><grammatical-info value="Verb"/><gloss lang="en"><text>berry (a small succulent fruit, of any one of many varieties)</text></gloss></sense><sense id="beri_2" guid="b4e2ce2d-9541-51e4-9d61-06bed9dd1744"><grammatical-info value="Verb"/><gloss lang="en"><text>berry (a soft fruit which develops from a single ovary and contains seeds not encased in pits)</text></gloss></sense></entry>
<entry id="berian" guid="d731bc5b-b48f-5e04-a479-9d6f5147049f"><lexical-unit><form lang="id"><text>berian</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berian_0" guid="010eeca2-80b6-5464-a0a1-32647cf8c929"><grammatical-info value="Noun"/><gloss lang="en"><text>giving, conferring, imparting (the act of bestowing as a gift)</text></gloss></sense><sense id="berian_1" guid="d432f61c-4c89-5a1a-8e71-915d3d1a2694"><grammatical-info value="Noun"/><gloss lang="en"><text>giving, gift, benefaction</text></gloss></sense><sense id="berian_2" guid="afc26fc4-744e-5856-8e97-352ff0f662d8"><grammatical-info value="Noun"/><gloss lang="en"><text>dowry (property or payment given at time of marriage)</text></gloss></sense></entry>
<entry id="berikan" guid="cbb9a4e3-cc11-5ef4-a9f3-a56f9fc244e1"><lexical-unit><form lang="id"><text>berikan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berikan_0" guid="260d01b1-90fb-5978-910f-8dcc63b4e656"><grammatical-info value="Verb"/><gloss lang="en"><text>have a fish</text></gloss></sense><sense id="berikan_1" guid="6f4e9fa0-385f-5ecb-af9b-c9355b7ca021"><grammatical-info value="Verb"/><gloss lang="en"><text>full of fish</text></gloss></sense><sense id="berikan_2" guid="d93839e1-681a-5a24-8f3e-9b188aa69ed4"><grammatical-info value="Verb"/><gloss lang="en"><text>to fish (to hunt fish)</text></gloss></sense><sense id="berikan_3" guid="3c8318c6-1a22-53e3-81a1-40950f18672b"><grammatical-info value="Verb"/><gloss lang="en"><text>synonym of beri (“to give”)</text></gloss></sense></entry>
<entry id="berikut" guid="52330762-e9cb-5fba-af5d-036229f7bd18"><lexical-unit><form lang="id"><text>berikut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berikut_0" guid="6227cb89-d979-55c9-b91c-f30ba2e0e043"><grammatical-info value="Verb"/><gloss lang="en"><text>to follow</text></gloss></sense><sense id="berikut_1" guid="803efd36-a6c5-51f7-a33d-0b7c96c2329a"><grammatical-info value="Verb"/><gloss lang="en"><text>something subsequent, next, ensuing</text></gloss></sense></entry>
<entry id="berita" guid="44d1a137-c0bf-54ad-b134-d69293983e71"><lexical-unit><form lang="id"><text>berita</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berita_0" guid="daf30f77-4c8b-56f7-a192-a1757a88c083"><grammatical-info value="Noun"/><gloss lang="en"><text>news</text></gloss></sense><sense id="berita_1" guid="ca24a60d-3187-52d5-9991-6069301eb56b"><grammatical-info value="Noun"/><gloss lang="en"><text>report</text></gloss></sense><sense id="berita_2" guid="2ee3fc2b-4782-5dfb-8edb-f923cb009100"><grammatical-info value="Noun"/><gloss lang="en"><text>announcement</text></gloss></sense></entry>
<entry id="beritahu" guid="07bbba37-c6ff-566e-9d48-738db99237be"><lexical-unit><form lang="id"><text>beritahu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="beritahu_0" guid="43dff55f-66e5-5716-a790-daa3254b43e7"><grammatical-info value="Verb"/><gloss lang="en"><text>alternative form of beri tahu (“to tell”)</text></gloss></sense></entry>
<entry id="beritahukan" guid="a6b3b482-6052-5672-9057-178d452506ef"><lexical-unit><form lang="id"><text>beritahukan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="beritahukan_0" guid="a66f5666-bd73-5098-afb9-7a120a59c1bd"><grammatical-info value="Verb"/><gloss lang="en"><text>to tell, inform, notify</text></gloss></sense></entry>
<entry id="berjalan" guid="41517432-86fc-58f9-b39f-b9ef4842a95f"><lexical-unit><form lang="id"><text>berjalan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berjalan_0" guid="aa7b7734-fb94-53bb-9583-514cd7de4a77"><grammatical-info value="Verb"/><gloss lang="en"><text>to walk</text></gloss></sense><sense id="berjalan_1" guid="b71077a2-58d6-594c-abff-860128746f54"><grammatical-info value="Verb"/><gloss lang="en"><text>to move on the feet by alternately setting each foot (or pair or group of feet, in the case of animals with four or more feet) forward, with at least one foot on the ground at all times</text></gloss></sense><sense id="berjalan_2" guid="c9a60fbe-d7c7-5b26-b65c-9be96a7e65d9"><grammatical-info value="Verb"/><gloss lang="en"><text>to travel (a distance) by walking</text></gloss></sense><sense id="berjalan_3" guid="202d05e6-e9dc-50fb-9938-08d850877ef8"><grammatical-info value="Verb"/><gloss lang="en"><text>to take place (to happen or to occur)</text></gloss></sense><sense id="berjalan_4" guid="2f8ed18b-40a8-5605-9f48-4f88128e3322"><grammatical-info value="Verb"/><gloss lang="en"><text>in effect (operate or functioning; in force; in play)</text></gloss></sense><sense id="berjalan_5" guid="bb30f3ef-9ac2-59f0-8683-bb37d0ef4236"><grammatical-info value="Verb"/><gloss lang="en"><text>running (of a company, organization, association, etc.)</text></gloss></sense></entry>
<entry id="berjanji" guid="3a386341-84e4-5d78-bb33-8b0a8044ccf3"><lexical-unit><form lang="id"><text>berjanji</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berjanji_0" guid="56057419-e109-5bf8-9f4e-8d858cb4a3ec"><grammatical-info value="Verb"/><gloss lang="en"><text>to promise</text></gloss></sense></entry>
<entry id="berkabung" guid="510aaaad-a2d6-5824-a60e-d7ffadfa11ef"><lexical-unit><form lang="id"><text>berkabung</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berkabung_0" guid="fd2c556a-8c47-5dbe-b65f-6b437f1d62ed"><grammatical-info value="Verb"/><gloss lang="en"><text>to wear a white headscarf to show mourning</text></gloss></sense><sense id="berkabung_1" guid="2abee44f-1dc3-5276-81d9-e63b71db0f3d"><grammatical-info value="Verb"/><gloss lang="en"><text>to mourn</text></gloss></sense></entry>
<entry id="berkat" guid="9f7cea60-948d-53a6-87ec-53bb4d908753"><lexical-unit><form lang="id"><text>berkat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berkat_0" guid="2fc1c46b-9e25-5548-94d0-1655be3ae5b8"><grammatical-info value="Adposition"/><gloss lang="en"><text>blessing (divine or supernatural aid or reward)</text></gloss></sense><sense id="berkat_1" guid="b68173bc-33ff-54d8-a7f2-827b6406c1a3"><grammatical-info value="Adposition"/><gloss lang="en"><text>blessing (pronouncement invoking divine aid)</text></gloss></sense><sense id="berkat_2" guid="231a1b5d-e663-5ae9-9f09-1667683756b5"><grammatical-info value="Adposition"/><gloss lang="en"><text>food (usually rice and side dishes) or something to take home after the feast in Javanese tradition</text></gloss></sense><sense id="berkat_3" guid="519d2f6a-3c24-5fc2-94f8-6ea7aee40967"><grammatical-info value="Adposition"/><gloss lang="en"><text>thanks to (because of)</text></gloss></sense><sense id="berkat_4" guid="18fb45ea-829e-5dd8-8157-65e6d352dc50"><grammatical-info value="Adposition"/><gloss lang="en"><text>synonym of berkah</text></gloss></sense></entry>
<entry id="berkata" guid="a4a8913e-7706-5558-8110-4c5c5b7fd08f"><lexical-unit><form lang="id"><text>berkata</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berkata_0" guid="f1e1aff7-c796-54df-8997-081aa0a54acc"><grammatical-info value="Verb"/><gloss lang="en"><text>to be in a state of saying</text></gloss></sense></entry>
<entry id="berkumpul" guid="47d4de38-4255-5356-a038-65007ea02ee2"><lexical-unit><form lang="id"><text>berkumpul</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berkumpul_0" guid="bdb2c2c1-bece-5a19-b221-fae2646aed16"><grammatical-info value="Verb"/><gloss lang="en"><text>to assemble, to gather, to get together</text></gloss></sense></entry>
