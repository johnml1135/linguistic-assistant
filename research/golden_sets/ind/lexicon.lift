<entry id="bahu" guid="54e530c5-883d-5955-b4e2-de5e74daecdb"><lexical-unit><form lang="id"><text>bahu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bahu_0" guid="73dc7d65-5346-52eb-b600-82587bfd2e7d"><grammatical-info value="Noun"/><gloss lang="en"><text>shoulder</text></gloss></sense><sense id="bahu_1" guid="0cb9ab3d-73bb-592d-8b9a-eec142e4d67d"><grammatical-info value="Noun"/><gloss lang="en"><text>edge of musical percussion instrument that takes the form of a flat, circular metal disc which is hit with a mallet, such as gong (the shoulder of the instrument)</text></gloss></sense><sense id="bahu_2" guid="28f0f271-1b6b-5cca-8e8b-43b69abdba1f"><grammatical-info value="Noun"/><gloss lang="en"><text>village chief assistant, kepala dusun (Java)</text></gloss></sense><sense id="bahu_3" guid="06a9d1f5-5686-57b1-a882-09fe58650921"><grammatical-info value="Noun"/><gloss lang="en"><text>many</text></gloss></sense><sense id="bahu_4" guid="16559a58-b185-537d-a78f-38ec9eb70202"><grammatical-info value="Noun"/><gloss lang="en"><text>newly burned land ready for planting</text></gloss></sense></entry>
<entry id="bahwa" guid="a1811c26-1ffd-5c42-a5a4-6e43d230a5ed"><lexical-unit><form lang="id"><text>bahwa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bahwa_0" guid="c0195b9e-5601-5cbc-ba5c-101e4545b262"><grammatical-info value="Subordinating connective"/><gloss lang="en"><text>that (connecting a noun clause)</text></gloss></sense></entry>
<entry id="baik" guid="f51c77e6-01ad-53d8-a463-9bc0d3a7fd3e"><lexical-unit><form lang="id"><text>baik</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="baik_0" guid="50a22df7-aa5e-51d3-8f8a-d54d58e8c773"><grammatical-info value="Adjective"/><gloss lang="en"><text>good, nice, decent</text></gloss></sense><sense id="baik_1" guid="5fb54886-cee0-5711-b2d0-90d4c5ffd6fb"><grammatical-info value="Adjective"/><gloss lang="en"><text>decent, okay</text></gloss></sense><sense id="baik_2" guid="d72379a9-77c9-567b-927d-ba24ac47aa8e"><grammatical-info value="Adjective"/><gloss lang="en"><text>okay</text></gloss></sense></entry>
<entry id="bait" guid="530d33d2-7fd9-548b-bc23-3f5fa1841075"><lexical-unit><form lang="id"><text>bait</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bait_0" guid="fc3c0796-2ed9-5759-9df7-53bf04fb7b86"><grammatical-info value="Noun"/><gloss lang="en"><text>house (abode)</text></gloss></sense><sense id="bait_1" guid="b23309a4-a602-5a83-875a-1e1adea2f015"><grammatical-info value="Noun"/><gloss lang="en"><text>home (house or structure in which someone lives)</text></gloss></sense><sense id="bait_2" guid="531caa2b-cf49-5c91-959f-e6a1306afb02"><grammatical-info value="Noun"/><gloss lang="en"><text>couplet (a pair of lines in poetry)</text></gloss></sense><sense id="bait_3" guid="24687ae2-08fd-5f73-a236-81f6481196ba"><grammatical-info value="Noun"/><gloss lang="en"><text>stanza (a unit of a poem, often in the form of a paragraph)</text></gloss></sense><sense id="bait_4" guid="7ac2d81d-89d7-58ee-a3d3-40bc3220cd29"><grammatical-info value="Noun"/><gloss lang="en"><text>alternative spelling of bita</text></gloss></sense></entry>
<entry id="bajak" guid="9e16ab99-43e7-5e82-90dd-1d1bd676153d"><lexical-unit><form lang="id"><text>bajak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bajak_0" guid="471c584c-b609-5199-ad5e-84e0abc762ce"><grammatical-info value="Noun"/><gloss lang="en"><text>plough</text></gloss></sense><sense id="bajak_1" guid="3dcc6ed8-a668-5523-a6f2-aa6f8e5c9c55"><grammatical-info value="Noun"/><gloss lang="en"><text>to plough</text></gloss></sense><sense id="bajak_2" guid="cf24891e-b7a9-541b-ba2a-6f6ad4efbf1c"><grammatical-info value="Noun"/><gloss lang="en"><text>piracy</text></gloss></sense><sense id="bajak_3" guid="39efd2f7-f3d5-553f-a231-08b9b35e8637"><grammatical-info value="Noun"/><gloss lang="en"><text>to hijack</text></gloss></sense></entry>
<entry id="baju" guid="23c640ef-9e31-56cc-ae52-b247725eb50a"><lexical-unit><form lang="id"><text>baju</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="baju_0" guid="3bbdf2e0-5eac-5b3d-9f13-85ae8b21be16"><grammatical-info value="Noun"/><gloss lang="en"><text>top (clothing that covers upper body)</text></gloss></sense></entry>
<entry id="bak" guid="609ab2a6-c653-574e-b882-04028b22f296"><lexical-unit><form lang="id"><text>bak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bak_0" guid="c8dca52b-d2e3-54f5-946a-0d7ee2c79470"><grammatical-info value="Noun"/><gloss lang="en"><text>Indicating comparison, usually as a way to introduce idiomatic analogies; like, as though.</text></gloss></sense><sense id="bak_1" guid="0e7f470e-2867-5b22-a6eb-13557ace3da8"><grammatical-info value="Noun"/><gloss lang="en"><text>container</text></gloss></sense><sense id="bak_2" guid="cd7d65b0-5628-58c5-a40f-1b6f3a857867"><grammatical-info value="Noun"/><gloss lang="en"><text>water container</text></gloss></sense><sense id="bak_3" guid="c607e8c8-a81f-5606-9109-a068f22ff3dd"><grammatical-info value="Noun"/><gloss lang="en"><text>black Chinese ink</text></gloss></sense><sense id="bak_4" guid="779ca258-24a0-5126-98a8-4134155f6e29"><grammatical-info value="Noun"/><gloss lang="en"><text>The sound of slapping or punching; whack, thwack.</text></gloss></sense><sense id="bak_5" guid="22082256-40a9-53a1-8979-cd2c358596fa"><grammatical-info value="Noun"/><gloss lang="en"><text>initialism of buang air kecil</text></gloss></sense><sense id="bak_6" guid="d609eb27-11a5-5910-93f6-2857df8d65bc"><grammatical-info value="Noun"/><gloss lang="en"><text>initialism of biro administrasi keuangan (“finance bureau”)</text></gloss></sense></entry>
<entry id="bakar" guid="b29d2513-7850-5a36-9d17-e60ae10fa4da"><lexical-unit><form lang="id"><text>bakar</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bakar_0" guid="359a29ff-c827-557a-8db9-188a498fa721"><grammatical-info value="Noun"/><gloss lang="en"><text>to burn, put on fire</text></gloss></sense><sense id="bakar_1" guid="fcbb6db3-d01b-57d0-808f-876140cb2ea7"><grammatical-info value="Noun"/><gloss lang="en"><text>to grill</text></gloss></sense><sense id="bakar_2" guid="1fcefa4b-7d04-504a-bc90-de6e9a6583a9"><grammatical-info value="Noun"/><gloss lang="en"><text>grilled</text></gloss></sense></entry>
<entry id="bakti" guid="73f0723f-63c2-5851-b0e3-df4af0bcad07"><lexical-unit><form lang="id"><text>bakti</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bakti_0" guid="21651a69-21ee-50db-8fe3-c608dec1db23"><grammatical-info value="Proper noun"/><gloss lang="en"><text>reverence</text></gloss></sense><sense id="bakti_1" guid="af1020bf-3435-5c07-b0e0-aeaaafb5db10"><grammatical-info value="Proper noun"/><gloss lang="en"><text>devotion</text></gloss></sense></entry>
<entry id="bakul" guid="eb5701c1-ccc4-5dcd-bc65-b61a2cfe5395"><lexical-unit><form lang="id"><text>bakul</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bakul_0" guid="98aa48af-8b1e-50c1-95d7-114b8135940c"><grammatical-info value="Noun"/><gloss lang="en"><text>basket (container)</text></gloss></sense><sense id="bakul_1" guid="61afb5ff-c0d2-51e3-a86b-25be7ecb5155"><grammatical-info value="Noun"/><gloss lang="en"><text>petty trader</text></gloss></sense></entry>
<entry id="bal" guid="10df90d3-a538-512b-bcc2-1e0c66b5a4a6"><lexical-unit><form lang="id"><text>bal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bal_0" guid="3a80a4da-0af4-575b-ab91-3e1351251b42"><grammatical-info value="Proper noun"/><gloss lang="en"><text>ball, a solid or hollow sphere, or roughly spherical mass</text></gloss></sense><sense id="bal_1" guid="f89bcd98-b617-5944-9a61-295474c59b48"><grammatical-info value="Proper noun"/><gloss lang="en"><text>bale, a rounded bundle or package of goods in a cloth cover, and corded for storage or transportation</text></gloss></sense><sense id="bal_2" guid="f51b2315-d433-5f34-b17c-b7729b8ec5fc"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a closed bag or package of wares</text></gloss></sense><sense id="bal_3" guid="8ccf0322-7a41-561c-8b30-426610f4c0cb"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a package made of soft, non-rigid, box-shaped material</text></gloss></sense><sense id="bal_4" guid="61b97453-8a90-5760-90e7-a15ab8191f32"><grammatical-info value="Proper noun"/><gloss lang="en"><text>musical notation</text></gloss></sense></entry>
<entry id="bala" guid="c3212dd7-79cf-501e-be2e-ac6e685f6fbd"><lexical-unit><form lang="id"><text>bala</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bala_0" guid="5a96d22a-0ebe-5c66-9f15-c68cf5faea54"><grammatical-info value="Noun"/><gloss lang="en"><text>force, army</text></gloss></sense><sense id="bala_1" guid="45ffccb5-6cd7-5722-a525-3da031e5faf5"><grammatical-info value="Noun"/><gloss lang="en"><text>misfortune</text></gloss></sense><sense id="bala_2" guid="e13ae050-e946-5c36-bf9f-8f8114e2e951"><grammatical-info value="Noun"/><gloss lang="en"><text>25th wuku of the Pawukon calendar</text></gloss></sense><sense id="bala_3" guid="83e6a6ac-fcbc-500c-8767-ab0d8aba1afc"><grammatical-info value="Noun"/><gloss lang="en"><text>birds that are deemed able to give signal through their movements or sound</text></gloss></sense></entry>
<entry id="balak" guid="448e2bcd-12e0-5b43-b7d8-5332a945ccb0"><lexical-unit><form lang="id"><text>balak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="balak_0" guid="c5099b92-a57b-5264-8ac6-c450b6a0a7e5"><grammatical-info value="Adjective"/><gloss lang="en"><text>spotted, blemished</text></gloss></sense><sense id="balak_1" guid="61b4736c-3767-5b42-b2b2-f57af98cab10"><grammatical-info value="Adjective"/><gloss lang="en"><text>clan territory</text></gloss></sense><sense id="balak_2" guid="f181b896-003e-59fc-b5c7-4015f9218a91"><grammatical-info value="Adjective"/><gloss lang="en"><text>log: the trunk of a dead tree, cleared of branches; any bulky piece as cut from the above, used as timber, fuel etc</text></gloss></sense><sense id="balak_3" guid="98d382da-9b93-57bb-988a-6a891d3ce5a0"><grammatical-info value="Adjective"/><gloss lang="en"><text>double tiles, doublet tiles: a tile that has the same pips-value on each end</text></gloss></sense><sense id="balak_4" guid="60379bd8-8060-502b-b60b-0e43fc54262f"><grammatical-info value="Adjective"/><gloss lang="en"><text>smegma</text></gloss></sense><sense id="balak_5" guid="3a3fb540-1aa7-531b-baaa-2fb5e6da8b5d"><grammatical-info value="Adjective"/><gloss lang="en"><text>greater lizardfish (Saurida tumbil)</text></gloss></sense><sense id="balak_6" guid="ce33d0de-0cce-55b9-bdff-9fa78ad7045c"><grammatical-info value="Adjective"/><gloss lang="en"><text>Polyphhereima elongata</text></gloss></sense><sense id="balak_7" guid="876de0f2-2415-5a22-8dbf-50e5813b92c5"><grammatical-info value="Adjective"/><gloss lang="en"><text>syllabic abbreviation of badan pelaksana (“executive body”)</text></gloss></sense></entry>
<entry id="balas" guid="29b67680-d57f-53de-9f83-2603a7d857d2"><lexical-unit><form lang="id"><text>balas</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="balas_0" guid="a796c2ef-ecac-5d2d-af5b-31bdf1af953d"><grammatical-info value="Noun"/><gloss lang="en"><text>answer</text></gloss></sense><sense id="balas_1" guid="4d636026-ef4c-54bd-a9b1-6187dca5a6e5"><grammatical-info value="Noun"/><gloss lang="en"><text>response</text></gloss></sense><sense id="balas_2" guid="5d47a388-6a86-5c59-bedc-aca1ac575a6e"><grammatical-info value="Noun"/><gloss lang="en"><text>punishment</text></gloss></sense><sense id="balas_3" guid="3692a491-f091-5a11-9ecc-4c014d115334"><grammatical-info value="Noun"/><gloss lang="en"><text>ballast,</text></gloss></sense><sense id="balas_4" guid="ff3b4618-6bf8-53fb-bf0b-68138b1553bf"><grammatical-info value="Noun"/><gloss lang="en"><text>heavy material that is placed in the hold of a ship (or in the gondola of a balloon), to provide stability</text></gloss></sense><sense id="balas_5" guid="32e5d983-0490-5cb3-b286-9e42c695718c"><grammatical-info value="Noun"/><gloss lang="en"><text>coarse gravel or similar material laid to form a bed for roads or railroads, or in making concrete</text></gloss></sense><sense id="balas_6" guid="837b8e99-81b7-5053-a2d2-e8eed7509fe1"><grammatical-info value="Noun"/><gloss lang="en"><text>baggage, something that hampers functioning</text></gloss></sense></entry>
<entry id="balasan" guid="f947e0f9-f7a0-57f4-8628-205e4df4809d"><lexical-unit><form lang="id"><text>balasan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="balasan_0" guid="920004b8-861b-5390-9d3d-156112717843"><grammatical-info value="Noun"/><gloss lang="en"><text>A reply</text></gloss></sense><sense id="balasan_1" guid="694dfa62-65ea-55c8-bf1b-5bc5a9714e40"><grammatical-info value="Noun"/><gloss lang="en"><text>a written or spoken response; part of a conversation.</text></gloss></sense><sense id="balasan_2" guid="cee07fcb-64b5-5444-8939-9b0b91996700"><grammatical-info value="Noun"/><gloss lang="en"><text>something given in reply.</text></gloss></sense><sense id="balasan_3" guid="29bd3731-ee13-5eb0-be70-14cf01edb27b"><grammatical-info value="Noun"/><gloss lang="en"><text>A response</text></gloss></sense><sense id="balasan_4" guid="f8bee780-d670-506e-8cfc-b15f2ed552d2"><grammatical-info value="Noun"/><gloss lang="en"><text>An answer</text></gloss></sense><sense id="balasan_5" guid="d577ed57-11dc-597c-a4f1-e609dab99e4e"><grammatical-info value="Noun"/><gloss lang="en"><text>A requital, typically one that is retaliatory in nature; a reprisal, revenge.</text></gloss></sense></entry>
<entry id="balik" guid="e5163ab9-e817-5baa-91a1-ab92eedca216"><lexical-unit><form lang="id"><text>balik</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="balik_0" guid="15518823-6b0b-57d4-9bcc-3658921fc1a2"><grammatical-info value="Noun"/><gloss lang="en"><text>behind, rear, back-end</text></gloss></sense><sense id="balik_1" guid="2cb74976-7a15-5ab1-b071-7d0d3f3f5c66"><grammatical-info value="Noun"/><gloss lang="en"><text>to return</text></gloss></sense></entry>
<entry id="balok" guid="4e7fc6f0-2bcb-578d-b321-4891afad2cd0"><lexical-unit><form lang="id"><text>balok</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="balok_0" guid="abb01dad-2dca-5dfc-addc-00eb47ac8512"><grammatical-info value="Noun"/><gloss lang="en"><text>block: a substantial, often approximately cuboid, piece of any substance</text></gloss></sense><sense id="balok_1" guid="f32c2245-8ed1-5d37-bb57-a2b3dd212d2a"><grammatical-info value="Noun"/><gloss lang="en"><text>log: the trunk of a dead tree, cleared of branches; any bulky piece as cut from the above, used as timber, fuel etc</text></gloss></sense><sense id="balok_2" guid="c9c20234-aa79-5b0f-b380-04b93c11b301"><grammatical-info value="Noun"/><gloss lang="en"><text>cuboid: a parallelepiped having six rectangular faces</text></gloss></sense><sense id="balok_3" guid="fb4f8ae1-0f5f-5914-9733-bd845ebfaf37"><grammatical-info value="Noun"/><gloss lang="en"><text>board:</text></gloss></sense><sense id="balok_4" guid="6903e89b-0ba2-5d9e-b51c-3258002c2d53"><grammatical-info value="Noun"/><gloss lang="en"><text>the side of a ship</text></gloss></sense><sense id="balok_5" guid="126a29e4-1df4-578e-8c7f-9cd0affd9011"><grammatical-info value="Noun"/><gloss lang="en"><text>takeoff board of long jump</text></gloss></sense><sense id="balok_6" guid="83614636-23b5-56c4-8659-0bba45c8d720"><grammatical-info value="Noun"/><gloss lang="en"><text>beam:</text></gloss></sense><sense id="balok_7" guid="77b82af8-17f1-561e-8f92-36b7b8ed3fba"><grammatical-info value="Noun"/><gloss lang="en"><text>any large piece of timber or iron long in proportion to its thickness, and prepared for use</text></gloss></sense></entry>
<entry id="balsam" guid="b42b73a0-d94b-5bd0-9dfd-375568011f6a"><lexical-unit><form lang="id"><text>balsam</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="balsam_0" guid="0a28f906-24fb-52fd-ae7d-76a51ba7bdd1"><grammatical-info value="Noun"/><gloss lang="en"><text>balsam: a sweet-smelling oil or resin derived from various plants</text></gloss></sense></entry>
<entry id="balut" guid="f41c2cb3-c7c6-56a3-83e0-f30d9c1de428"><lexical-unit><form lang="id"><text>balut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="balut_0" guid="02e533ba-bdba-5ea3-82c7-9c0466800eda"><grammatical-info value="Noun"/><gloss lang="en"><text>wrapper, wrapping</text></gloss></sense><sense id="balut_1" guid="c97963c5-d841-5aef-bb4d-1bd1e06610a5"><grammatical-info value="Noun"/><gloss lang="en"><text>bandage: a strip of gauze or similar material used to protect or support a wound or injury</text></gloss></sense><sense id="balut_2" guid="c25380ef-d13f-5c84-a457-8f6a6b13601b"><grammatical-info value="Noun"/><gloss lang="en"><text>balut: Asian street food consisting of a developing duck embryo boiled alive and eaten in the shell</text></gloss></sense><sense id="balut_3" guid="96cba614-13e4-5d25-87da-1b49125fccf5"><grammatical-info value="Noun"/><gloss lang="en"><text>thick like swelling</text></gloss></sense></entry>
<entry id="ban" guid="3a85f7cb-3a39-5fa5-a535-c031e9f99244"><lexical-unit><form lang="id"><text>ban</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="ban_0" guid="ec93056b-b0dc-5fdd-89d1-c200f86fced8"><grammatical-info value="Proper noun"/><gloss lang="en"><text>tyre, tire</text></gloss></sense><sense id="ban_1" guid="52e1b83b-a4cf-5d91-8e6a-6803c243064a"><grammatical-info value="Proper noun"/><gloss lang="en"><text>tape</text></gloss></sense><sense id="ban_2" guid="bd2705e3-0d01-5006-8bdd-83520ec4d40f"><grammatical-info value="Proper noun"/><gloss lang="en"><text>belt</text></gloss></sense><sense id="ban_3" guid="249a93cb-39af-5b16-bc44-ff45c0ed8e3e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>band worn on arm/hat</text></gloss></sense><sense id="ban_4" guid="62496594-c4cf-5a89-b3bc-5519b1c1eb57"><grammatical-info value="Proper noun"/><gloss lang="en"><text>band (a part of the electromagnetic spectrum)</text></gloss></sense><sense id="ban_5" guid="fef6460a-ebc9-57c9-be93-cfd1d376bc66"><grammatical-info value="Proper noun"/><gloss lang="en"><text>band (group of musicians)</text></gloss></sense><sense id="ban_6" guid="f5fec8c3-3051-5594-a591-8c6dffef6bd2"><grammatical-info value="Proper noun"/><gloss lang="en"><text>road, way, path</text></gloss></sense><sense id="ban_7" guid="a9966f2e-5359-597d-8168-e8e87f0ed10e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a track, lane</text></gloss></sense></entry>
<entry id="bandang" guid="2d4d8f39-1c92-57f2-9e56-010e360ab0a0"><lexical-unit><form lang="id"><text>bandang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bandang_0" guid="cbfeae89-1a12-5eac-8119-1a89864b3620"><grammatical-info value="Adjective"/><gloss lang="en"><text>big and fast, rushing</text></gloss></sense><sense id="bandang_1" guid="8f1da8cb-282e-5fb3-a392-f506cea5b891"><grammatical-info value="Adjective"/><gloss lang="en"><text>to run very fast (about horse)</text></gloss></sense><sense id="bandang_2" guid="ef8f235e-2c06-55a9-8699-194bc3f3f786"><grammatical-info value="Adjective"/><gloss lang="en"><text>parents who did not marry until the end of their lives</text></gloss></sense><sense id="bandang_3" guid="8ce23693-b3d2-5013-8626-02121f65c5c7"><grammatical-info value="Adjective"/><gloss lang="en"><text>a necklace of colored silk thread worn around the dancer's neck</text></gloss></sense><sense id="bandang_4" guid="3f42b398-4f38-5a02-a26e-d699a7fa0fd6"><grammatical-info value="Adjective"/><gloss lang="en"><text>Borassodendron borneense</text></gloss></sense><sense id="bandang_5" guid="b2971001-c876-5e08-bb85-7196bd11e927"><grammatical-info value="Adjective"/><gloss lang="en"><text>basket for store and transport sugar cane seedling</text></gloss></sense><sense id="bandang_6" guid="2127f94f-b132-5979-9b2f-13dd6df2406f"><grammatical-info value="Adjective"/><gloss lang="en"><text>to follow and supervise prisoners</text></gloss></sense><sense id="bandang_7" guid="a2571dca-53ce-510f-9a2b-3d0474c3fb1b"><grammatical-info value="Adjective"/><gloss lang="en"><text>alternative spelling of bandeng</text></gloss></sense></entry>
<entry id="banding" guid="01cf36db-c302-5b4d-b035-6c07cfa390a3"><lexical-unit><form lang="id"><text>banding</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="banding_0" guid="ed10683b-4ced-58ac-b3a1-bf2d1da117f4"><grammatical-info value="Noun"/><gloss lang="en"><text>comparison</text></gloss></sense><sense id="banding_1" guid="5c7eb404-eafc-55a9-aa4c-6c3affed6926"><grammatical-info value="Noun"/><gloss lang="en"><text>appeal: an application to a superior court or judge for a decision or order by an inferior court or judge to be reviewed and overturned</text></gloss></sense></entry>
<entry id="bang" guid="a162ce52-da44-5a5c-b8ba-bfcb459be79f"><lexical-unit><form lang="id"><text>bang</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bang_0" guid="024a453d-aa05-5fd9-a2c2-bacc893c6c89"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Title or term of address for brother</text></gloss></sense><sense id="bang_1" guid="a8526229-1ce3-5f84-892b-75b58c2dfd98"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a sudden percussive noise</text></gloss></sense><sense id="bang_2" guid="a0db4f26-2d9e-558e-a7d7-cd73609fd0d7"><grammatical-info value="Proper noun"/><gloss lang="en"><text>adhan</text></gloss></sense></entry>
<entry id="bangga" guid="2d446f2a-b9c1-5698-a422-cd8c38c7fe3c"><lexical-unit><form lang="id"><text>bangga</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bangga_0" guid="a57cf967-2c0f-5f0a-ac95-193af3b36b61"><grammatical-info value="Verb"/><gloss lang="en"><text>proud</text></gloss></sense><sense id="bangga_1" guid="0ed86bb3-8f77-5d95-ba27-53e3007a800e"><grammatical-info value="Verb"/><gloss lang="en"><text>rebellious</text></gloss></sense><sense id="bangga_2" guid="e5afa408-6274-576b-b61f-d6e325e5695d"><grammatical-info value="Verb"/><gloss lang="en"><text>hard to be done</text></gloss></sense><sense id="bangga_3" guid="4da9726f-b55c-571b-8c95-24d077bb357a"><grammatical-info value="Verb"/><gloss lang="en"><text>decorated room with colorful fabrics, used in rituals to summon spirits to help with traditional healing</text></gloss></sense></entry>
<entry id="bangka" guid="210fd2e6-62aa-53f5-ba9f-af34c88d7459"><lexical-unit><form lang="id"><text>bangka</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bangka_0" guid="394d2f77-0fe4-5623-95a4-fa7784ee2db7"><grammatical-info value="Proper noun"/><gloss lang="en"><text>outrigger canoe</text></gloss></sense></entry>
<entry id="bangkit" guid="3ab9f52a-7f72-501f-96f3-c18a0b4b47ba"><lexical-unit><form lang="id"><text>bangkit</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bangkit_0" guid="2c203e2e-9cc9-550f-8827-daf563fb1f34"><grammatical-info value="Verb"/><gloss lang="en"><text>to get up (e.g. from sitting position)</text></gloss></sense><sense id="bangkit_1" guid="d1a805e4-7064-5c8c-9d7a-7e49c2621959"><grammatical-info value="Verb"/><gloss lang="en"><text>to rise</text></gloss></sense><sense id="bangkit_2" guid="b2a5fe8a-7239-5d99-bd0a-03297a5f6e6a"><grammatical-info value="Verb"/><gloss lang="en"><text>to arise (e.g. feelings, emotions)</text></gloss></sense><sense id="bangkit_3" guid="3a237e19-a903-574c-bbfc-ed9cbe59dbdc"><grammatical-info value="Verb"/><gloss lang="en"><text>to rise from the dead</text></gloss></sense><sense id="bangkit_4" guid="66d7a7b7-cd65-59c7-9124-ae3a3a27bf88"><grammatical-info value="Verb"/><gloss lang="en"><text>to swell or puff up in the process of making dough</text></gloss></sense><sense id="bangkit_5" guid="ba8221f9-deaa-52a8-9f2f-270e44a77216"><grammatical-info value="Verb"/><gloss lang="en"><text>to recur; relapse (of a disease)</text></gloss></sense></entry>
<entry id="bangsa" guid="ba233888-d275-5449-9e2a-ab0db42e324d"><lexical-unit><form lang="id"><text>bangsa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bangsa_0" guid="a73e00db-5843-5f23-8795-0dfb75d0ee66"><grammatical-info value="Noun"/><gloss lang="en"><text>a group of people, animals, or plants with shared origin and the same characteristic</text></gloss></sense><sense id="bangsa_1" guid="d9b2e879-1bb9-5c65-986c-03301ba4a33f"><grammatical-info value="Noun"/><gloss lang="en"><text>a nation; a people or folk: group or community with often shared ancestral-lines, custom, language, and history; usually formed due to a sense of unity in terms of national, linguistic, or cultural ties, whilst also typically inhabiting a specific region on earth</text></gloss></sense><sense id="bangsa_2" guid="8e2efe3a-e885-5509-bb3c-b198050d4b94"><grammatical-info value="Noun"/><gloss lang="en"><text>sex</text></gloss></sense><sense id="bangsa_3" guid="80516ceb-9aa6-53a8-8f85-2258a7911f1e"><grammatical-info value="Noun"/><gloss lang="en"><text>order: a taxonomy unit (taxon) between the family and class, also functioned as the umbrella term for family which cognates to one another (in plants, the family names end with -ales, e.g. Zingiberales)</text></gloss></sense><sense id="bangsa_4" guid="2a4485d1-493e-5260-926e-b7ec5fca94d7"><grammatical-info value="Noun"/><gloss lang="en"><text>race: a group of sentient beings, particularly people, distinguished by common ancestry, heritage or characteristics</text></gloss></sense><sense id="bangsa_5" guid="583342af-d446-5b4e-a797-1192665c00c6"><grammatical-info value="Noun"/><gloss lang="en"><text>a clan</text></gloss></sense><sense id="bangsa_6" guid="0a918688-6bac-51b4-8017-9a5c16efb28f"><grammatical-info value="Noun"/><gloss lang="en"><text>a dynasty; a house of noble lineage</text></gloss></sense><sense id="bangsa_7" guid="7fec2910-2021-5b8a-969e-9e745a418664"><grammatical-info value="Noun"/><gloss lang="en"><text>prestige</text></gloss></sense></entry>
<entry id="bangun" guid="dc778563-75eb-5919-92c6-65dedc429c66"><lexical-unit><form lang="id"><text>bangun</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bangun_0" guid="f55d0a98-7576-5918-ac08-d983c98b2012"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to awake; to wake up</text></gloss></sense><sense id="bangun_1" guid="00019a0f-c04e-55ef-87c1-acbe683dff77"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to become conscious after having slept</text></gloss></sense><sense id="bangun_2" guid="cda140d5-db21-5fab-8c49-5efd32824c66"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to come out of a state of inaction or dormancy</text></gloss></sense><sense id="bangun_3" guid="fd07eb72-661c-5623-9712-e88ee341d3b5"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to get up</text></gloss></sense><sense id="bangun_4" guid="6ec993ac-f440-5a4d-b6b6-89b85415a90a"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to rise from one's bed, usually upon waking up in order to begin one's day</text></gloss></sense><sense id="bangun_5" guid="27f01418-af51-5250-90b6-343574cac51e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to move from a lying or sitting position to a standing position; to stand up</text></gloss></sense><sense id="bangun_6" guid="f7ec0f5c-373d-5162-83f5-757757ec2fd5"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to rise (to swell or puff up in the process of fermentation; to become light)</text></gloss></sense><sense id="bangun_7" guid="a786f8e2-dc4d-5fb8-bd5d-f0d2ff0b06fa"><grammatical-info value="Proper noun"/><gloss lang="en"><text>to arise (to spring up; to come into action, being, or notice; to become operative, sensible, or visible; to begin to act a part; to present itself)</text></gloss></sense></entry>
<entry id="bangunan" guid="af27a9a9-033a-5db2-971b-360e0d0792ca"><lexical-unit><form lang="id"><text>bangunan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bangunan_0" guid="e486f152-4594-5396-9ae5-b0c47cdfa4da"><grammatical-info value="Noun"/><gloss lang="en"><text>building (a closed structure with walls and a roof)</text></gloss></sense></entry>
<entry id="bangunkan" guid="d73f8d39-61ec-5124-8dff-bf6e22ccfdcd"><lexical-unit><form lang="id"><text>bangunkan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bangunkan_0" guid="0fc458c8-e99b-5a1b-baff-56c89036dea3"><grammatical-info value="Verb"/><gloss lang="en"><text>to wake up (to awaken somebody)</text></gloss></sense><sense id="bangunkan_1" guid="64f22d26-bc6e-59a8-b526-f025c10dd801"><grammatical-info value="Verb"/><gloss lang="en"><text>to awaken</text></gloss></sense><sense id="bangunkan_2" guid="ba38f1d8-599d-531b-8912-5542746fd2f1"><grammatical-info value="Verb"/><gloss lang="en"><text>to rise (to cause to rise; to lift or elevate)</text></gloss></sense></entry>
<entry id="banjir" guid="9a25598b-8a4b-57e0-a379-16f0de53835e"><lexical-unit><form lang="id"><text>banjir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="banjir_0" guid="86b666ad-d2c9-5ed8-bb00-3b820bbc64c4"><grammatical-info value="Noun"/><gloss lang="en"><text>to flood, to overflow</text></gloss></sense><sense id="banjir_1" guid="e277585a-0501-5562-84da-dbea57cb5155"><grammatical-info value="Noun"/><gloss lang="en"><text>flood (overflow of water)</text></gloss></sense></entry>
<entry id="bank" guid="d0f979d4-cfe3-5437-905d-ccf7fd7ce0ea"><lexical-unit><form lang="id"><text>bank</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bank_0" guid="7cdc8c19-40ae-5dba-8d74-07a6055b6726"><grammatical-info value="Noun"/><gloss lang="en"><text>bank:</text></gloss></sense><sense id="bank_1" guid="d93b72d0-8436-56db-9b21-b16bed71df94"><grammatical-info value="Noun"/><gloss lang="en"><text>an institution where one can place and borrow money and take care of financial affairs</text></gloss></sense><sense id="bank_2" guid="29055291-2a21-5a45-bff3-db3093e37048"><grammatical-info value="Noun"/><gloss lang="en"><text>a safe and guaranteed place of storage for and retrieval of important items or goods</text></gloss></sense></entry>
<entry id="bantah" guid="6dc8c7ca-5192-50f0-86d4-0f17a56848bf"><lexical-unit><form lang="id"><text>bantah</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bantah_0" guid="5b6de3ce-0279-5798-b512-f07f33f587e0"><grammatical-info value="Noun"/><gloss lang="en"><text>contradict</text></gloss></sense></entry>
<entry id="bantai" guid="ee129cdc-98d4-57ab-a757-c7c94a0ceec3"><lexical-unit><form lang="id"><text>bantai</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bantai_0" guid="d643ed01-683c-55ef-93c1-3df62f1ad5d4"><grammatical-info value="Noun"/><gloss lang="en"><text>meat; slaughtered animal.</text></gloss></sense><sense id="bantai_1" guid="1bb15797-9be7-5ae8-891e-0a096463ef2c"><grammatical-info value="Noun"/><gloss lang="en"><text>to cut up, to butcher, to slaughter</text></gloss></sense><sense id="bantai_2" guid="f08da952-9e10-5075-81d3-8168e5d7500f"><grammatical-info value="Noun"/><gloss lang="en"><text>to massacre, to kill off, to slaughter.</text></gloss></sense><sense id="bantai_3" guid="19ca8fe7-38c8-510e-8c48-dd9b866cbff2"><grammatical-info value="Noun"/><gloss lang="en"><text>to destroy, to ruin</text></gloss></sense><sense id="bantai_4" guid="e790ef4a-9294-539b-ab0c-eb09c0b4e626"><grammatical-info value="Noun"/><gloss lang="en"><text>to exterminate, to wipe out</text></gloss></sense><sense id="bantai_5" guid="4f132daf-49ad-524a-919e-40a954a6f806"><grammatical-info value="Noun"/><gloss lang="en"><text>to finish up</text></gloss></sense><sense id="bantai_6" guid="055a82e9-f820-5c9c-a2d2-c0a2150cff5d"><grammatical-info value="Noun"/><gloss lang="en"><text>to kill cruelly with more than one victim</text></gloss></sense><sense id="bantai_7" guid="3b70834b-64e3-50f1-b2f3-581c90b6c3bb"><grammatical-info value="Noun"/><gloss lang="en"><text>the part of the kitchen under the firewood storage, usually where smoked fish or meat is stored.</text></gloss></sense></entry>
<entry id="bantal" guid="3a0cd7d9-6dcd-5485-acd2-58519455991e"><lexical-unit><form lang="id"><text>bantal</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bantal_0" guid="71f9606b-3740-513b-b4ab-d4ed858fae88"><grammatical-info value="Noun"/><gloss lang="en"><text>pillow (soft cushion used to support the head in bed)</text></gloss></sense><sense id="bantal_1" guid="f1554c69-f0d7-56de-a080-f8d3f2aa377f"><grammatical-info value="Noun"/><gloss lang="en"><text>a snack made from sticky rice, filled with banana or red beans, shaped like a rectangular pillow, wrapped in coconut leaves, cooked by steaming</text></gloss></sense><sense id="bantal_2" guid="c218bb41-a022-5728-8115-e47cf045991e"><grammatical-info value="Noun"/><gloss lang="en"><text>the size of factory thread containing 22 pores, usually produces approximately two pieces of cloth measuring 2-3 m</text></gloss></sense><sense id="bantal_3" guid="c2c0ac58-d412-56c7-8f29-5ca8fbbfc170"><grammatical-info value="Noun"/><gloss lang="en"><text>a snack made from sticky rice, grated coconut and salt, wrapped in rolled coconut leaves, then boiled</text></gloss></sense></entry>
<entry id="bantu" guid="1168f319-f085-5e2e-b6b7-663d018cf116"><lexical-unit><form lang="id"><text>bantu</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bantu_0" guid="b9d53ca8-0e24-5fd5-9a2a-c5b7b37feaf3"><grammatical-info value="Noun"/><gloss lang="en"><text>to help; to aid; to assist</text></gloss></sense><sense id="bantu_1" guid="0333b7e8-923b-5d66-96fd-193e24ec148f"><grammatical-info value="Noun"/><gloss lang="en"><text>assistant, helper</text></gloss></sense></entry>
<entry id="banyak" guid="d8a74682-82c4-557d-8c74-40c66e9b8bd4"><lexical-unit><form lang="id"><text>banyak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="banyak_0" guid="5ce38c56-030a-51d9-9964-1748eec78d42"><grammatical-info value="Adverb"/><gloss lang="en"><text>many</text></gloss></sense><sense id="banyak_1" guid="89885ca9-1238-5092-b3d6-4f63806837ac"><grammatical-info value="Adverb"/><gloss lang="en"><text>a lot</text></gloss></sense></entry>
<entry id="bapa" guid="d4cc70be-2b0a-5f51-bf4b-121e33bcacb3"><lexical-unit><form lang="id"><text>bapa</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bapa_0" guid="bcebf737-19cb-538b-b129-10679c39bc0f"><grammatical-info value="Noun"/><gloss lang="en"><text>father</text></gloss></sense><sense id="bapa_1" guid="1a73e9f1-046f-5bde-b750-0f26c53040ae"><grammatical-info value="Noun"/><gloss lang="en"><text>mister, sir</text></gloss></sense><sense id="bapa_2" guid="b6ddc444-59c6-596a-9dca-b72bf3499927"><grammatical-info value="Noun"/><gloss lang="en"><text>God, the father of Creation</text></gloss></sense></entry>
<entry id="bapak" guid="f7987d0e-cb92-5524-b084-0236c1326a9a"><lexical-unit><form lang="id"><text>bapak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bapak_0" guid="09705cb1-fe52-5179-8604-c4e43b1c4260"><grammatical-info value="Noun"/><gloss lang="en"><text>father</text></gloss></sense><sense id="bapak_1" guid="f542f9d8-08eb-52f6-83db-9cfaa4bb62ee"><grammatical-info value="Noun"/><gloss lang="en"><text>mister, sir</text></gloss></sense><sense id="bapak_2" guid="992c9796-116c-5e5e-82b9-78a926a8fbce"><grammatical-info value="Noun"/><gloss lang="en"><text>you</text></gloss></sense><sense id="bapak_3" guid="8e75afcc-e357-56af-accd-ca190ae5b0b8"><grammatical-info value="Noun"/><gloss lang="en"><text>uncle</text></gloss></sense></entry>
<entry id="baptis" guid="cd67663a-8219-500a-984b-390f7323fc3c"><lexical-unit><form lang="id"><text>baptis</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="baptis_0" guid="19d0ef9b-a2ff-55df-bdb7-3b95942be3f3"><grammatical-info value="Noun"/><gloss lang="en"><text>baptism</text></gloss></sense></entry>
<entry id="bara" guid="969f8a22-11b7-5ada-9af3-34e5d87f753b"><lexical-unit><form lang="id"><text>bara</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bara_0" guid="94ce2df0-2347-5559-8017-1bff498de382"><grammatical-info value="Noun"/><gloss lang="en"><text>embers, cinder</text></gloss></sense><sense id="bara_1" guid="d4361372-2dc1-53dc-99e3-7604f6298f7d"><grammatical-info value="Noun"/><gloss lang="en"><text>under the house used as a livestock pen</text></gloss></sense><sense id="bara_2" guid="d1b09258-0a88-5678-82da-8efc3c95c26b"><grammatical-info value="Noun"/><gloss lang="en"><text>poultry cages made of bamboo or wood in a rectangular shape</text></gloss></sense><sense id="bara_3" guid="a368d194-85a3-5285-973b-926b0feb4305"><grammatical-info value="Noun"/><gloss lang="en"><text>a traditional sword from Sangihe, North Sulawesi, one side is sharp and the other side is curved, about 55 cm long, the hilt is made of wood or buffalo horn, used for hunting and war</text></gloss></sense><sense id="bara_4" guid="60daf97b-4946-5da8-96a7-9ff761f5e5ca"><grammatical-info value="Noun"/><gloss lang="en"><text>lemang cooked without being wrapped in banana leaves, usually used for healing rituals</text></gloss></sense></entry>
