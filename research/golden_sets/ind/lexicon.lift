<entry id="menetap" guid="8c2f0717-6ae5-5807-af7f-2891f0d3b887"><lexical-unit><form lang="id"><text>menetap</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="menetap_0" guid="32d5b681-ba03-597f-9521-e08a04113826"><grammatical-info value="Verb"/><gloss lang="en"><text>to reside, to go and live</text></gloss></sense></entry>
