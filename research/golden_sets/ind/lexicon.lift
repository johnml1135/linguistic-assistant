<entry id="majikan" guid="e6c65e30-8789-5656-818b-23897bd415ef"><lexical-unit><form lang="id"><text>majikan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="majikan_0" guid="063ccbd6-b982-5dbd-93f8-a64dd8911be6"><grammatical-info value="Noun"/><gloss lang="en"><text>master (someone who has control over or employs something or someone)</text></gloss></sense></entry>
<entry id="maju" guid="2f8f7eff-77eb-5a7a-b1c6-88b26e98e02f"><lexical-unit><form lang="id"><text>maju</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="maju_0" guid="a7b230d8-49e6-516c-b0d3-36dbaf6a6db3"><grammatical-info value="Verb"/><gloss lang="en"><text>to go forward, to advance</text></gloss></sense><sense id="maju_1" guid="27e824f7-e83d-5f58-ab8a-c8060d425fae"><grammatical-info value="Verb"/><gloss lang="en"><text>progressive</text></gloss></sense><sense id="maju_2" guid="1aeaf357-dd84-5be5-96dc-eee5dfabd6b7"><grammatical-info value="Verb"/><gloss lang="en"><text>advanced</text></gloss></sense></entry>
