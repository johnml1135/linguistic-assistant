<entry id="pes" guid="4706533f-aff6-53ea-bb5f-e4a061a3ff87"><lexical-unit><form lang="id"><text>pes</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pes_0" guid="796c7046-16e8-57f3-bfa8-8d4640e9e53d"><grammatical-info value="Noun"/><gloss lang="en"><text>pest, plague</text></gloss></sense><sense id="pes_1" guid="2cb73dd4-53cd-5f18-be66-df773b13251f"><grammatical-info value="Noun"/><gloss lang="en"><text>a word used as a warning sign of death in the game of gobak sodor when there are two people in one box</text></gloss></sense><sense id="pes_2" guid="dbe74286-3146-52db-aebc-db995a5d5472"><grammatical-info value="Noun"/><gloss lang="en"><text>foot</text></gloss></sense></entry>
<entry id="pesan" guid="76ed6b6f-b56c-528a-b528-4ff7985d63ca"><lexical-unit><form lang="id"><text>pesan</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pesan_0" guid="bfd78a39-8393-5e3e-b3ce-8d2950087ada"><grammatical-info value="Noun"/><gloss lang="en"><text>message</text></gloss></sense><sense id="pesan_1" guid="29e3eca9-93a7-55ea-8686-a58f87e122a6"><grammatical-info value="Noun"/><gloss lang="en"><text>a communication, or what is communicated; any concept or information conveyed</text></gloss></sense><sense id="pesan_2" guid="88e01fca-0bc0-57f2-aca1-1e0f55470190"><grammatical-info value="Noun"/><gloss lang="en"><text>an underlying theme or conclusion to be drawn from something</text></gloss></sense><sense id="pesan_3" guid="062ae3d5-b8c6-5531-957e-de193a2ba850"><grammatical-info value="Noun"/><gloss lang="en"><text>will, testament</text></gloss></sense><sense id="pesan_4" guid="779cf90b-88c1-5b0b-ac00-c18a52d54f1f"><grammatical-info value="Noun"/><gloss lang="en"><text>order</text></gloss></sense><sense id="pesan_5" guid="8e0dffe2-1291-5f0b-84b7-58c014f51466"><grammatical-info value="Noun"/><gloss lang="en"><text>command</text></gloss></sense><sense id="pesan_6" guid="13fa33f4-7865-59c5-8948-e7eebb87db60"><grammatical-info value="Noun"/><gloss lang="en"><text>a request for some product or service; a commission to purchase, sell, or supply goods</text></gloss></sense><sense id="pesan_7" guid="6c95b5fd-22d8-5b65-928b-2ee41e2168d6"><grammatical-info value="Noun"/><gloss lang="en"><text>request</text></gloss></sense></entry>
<entry id="pesona" guid="ada1f9d5-12fb-5037-92c0-181e78985cd2"><lexical-unit><form lang="id"><text>pesona</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pesona_0" guid="64d393a5-d3e7-5e94-9078-2b06fe89813e"><grammatical-info value="Noun"/><gloss lang="en"><text>A charm, incantation, magic spell; utilized to tempt, allure, or imbue someone or something with enchantment.</text></gloss></sense><sense id="pesona_1" guid="3d6b4d33-4271-5985-8763-251c109f586f"><grammatical-info value="Noun"/><gloss lang="en"><text>A love charm, potion, or philter.</text></gloss></sense><sense id="pesona_2" guid="3aabd29d-8a94-5353-b780-36bf92c41730"><grammatical-info value="Noun"/><gloss lang="en"><text>Charm, allure, appeal; ability to persuade, attract, delight or arouse admiration.</text></gloss></sense></entry>
<entry id="pesta" guid="b0d66b92-d171-5067-939f-03437e26e317"><lexical-unit><form lang="id"><text>pesta</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pesta_0" guid="7c20b128-8a91-5ff0-9450-74059e777765"><grammatical-info value="Noun"/><gloss lang="en"><text>party, a social gathering, a gathering of usually invited guests for entertainment, fun and socializing</text></gloss></sense></entry>
<entry id="pet" guid="c62869b6-dfb3-5bae-86a7-7f717fd020d4"><lexical-unit><form lang="id"><text>pet</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="pet_0" guid="7c080e7f-a26d-56e4-ad3f-a9fc21fef224"><grammatical-info value="Noun"/><gloss lang="en"><text>cap (headwear with a peak at the front)</text></gloss></sense></entry>
<entry id="petik" guid="37b1cf41-d222-563d-b10d-8046f9ded821"><lexical-unit><form lang="id"><text>petik</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="petik_0" guid="63a819d2-6b13-5441-9b02-2bc464303961"><grammatical-info value="Verb"/><gloss lang="en"><text>to pick, to pluck</text></gloss></sense><sense id="petik_1" guid="5e6b177f-74b2-5920-baa5-c6cd6df2fda5"><grammatical-info value="Verb"/><gloss lang="en"><text>to quote</text></gloss></sense><sense id="petik_2" guid="68fe5d95-040f-58a0-ad2f-ea17b13292ed"><grammatical-info value="Verb"/><gloss lang="en"><text>Jember's special ritual to start the rice harvest</text></gloss></sense><sense id="petik_3" guid="3bad3452-70d4-5c46-bff5-ac54f924c24a"><grammatical-info value="Verb"/><gloss lang="en"><text>large animal trap made of sharpened bamboo, lever attached to a spring with rope, placed on the animal's path</text></gloss></sense></entry>
<entry id="petrus" guid="b130cc27-8b00-5458-9986-95c6cc6e8f54"><lexical-unit><form lang="id"><text>petrus</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="petrus_0" guid="5c6a6940-7a5b-5c29-acdf-7d5ef2b8ee8e"><grammatical-info value="Proper noun"/><gloss lang="en"><text>Peter</text></gloss></sense><sense id="petrus_1" guid="465427dc-d426-5854-a8cc-5dcf1fbab64b"><grammatical-info value="Proper noun"/><gloss lang="en"><text>extrajudicial official executioner</text></gloss></sense><sense id="petrus_2" guid="2984007e-ce45-5c6a-9a9b-675c1a9a5ac3"><grammatical-info value="Proper noun"/><gloss lang="en"><text>a male given name from Dutch [in turn from Latin], equivalent to English Peter</text></gloss></sense><sense id="petrus_3" guid="f7347067-b601-5db0-8be8-1a92c704772f"><grammatical-info value="Proper noun"/><gloss lang="en"><text>syllabic abbreviation of penembakan misterius (literally “mysterious shooting”)</text></gloss></sense></entry>
