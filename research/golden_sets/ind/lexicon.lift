<entry id="hasil" guid="2b4c381a-24ec-55b2-a6a2-7b85880ae4aa"><lexical-unit><form lang="id"><text>hasil</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="hasil_0" guid="0e874972-f0f8-5ac8-8618-93bf41e07f6d"><grammatical-info value="Noun"/><gloss lang="en"><text>result, outcome (that which results)</text></gloss></sense><sense id="hasil_1" guid="aa6ea3ec-e7f0-5eaa-810f-c74cf9b911b4"><grammatical-info value="Noun"/><gloss lang="en"><text>result (fruit, beneficial or tangible effect)</text></gloss></sense><sense id="hasil_2" guid="58455605-5008-5d1e-94ff-bfdb50cbc97d"><grammatical-info value="Noun"/><gloss lang="en"><text>output (production; quantity produced, created, or completed)</text></gloss></sense><sense id="hasil_3" guid="a5f92849-fba8-557f-a024-e91a0a476c13"><grammatical-info value="Noun"/><gloss lang="en"><text>income, earnings (money one earns by working or by capitalising on the work of others)</text></gloss></sense><sense id="hasil_4" guid="a1c69735-7502-527b-844f-3d2060a56779"><grammatical-info value="Noun"/><gloss lang="en"><text>tax (especially land tax)</text></gloss></sense><sense id="hasil_5" guid="0cefff03-19e2-5ae7-a4ac-c158d7cc7b26"><grammatical-info value="Noun"/><gloss lang="en"><text>synonym of berhasil (“having a result, successful”)</text></gloss></sense></entry>
