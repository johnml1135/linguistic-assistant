<entry id="hukum" guid="c727d6ba-d23b-565a-a812-b5e9f36de9bf"><lexical-unit><form lang="id"><text>hukum</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="hukum_0" guid="c777f470-66da-5dd5-9a30-45e985b2e365"><grammatical-info value="Noun"/><gloss lang="en"><text>law:</text></gloss></sense><sense id="hukum_1" guid="c480ea91-6855-5add-9874-078d0952faa1"><grammatical-info value="Noun"/><gloss lang="en"><text>a binding regulation or custom established by its legislative and judicial authorities in a community</text></gloss></sense><sense id="hukum_2" guid="abdd57f2-f2c6-532b-923f-41a3660e4e6a"><grammatical-info value="Noun"/><gloss lang="en"><text>a statement (in physics, etc) of an (observed, established) order or sequence or relationship of phenomena which is invariable under certain conditions</text></gloss></sense><sense id="hukum_3" guid="f102635d-a3ea-5278-a940-b2203d0ad76c"><grammatical-info value="Noun"/><gloss lang="en"><text>sentence, verdict, the decision or judgement of a court</text></gloss></sense><sense id="hukum_4" guid="4e53bcfb-4abd-5df8-af23-b493e2d7979a"><grammatical-info value="Noun"/><gloss lang="en"><text>legal ruling or legal opinion</text></gloss></sense></entry>
<entry id="hukuman" guid="9f3fb15a-9964-534d-9559-aa66ca202d6f"><lexical-unit><form lang="id"><text>hukuman</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="hukuman_0" guid="e905e288-799d-5258-b8d2-2a724e408c74"><grammatical-info value="Noun"/><gloss lang="en"><text>punishment:</text></gloss></sense><sense id="hukuman_1" guid="2c5290c1-aa39-5a04-a8bf-c7a8945cb221"><grammatical-info value="Noun"/><gloss lang="en"><text>the act or process of punishing, imposing and/or applying a sanction</text></gloss></sense><sense id="hukuman_2" guid="c518e694-25bc-5ef0-801e-800404fd9a1e"><grammatical-info value="Noun"/><gloss lang="en"><text>a penalty to punish wrongdoing, especially for crime</text></gloss></sense><sense id="hukuman_3" guid="68e31467-5220-5353-b51f-f7361cc2afb0"><grammatical-info value="Noun"/><gloss lang="en"><text>sentence, verdict, the decision or judgement of a court</text></gloss></sense></entry>
<entry id="huni" guid="1d5d0545-1b42-58ee-8a39-50380b508fee"><lexical-unit><form lang="id"><text>huni</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="huni_0" guid="87ed7efa-00f9-539b-81d2-e49755c345cb"><grammatical-info value="Verb"/><gloss lang="en"><text>to inhabit</text></gloss></sense><sense id="huni_1" guid="8ef2c204-eb9e-5884-8580-07b7bac9093a"><grammatical-info value="Verb"/><gloss lang="en"><text>small path around the garden</text></gloss></sense></entry>
