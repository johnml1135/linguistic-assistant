<entry id="berlutut" guid="0bf3ef72-1274-5b55-a5ac-51933fb82a58"><lexical-unit><form lang="id"><text>berlutut</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berlutut_0" guid="9b92e9ad-c820-5b7c-be3d-8ed81b46d2b7"><grammatical-info value="Verb"/><gloss lang="en"><text>to knee, to kneel to</text></gloss></sense></entry>
<entry id="bermanfaat" guid="39bcf4df-e4f3-5588-8d35-e558a70ef7e7"><lexical-unit><form lang="id"><text>bermanfaat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bermanfaat_0" guid="c6ffbd44-e5d0-52f5-bd02-c39b7187c004"><grammatical-info value="Verb"/><gloss lang="en"><text>to be useful, to be advantageous</text></gloss></sense></entry>
<entry id="bermusuh" guid="59a312fb-4f95-5095-9014-32bc243fd766"><lexical-unit><form lang="id"><text>bermusuh</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bermusuh_0" guid="79db00a4-502c-570d-8b65-25c29522c7fe"><grammatical-info value="Verb"/><gloss lang="en"><text>synonym of bermusuhan</text></gloss></sense></entry>
<entry id="berontak" guid="dee82b93-c727-5ec7-9053-edf63d18f710"><lexical-unit><form lang="id"><text>berontak</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berontak_0" guid="65393bbb-d572-5616-8d30-1c89a15b2578"><grammatical-info value="Verb"/><gloss lang="en"><text>to struggle</text></gloss></sense><sense id="berontak_1" guid="e375e26b-c939-59e1-be71-94237d92f1f5"><grammatical-info value="Verb"/><gloss lang="en"><text>to disobey</text></gloss></sense><sense id="berontak_2" guid="a1c6a64a-eb4e-5384-93bd-2e067da0c7b5"><grammatical-info value="Verb"/><gloss lang="en"><text>to revolt, to rebel, to uprise</text></gloss></sense></entry>
<entry id="berpikir" guid="2fb2a28f-410c-52ac-8453-965c6423379d"><lexical-unit><form lang="id"><text>berpikir</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="berpikir_0" guid="ae6c4661-ec7d-53ad-b533-14b5f48296cb"><grammatical-info value="Verb"/><gloss lang="en"><text>active of pikir</text></gloss></sense></entry>
<entry id="bersama" guid="a034ca78-65b8-5a6b-b41b-6a343c89c95d"><lexical-unit><form lang="id"><text>bersama</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="bersama_0" guid="4fe820b1-5876-520d-993f-f88df6be61c0"><grammatical-info value="Adposition"/><gloss lang="en"><text>with, together with</text></gloss></sense><sense id="bersama_1" guid="04da2a1d-8074-552a-8039-d0eb08a045a6"><grammatical-info value="Adposition"/><gloss lang="en"><text>together, mutually, jointly</text></gloss></sense><sense id="bersama_2" guid="e2338002-b637-55d2-89e1-e7f9656f7fd3"><grammatical-info value="Adposition"/><gloss lang="en"><text>simultaneously</text></gloss></sense><sense id="bersama_3" guid="8860a63c-2a49-5025-a27a-324c71686176"><grammatical-info value="Adposition"/><gloss lang="en"><text>mutual</text></gloss></sense></entry>
