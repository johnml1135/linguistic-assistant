<entry id="belok" guid="e850b510-ad4b-528b-b62a-9a6dc6bdb1f8"><lexical-unit><form lang="id"><text>belok</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="belok_0" guid="f53ec712-e672-50a0-b79f-5e7fcfba4f4c"><grammatical-info value="Verb"/><gloss lang="en"><text>to turn (move around an axis through itself)</text></gloss></sense><sense id="belok_1" guid="2938df95-b9a8-5209-b541-fe1b6c693c19"><grammatical-info value="Verb"/><gloss lang="en"><text>wide-eyed, moon-eyed, owly-eyed, pie-eyed, saucer-eyed, goggle-eyed</text></gloss></sense><sense id="belok_2" guid="ccc6580d-fbee-52f1-8fc6-9819494871b2"><grammatical-info value="Verb"/><gloss lang="en"><text>muddy</text></gloss></sense><sense id="belok_3" guid="a379caca-306b-5edf-85e7-dbab94e33062"><grammatical-info value="Verb"/><gloss lang="en"><text>mud</text></gloss></sense><sense id="belok_4" guid="da00a143-964f-52a1-980d-1841441da444"><grammatical-info value="Verb"/><gloss lang="en"><text>block: a case or frame housing one or more sheaves (pulleys), used with ropes to increase or redirect force, for example as part of lifting gear or a sailing ship's rigging.</text></gloss></sense><sense id="belok_5" guid="b02643cd-d871-534d-849b-eefb182202bf"><grammatical-info value="Verb"/><gloss lang="en"><text>stock</text></gloss></sense></entry>
