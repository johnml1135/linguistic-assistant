<entry id="kalian" guid="522887a9-de11-5062-956f-9f4714e11925"><lexical-unit><form lang="id"><text>kalian</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kalian_0" guid="ecd4cd1b-7f4d-54f1-ba09-c384a1bb8956"><grammatical-info value="Pronoun"/></sense></entry>
<entry id="kalimat" guid="9f41fcbf-30ac-58fa-967a-895e9abd0f55"><lexical-unit><form lang="id"><text>kalimat</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="kalimat_0" guid="6618308c-7553-5ef7-8b7a-8526a1ce2ddf"><grammatical-info value="Noun"/><gloss lang="en"><text>sentence: a grammatically complete series of words consisting of a subject and predicate, even if one or the other is implied, and typically beginning with a capital letter and ending with a full stop</text></gloss></sense></entry>
