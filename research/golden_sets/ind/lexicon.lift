<entry id="hargai" guid="438ca5ed-2bc1-5b89-b2a5-6622abfb1f48"><lexical-unit><form lang="id"><text>hargai</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="hargai_0" guid="56c7a0f9-83aa-50d5-80fa-4b7cf5ba6fe3"><grammatical-info value="Verb"/><gloss lang="en"><text>to value:</text></gloss></sense><sense id="hargai_1" guid="5e1e92fa-edd4-53f0-b21a-b48373f01b99"><grammatical-info value="Verb"/><gloss lang="en"><text>to estimate or determine the value of; judge the worth of something</text></gloss></sense><sense id="hargai_2" guid="0b218091-59dd-5731-b549-c622693028eb"><grammatical-info value="Verb"/><gloss lang="en"><text>to regard highly; think much of; place importance upon</text></gloss></sense><sense id="hargai_3" guid="19de93b0-a262-5bb4-82e9-cf98acb51267"><grammatical-info value="Verb"/><gloss lang="en"><text>to hold dear</text></gloss></sense></entry>
<entry id="hari" guid="8aae0c90-dc6d-5228-a440-358a0d32b22f"><lexical-unit><form lang="id"><text>hari</text></form></lexical-unit><trait name="morph-type" value="stem"/><sense id="hari_0" guid="850173a1-aa5f-54b4-91da-734a4875c3d4"><grammatical-info value="Noun"/><gloss lang="en"><text>day:</text></gloss></sense><sense id="hari_1" guid="8c15dafd-717f-5a49-b8f5-3818ba616cc8"><grammatical-info value="Noun"/><gloss lang="en"><text>any period of 24 hours</text></gloss></sense><sense id="hari_2" guid="944b7514-ed66-55f2-a713-006aa5e5670a"><grammatical-info value="Noun"/><gloss lang="en"><text>a period from midnight to the following midnight</text></gloss></sense><sense id="hari_3" guid="650b2d22-6109-5560-b307-6b9c5d94ef97"><grammatical-info value="Noun"/><gloss lang="en"><text>rotational period of a planet (especially Earth)</text></gloss></sense><sense id="hari_4" guid="7b8647a6-be8a-5649-892d-1ee37c3cd762"><grammatical-info value="Noun"/><gloss lang="en"><text>the part of a day period which one spends at one’s job, school, etc.</text></gloss></sense><sense id="hari_5" guid="f602ea48-f2bb-584f-b381-4f14c44123c6"><grammatical-info value="Noun"/><gloss lang="en"><text>a 24-hour period beginning at 6am or sunrise</text></gloss></sense><sense id="hari_6" guid="4cdd0cba-b874-5804-a6c0-d79e955ed3ee"><grammatical-info value="Noun"/><gloss lang="en"><text>daytime: part of a day period between sunrise and sunset where one enjoys daylight</text></gloss></sense></entry>
